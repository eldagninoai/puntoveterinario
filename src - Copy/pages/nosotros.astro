<style>
    .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        border: 0;
    }

    .hero {
        background: none; /* override Generic hero bg if needed */
    }

    @media (min-width: 64.0625rem) {
        .hero__text {
            max-width: 80%;
        }
    }

    /* GRID EQUIPO MÃ‰DICO */
    .grid-equipo {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: max(1.5rem, 3vw);
        margin: 0 auto;
    }
    @media (max-width: 64rem) {
        .grid-equipo {
            grid-template-columns: 1fr;
            max-width: max(40rem, 70vw);
        }
    }

    .card-equipo {
        background: var(--color-bg);
        border: max(0.05rem, 0.1vw) solid var(--color-border);
        border-radius: max(0.5rem, 1.5vw);
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        transition:
            transform 0.3s,
            box-shadow 0.3s;
        display: flex;
        flex-direction: column;
    }
    .card-equipo:hover {
        transform: translateY(-0.25rem);
        box-shadow: var(--shadow-md);
    }

    .equipo-img {
        width: 100%;
        height: max(15rem, 25vw);
        object-fit: cover;
        object-position: top center;
        background: var(--color-bg-soft);
        border-bottom: max(0.05rem, 0.1vw) solid var(--color-border);
    }

    .equipo-info {
        padding: max(1.2rem, 2vw);
        text-align: center;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }
    .equipo-nombre {
        font-size: max(1.2rem, 1.8vw);
        color: var(--color-primary-dark);
        margin-bottom: max(0.5rem, 1vw);
        line-height: 1.2;
    }
    .equipo-exp {
        font-size: max(0.95rem, 1.2vw);
        color: var(--color-text-soft);
        line-height: 1.6;
        margin: 0;
    }

    /* BENTO GALLERY INSTALACIONES */
    .bento-gallery {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        grid-auto-rows: max(8rem, 15vw);
        gap: max(0.8rem, 1.5vw);
    }

    .bento-item {
        border-radius: max(0.5rem, 1vw);
        overflow: hidden;
        position: relative;
        box-shadow: var(--shadow-sm);
        transition:
            transform 0.3s,
            box-shadow 0.3s;
        background: var(--color-bg-soft);
    }
    .bento-item:hover {
        transform: translateY(-0.15rem);
        box-shadow: var(--shadow-md);
    }
    .bento-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.5s ease;
    }
    .bento-item:hover .bento-img {
        transform: scale(1.05);
    }

    /* Desktop Layout */
    .bento-item--1 {
        grid-column: span 2;
        grid-row: span 2;
    } /* Large Hero Image */
    .bento-item--2 {
        grid-column: span 2;
        grid-row: span 1;
    } /* Wide Top Right */
    .bento-item--3 {
        grid-column: span 1;
        grid-row: span 1;
    } /* Square Bottom Middle */
    .bento-item--4 {
        grid-column: span 1;
        grid-row: span 1;
    } /* Square Bottom Right */

    /* Tablet Layout */
    @media (max-width: 64rem) {
        .bento-gallery {
            grid-template-columns: repeat(2, 1fr);
        }
        .bento-item--1 {
            grid-column: span 2;
            grid-row: span 2;
        }
        .bento-item--2 {
            grid-column: span 2;
            grid-row: span 1;
        }
        .bento-item--3 {
            grid-column: span 1;
            grid-row: span 1;
        }
        .bento-item--4 {
            grid-column: span 1;
            grid-row: span 1;
        }
    }
    /* Mobile Layout */
    @media (max-width: 48rem) {
        .bento-gallery {
            grid-template-columns: repeat(2, 1fr);
            grid-auto-rows: max(12rem, 40vw);
        }
        .bento-item--1,
        .bento-item--2,
        .bento-item--3,
        .bento-item--4 {
            grid-column: span 1;
            grid-row: span 1;
        }
    }
</style>
