---
interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  schema?: Record<string, any>;
}

const {
  title,
  description,
  canonical = Astro.url.href,
  ogImage = "/images/veterinaria-coyoacan-punto-veterinario.svg",
  schema,
} = Astro.props;

// Asegurar URL canonical sin trailing slash
const canonicalURL =
  canonical.endsWith("/") && canonical.length > 1
    ? canonical.slice(0, -1)
    : canonical;
---

<!-- Global Metadata -->
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Fredoka:wght@300;400;500;600;700&display=swap"
  rel="stylesheet"
/>
<link rel="preconnect" href="https://maps.googleapis.com" />
<link rel="dns-prefetch" href="https://www.google-analytics.com" />
<link rel="dns-prefetch" href="https://wa.me" />
<link
  rel="icon"
  type="image/svg+xml"
  href="/images/veterinaria-coyoacan-punto-veterinario.svg"
/>
<link
  rel="apple-touch-icon"
  href="/images/veterinaria-coyoacan-punto-veterinario.svg"
/>

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:locale" content="es_MX" />
<meta property="og:site_name" content="Punto Veterinario" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<!-- Image SEO -->
<meta property="og:image:width" content="800" />
<meta property="og:image:height" content="600" />
<meta
  property="og:image:alt"
  content="Veterinaria Punto Veterinario en Coyoacán, San Pablo Tepetlapa, CDMX"
/>
<meta property="og:image:type" content="image/svg+xml" />
<meta
  name="thumbnail"
  content="https://puntoveterinario.com/images/veterinaria-coyoacan-punto-veterinario.svg"
/>

<!-- Schema JSON-LD -->
{
  schema && (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )
}
