---
const currentPath = Astro.url.pathname;

const servicios = [
  {
    href: "/servicios/consulta-veterinaria",
    label: "Consulta Médica",
    emoji: "🩺",
  },
  { href: "/servicios/estetica-canina", label: "Estética Canina", emoji: "🛁" },
  { href: "/servicios/esterilizacion", label: "Esterilización", emoji: "✂️" },
  { href: "/servicios/cirugia-veterinaria", label: "Cirugías", emoji: "🏥" },
  { href: "/servicios/laboratorio-clinico", label: "Laboratorio", emoji: "🔬" },
  { href: "/servicios/alimento-mascotas", label: "Alimento", emoji: "🛒" },
];

const serviciosActivo = currentPath.startsWith("/servicios");
---

<header class="header">
  <div class="container header__inner">
    <a href="/" class="logo" aria-label="Inicio">
      🐾 <span>Punto Veterinario</span>
    </a>

    <div class="nav-overlay" id="nav-overlay"></div>

    <nav class="nav-menu" id="nav-menu" aria-label="Navegación principal">
      <ul class="nav-list">
        <li>
          <a href="/" class={`nav-link ${currentPath === "/" ? "active" : ""}`}>
            Inicio
          </a>
        </li>

        <!-- SERVICIOS: un solo elemento, funciona en desktop y mobile -->
        <li class="nav-item-dropdown">
          <button
            class={`nav-link dropdown-trigger ${serviciosActivo ? "active" : ""}`}
            aria-expanded="false"
            aria-haspopup="true"
            id="servicios-btn"
          >
            Servicios <span class="chevron">▾</span>
          </button>
          <ul class="dropdown-menu" id="dropdown-menu" role="menu">
            {
              servicios.map((s) => (
                <li role="none">
                  <a
                    href={s.href}
                    role="menuitem"
                    class={`dropdown-link ${currentPath === s.href ? "active" : ""}`}
                  >
                    <span class="dropdown-emoji">{s.emoji}</span>
                    {s.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </li>

        <li>
          <a
            href="/nosotros"
            class={`nav-link ${currentPath === "/nosotros" ? "active" : ""}`}
          >
            Nosotros
          </a>
        </li>
        <li>
          <a
            href="/ubicacion"
            class={`nav-link ${currentPath === "/ubicacion" ? "active" : ""}`}
          >
            Ubicación
          </a>
        </li>
        <li>
          <a
            href="/blog"
            class={`nav-link ${currentPath.startsWith("/blog") ? "active" : ""}`}
          >
            Blog
          </a>
        </li>
      </ul>
    </nav>

    <div class="header-actions">
      <a href="/contacto" class="btn-cta">📅 Agendar Cita</a>
      <button
        class="nav-toggle"
        aria-label="Abrir menú"
        aria-expanded="false"
        id="nav-toggle"
      >
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #fff;
    border-bottom: 0.1rem solid var(--color-border);
    padding-block: max(0.6rem, 1vw);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: max(1rem, 2vw);
  }

  /* LOGO */
  .logo {
    display: flex;
    align-items: center;
    gap: max(0.3rem, 0.5vw);
    text-decoration: none;
    font-size: max(1rem, 1.6vw);
    font-weight: 700;
    color: var(--color-primary);
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* NAV */
  .nav-menu {
    flex: 1;
    display: flex;
    justify-content: center;
  }
  .nav-list {
    display: flex;
    list-style: none;
    gap: max(0.2rem, 0.5vw);
    align-items: center;
    justify-content: center;
    margin: 0;
    padding: 0;
  }

  /* NAV LINKS */
  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.3em;
    text-decoration: none;
    color: var(--color-text);
    font-size: max(0.8rem, 1vw);
    font-weight: 500;
    padding: max(0.35rem, 0.5vw) max(0.5rem, 0.8vw);
    border-radius: var(--radius-sm);
    transition:
      background 0.2s,
      color 0.2s;
    white-space: nowrap;
    cursor: pointer;
    background: none;
    border: none;
    font-family: var(--font-main);
  }
  .nav-link:hover {
    background: var(--color-primary-light);
    color: var(--color-primary-dark);
  }
  .nav-link.active {
    background: var(--color-primary-light);
    color: var(--color-primary-dark);
    font-weight: 600;
  }
  .chevron {
    color: inherit;
    font-size: 0.7em;
    transition: transform 0.2s;
    display: inline-block;
    opacity: 0.7;
  }
  .dropdown-trigger[aria-expanded="true"] .chevron {
    transform: rotate(180deg);
  }

  /* =========================================
     DROPDOWN DE SERVICIOS
     ========================================= */
  .nav-item-dropdown {
    position: relative;
    /* Móvil: ancho completo; desktop: auto (sobreescrito abajo) */
    width: 100%;
  }

  /* -- DEFECTO MÓVIL: fluye con el documento, NO flota -- */
  .dropdown-menu {
    position: static;
    display: none; /* oculto, sin ocupar espacio */
    flex-direction: column;
    width: 100%;
    background: var(--color-bg-soft, #f8fafc);
    border-left: 0.2rem solid var(--color-primary-light);
    border-radius: max(0.5rem, 1vw);
    padding: max(0.8rem, 1.5vw) 0;
    margin-top: max(0.4rem, 0.8vw);
    list-style: none;
    text-align: left;
    /* Anula cualquier posicionamiento residual */
    transform: none !important;
    left: 0 !important;
    /* Sin transiciones en móvil */
    transition: none;
    box-shadow: none;
    border-top: none;
    border-right: none;
    border-bottom: none;
  }
  .dropdown-menu.open {
    display: flex;
  }

  .dropdown-link {
    display: flex;
    align-items: center;
    gap: max(0.4rem, 0.6vw);
    text-decoration: none !important;
    color: var(--color-text);
    font-size: max(0.9rem, 1vw);
    padding: max(0.5rem, 0.8vw) max(0.6rem, 1vw);
    border-radius: var(--radius-sm);
    white-space: nowrap;
    transition:
      background 0.15s,
      color 0.15s;
  }
  .dropdown-link:hover,
  .dropdown-link.active {
    background: var(--color-primary-light);
    color: var(--color-primary-dark);
  }
  .dropdown-link.active {
    font-weight: 600;
  }
  .dropdown-emoji {
    font-size: 1em;
  }

  /* -- DESKTOP: flotante centrado, visibilidad por opacidad -- */
  @media (min-width: 768px) {
    .nav-item-dropdown {
      width: auto;
    }
    .dropdown-menu {
      position: absolute;
      top: calc(100% + max(0.3rem, 0.5vw));
      left: 50%;
      transform: translateX(-50%) translateY(-0.5rem) !important;
      width: max(13rem, 16vw);
      background: #fff;
      border: 0.1rem solid var(--color-border);
      border-radius: var(--radius-lg);
      box-shadow: 0 max(0.3rem, 0.5vw) max(1rem, 1.5vw) rgba(0, 0, 0, 0.12);
      padding: max(0.4rem, 0.6vw);
      margin-top: 0;
      z-index: 200;
      text-align: left;
      /* Oculto con opacidad (no display) para animar suavemente) */
      display: flex;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transition:
        opacity 0.2s ease,
        transform 0.2s ease,
        visibility 0.2s;
    }
    .dropdown-menu.open {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transform: translateX(-50%) translateY(0) !important;
    }
    .dropdown-link {
      font-size: max(0.8rem, 1vw);
    }
  }

  /* CTA */
  .header-actions {
    display: flex;
    align-items: center;
    gap: max(0.5rem, 1vw);
    flex-shrink: 0;
  }
  .btn-cta {
    background: var(--color-primary);
    color: #fff;
    text-decoration: none;
    font-size: max(0.8rem, 1vw);
    padding: max(0.35rem, 0.5vw) max(0.7rem, 1.2vw);
    border-radius: var(--radius);
    font-weight: 700;
    white-space: nowrap;
    transition:
      filter 0.2s,
      transform 0.2s;
  }
  .btn-cta:hover {
    filter: brightness(1.08);
    transform: translateY(-0.1rem);
  }

  /* HAMBURGER — oculto en desktop */
  .nav-toggle {
    display: none;
  }
  .nav-overlay {
    display: none;
  }

  /* ===== MOBILE (hamburguesa) ===== */
  @media (max-width: 767px) {
    /* Mostrar botón hamburguesa */
    .nav-toggle {
      display: flex;
      flex-direction: column;
      justify-content: center;
      gap: 0.3rem;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.4rem;
      z-index: 102;
    }
    .nav-toggle span {
      display: block;
      width: 1.5rem;
      height: 0.15rem;
      background: var(--color-primary);
      border-radius: 1rem;
      transition: all 0.3s;
    }
    .nav-toggle.open span:nth-child(1) {
      transform: translateY(0.45rem) rotate(45deg);
    }
    .nav-toggle.open span:nth-child(2) {
      opacity: 0;
    }
    .nav-toggle.open span:nth-child(3) {
      transform: translateY(-0.45rem) rotate(-45deg);
    }

    /* Overlay oscuro */
    .nav-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.4);
      z-index: 100;
      display: none;
    }
    .nav-overlay.active {
      display: block;
    }

    /* Panel de nav: desliza desde la derecha */
    .nav-menu {
      position: fixed;
      top: 0;
      right: -100%;
      bottom: 0;
      width: min(75vw, 20rem);
      background: #fff;
      z-index: 101;
      flex-direction: column;
      justify-content: flex-start;
      padding: 4rem 1.5rem 2rem;
      box-shadow: -0.2rem 0 1.5rem rgba(0, 0, 0, 0.1);
      transition: right 0.3s ease;
      overflow-y: auto;
    }
    .nav-menu.open {
      right: 0;
    }

    .nav-list {
      flex-direction: column;
      align-items: stretch;
      gap: 0.3rem;
      width: 100%;
    }
    .nav-link {
      width: 100%;
      font-size: 1rem;
      padding: 0.7rem 0.8rem;
      justify-content: space-between;
    }

    /* Dropdown mobile — ya está configurado mobile-first en los estilos base */
    .nav-item-dropdown {
      width: 100%;
    }
  } /* fin @media (max-width: 767px) */
</style>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const toggle = document.getElementById("nav-toggle");
    const nav = document.getElementById("nav-menu");
    const overlay = document.getElementById("nav-overlay");
    const serviciosBtn = document.getElementById("servicios-btn");
    const dropdownMenu = document.getElementById("dropdown-menu");

    // ── Menú mobile ──
    function closeMenu() {
      nav?.classList.remove("open");
      toggle?.classList.remove("open");
      overlay?.classList.remove("active");
      toggle?.setAttribute("aria-expanded", "false");
    }
    function openMenu() {
      nav?.classList.add("open");
      toggle?.classList.add("open");
      overlay?.classList.add("active");
      toggle?.setAttribute("aria-expanded", "true");
    }
    toggle?.addEventListener("click", () => {
      nav?.classList.contains("open") ? closeMenu() : openMenu();
    });
    overlay?.addEventListener("click", closeMenu);

    // Cerrar mobile al hacer clic en links (excepto el botón de servicios)
    nav?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    // ── Dropdown servicios ──
    function closeDropdown() {
      dropdownMenu?.classList.remove("open");
      serviciosBtn?.setAttribute("aria-expanded", "false");
    }
    function openDropdown() {
      dropdownMenu?.classList.add("open");
      serviciosBtn?.setAttribute("aria-expanded", "true");
    }
    function toggleDropdown() {
      dropdownMenu?.classList.contains("open")
        ? closeDropdown()
        : openDropdown();
    }

    serviciosBtn?.addEventListener("click", (e) => {
      e.stopPropagation();
      toggleDropdown();
    });

    // Cerrar dropdown al hacer clic fuera
    document.addEventListener("click", (e) => {
      if (
        !serviciosBtn?.contains(e.target) &&
        !dropdownMenu?.contains(e.target)
      ) {
        closeDropdown();
      }
    });

    // Cerrar dropdown al presionar Escape
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") closeDropdown();
    });
  });
</script>
