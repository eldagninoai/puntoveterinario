---
const servicios = [
  { href: "/servicios/consulta-veterinaria", label: "Consulta Médica" },
  {
    href: "/servicios/estetica-canina-felina",
    label: "Estética Canina y Felina",
  },
  { href: "/servicios/esterilizacion", label: "Esterilización" },
  { href: "/servicios/cirugia-veterinaria", label: "Cirugías" },
  { href: "/servicios/laboratorio-clinico", label: "Laboratorio Clínico" },
  { href: "/servicios/alimento-mascotas", label: "Alimento para Mascotas" },
];

const linksExtra = [
  { href: "/ubicacion", label: "📍 Cómo llegar" },
  { href: "/urgencias", label: "🚨 Urgencias" },
  { href: "/blog", label: "📝 Blog veterinario" },
  { href: "/contacto", label: "📅 Agendar cita" },
];

const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__grid">
    <!-- Columna 1 — Marca -->
    <div class="footer__brand">
      <a href="/" class="footer__logo">🐾 Punto Veterinario</a>
      <p class="footer__slogan">¡De cola a nariz, tu mascota feliz!</p>
      <p class="footer__desc">
        Atendemos a tu compañero con amor y profesionalismo en Coyoacán, CDMX.
      </p>
      <a
        href="https://www.instagram.com/punto_veterinario/"
        target="_blank"
        rel="noopener"
        class="footer__social"
        aria-label="Instagram de Punto Veterinario"
      >
        📸 @punto_veterinario
      </a>
    </div>

    <!-- Columna 2 — Servicios -->
    <div class="footer__col">
      <h3>Servicios</h3>
      <ul class="footer__list">
        {
          servicios.map((s) => (
            <li>
              <a href={s.href}>{s.label}</a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Columna 3 — Contacto -->
    <div class="footer__col">
      <h3>Contacto</h3>
      <ul class="footer__list footer__contact">
        <li>
          <span>📍</span>
          <div>
            Av. División del Norte 3595<br />
            San Pablo Tepetlapa<br />
            CP 04620, Coyoacán, CDMX
          </div>
        </li>
        <li>
          <span>📞</span>
          <a href="tel:+525513843004">+52 55 1384 3004</a>
        </li>
        <li>
          <span>✉️</span>
          <a href="mailto:puntovetcdmx@gmail.com">puntovetcdmx@gmail.com</a>
        </li>
        <li>
          <span>💬</span>
          <a href="https://wa.me/525513843004" target="_blank" rel="noopener"
            >WhatsApp</a
          >
        </li>
      </ul>
    </div>

    <!-- Columna 4 — Horario + Links -->
    <div class="footer__col">
      <h3>Horario</h3>
      <div class="footer__horario">
        <p>Lunes: Cerrado</p>
        <p>Mar-Sáb: 10:00 - 19:00</p>
        <p>Dom: 10:00 - 17:00</p>
      </div>
      <h3 class="mt-md">Enlaces Rápidos</h3>
      <ul class="footer__list">
        {
          linksExtra.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p>© {currentYear} Punto Veterinario · Coyoacán, CDMX</p>
      <p>Av. División del Norte 3595, San Pablo Tepetlapa, CP 04620</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-primary-dark, #3dada9);
    color: var(--color-bg, #ffffff);
    margin-top: var(--space-xl);
  }

  .footer__grid {
    display: grid;
    /* Grid de 4 columnas fluido que colapsa en móvil */
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: var(--space-lg);
    padding-block: var(--space-xl);
  }

  .footer__logo {
    display: inline-block;
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-bg, #ffffff);
    text-decoration: none;
    margin-bottom: var(--space-xs);
  }

  .footer__slogan {
    font-weight: 600;
    font-size: var(--text-base);
    margin-bottom: var(--space-xs);
    color: var(--color-primary-light, #e8fafa);
  }

  .footer__desc {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: var(--space-md);
    line-height: 1.5;
  }

  .footer__social {
    color: var(--color-bg, #ffffff);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: 500;
    transition:
      color 0.2s ease,
      transform 0.2s ease;
    display: inline-block;
  }

  .footer__social:hover {
    color: var(--color-secondary, #cfbaaa);
    transform: translateY(-0.15rem);
  }

  .footer__col h3 {
    font-size: var(--text-md);
    font-weight: 600;
    color: var(--color-bg, #ffffff);
    margin-bottom: var(--space-sm);
    border-bottom: 0.1rem solid rgba(255, 255, 255, 0.2);
    padding-bottom: var(--space-xs);
  }

  .mt-md {
    margin-top: var(--space-md);
  }

  .footer__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    padding: 0;
    margin: 0;
  }

  .footer__list li {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.4;
  }

  .footer__list a {
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    transition:
      color 0.2s,
      padding-left 0.2s;
    display: inline-block;
  }

  .footer__list a:hover {
    color: var(--color-bg, #ffffff);
    padding-left: 0.3rem; /* subtil hover animation */
  }

  .footer__contact li {
    display: flex;
    gap: var(--space-xs);
    align-items: flex-start;
  }

  .footer__contact span {
    flex-shrink: 0;
  }

  .footer__horario {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.85);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    line-height: 1.4;
  }

  .footer__bottom {
    border-top: 0.1rem solid rgba(255, 255, 255, 0.15);
    padding-block: var(--space-md);
    background: rgba(
      0,
      0,
      0,
      0.05
    ); /* Slight darkening for the very bottom bar */
  }

  .footer__bottom-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
    text-align: center;
  }

  .footer__bottom p {
    font-size: var(--text-xs);
    color: rgba(255, 255, 255, 0.7);
    margin: 0;
  }

  /* MEDIA QUERIES (if any needed besides auto-fit grid) */
  @media (min-width: 48rem) {
    .footer__bottom-inner {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }
</style>
