---
const servicios = [
  { href: "/servicios/consulta-veterinaria", label: "Consulta Médica" },
  {
    href: "/servicios/estetica-canina",
    label: "Estética Canina",
  },
  { href: "/servicios/esterilizacion", label: "Esterilización" },
  { href: "/servicios/cirugia-veterinaria", label: "Cirugías" },
  { href: "/servicios/laboratorio-clinico", label: "Laboratorio Clínico" },
  { href: "/servicios/alimento-mascotas", label: "Alimento para Mascotas" },
];

const linksExtra = [
  { href: "/ubicacion", label: "📍 Cómo llegar" },
  { href: "/blog", label: "📝 Blog veterinario" },
  { href: "/contacto", label: "📅 Agendar cita" },
];

const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__grid">
    <!-- Columna 1 — Marca -->
    <div class="footer__brand">
      <a href="/" class="footer__logo">🐾 Punto Veterinario</a>
      <p class="footer__slogan">¡De cola a nariz, tu mascota feliz!</p>
      <p class="footer__desc">
        Atendemos a tu compañero con amor y profesionalismo en Coyoacán, CDMX.
      </p>
      <a
        href="https://www.instagram.com/punto_veterinario/"
        target="_blank"
        rel="noopener"
        class="footer__social"
        aria-label="Instagram de Punto Veterinario"
      >
        📸 @punto_veterinario
      </a>
    </div>

    <!-- Columna 2 — Servicios -->
    <div class="footer__col">
      <h3>Servicios</h3>
      <ul class="footer__list">
        {
          servicios.map((s) => (
            <li>
              <a href={s.href}>{s.label}</a>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Columna 3 — Contacto -->
    <div class="footer__col">
      <h3>Contacto</h3>
      <ul class="footer__list footer__contact">
        <li>
          <span>📍</span>
          <div>
            <a
              href="https://maps.app.goo.gl/GricGKCzpp6BXJgE7?g_st=aw"
              target="_blank"
              rel="noopener"
              aria-label="Ver ubicación en Google Maps"
              class="maps-link"
            >
              Av. División del Norte 3595, San Pablo Tepetlapa, CP 04620,
              Coyoacán, CDMX
            </a>
          </div>
        </li>
        <li>
          <span>📞</span>
          <a href="tel:+525513843004">+52 55 1384 3004</a>
        </li>
        <li>
          <span>✉️</span>
          <a href="mailto:puntovetcdmx@gmail.com">puntovetcdmx@gmail.com</a>
        </li>
        <li>
          <span>💬</span>
          <a href="https://wa.me/525513843004" target="_blank" rel="noopener"
            >WhatsApp</a
          >
        </li>
      </ul>
    </div>

    <!-- Columna 4 — Horario + Links -->
    <div class="footer__col">
      <h3>Horario</h3>
      <div class="footer__horario">
        <p>Lunes: Cerrado</p>
        <p>Mar-Sáb: 10:00 - 19:00</p>
        <p>Dom: 10:00 - 17:00</p>
      </div>
      <h3 class="mt-md">Enlaces Rápidos</h3>
      <ul class="footer__list">
        {
          linksExtra.map((link) => (
            <li>
              <a href={link.href}>{link.label}</a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p>© {currentYear} Punto Veterinario · Coyoacán, CDMX</p>
      <p>
        <a
          href="https://maps.app.goo.gl/GricGKCzpp6BXJgE7?g_st=aw"
          target="_blank"
          rel="noopener"
          aria-label="Ver ubicación en Google Maps"
          class="maps-link"
        >
          Av. División del Norte 3595, San Pablo Tepetlapa, CP 04620, Coyoacán,
          CDMX
        </a>
      </p>
    </div>
  </div>
</footer>

<style>


  .footer {
    background: var(--color-primary-dark, #3dada9);
    color: var(--color-bg, #ffffff);
    margin-top: clamp(2rem, 5vw, 10vw);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 18vw), 1fr));
    gap: clamp(1.5rem, 3vw, 5vw);
    padding-block: clamp(2rem, 4vw, 7vw);
  }

  .footer__logo {
    display: inline-block;
    font-size: clamp(1.2rem, 1.8vw, 3vw);
    font-weight: 700;
    color: var(--color-bg, #ffffff);
    text-decoration: none;
    margin-bottom: clamp(0.5rem, 1vw, 2vw);
  }

  .footer__slogan {
    font-weight: 600;
    font-size: clamp(0.9rem, 1.2vw, 2.2vw);
    margin-bottom: clamp(0.5rem, 1vw, 2vw);
    color: var(--color-primary-light, #e8fafa);
  }

  .footer__desc {
    font-size: clamp(0.85rem, 1.1vw, 2vw);
    color: rgba(255, 255, 255, 0.85);
    margin-bottom: clamp(1rem, 2vw, 4vw);
    line-height: 1.5;
  }

  .footer__social {
    color: var(--color-bg, #ffffff);
    text-decoration: none;
    font-size: clamp(0.85rem, 1.1vw, 2vw);
    font-weight: 500;
    transition:
      color 0.2s ease,
      transform 0.2s ease;
    display: inline-block;
  }

  .footer__social:hover {
    color: var(--color-secondary, #cfbaaa);
    transform: translateY(-0.15rem);
  }

  .footer__col h3 {
    font-size: clamp(1rem, 1.4vw, 2.5vw);
    font-weight: 600;
    color: var(--color-bg, #ffffff);
    margin-bottom: clamp(0.8rem, 1.5vw, 3vw);
    border-bottom: 0.1rem solid rgba(255, 255, 255, 0.2);
    padding-bottom: clamp(0.4rem, 0.8vw, 1.6vw);
  }

  .mt-md {
    margin-top: clamp(1.5rem, 3vw, 5vw);
  }

  .footer__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: clamp(0.5rem, 1vw, 2vw);
    padding: 0;
    margin: 0;
  }

  .footer__list li {
    font-size: clamp(0.85rem, 1.1vw, 2vw);
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.4;
  }

  .footer__list a {
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    transition:
      color 0.2s,
      padding-left 0.2s;
    display: inline-block;
  }

  .footer__list a:hover {
    color: var(--color-bg, #ffffff);
    padding-left: clamp(0.2rem, 0.4vw, 0.8vw);
  }

  .footer__contact li {
    display: flex;
    gap: clamp(0.5rem, 1vw, 2vw);
    align-items: flex-start;
  }

  .footer__contact span {
    flex-shrink: 0;
    font-size: clamp(1rem, 1.2vw, 2.2vw);
  }

  .footer__horario {
    font-size: clamp(0.85rem, 1.1vw, 2vw);
    color: rgba(255, 255, 255, 0.85);
    display: flex;
    flex-direction: column;
    gap: clamp(0.3rem, 0.6vw, 1.2vw);
    line-height: 1.4;
  }
  .footer__horario p {
    margin: 0;
  }

  .footer__bottom {
    border-top: 0.1rem solid rgba(255, 255, 255, 0.15);
    padding-block: clamp(1.5rem, 3vw, 6vw);
    background: rgba(0, 0, 0, 0.05);
  }

  .footer__bottom-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: clamp(0.5rem, 1vw, 2vw);
    font-size: clamp(0.75rem, 1vw, 1.8vw);
    color: rgba(255, 255, 255, 0.6);
  }

  @media (min-width: 48rem) {
    .footer__bottom-inner {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }

  .footer__bottom p {
    margin: 0;
  }

  .maps-link {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: rgba(255, 255, 255, 0.4);
    text-underline-offset: 0.2rem;
    transition:
      color 0.2s,
      text-decoration-color 0.2s;
  }
  .maps-link:hover {
    color: #fff;
    text-decoration-color: #fff;
  }

    @media (max-width: 48rem) {
        [class*="grid-"] {
            grid-template-columns: repeat(2, 1fr) !important;
        }
    }
    @media (max-width: 30rem) {
        [class*="grid-"] {
            grid-template-columns: 1fr !important;
        }
    }
</style>
