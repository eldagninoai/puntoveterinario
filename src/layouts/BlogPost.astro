---
import BaseLayout from "./BaseLayout.astro";

const { frontmatter } = Astro.props;
const {
    title,
    description,
    pubDate,
    updatedDate,
    heroImage,
    authorName = "Pilar",
    authorImage = "/placeholder-doctora.webp",
} = frontmatter || Astro.props;

// Construimos el canonical dinámicamente sin trailing slash
const url = new URL(
    Astro.url.pathname.replace(/\/$/, "") || "/",
    Astro.site || "https://puntoveterinario.com",
).href;

const schema = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    mainEntityOfPage: {
        "@type": "WebPage",
        "@id": url,
    },
    headline: title,
    image: heroImage
        ? new URL(heroImage, Astro.site || "https://puntoveterinario.com").href
        : "https://puntoveterinario.com/logo.png",
    author: {
        "@type": "Person",
        name: `MVZ. ${authorName}`,
        url: "https://puntoveterinario.com/nosotros",
    },
    publisher: {
        "@type": "Organization",
        name: "Punto Veterinario",
        logo: {
            "@type": "ImageObject",
            url: "https://puntoveterinario.com/logo.png",
        },
    },
    datePublished: pubDate,
    dateModified: updatedDate || pubDate,
};

// Formateador humano para la fecha
const displayDate = new Date(pubDate).toLocaleDateString("es-MX", {
    year: "numeric",
    month: "long",
    day: "numeric",
});
---

<BaseLayout
    title={`${title} | Blog Punto Veterinario`}
    description={description}
    canonical={url}
>
    <Fragment slot="head">
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    </Fragment>

    <main class="article-wrapper">
        <article class="prose-container">
            <!-- HERO DEL ARTÍCULO -->
            <header class="article-header">
                <h1 class="article-title">{title}</h1>

                <!-- MATRIZ E-E-A-T: CAJA DE AUTOR -->
                <div class="author-box">
                    <a
                        href="/nosotros"
                        class="author-link"
                        aria-label={`Perfil de ${authorName}`}
                    >
                        <img
                            src={authorImage}
                            alt={`Foto de MVZ. ${authorName}`}
                            class="author-avatar"
                            width="100"
                            height="100"
                            loading="lazy"
                            decoding="async"
                        />
                    </a>
                    <div class="author-meta">
                        <span class="author-name"
                            >Por: <a href="/nosotros" class="author-text-link"
                                >MVZ. {authorName}</a
                            ></span
                        >
                        <span class="author-role"
                            >Médico Veterinario Zootecnista</span
                        >
                        <time datetime={pubDate} class="article-date"
                            >Publicado el {displayDate}</time
                        >
                    </div>
                </div>

                {
                    heroImage && (
                        <figure class="article-hero-figure">
                            <img
                                src={heroImage}
                                alt={title}
                                class="article-hero-image"
                                width="1200"
                                height="630"
                                loading="eager"
                                decoding="async"
                            />
                        </figure>
                    )
                }
            </header>

            <!-- TABLA DE CONTENIDOS (Opcional, insertada por Markdown si existe, pero el layout le da soporte local) -->

            <!-- CUERPO DEL TEXTO (MDX/MARKDOWN RENDER) -->
            <div class="prose">
                <slot />
            </div>

            <!-- BANNER CTA FINAL (DENTRO DEL ARTÍCULO) -->
            <div class="article-cta">
                <h3 class="article-cta-title">
                    ¿Necesitas ayuda profesional para tu mejor amigo?
                </h3>
                <p class="article-cta-desc">
                    Si vives en el sur de la CDMX (Coyoacán, San Pablo
                    Tepetlapa, Pedregal) y notas estos síntomas en tu mascota,
                    agenda una revisión en Punto Veterinario. Evaluaremos su
                    caso con equipo de vanguardia y trato libre de estrés.
                </p>
                <div class="article-cta-btns">
                    <a href="/contacto" class="btn-primary">
                        📅 Agendar Cita en Coyoacán
                    </a>
                    <a
                        href="https://wa.me/525513843004"
                        target="_blank"
                        rel="noopener"
                        class="btn-wa-post"
                    >
                        💬 Consultar Whatsapp
                    </a>
                </div>
            </div>
        </article>
    </main>
</BaseLayout>

<style>
    /* ====== CLAMP SYSTEM + RESPONSIVE ====== */
    /* NO TAILWIND. FLUJO LECTURA OPTIMIZADO */

    .article-wrapper {
        background: var(--color-bg);
        padding-block: max(3rem, 6vw);
        width: 100%;
    }

    .prose-container {
        /* Align content with header logo/nav edges and allow near full-screen width */
        width: 100%;
        max-width: 100%; /* Occupy full available width minus padding */
        margin: 0;
        padding-inline: max(
            1.5rem,
            6vw
        ); /* Matches Header padding-inline for alignment */
    }

    /* HEADER ARTÍCULO */
    .article-header {
        margin-bottom: max(2rem, 4vw);
        background: var(--color-bg-soft);
        padding: max(2rem, 3vw);
        border-radius: max(1rem, 2vw);
        box-shadow: 0 max(0.4rem, 1vw) max(1rem, 2vw) rgba(0, 0, 0, 0.03);
    }

    .article-title {
        font-size: max(2.5rem, 4vw);
        line-height: 1.15;
        margin-bottom: max(1.5rem, 3vw);
        text-wrap: balance;
        /* Gradient title */
        background: linear-gradient(90deg, #2bb3c0, #f15a24);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        color: transparent;
    }

    /* CAJA DE AUTOR E-E-A-T */
    .author-box {
        display: flex;
        align-items: center;
        gap: max(1rem, 1.5vw);
        padding: max(1rem, 1.5vw);
        background: var(--color-bg-soft);
        border-radius: max(0.8rem, 1.5vw);
        margin-bottom: max(2rem, 4vw);
    }

    .author-avatar {
        width: max(4rem, 6vw);
        height: max(4rem, 6vw);
        border-radius: 50%;
        object-fit: cover;
        background: var(--color-bg-soft);
        border: max(0.2rem, 0.3vw) solid var(--mural-teal);
        display: block; /* Fix possible inline-block padding issues */
    }

    .author-meta {
        display: flex;
        flex-direction: column;
        gap: max(0.2rem, 0.4vw);
    }

    .author-name {
        font-size: max(1.1rem, 1.5vw);
        color: var(--color-primary-dark);
        font-weight: 700;
    }

    .author-role {
        font-size: max(0.9rem, 1.2vw);
        color: var(--mural-teal);
        font-weight: 600;
        margin-bottom: max(0.2rem, 0.4vw);
    }
    .author-text-link {
        color: inherit;
        text-decoration: none;
        transition: color 0.2s;
    }
    .author-text-link:hover {
        color: var(--color-primary);
        text-decoration: underline;
        text-underline-offset: 0.2rem;
    }

    .article-date {
        font-size: max(0.85rem, 1.1vw);
        color: var(--color-text-soft);
    }

    /* HERO IMAGE */
    .article-hero-figure {
        width: 100%;
        margin: 0;
        margin-top: max(2rem, 4vw);
        border-radius: max(1rem, 2vw);
        overflow: hidden;
        aspect-ratio: 16 / 9;
        box-shadow: 0 max(0.5rem, 1vw) max(2rem, 3vw) rgba(0, 0, 0, 0.15);
    }
    .article-hero-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    /* =======================================
     PROSE (MDX/MARKDOWN RENDER STYLES)
     Optimizados para Featured Snippets Google
  ======================================= */
    .prose {
        font-size: max(1.15rem, 1.4vw);
        line-height: 2.1; /* Extreme line-height for maximum legibility */
        color: var(--color-text);
        letter-spacing: 0.01ch; /* Subtle breathing room for letters */
    }

    /* Párrafos e inferiores */
    .prose p {
        margin-bottom: max(
            3rem,
            4.5vw
        ); /* Massive vertical separation between paragraphs */
    }

    /* Headers Semánticos en artículo */
    .prose h2,
    .prose h3,
    .prose h4 {
        line-height: 1.3;
        margin-top: max(
            5rem,
            8vw
        ); /* Huge space before headings to separate sections */
        margin-bottom: max(1.5rem, 2vw);
        font-weight: 700;
    }

    /* Colores intercalados del mural para Headings */
    .prose h2 {
        font-size: max(1.8rem, 2.5vw);
        color: var(--mural-teal);
    }
    .prose h3 {
        font-size: max(1.4rem, 2vw);
        color: var(--mural-orange);
    }
    .prose h4 {
        font-size: max(1.2rem, 1.6vw);
        color: var(--mural-pink);
    }

    /* Listas (Críticas para Fragmentos Destacados SEO) */
    .prose ul,
    .prose ol {
        margin-bottom: max(1.5rem, 2vw);
        padding-left: max(1.5rem, 2vw);
    }
    .prose li {
        margin-bottom: max(0.5rem, 0.8vw);
    }
    .prose li::marker {
        color: var(--color-primary);
        font-weight: 700;
    }

    /* Blockquotes (Citas médicas/E-E-A-T) */
    .prose blockquote {
        border-left: max(0.3rem, 0.4vw) solid var(--color-primary);
        background: var(--color-bg-soft);
        padding: max(1rem, 1.5vw) max(1.5rem, 2vw);
        margin: max(2rem, 3vw) 0;
        border-radius: 0 max(0.5rem, 1vw) max(0.5rem, 1vw) 0;
        font-style: italic;
        color: var(--color-primary-dark);
    }
    .prose blockquote p:last-child {
        margin-bottom: 0;
    }

    /* Imágenes en Markdown */
    .prose img {
        max-width: 100%;
        height: auto;
        border-radius: max(0.4rem, 0.8vw);
        margin: max(3.5rem, 6vw) 0; /* Huge separation for images */
        box-shadow: var(--shadow-sm);
    }

    /* Enlaces de texto */
    .prose a {
        color: var(--color-primary);
        text-decoration: underline;
        text-underline-offset: 0.2rem;
        transition: color 0.2s;
    }
    .prose a:hover {
        color: var(--color-primary-dark);
    }

    /* CTA INTERMEDIO / FINAL */
    .article-cta {
        background: var(--color-bg-soft);
        border: max(0.05rem, 0.1vw) solid var(--color-border);
        border-radius: max(0.5rem, 1.5vw);
        padding: max(2rem, 3vw);
        margin-top: max(4rem, 6vw);
        text-align: center;
        box-shadow: var(--shadow-sm);
    }

    .article-cta-title {
        font-size: max(1.4rem, 2vw);
        color: var(--color-primary-dark);
        margin-bottom: max(1rem, 1.5vw);
        line-height: 1.25;
    }

    .article-cta-desc {
        font-size: max(0.95rem, 1.2vw);
        color: var(--color-text-soft);
        line-height: 1.6;
        margin-bottom: max(2rem, 3vw);
        max-width: 90%;
        margin-inline: auto;
    }

    .article-cta-btns {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: max(1rem, 1.5vw);
    }

    .btn-primary {
        background: var(--color-primary);
        color: #fff;
        padding: max(0.8rem, 1.2vw) max(1.5rem, 2.5vw);
        font-size: max(1rem, 1.4vw);
        border-radius: max(2rem, 3vw); /* Rounded fluid style */
        font-weight: 600;
        text-decoration: none;
        transition:
            background 0.2s,
            transform 0.2s,
            box-shadow 0.2s;
        box-shadow: 0 max(0.4rem, 0.8vw) max(1rem, 2vw) rgba(43, 179, 192, 0.3);
    }
    .btn-primary:hover {
        background: var(--color-primary-dark);
        transform: translateY(max(-0.2rem, -0.4vw));
        box-shadow: 0 max(0.6rem, 1.2vw) max(1.5rem, 3vw)
            rgba(43, 179, 192, 0.4);
    }

    .btn-wa-post {
        background: #25d366; /* Verde oficial WhatsApp */
        color: #fff;
        padding: max(0.8rem, 1.2vw) max(1.5rem, 2.5vw);
        font-size: max(1rem, 1.4vw);
        border-radius: max(2rem, 3vw); /* Rounded fluid style */
        font-weight: 600;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: max(0.5rem, 1vw);
        transition:
            background 0.2s,
            transform 0.2s,
            box-shadow 0.2s;
        box-shadow: 0 max(0.4rem, 0.8vw) max(1rem, 2vw) rgba(37, 211, 102, 0.3);
    }
    .btn-wa-post:hover {
        background: #128c7e;
        transform: translateY(max(-0.2rem, -0.4vw));
        box-shadow: 0 max(0.6rem, 1.2vw) max(1.5rem, 3vw)
            rgba(37, 211, 102, 0.4);
    }
</style>
