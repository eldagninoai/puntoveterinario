---
import BaseLayout from "../layouts/BaseLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Blog de Punto Veterinario",
  url: "https://puntoveterinario.com/blog",
  description:
    "Artículos sobre salud, nutrición y cuidados veterinarios para perros y gatos en México.",
  publisher: {
    "@type": "VeterinaryCare",
    name: "Punto Veterinario",
    logo: {
      "@type": "ImageObject",
      url: "https://puntoveterinario.com/logo.png",
    },
  },
};

const articulos = [
  {
    imagen: "/placeholder-blog-1.webp",
    categoria: "Prevención",
    titulo: "¿Cada cuánto vacunar a mi perro? Calendario México 2026",
    fecha: "2026-01-15",
    fechaDisplay: "15 de Enero, 2026",
    extracto:
      "El calendario oficial de vacunación para perros en México, explicado paso a paso por nuestros veterinarios en Coyoacán para mantener la inmunidad de tu mejor amigo.",
    href: "#",
  },
  {
    imagen: "/placeholder-blog-2.webp",
    categoria: "Cirugías",
    titulo: "La verdad sobre la esterilización: mitos y realidades",
    fecha: "2026-02-10",
    fechaDisplay: "10 de Febrero, 2026",
    extracto:
      "Conoce por qué la esterilización temprana no solo previene enfermedades graves como la piometra, sino que alarga la esperanza de vida de tu mascota.",
    href: "#",
  },
  {
    imagen: "/placeholder-blog-3.webp",
    categoria: "Nutrición",
    titulo: "¿Croquetas de súper o alimento premium? Guía definitiva",
    fecha: "2026-03-01",
    fechaDisplay: "1 de Marzo, 2026",
    extracto:
      "Aprende a leer las etiquetas de los alimentos. Descubre por qué la taurina y la digestibilidad son los factores médicos más importantes en la dieta diaria.",
    href: "#",
  },
];
---

<BaseLayout
  title="Blog Veterinario: Cuidados para Perros y Gatos en CDMX"
  description="Consejos médicos, nutrición y guías de cuidado para perros y gatos, escritos por los médicos especialistas de Punto Veterinario en Coyoacán, CDMX."
  canonical="https://puntoveterinario.com/blog"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <!-- SECCIÓN 1 — HERO DEL BLOG -->
  <section class="hero content-section">
      <div class="hero__text">
        <h1 class="h1-hero">
          Blog y Consejos Veterinarios para Mascotas en CDMX
        </h1>
        <p class="hero__desc">
          Guías de salud, nutrición y prevención escritas por nuestro equipo
          médico en Coyoacán. Encuentra respuestas confiables para el cuidado
          diario de tu perro o gato.
        </p>
      </div>
    </section>

  <!-- SECCIÓN 2 — GRID DE ARTÍCULOS RECIENTES -->
  <section class="content-section bg-soft">
      <div class="grid-blog">
        {
          articulos.map((articulo) => (
            <article class="blog-card">
              <div class="blog-imagen-wrapper">
                <img
                  src={articulo.imagen}
                  alt={`Imagen representativa del artículo: ${articulo.titulo}`}
                  class="blog-img"
                  width="800"
                  height="450"
                  loading="lazy"
                  decoding="async"
                  onerror="this.src='/placeholder-fachada.webp'; this.alt='Imagen por defecto del blog veterinario';"
                />
                <span class="blog-categoria">{articulo.categoria}</span>
              </div>

              <div class="blog-contenido">
                <time datetime={articulo.fecha} class="blog-fecha">
                  {articulo.fechaDisplay}
                </time>
                <h2 class="blog-titulo">
                  <a href={articulo.href} class="blog-link">
                    {articulo.titulo}
                  </a>
                </h2>
                <p class="blog-extracto">{articulo.extracto}</p>
                <a href={articulo.href} class="blog-readmore">
                  Leer artículo completo &rarr;
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </section>

  <!-- SECCIÓN 3 — CTA URGENCIA -->
  <section class="content-section bg-soft-alt">
      <h2 class="cta-titulo">
        ¿No encuentras lo que buscas o tu mascota se siente mal?
      </h2>
      <p class="cta-desc">
        La información de internet no sustituye un diagnóstico profesional. Si
        tienes dudas sobre la salud de tu mascota, escríbenos directamente.
      </p>
      <div class="cta-btns">
        <a
          href="https://wa.me/525513843004"
          target="_blank"
          rel="noopener"
          class="btn-wa"
        >
          💬 Consultar por WhatsApp
        </a>
      </div>
    </section>
</BaseLayout>

<style>
  /* ====== CLAMP SYSTEM + RESPONSIVE ====== */
  /* 100% Fluid Vanilla CSS */

  .content-section {
    padding-block: max(3rem, 6vw);
  }
  .bg-soft {
    background: var(--color-bg-soft);
  }
  .bg-soft-alt {
    background: #f4f6f8; /* Un gris apenas más contrastante si se requiere separar visualmente */
  }

  /* HERO */
  .hero {
    background: var(--color-bg);
  }
  .hero__inner {
    text-align: center;
  }
  .hero__text {
    max-width: max(20rem, 80vw);
    margin: 0 auto;
  }
  .h1-hero {
    font-size: max(1.8rem, 3.2vw);
    color: var(--color-primary-dark);
    line-height: 1.15;
    margin-bottom: max(1rem, 2vw);
  }
  .hero__desc {
    font-size: max(0.95rem, 1.4vw);
    color: var(--color-text-soft);
    line-height: 1.6;
    margin: 0;
  }

  /* GRID DE BLOG */
  .grid-blog {
    display: grid;
    /* 3 Desktop, 2 Tablet, 1 Mobile */
    grid-template-columns: repeat(3, 1fr);
    gap: max(1.5rem, 3vw);
  }
  @media (
    }
  }
  @media (
    }
  }

  .blog-card {
    background: var(--color-bg);
    border: max(0.05rem, 0.1vw) solid var(--color-border);
    border-radius: max(0.5rem, 1vw);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    transition:
      transform 0.2s,
      box-shadow 0.2s;
  }
  .blog-card:hover {
    transform: translateY(-0.25rem);
    box-shadow: var(--shadow-md);
  }

  .blog-imagen-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: var(--color-bg-soft);
    overflow: hidden;
    border-bottom: max(0.05rem, 0.1vw) solid var(--color-border);
  }
  .blog-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .blog-card:hover .blog-img {
    transform: scale(1.03); /* Suave zoom perceptivo */
  }

  /* Píldora Categoria Flotante */
  .blog-categoria {
    position: absolute;
    top: max(0.5rem, 1vw);
    left: max(0.5rem, 1vw);
    background: var(--color-bg);
    color: var(--color-primary-dark);
    font-size: max(0.7rem, 0.9vw);
    font-weight: 700;
    padding: max(0.2rem, 0.4vw) max(0.6rem, 1vw);
    border-radius: max(0.2rem, 0.5vw);
    text-transform: uppercase;
    letter-spacing: 0.05rem;
    box-shadow: var(--shadow-sm);
    z-index: 10;
  }

  .blog-contenido {
    padding: max(1.2rem, 2vw);
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .blog-fecha {
    font-size: max(0.8rem, 1vw);
    color: var(--color-text-soft);
    margin-bottom: max(0.4rem, 0.8vw);
    display: block;
  }

  .blog-titulo {
    font-size: max(1.2rem, 1.6vw);
    color: var(--color-primary-dark);
    margin-bottom: max(0.8rem, 1.2vw);
    line-height: 1.25;
  }
  .blog-link {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }
  .blog-link:hover {
    color: var(--color-primary);
  }

  .blog-extracto {
    font-size: max(0.9rem, 1.2vw);
    color: var(--color-text-soft);
    line-height: 1.6;
    margin-bottom: max(1rem, 2vw);

    /* Truncado a 2 líneas nativo */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .blog-readmore {
    margin-top: auto; /* Empuja el cta al fondo de la card */
    font-size: max(0.9rem, 1.1vw);
    color: var(--color-primary);
    font-weight: 700;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.05rem;
    transition: color 0.2s;
  }
  .blog-readmore:hover {
    color: var(--color-primary-dark);
    text-decoration: underline;
    text-underline-offset: 0.2rem;
  }

  /* CTA FINAL (URGENCIA) */
  .cta-inner {
    text-align: center;
    max-width: max(20rem, 80vw);
    margin: 0 auto;
    border: max(0.05rem, 0.1vw) dashed var(--color-primary);
    padding: max(2rem, 4vw);
    border-radius: max(0.5rem, 1vw);
    background: #fff;
  }

  .cta-titulo {
    font-size: max(1.6rem, 2.4vw);
    color: var(--color-primary-dark);
    margin-bottom: max(1rem, 1.5vw);
    line-height: 1.2;
  }

  .cta-desc {
    font-size: max(0.95rem, 1.3vw);
    color: var(--color-text-soft);
    line-height: 1.6;
    margin-bottom: max(2rem, 4vw);
  }

  .cta-btns {
    display: flex;
    justify-content: center;
  }

  .btn-wa {
    background: var(--color-primary);
    color: #fff;
    padding: max(0.6rem, 1.2vw) max(1.2rem, 2.5vw);
    font-size: max(0.9rem, 1.2vw);
    border-radius: max(0.4rem, 1vw);
    font-weight: 600;
    text-decoration: none;
    transition:
      background 0.2s,
      transform 0.2s;
    text-align: center;
    box-shadow: var(--shadow-sm);
  }
  .btn-wa:hover {
    background: var(--color-primary-dark);
    transform: translateY(-0.15rem);
    box-shadow: var(--shadow-md);
  }
</style>
