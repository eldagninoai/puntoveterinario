---
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogSection from "../components/BlogSection.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  name: "Blog de Punto Veterinario",
  url: "https://puntoveterinario.com/blog",
  description:
    "Artículos sobre salud, nutrición y cuidados veterinarios para perros y gatos en México.",
  publisher: {
    "@type": "VeterinaryCare",
    name: "Punto Veterinario",
    logo: {
      "@type": "ImageObject",
      url: "https://puntoveterinario.com/logo.png",
    },
  },
};
---

<BaseLayout
  title="Blog Veterinario: Cuidados para Perros y Gatos en CDMX"
  description="Consejos médicos, nutrición y guías de cuidado para perros y gatos, escritos por los médicos especialistas de Punto Veterinario en Coyoacán, CDMX."
  canonical="https://puntoveterinario.com/blog"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <!-- SECCIÓN 1 — HERO DEL BLOG -->
  <section class="hero content-section">
    <div class="hero__text">
      <h1 class="h1-hero">
        Blog y Consejos Veterinarios para Mascotas en CDMX
      </h1>
      <p class="hero__desc">
        Guías de salud, nutrición y prevención escritas por nuestro equipo
        médico en Coyoacán. Encuentra respuestas confiables para el cuidado
        diario de tu perro o gato.
      </p>
    </div>
  </section>

  <!-- SECCIÓN 2 — GRID DE ARTÍCULOS -->
  <BlogSection />

  <!-- SECCIÓN 3 — CTA URGENCIA -->
  <section class="content-section bg-soft-alt">
    <h2 class="cta-titulo">
      ¿No encuentras lo que buscas o tu mascota se siente mal?
    </h2>
    <p class="cta-desc">
      La información de internet no sustituye un diagnóstico profesional. Si
      tienes dudas sobre la salud de tu mascota, escríbenos directamente.
    </p>
    <div class="cta-btns">
      <a
        href="https://wa.me/525513843004"
        target="_blank"
        rel="noopener"
        class="btn-wa"
      >
        💬 Consultar por WhatsApp
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  /* ====== CLAMP SYSTEM + RESPONSIVE (De esterilizacion.astro) ====== */
  .content-section {
    padding-block: max(3rem, 6vw);
  }
  .bg-soft {
    background: var(--color-bg-soft);
  }

  .bg-soft-alt {
    background: #f4f6f8;
  }

  .h1-hero {
    font-size: max(1.8rem, 3.2vw);
    color: var(--color-text);
    line-height: 1.15;
    margin-bottom: max(1rem, 2vw);
  }

  /* HERO CLASSES */
  .hero {
    background: var(--color-bg);
  }
  .hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .hero__text {
    width: 100%;
    margin-inline: auto;
  }
  @media (min-width: 48rem) {
    .hero__text {
      max-width: 80%;
    }
  }

  .hero__desc {
    font-size: max(0.95rem, 1.4vw);
    color: var(--color-text-soft);
    line-height: 1.6;
    margin-bottom: max(1.5rem, 2vw);
    margin-inline: auto;
  }

  .hero__btns {
    display: flex;
    justify-content: center;
  }

  .btn-wa {
    background: var(--color-primary);
    color: #fff;
    padding: max(0.6rem, 1.2vw) max(1.2rem, 2.5vw);
    font-size: max(0.9rem, 1.2vw);
    border-radius: max(0.4rem, 1vw);
    font-weight: 600;
    text-decoration: none;
    transition:
      background 0.2s,
      transform 0.2s;
  }
  .btn-wa:hover {
    background: var(--color-primary-dark);
    transform: translateY(-0.15rem);
  }

  /* CTA FINAL (URGENCIA) */
  .cta-titulo {
    font-size: max(1.6rem, 2.4vw);
    color: var(--color-primary-dark);
    margin-bottom: max(1rem, 1.5vw);
    line-height: 1.2;
    text-align: center;
  }
  .cta-desc {
    font-size: max(0.95rem, 1.3vw);
    color: var(--color-text-soft);
    line-height: 1.6;
    margin-bottom: max(2rem, 4vw);
    text-align: center;
  }
  .cta-btns {
    display: flex;
    justify-content: center;
  }
</style>
