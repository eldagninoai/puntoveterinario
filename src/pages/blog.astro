---
import BaseLayout from '../layouts/BaseLayout.astro';
import Schema from '../components/Schema.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Blog",
    "name": "Blog Veterinario | Punto Veterinario",
    "url": "https://puntoveterinario.com/blog",
    "description": "Artículos, consejos y guías sobre salud animal, cuidados, cirugías y más, redactados por médicos veterinarios zootecnistas en Coyoacán.",
    "publisher": {
      "@type": "VeterinaryCare",
      "name": "Punto Veterinario"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Inicio",
        "item": "https://puntoveterinario.com/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Blog",
        "item": "https://puntoveterinario.com/blog"
      }
    ]
  }
];

const articulos = [
  {
    categoria: 'Cirugías y Procedimientos',
    titulo: '¿Cuánto cuesta esterilizar a un perro en Coyoacán en 2026?',
    extracto: 'Conoce los precios reales, qué incluye el procedimiento y por qué la esterilización privada puede ser la mejor opción para tu mascota en Coyoacán.',
    href: '#'
  },
  {
    categoria: 'SEO Local Veterinario',
    titulo: 'Veterinaria en Pedregal de Santo Domingo: todo lo que necesitas',
    extracto: 'Guía completa de servicios veterinarios disponibles en Pedregal de Santo Domingo y colonias cercanas del CP 04620.',
    href: '#'
  },
  {
    categoria: 'Salud Preventiva',
    titulo: '¿Cada cuánto vacunar a mi perro? Calendario México 2026',
    extracto: 'El calendario oficial de vacunación para perros en México, explicado por nuestros veterinarios en Coyoacán.',
    href: '#'
  }
];
---
<BaseLayout
  title="Blog Veterinario CDMX | Consejos para tu Mascota"
  description="Guías, consejos y recursos veterinarios para dueños de mascotas en Coyoacán y sur de CDMX. Escrito por los médicos de Punto Veterinario."
  schema={schema}
>

  <!-- 1. HERO -->
  <section class="hero bg-white py-xl text-center">
    <div class="container max-w-lg mx-auto">
      <h1 class="text-2xl text-primary-dark mb-md lh-1">Blog Veterinario en Coyoacán | Consejos para tu Mascota</h1>
      <p class="text-lg text-soft mb-lg lh-relaxed">
        Descubre nuestros invaluables e informativos artículos médicos redactados directamente por la firme y diestra mano de nuestros mejores médicos tratantes. Una fuente inagotable de sabiduría animal zootécnica desde <strong>Pedregal de Santo Domingo</strong> y la <strong>Av. División del Norte 3595</strong>, que empodera tu rol de tutor y resguarda con supremo conocimiento la inquebrantable vitalidad canina o felina de tu hogar sureño en particular.
      </p>
    </div>
  </section>

  <!-- 2. GRID DE ARTÍCULOS -->
  <section class="bg-soft py-xl">
    <div class="container">
      <h2 class="text-center mb-xl text-primary-dark">Artículos más recientes</h2>
      <div class="grid-3 gap-lg">
        {articulos.map(articulo => (
          <div class="card bg-white border-subtle border-radius overflow-hidden flex-col form-box-shadow transition-transform hover-lift">
            <!-- Imagen Placeholder -->
            <div class="image-placeholder bg-light-gray flex items-center justify-center border-bottom">
              <span class="emoji-xl text-soft block opacity-50">🐾</span>
            </div>
            
            <div class="p-lg flex-col gap-sm flex-fill">
              <span class="text-xs fw-bold text-primary t-uppercase letter-spacing-sm block">{articulo.categoria}</span>
              <h3 class="text-md text-primary-dark m-0 lh-1">{articulo.titulo}</h3>
              <p class="text-sm text-soft lh-relaxed m-0 mt-xs flex-fill">{articulo.extracto}</p>
              
              <a href={articulo.href} class="text-primary fw-bold text-sm mt-sm inline-block btn-read pointer">Leer más →</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 3. CTA -->
  <section class="cta-section bg-primary py-xl text-center">
    <div class="container max-w-lg mx-auto">
      <h2 class="text-white mb-lg text-2xl lh-1">¿Tu mascota necesita atención veterinaria en Coyoacán?</h2>
      <div class="flex flex-wrap justify-center gap-md">
        <a href="/contacto" class="btn-white-theme text-primary fw-bold text-md px-lg py-sm border-radius transition-transform inline-block">📅 Agendar Cita</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Local Fluid CSS Utilities - NO FIXED PX */
  .bg-white { background-color: var(--color-bg); }
  .bg-soft { background-color: var(--color-bg-soft); }
  .bg-primary { background-color: var(--color-primary); }
  .bg-light-gray { background-color: #EFEFEF; }
  
  .text-white { color: var(--color-bg); }
  .text-primary { color: var(--color-primary); }
  .text-primary-dark { color: var(--color-primary-dark); }
  .text-soft { color: var(--color-text-soft); }
  
  .text-center { text-align: center; }
  .text-left { text-align: left; }
  .text-xs { font-size: calc(var(--text-sm) * 0.85); }
  .text-sm { font-size: var(--text-sm); }
  .text-md { font-size: var(--text-md); }
  .text-lg { font-size: var(--text-lg); }
  .text-2xl { font-size: var(--text-2xl); }
  .fw-bold { font-weight: 700; }
  .t-uppercase { text-transform: uppercase; }
  .letter-spacing-sm { letter-spacing: 0.1rem; }
  
  .block { display: block; }
  .inline-block { display: inline-block; }
  .flex { display: flex; }
  .flex-col { display: flex; flex-direction: column; }
  .flex-wrap { flex-wrap: wrap; }
  .flex-fill { flex: 1; }
  .items-center { align-items: center; }
  .items-start { align-items: flex-start; }
  .justify-center { justify-content: center; }
  .overflow-hidden { overflow: hidden; }
  
  .m-0 { margin: 0; }
  .my-sm { margin-block: var(--space-sm); }
  .mt-sm { margin-top: var(--space-sm); }
  .mt-xs { margin-top: var(--space-xs); }
  .mt-auto { margin-top: auto; }
  .mb-xs { margin-bottom: var(--space-xs); }
  .mb-sm { margin-bottom: var(--space-sm); }
  .mb-md { margin-bottom: var(--space-md); }
  .mb-lg { margin-bottom: var(--space-lg); }
  .mb-xl { margin-bottom: var(--space-xl); }
  .pb-xs { padding-bottom: var(--space-xs); }
  .pt-xs { padding-top: var(--space-xs); }
  .mx-auto { margin-inline: auto; }
  
  .py-sm { padding-block: var(--space-sm); }
  .p-sm { padding: var(--space-sm); }
  .py-xl { padding-block: var(--space-xl); }
  .p-lg { padding: var(--space-lg); }
  .px-lg { padding-inline: var(--space-lg); }
  
  .gap-xs { gap: var(--space-xs); }
  .gap-sm { gap: var(--space-sm); }
  .gap-md { gap: var(--space-md); }
  .gap-lg { gap: var(--space-lg); }
  .gap-xl { gap: var(--space-xl); }
  
  .lh-1 { line-height: 1.2; }
  .lh-relaxed { line-height: 1.6; }
  .max-w-lg { max-width: 60rem; }
  .opacity-50 { opacity: 0.5; }
  
  .border-radius { border-radius: var(--radius); }
  .border-radius-sm { border-radius: var(--radius-sm); }
  .border-subtle { border: 0.1rem solid var(--color-border); border-radius: var(--radius-lg); }
  .border-bottom { border-bottom: 0.1rem solid var(--color-border); }
  
  .emoji-md { font-size: clamp(1.2rem, 2vw, 1.8rem); line-height: 1; }
  .emoji-lg { font-size: clamp(1.5rem, 3vw, 2.5rem); }
  .emoji-xl { font-size: clamp(2.5rem, 5vw, 4rem); }

  .image-placeholder { min-height: clamp(12rem, 25vw, 14rem); }
  
  .transition-transform { transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease; }
  .hover-lift:hover { transform: translateY(-0.2rem); box-shadow: var(--shadow-md); border-color: var(--color-primary-light); }

  a { text-decoration: none; }
  .pointer { cursor: pointer; }
  .form-box-shadow { box-shadow: var(--shadow-sm); }

  /* Butons */
  .btn-white-theme {
    background-color: var(--color-bg);
    border: 0.15rem solid var(--color-bg);
    color: var(--color-primary);
  }
  .btn-white-theme:hover {
    transform: translateY(-0.2rem);
    box-shadow: var(--shadow-md);
    background-color: var(--color-bg-soft);
  }

  .btn-read {
    opacity: 0.5;
    cursor: default;
  }
  
  /* Make second and third links active pointer per instructions */
  .card:nth-child(n+2) .btn-read {
    opacity: 1;
    cursor: pointer;
  }
  .card:nth-child(n+2) .btn-read:hover { text-decoration: underline; text-underline-offset: 0.2rem; }

</style>
