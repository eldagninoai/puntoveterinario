---
import BaseLayout from "../layouts/BaseLayout.astro";

const schema = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "AboutPage",
            name: "Sobre Punto Veterinario",
            url: "https://puntoveterinario.com/nosotros",
            description:
                "Clínica veterinaria familiar en Coyoacán, CDMX. Conoce a nuestro equipo de médicos especialistas enfocados en el bienestar animal.",
        },
        {
            "@type": "VideoObject",
            name: "Conoce Punto Veterinario - Nuestra Clínica en Coyoacán",
            description:
                "Un recorrido por nuestras instalaciones y nuestra filosofía de cuidado y medicina preventiva para perros y gatos en San Pablo Tepetlapa, CDMX.",
            thumbnailUrl: "https://puntoveterinario.com/video-thumbnail.webp",
            uploadDate: "2024-01-01T08:00:00+08:00",
            contentUrl: "https://www.youtube.com/embed/dQw4w9WgXcQ",
        },
    ],
};

const equipoCards = [
    {
        imagen: "/placeholder-doctora.webp",
        nombre: "Dra. Pilar",
        experiencia:
            "Medicina interna y preventiva. Especialista en asegurar el bienestar de perros y gatos desde el primer día.",
    },
    {
        imagen: "/placeholder-doctor.webp",
        nombre: "Dr. [Nombre del Doctor]",
        experiencia:
            "Cirugía de tejidos blandos y odontología canina. Enfoque riguroso en procedimientos seguros y libres de estrés.",
    },
];

const filosofiaCards = [
    {
        emoji: "🔍",
        titulo: "Transparencia Médica",
        desc: "Nunca te pediremos estudios innecesarios. Te explicamos cada diagnóstico de forma clara y honesta para que tomes la mejor decisión.",
    },
    {
        emoji: "🧘",
        titulo: "Trato Libre de Estrés",
        desc: "Entendemos que ir al veterinario puede darles miedo. Nos tomamos el tiempo para que se relajen, usando premios y un manejo paciente.",
    },
    {
        emoji: "📚",
        titulo: "Actualización Constante",
        desc: "La medicina veterinaria avanza rápido. Nuestro equipo se capacita continuamente para ofrecerte los tratamientos más seguros y modernos del sur de CDMX.",
    },
];

const instalacionesImgs = [
    {
        src: "/placeholder-recepcion.webp",
        alt: "Recepción limpia y moderna en Punto Veterinario Coyoacán",
    },
    {
        src: "/placeholder-quirofano.webp",
        alt: "Quirófano totalmente equipado en Punto Veterinario Coyoacán",
    },
    {
        src: "/placeholder-consultorio.webp",
        alt: "Consultorio amplio para atención libre de estrés en Punto Veterinario Coyoacán",
    },
    {
        src: "/placeholder-estetica.webp",
        alt: "Área de estética canina e higiene preventiva en Punto Veterinario Coyoacán",
    },
];
---

<BaseLayout
    title="Médicos Veterinarios de Confianza en Coyoacán | Punto Veterinario"
    description="Conoce a nuestro equipo de médicos veterinarios en Coyoacán. Especialistas en medicina preventiva, cirugía y cuidado animal en San Pablo Tepetlapa."
    canonical="https://puntoveterinario.com/nosotros"
>
    <Fragment slot="head">
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    </Fragment>

    <!-- SECCIÓN 1 — HERO -->
    <section class="hero content-section">
            <div class="hero__text">
                <h1 class="h1-hero">
                    Médicos Veterinarios de Confianza en Coyoacán
                </h1>
                <p class="hero__desc">
                    Sabemos que tu perro o gato no es solo una mascota, es parte
                    de tu familia. En Punto Veterinario combinamos experiencia
                    médica, instalaciones seguras y un trato profundamente
                    humano para cuidar de ellos en San Pablo Tepetlapa.
                </p>
                <div class="hero__btns">
                    <a
                        href="https://wa.me/525513843004"
                        class="btn-wa"
                        target="_blank"
                        rel="noopener"
                    >
                        💬 Hablar con el equipo
                    </a>
                </div>
            </div>
        </section>

    <!-- SECCIÓN 2 — EL VIDEO (IMPLEMENTACIÓN FACADE) -->
    <section class="content-section bg-soft">
            <h2 class="visually-hidden">Nuestra clínica por dentro</h2>

            <div class="video-container" id="video-facade">
                <!-- Fachada Initial Load -->
                <img
                    src="/video-thumbnail.webp"
                    alt="Recorrido por la clínica Punto Veterinario en Coyoacán"
                    class="video-thumbnail"
                    width="800"
                    height="450"
                    loading="lazy"
                    decoding="async"
                />
                <button
                    class="play-btn"
                    aria-label="Reproducir video de presentación"
                >
                    <svg viewBox="0 0 24 24" width="24" height="24">
                        <path d="M8 5v14l11-7z" fill="currentColor"></path>
                    </svg>
                </button>
            </div>
        </section>

    <!-- SECCIÓN 3 — NUESTRO EQUIPO MÉDICO -->
    <section class="content-section">
            <h2 class="titulo-sec">
                Conoce a los expertos detrás de la salud de tu mascota
            </h2>
            <div class="grid-equipo">
                {
                    equipoCards.map((doc) => (
                        <div class="card-equipo">
                            <img
                                src={doc.imagen}
                                alt={`Fotografía de ${doc.nombre}, médico veterinario en Coyoacán CDMX`}
                                class="equipo-img"
                                width="400"
                                height="400"
                                loading="lazy"
                                decoding="async"
                            />
                            <div class="equipo-info">
                                <h3 class="equipo-nombre">MVZ. {doc.nombre}</h3>
                                <p class="equipo-exp">{doc.experiencia}</p>
                            </div>
                        </div>
                    ))
                }
            </div>
        </section>

    <!-- SECCIÓN 4 — NUESTRA FILOSOFÍA Y VALORES -->
    <section class="content-section bg-soft">
            <h2 class="titulo-sec">Nuestra promesa para ti y tu mascota</h2>
            <div class="grid-tres">
                {
                    filosofiaCards.map((item) => (
                        <div class="card card-hover">
                            <span class="card-emoji">{item.emoji}</span>
                            <h3 class="card-titulo">{item.titulo}</h3>
                            <p class="card-desc">{item.desc}</p>
                        </div>
                    ))
                }
            </div>
        </section>

    <!-- SECCIÓN 5 — INSTALACIONES (PRUEBA SOCIAL VISUAL BENTO GRID) -->
    <section class="content-section">
            <h2 class="titulo-sec">Un espacio diseñado para su bienestar</h2>
            <div class="bento-gallery">
                {
                    instalacionesImgs.map((img, index) => (
                        <div class={`bento-item bento-item--${index + 1}`}>
                            <img
                                src={img.src}
                                alt={img.alt}
                                class="bento-img"
                                width="800"
                                height="600"
                                loading="lazy"
                                decoding="async"
                            />
                        </div>
                    ))
                }
            </div>
        </section>

    <!-- SECCIÓN 6 — CTA FINAL LOCAL -->
    <section class="cta-final content-section">
            <h2 class="cta-titulo-blanc">
                Pon la salud de tu mejor amigo en buenas manos
            </h2>
            <p class="cta-desc-blanc">
                Estamos listos para recibir a tu mascota en Av. División del
                Norte 3595, San Pablo Tepetlapa. Únete a las familias de
                Coyoacán que confían en Punto Veterinario.
            </p>
            <div class="cta-btns">
                <a
                    href="https://wa.me/525513843004"
                    target="_blank"
                    rel="noopener"
                    class="btn-cta-blanco"
                >
                    💬 Contactar por WhatsApp
                </a>
                <a href="/ubicacion" class="btn-cta-outline">
                    📍 ¿Cómo llegar?
                </a>
            </div>
        </section>
</BaseLayout>

<script>
    // PATRÓN FACADE PARA VIDEO
    // Inyecta el iframe solo tras el evento click para salvar métrica TBT en Lighthouse.
    document.addEventListener("DOMContentLoaded", () => {
        const facade = document.getElementById("video-facade");
        if (!facade) return;

        facade.addEventListener(
            "click",
            () => {
                const iframeUrl =
                    "https://www.youtube.com/embed/dQw4w9WgXcQ?autoplay=1&rel=0";
                // NOTA AL CLIENTE: Sustituir dQw4w9WgXcQ por el ID real del video de YouTube.

                const iframe = document.createElement("iframe");
                iframe.setAttribute("src", iframeUrl);
                iframe.setAttribute("frameborder", "0");
                iframe.setAttribute(
                    "allow",
                    "accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture",
                );
                iframe.setAttribute("allowfullscreen", "true");
                iframe.classList.add("video-iframe");

                facade.innerHTML = "";
                facade.appendChild(iframe);
            },
            { once: true },
        );
    });
</script>

<style>
    /* ====== CLAMP SYSTEM + RESPONSIVE ====== */
    /* No Tailwind/Bootstrap allowed, 100% Fluid Vanilla CSS */

    .content-section {
        padding-block: clamp(3rem, 6vw, 12rem);
    }
    .bg-soft {
        background: var(--color-bg-soft);
    }

    .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        border: 0;
    }

    .h1-hero {
        font-size: clamp(1.8rem, 3.2vw, 6rem);
        color: var(--color-text);
        line-height: 1.15;
        margin-bottom: clamp(1rem, 2vw, 3rem);
    }

    .titulo-sec {
        font-size: clamp(1.6rem, 2.8vw, 5rem);
        color: var(--color-primary);
        text-align: center;
        margin-bottom: clamp(2rem, 4vw, 7rem);
        line-height: 1.2;
    }

    .text-center {
        text-align: center;
    }

    /* HERO CLASSES */
    .hero {
        background: var(--color-bg);
    }
    .hero__inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }
    .hero__text {
        width: 100%;
        margin-inline: auto;
    }
    @media (min-width: 48rem) {
        .hero__text {
            max-width: 80%;
        }
    }

    .hero__desc {
        font-size: clamp(0.95rem, 1.4vw, 2.8rem);
        color: var(--color-text-soft);
        line-height: 1.6;
        margin-bottom: clamp(1.5rem, 2vw, 4rem);
        margin-inline: auto;
    }

    .hero__btns {
        display: flex;
        justify-content: center;
    }

    .btn-wa {
        background: var(--color-primary);
        color: #fff;
        padding: clamp(0.6rem, 1.2vw, 2.5rem) clamp(1.2rem, 2.5vw, 5rem);
        font-size: clamp(0.9rem, 1.2vw, 2.4rem);
        border-radius: clamp(0.4rem, 1vw, 1.5rem);
        font-weight: 600;
        text-decoration: none;
        transition:
            background 0.2s,
            transform 0.2s;
    }
    .btn-wa:hover {
        background: var(--color-primary-dark);
        transform: translateY(-0.15rem);
    }

    /* VIDEO FACADE */
    .video-container {
        position: relative;
        width: 100%;
        max-width: clamp(20rem, 80vw, 800px);
        margin: 0 auto;
        aspect-ratio: 16 / 9;
        background: #000; /* Placeholder color before img loads */
        border-radius: clamp(0.5rem, 1vw, 2rem);
        overflow: hidden;
        cursor: pointer;
        box-shadow: var(--shadow-md);
        transition:
            transform 0.2s,
            box-shadow 0.2s;
    }
    .video-container:hover {
        transform: translateY(-0.25rem);
        box-shadow: var(--shadow-lg);
    }
    .video-container:hover .play-btn {
        transform: translate(-50%, -50%) scale(1.1);
        background: rgba(98, 215, 213, 0.95); /* Primary hover */
    }

    .video-thumbnail {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        opacity: 0.8; /* Slight dim for play button contrast */
        transition: opacity 0.3s;
    }
    .video-container:hover .video-thumbnail {
        opacity: 0.9;
    }

    .play-btn {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: clamp(4rem, 6vw, 10rem);
        height: clamp(4rem, 6vw, 10rem);
        background: rgba(98, 215, 213, 0.85); /* Primary */
        color: #fff;
        border: none;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        cursor: pointer;
        transition:
            transform 0.2s,
            background 0.2s;
        backdrop-filter: blur(4px);
    }
    .play-btn svg {
        width: clamp(2rem, 3vw, 5rem);
        height: auto;
        margin-left: clamp(
            0.2rem,
            0.4vw,
            0.8rem
        ); /* Visual balance for triangle */
    }

    :global(.video-iframe) {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border-radius: clamp(0.5rem, 1vw, 2rem);
    }

    /* GRID EQUIPO MÉDICO */
    .grid-equipo {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: clamp(1.5rem, 3vw, 6rem);
        max-width: 900px;
        margin: 0 auto;
    }
    @media (max-width: 48rem) {
        .grid-equipo {
            grid-template-columns: 1fr;
            max-width: 500px;
        }
    }

    .card-equipo {
        background: var(--color-bg);
        border: clamp(0.05rem, 0.1vw, 0.2rem) solid var(--color-border);
        border-radius: clamp(0.5rem, 1.5vw, 2.5rem);
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        transition:
            transform 0.3s,
            box-shadow 0.3s;
        display: flex;
        flex-direction: column;
    }
    .card-equipo:hover {
        transform: translateY(-0.25rem);
        box-shadow: var(--shadow-md);
    }

    .equipo-img {
        width: 100%;
        height: clamp(15rem, 25vw, 35rem);
        object-fit: cover;
        object-position: top center;
        background: var(--color-bg-soft);
        border-bottom: clamp(0.05rem, 0.1vw, 0.2rem) solid var(--color-border);
    }

    .equipo-info {
        padding: clamp(1.2rem, 2vw, 4rem);
        text-align: center;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }
    .equipo-nombre {
        font-size: clamp(1.2rem, 1.8vw, 3.5rem);
        color: var(--color-primary-dark);
        margin-bottom: clamp(0.5rem, 1vw, 2rem);
        line-height: 1.2;
    }
    .equipo-exp {
        font-size: clamp(0.95rem, 1.2vw, 2.4rem);
        color: var(--color-text-soft);
        line-height: 1.6;
        margin: 0;
    }

    /* GRID FILOSOFÍA (3 COLS) */
    .grid-tres {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: clamp(1.5rem, 3vw, 6rem);
    }
    @media (max-width: 60rem) {
        .grid-tres {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    @media (max-width: 35rem) {
        .grid-tres {
            grid-template-columns: 1fr;
        }
    }

    .card {
        background: var(--color-bg);
        border: clamp(0.05rem, 0.1vw, 0.2rem) solid var(--color-border);
        border-radius: clamp(0.5rem, 1.5vw, 2.5rem);
        padding: clamp(1.2rem, 2vw, 4rem);
        display: flex;
        flex-direction: column;
        text-align: center;
        transition:
            transform 0.3s,
            box-shadow 0.3s;
        box-shadow: var(--shadow-sm);
    }
    .card-hover:hover {
        transform: translateY(-0.25rem);
        box-shadow: var(--shadow-md);
    }

    .card-emoji {
        font-size: clamp(2rem, 3.5vw, 7rem);
        margin-bottom: clamp(0.8rem, 1.2vw, 2.5rem);
        display: block;
    }

    .card-titulo {
        font-size: clamp(1.1rem, 1.6vw, 3.2rem);
        color: var(--color-primary-dark);
        margin-bottom: clamp(0.5rem, 1vw, 2rem);
        line-height: 1.3;
    }
    .card-desc {
        font-size: clamp(0.95rem, 1.3vw, 2.6rem);
        color: var(--color-text-soft);
        line-height: 1.6;
        margin: 0;
    }

    /* BENTO GALLERY INSTALACIONES */
    .bento-gallery {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        grid-auto-rows: clamp(8rem, 15vw, 25rem);
        gap: clamp(0.8rem, 1.5vw, 3rem);
    }

    .bento-item {
        border-radius: clamp(0.5rem, 1vw, 2rem);
        overflow: hidden;
        position: relative;
        box-shadow: var(--shadow-sm);
        transition:
            transform 0.3s,
            box-shadow 0.3s;
        background: var(--color-bg-soft);
    }
    .bento-item:hover {
        transform: translateY(-0.15rem);
        box-shadow: var(--shadow-md);
    }
    .bento-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.5s ease;
    }
    .bento-item:hover .bento-img {
        transform: scale(1.05);
    }

    /* Desktop Layout */
    .bento-item--1 {
        grid-column: span 2;
        grid-row: span 2;
    } /* Large Hero Image */
    .bento-item--2 {
        grid-column: span 2;
        grid-row: span 1;
    } /* Wide Top Right */
    .bento-item--3 {
        grid-column: span 1;
        grid-row: span 1;
    } /* Square Bottom Middle */
    .bento-item--4 {
        grid-column: span 1;
        grid-row: span 1;
    } /* Square Bottom Right */

    /* Tablet Layout */
    @media (max-width: 60rem) {
        .bento-gallery {
            grid-template-columns: repeat(2, 1fr);
        }
        .bento-item--1 {
            grid-column: span 2;
            grid-row: span 2;
        }
        .bento-item--2 {
            grid-column: span 2;
            grid-row: span 1;
        }
        .bento-item--3 {
            grid-column: span 1;
            grid-row: span 1;
        }
        .bento-item--4 {
            grid-column: span 1;
            grid-row: span 1;
        }
    }
    /* Mobile Layout */
    @media (max-width: 35rem) {
        .bento-gallery {
            grid-template-columns: 1fr;
            grid-auto-rows: clamp(12rem, 40vw, 25rem);
        }
        .bento-item--1,
        .bento-item--2,
        .bento-item--3,
        .bento-item--4 {
            grid-column: span 1;
            grid-row: span 1;
        }
    }

    /* CTA FINAL */
    .cta-final {
        background: var(--color-primary);
        text-align: center;
        color: #fff;
    }
    .cta-titulo-blanc {
        font-size: clamp(1.6rem, 2.8vw, 5rem);
        color: #fff;
        margin-bottom: clamp(1rem, 1.5vw, 3rem);
        line-height: 1.2;
    }
    .cta-desc-blanc {
        font-size: clamp(1rem, 1.4vw, 2.8rem);
        margin-bottom: clamp(1.5rem, 2.5vw, 5rem);
        max-width: 70%;
        margin-inline: auto;
        color: #fff;
        opacity: 0.9;
        line-height: 1.6;
    }
    @media (max-width: 48rem) {
        .cta-desc-blanc {
            max-width: 90%;
        }
    }
    .cta-btns {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: clamp(0.8rem, 1.5vw, 3rem);
    }
    .btn-cta-blanco {
        background: #fff;
        color: var(--color-primary-dark);
        padding: clamp(0.6rem, 1.2vw, 2.5rem) clamp(1.2rem, 2.5vw, 5rem);
        font-size: clamp(0.9rem, 1.2vw, 2.4rem);
        border-radius: clamp(0.4rem, 1vw, 1.5rem);
        font-weight: 600;
        text-decoration: none;
        transition:
            transform 0.2s,
            background 0.2s;
    }
    .btn-cta-blanco:hover {
        transform: translateY(-0.15rem);
        background: var(--color-bg-soft);
    }

    .btn-cta-outline {
        border: clamp(0.1rem, 0.15vw, 0.3rem) solid #fff;
        color: #fff;
        padding: clamp(0.6rem, 1.2vw, 2.5rem) clamp(1.2rem, 2.5vw, 5rem);
        font-size: clamp(0.9rem, 1.2vw, 2.4rem);
        border-radius: clamp(0.4rem, 1vw, 1.5rem);
        font-weight: 600;
        text-decoration: none;
        transition:
            transform 0.2s,
            background 0.2s;
    }
    .btn-cta-outline:hover {
        transform: translateY(-0.15rem);
        background: rgba(255, 255, 255, 0.1);
    }
</style>
