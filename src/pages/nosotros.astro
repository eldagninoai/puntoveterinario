---
import BaseLayout from "../layouts/BaseLayout.astro";

const schema = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "AboutPage",
            name: "Sobre Punto Veterinario",
            url: "https://puntoveterinario.com/nosotros",
            description:
                "Clínica veterinaria familiar en Coyoacán, CDMX. Conoce a nuestro equipo de médicos especialistas enfocados en el bienestar animal.",
        },
        {
            "@type": "VideoObject",
            name: "Conoce Punto Veterinario - Nuestra Clínica en Coyoacán",
            description:
                "Un recorrido por nuestras instalaciones y nuestra filosofía de cuidado y medicina preventiva para perros y gatos en San Pablo Tepetlapa, CDMX.",
            thumbnailUrl: "https://puntoveterinario.com/video-thumbnail.webp",
            uploadDate: "2024-01-01T08:00:00+08:00",
            contentUrl: "https://www.youtube.com/embed/dQw4w9WgXcQ",
        },
    ],
};

const equipoCards = [
    {
        imagen: "/placeholder-doctora.svg",
        nombre: "Dra. Pilar",
        experiencia:
            "Medicina interna y preventiva. Especialista en asegurar el bienestar de perros y gatos desde el primer día.",
    },
    {
        imagen: "/placeholder-doctor.svg",
        nombre: "Dr. José Luis",
        experiencia:
            "Cirugía de tejidos blandos y odontología canina. Enfoque riguroso en procedimientos seguros y libres de estrés.",
    },
];

const filosofiaCards = [
    {
        emoji: "🔍",
        titulo: "Transparencia Médica",
        desc: "Nunca te pediremos estudios innecesarios. Te explicamos cada diagnóstico de forma clara y honesta para que tomes la mejor decisión.",
    },
    {
        emoji: "🧘",
        titulo: "Trato Libre de Estrés",
        desc: "Entendemos que ir al veterinario puede darles miedo. Nos tomamos el tiempo para que se relajen, usando premios y un manejo paciente.",
    },
    {
        emoji: "📚",
        titulo: "Actualización Constante",
        desc: "La medicina veterinaria avanza rápido. Nuestro equipo se capacita continuamente para ofrecerte los tratamientos más seguros y modernos del sur de CDMX.",
    },
];

const instalacionesImgs = [
    {
        src: "/placeholder-recepcion.svg",
        alt: "Recepción limpia y moderna en Punto Veterinario Coyoacán",
    },
    {
        src: "/placeholder-quirofano.svg",
        alt: "Quirófano totalmente equipado en Punto Veterinario Coyoacán",
    },
    {
        src: "/placeholder-consultorio.svg",
        alt: "Consultorio amplio para atención libre de estrés en Punto Veterinario Coyoacán",
    },
    {
        src: "/placeholder-estetica.svg",
        alt: "Área de estética canina e higiene preventiva en Punto Veterinario Coyoacán",
    },
];
---

<BaseLayout
    title="Médicos Veterinarios de Confianza en Coyoacán | Punto Veterinario"
    description="Conoce a nuestro equipo de médicos veterinarios en Coyoacán. Especialistas en medicina preventiva, cirugía y cuidado animal en San Pablo Tepetlapa."
    canonical="https://puntoveterinario.com/nosotros"
>
    <Fragment slot="head">
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    </Fragment>

    <!-- SECCIÓN 1 — HERO -->
    <section class="hero content-section">
        <div class="hero__text">
            <h1 class="h1-hero">
                Médicos Veterinarios de Confianza en Coyoacán
            </h1>
            <p class="hero__desc">
                Sabemos que tu perro o gato no es solo una mascota, es parte de
                tu familia. En Punto Veterinario combinamos experiencia médica,
                instalaciones seguras y un trato profundamente humano para
                cuidar de ellos en San Pablo Tepetlapa.
            </p>
            <div class="hero__btns">
                <a
                    href="https://wa.me/525513843004"
                    class="btn-wa"
                    target="_blank"
                    rel="noopener"
                >
                    💬 Hablar con el equipo
                </a>
            </div>
        </div>
    </section>

    <!-- SECCIÓN 3 — NUESTRO EQUIPO MÉDICO -->
    <section class="content-section">
        <h2 class="titulo-sec">
            Conoce a los expertos detrás de la salud de tu mascota
        </h2>
        <div class="grid-equipo">
            {
                equipoCards.map((doc) => (
                    <div class="card-equipo">
                        <img
                            src={doc.imagen}
                            alt={`Fotografía de ${doc.nombre}, médico veterinario en Coyoacán CDMX`}
                            class="equipo-img"
                            width="400"
                            height="400"
                            loading="lazy"
                            decoding="async"
                        />
                        <div class="equipo-info">
                            <h3 class="equipo-nombre">{doc.nombre}</h3>
                            <p class="equipo-exp">{doc.experiencia}</p>
                        </div>
                    </div>
                ))
            }
        </div>
    </section>

    <!-- SECCIÓN 4 — NUESTRA FILOSOFÍA Y VALORES -->
    <section class="content-section bg-soft">
        <h2 class="titulo-sec">Nuestra promesa para ti y tu mascota</h2>
        <div class="grid-auto">
            {
                filosofiaCards.map((item) => (
                    <div class="card-ui">
                        <span class="icon-scalable">{item.emoji}</span>
                        <h3 class="card-titulo">{item.titulo}</h3>
                        <p class="card-desc">{item.desc}</p>
                    </div>
                ))
            }
        </div>
    </section>

    <!-- SECCIÓN 5 — INSTALACIONES (PRUEBA SOCIAL VISUAL BENTO GRID) -->
    <section class="content-section">
        <h2 class="titulo-sec">Un espacio diseñado para su bienestar</h2>
        <div class="bento-gallery">
            {
                instalacionesImgs.map((img, index) => (
                    <div class={`bento-item bento-item--${index + 1}`}>
                        <img
                            src={img.src}
                            alt={img.alt}
                            class="bento-img"
                            width="800"
                            height="600"
                            loading="lazy"
                            decoding="async"
                        />
                    </div>
                ))
            }
        </div>
    </section>

    <!-- SECCIÓN 6 — CTA FINAL LOCAL -->
    <section class="cta-final content-section">
        <h2 class="cta-titulo-blanc">
            Pon la salud de tu mejor amigo en buenas manos
        </h2>
        <p class="cta-desc-blanc">
            Estamos listos para recibir a tu mascota en Av. División del Norte
            3595, San Pablo Tepetlapa. Únete a las familias de Coyoacán que
            confían en Punto Veterinario.
        </p>
        <div class="cta-btns">
            <a
                href="https://wa.me/525513843004"
                target="_blank"
                rel="noopener"
                class="btn-cta-blanco"
            >
                💬 Contactar por WhatsApp
            </a>
            <a href="/ubicacion" class="btn-cta-outline"> 📍 ¿Cómo llegar? </a>
        </div>
    </section>
</BaseLayout>

<style>
    .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        border: 0;
    }

    .hero {
        background: none; /* override Generic hero bg if needed */
    }

    @media (min-width: 64.0625rem) {
        .hero__text {
            max-width: 80%;
        }
    }

    /* GRID EQUIPO MÉDICO */
    .grid-equipo {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: max(1.5rem, 3vw);
        margin: 0 auto;
    }
    @media (max-width: 64rem) {
        .grid-equipo {
            grid-template-columns: 1fr;
            max-width: max(40rem, 70vw);
        }
    }

    .card-equipo {
        background: var(--color-bg);
        border: max(0.05rem, 0.1vw) solid var(--color-border);
        border-radius: max(0.5rem, 1.5vw);
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        transition:
            transform 0.3s,
            box-shadow 0.3s;
        display: flex;
        flex-direction: column;
    }
    .card-equipo:hover {
        transform: translateY(-0.25rem);
        box-shadow: var(--shadow-md);
    }

    .equipo-img {
        width: 100%;
        height: max(15rem, 25vw);
        object-fit: cover;
        object-position: top center;
        background: var(--color-bg-soft);
        border-bottom: max(0.05rem, 0.1vw) solid var(--color-border);
    }

    .equipo-info {
        padding: max(1.2rem, 2vw);
        text-align: center;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }
    .equipo-nombre {
        font-size: max(1.2rem, 1.8vw);
        color: var(--color-primary-dark);
        margin-bottom: max(0.5rem, 1vw);
        line-height: 1.2;
    }
    .equipo-exp {
        font-size: max(0.95rem, 1.2vw);
        color: var(--color-text-soft);
        line-height: 1.6;
        margin: 0;
    }

    /* BENTO GALLERY INSTALACIONES */
    .bento-gallery {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        grid-auto-rows: max(8rem, 15vw);
        gap: max(0.8rem, 1.5vw);
    }

    .bento-item {
        border-radius: max(0.5rem, 1vw);
        overflow: hidden;
        position: relative;
        box-shadow: var(--shadow-sm);
        transition:
            transform 0.3s,
            box-shadow 0.3s;
        background: var(--color-bg-soft);
    }
    .bento-item:hover {
        transform: translateY(-0.15rem);
        box-shadow: var(--shadow-md);
    }
    .bento-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.5s ease;
    }
    .bento-item:hover .bento-img {
        transform: scale(1.05);
    }

    /* Desktop Layout */
    .bento-item--1 {
        grid-column: span 2;
        grid-row: span 2;
    } /* Large Hero Image */
    .bento-item--2 {
        grid-column: span 2;
        grid-row: span 1;
    } /* Wide Top Right */
    .bento-item--3 {
        grid-column: span 1;
        grid-row: span 1;
    } /* Square Bottom Middle */
    .bento-item--4 {
        grid-column: span 1;
        grid-row: span 1;
    } /* Square Bottom Right */

    /* Tablet Layout */
    @media (max-width: 64rem) {
        .bento-gallery {
            grid-template-columns: repeat(2, 1fr);
        }
        .bento-item--1 {
            grid-column: span 2;
            grid-row: span 2;
        }
        .bento-item--2 {
            grid-column: span 2;
            grid-row: span 1;
        }
        .bento-item--3 {
            grid-column: span 1;
            grid-row: span 1;
        }
        .bento-item--4 {
            grid-column: span 1;
            grid-row: span 1;
        }
    }
    /* Mobile Layout */
    @media (max-width: 48rem) {
        .bento-gallery {
            grid-template-columns: repeat(2, 1fr);
            grid-auto-rows: max(12rem, 40vw);
        }
        .bento-item--1,
        .bento-item--2,
        .bento-item--3,
        .bento-item--4 {
            grid-column: span 1;
            grid-row: span 1;
        }
    }
</style>
