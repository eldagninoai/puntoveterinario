                        <span class="emoji-md m-0 inline-block">🕐</span> Nuestro
                        Horario
                    </h3>
                    <p
                        class="text-soft text-sm m-0 lh-relaxed border-bottom pb-xs"
                    >
                        <span class="fw-bold text-primary-dark block"
                            >Lunes:</span
                        >
                        Cerrado.
                    </p>
                    <p
                        class="text-soft text-sm m-0 lh-relaxed border-bottom pb-xs pt-xs"
                    >
                        <span class="fw-bold text-primary-dark block"
                            >Martes a Sábado:</span
                        >
                        Desde las 10:00 AM hasta las 19:00 PM hrs.
                    </p>
                    <p class="text-soft text-sm m-0 lh-relaxed pt-xs">
                        <span class="fw-bold text-primary-dark block"
                            >Domingo:</span
                        >
                        Desde las 10:00 AM hasta las 17:00 PM hrs.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- 3. MAPA PLACEHOLDER -->
    <section class="bg-white py-xl">
        <h2 class="text-primary-dark mb-lg lh-1">
            Encuéntranos fácilmente en Coyoacán
        </h2>
        <div class="map-container">
            <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3764.5!2d-99.13922!3d19.322004!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x85ce010007f0a32f%3A0x9c168bcfa6aad89f!2sPunto%20Veterinario!5e0!3m2!1ses!2smx!4v1"
                width="100%"
                height="450"
                style="border:0; border-radius: max(1rem, 2vw);"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
    </section>

    <!-- 4. CTA FINAL -->
    <section class="cta-section bg-primary py-xl text-center">
        <h2 class="text-white mb-lg text-2xl lh-1">
            ¡Te esperamos pronto en Coyoacán!
        </h2>
        <p class="text-white opacity-90 mb-xl text-lg lh-relaxed">
            Somos <strong>Punto Veterinario</strong>, clínica en <strong
                >San Pablo Tepetlapa</strong
            >
            (CP 04620), <strong>Coyoacán</strong>. Brindamos atención médica de
            calidad en
            <strong>Av. División del Norte 3595</strong>.
        </p>
        <div class="flex flex-wrap justify-center gap-md">
            <a
                href="https://wa.me/525513843004"
                target="_blank"
                rel="noopener"
                class="btn-white-theme text-primary fw-bold text-md px-lg py-sm border-radius transition-transform inline-block"
            >
                💬 Hablar por WhatsApp
            </a>
        </div>
    </section>

    <!-- 5. MODAL DE ÉXITO (REACT) -->
    <MissionSuccessDialog
        client:load
        title="¡Solicitud Recibida!"
        description="Tu mensaje ha llegado a Punto Veterinario. Te responderemos por WhatsApp o correo muy pronto."
        imageUrl="https://images.unsplash.com/photo-1543466835-00a7907e9de1?q=80&w=600&auto=format&fit=crop"
        primaryButtonText="💬 Abrir WhatsApp ahora"
        secondaryButtonText="Cerrar ventana"
    />
</BaseLayout>

<script>
    document.addEventListener("astro:page-load", () => {
        const form = document.querySelector(
            'form[name="contacto-punto-veterinario"]',
        ) as HTMLFormElement;

        if (!form) return;

        form.addEventListener("submit", async (e) => {
            e.preventDefault();

            const formData = new FormData(form);
            const submitButton = form.querySelector(
                'button[type="submit"]',
            ) as HTMLButtonElement;

            if (submitButton) {
                submitButton.disabled = true;
                submitButton.innerText = "Enviando...";
            }

            try {
                const response = await fetch(
                    "https://api.web3forms.com/submit",
                    {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/x-www-form-urlencoded",
                            Accept: "application/json",
                        },
                        body: new URLSearchParams(formData as any).toString(),
                    },
                );

                const data = await response.json();

                if (data.success) {
                    window.dispatchEvent(new CustomEvent("abrir-exito"));
                    form.reset();
                } else {
                    throw new Error(data.message || "Error al enviar");
                }
            } catch (error) {
                console.error("Error al enviar:", error);
                alert(
                    "Hubo un problema. Por favor contáctanos directo por WhatsApp.",
                );
            } finally {
                if (submitButton) {
                    submitButton.disabled = false;
                    submitButton.innerText = "📅 Enviar solicitud de cita";
                }
            }
        });
    });
</script>

