---
import BaseLayout from "../layouts/BaseLayout.astro";
import Schema from "../components/Schema.astro";

const schema = [
    {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        name: "Punto Veterinario",
        url: "https://puntoveterinario.com/contacto",
        telephone: "+525513843004",
        email: "puntovetcdmx@gmail.com",
        description:
            "Veterinaria en Coyoacán CDMX, ubicada en San Pablo Tepetlapa. Consultas, cirugías, estética, laboratorio y farmacia.",
        address: {
            "@type": "PostalAddress",
            streetAddress: "Av. División del Norte 3595",
            addressLocality: "San Pablo Tepetlapa",
            addressRegion: "Coyoacán, Ciudad de México",
            postalCode: "04620",
            addressCountry: "MX",
        },
        openingHoursSpecification: [
            {
                "@type": "OpeningHoursSpecification",
                dayOfWeek: [
                    "Tuesday",
                    "Wednesday",
                    "Thursday",
                    "Friday",
                    "Saturday",
                ],
                opens: "10:00",
                closes: "19:00",
            },
            {
                "@type": "OpeningHoursSpecification",
                dayOfWeek: ["Sunday"],
                opens: "10:00",
                closes: "17:00",
            },
        ],
    },
];
---

<BaseLayout
    title="Contacto y Citas | Punto Veterinario Coyoacán"
    description="Agenda tu cita en Punto Veterinario, Coyoacán. <a 
  href="https://maps.app.goo.gl/GricGKCzpp6BXJgE7?g_st=aw"
  target="_blank"
  rel="noopener"
  aria-label="Ver ubicación en Google Maps"
  class="maps-link"
>
  Av. División del Norte 3595, San Pablo Tepetlapa, 
  CP 04620, Coyoacán, CDMX
</a>. Tel: 55 1384 3004"
    schema={schema[0]}
>
    <!-- 1. HERO -->
    <section class="hero bg-white py-xl text-center">
        <div class="container max-w-lg mx-auto">
            <h1 class="text-2xl text-primary-dark mb-md lh-1">
                Contacto y Citas | Punto Veterinario Coyoacán
            </h1>
            <p class="text-lg text-soft lh-relaxed m-0">
                Nos encantará grandemente agilizar sin demora la tan urgente
                atención primaria para tu querido perro o gato incondicional.
                Ingrésanos amablemente tus datos generales en instantes para
                agendar firmemente tu lugar en nuestro consultorio o estética,
                ¡o mándanos un WhatsApp si deseas velocidad extrema!
            </p>
        </div>
    </section>

    <!-- 2. GRID 2 COLUMNAS -->
    <section class="bg-soft py-xl">
        <div class="container form-section-wrapper">
            <div class="grid-2-form gap-xl">
                <!-- Izquierda — Formulario HTML puro -->
                <div
                    class="form-container bg-white p-lg border-subtle border-radius flex-col gap-md form-box-shadow"
                >
                    <form
                        action="/gracias"
                        method="POST"
                        class="flex-col gap-sm"
                    >
                        <h2 class="text-primary-dark text-md m-0 mb-sm">
                            Envíanos un mensaje
                        </h2>

                        <div class="flex-col gap-xs form-group">
                            <label
                                for="nombre"
                                class="text-soft fw-bold text-sm"
                                >👤 Nombre Completo</label
                            >
                            <input
                                type="text"
                                id="nombre"
                                name="nombre"
                                class="form-input"
                                placeholder="Ej. Juan Pérez"
                                required
                            />
                        </div>

                        <div class="flex-col gap-xs form-group">
                            <label
                                for="telefono"
                                class="text-soft fw-bold text-sm"
                                >📞 Teléfono (Celular o Fijo)</label
                            >
                            <input
                                type="tel"
                                id="telefono"
                                name="telefono"
                                class="form-input"
                                placeholder="Ej. 55 1234 5678"
                                required
                            />
                        </div>

                        <div class="flex-col gap-xs form-group">
                            <label
                                for="servicio"
                                class="text-soft fw-bold text-sm"
                                >Mascota requiere el servicio de:</label
                            >
                            <select
                                id="servicio"
                                name="servicio"
                                class="form-input"
                                required
                            >
                                <option value="" disabled selected
                                    >▾ Selecciona un servicio médico</option
                                >
                                <option value="consulta"
                                    >Consulta Veterinaria</option
                                >
                                <option value="estetica"
                                    >Estética Canina / Felina</option
                                >
                                <option value="esterilizacion"
                                    >Esterilización</option
                                >
                                <option value="cirugia">Cirugía General</option>
                                <option value="laboratorio"
                                    >Laboratorio Clínico</option
                                >
                                <option value="otro"
                                    >Tienda y Alimentos / Otro</option
                                >
                            </select>
                        </div>

                        <div class="flex-col gap-xs form-group">
                            <label
                                for="mensaje"
                                class="text-soft fw-bold text-sm"
                                >📝 Cuentanos un poco sobre tu mascota</label
                            >
                            <textarea
                                id="mensaje"
                                name="mensaje"
                                class="form-input"
                                rows="4"
                                placeholder="Cualquier síntoma visual o detalle importante..."
                            ></textarea>
                        </div>

                        <button
                            type="submit"
                            class="btn-primary text-md fw-bold py-sm mt-sm border-radius transition-transform pointer"
                        >
                            📅 Enviar solicitud
                        </button>
                        <p class="text-center text-sm text-soft mt-xs m-0">
                            ¡También puedes escribirnos velozmente por WhatsApp!
                        </p>
                    </form>
                </div>

                <!-- Derecha — Datos de contacto -->
                <div class="contact-info flex-col gap-lg items-start text-left">
                    <div class="flex-col gap-xs">
                        <h2
                            class="text-primary-dark m-0 mb-sm border-bottom pb-xs"
                        >
                            Información de Contacto
                        </h2>

                        <div
                            class="flex items-start gap-sm mt-xs hover-lift p-sm border-radius-sm transition-transform bg-white border-subtle"
                        >
                            <span class="emoji-md m-0">📍</span>
                            <p
                                class="text-soft text-sm lh-relaxed m-0 text-primary-dark"
                            >
                                <span class="fw-bold block"
                                    >Visítanos centralmente en:</span
                                >
                                Av. División del Norte 3595,<br />
                                Colonia San Pablo Tepetlapa,<br />
                                CP 04620, Delegación Coyoacán, CDMX.
                            </p>
                        </div>

                        <a
                            href="tel:+525513843004"
                            class="flex items-center gap-sm mt-sm hover-lift p-sm border-radius-sm transition-transform bg-white border-subtle"
                        >
                            <span class="emoji-md m-0">📞</span>
                            <p
                                class="text-soft text-sm lh-relaxed m-0 text-primary-dark"
                            >
                                <span class="fw-bold block"
                                    >Teléfono de Citas:</span
                                > +52 55 1384 3004
                            </p>
                        </a>

                        <a
                            href="https://wa.me/525513843004"
                            target="_blank"
                            rel="noopener"
                            class="flex items-center gap-sm mt-sm hover-lift p-sm border-radius-sm transition-transform bg-white border-subtle"
                        >
                            <span class="emoji-md m-0">💬</span>
                            <p
                                class="text-soft text-sm lh-relaxed m-0 text-primary-dark"
                            >
                                <span class="fw-bold block"
                                    >Chat Inmediato:</span
                                > WhatsApp Oficial
                            </p>
                        </a>

                        <a
                            href="mailto:puntovetcdmx@gmail.com"
                            class="flex items-center gap-sm mt-sm hover-lift p-sm border-radius-sm transition-transform bg-white border-subtle"
                        >
                            <span class="emoji-md m-0">✉️</span>
                            <p
                                class="text-soft text-sm lh-relaxed m-0 text-primary-dark"
                            >
                                <span class="fw-bold block"
                                    >Correo Electrónico:</span
                                > puntovetcdmx@gmail.com
                            </p>
                        </a>

                        <a
                            href="https://instagram.com/punto_veterinario"
                            target="_blank"
                            rel="noopener"
                            class="flex items-center gap-sm mt-sm hover-lift p-sm border-radius-sm transition-transform bg-white border-subtle"
                        >
                            <span class="emoji-md m-0">📸</span>
                            <p
                                class="text-soft text-sm lh-relaxed m-0 text-primary-dark"
                            >
                                <span class="fw-bold block"
                                    >Instagram Comunidad:</span
                                > @punto_veterinario
                            </p>
                        </a>
                    </div>

                    <div
                        class="flex-col gap-xs mt-sm bg-white p-lg border-subtle border-radius form-box-shadow full-width"
                    >
                        <h3
                            class="text-primary-dark m-0 mb-xs text-lg flex items-center gap-xs"
                        >
                            <span class="emoji-md m-0 inline-block">🕐</span> Nuestro
                            Horario
                        </h3>
                        <p
                            class="text-soft text-sm m-0 lh-relaxed border-bottom pb-xs"
                        >
                            <span class="fw-bold text-primary-dark block"
                                >Lunes:</span
                            >
                            Cerrado.
                        </p>
                        <p
                            class="text-soft text-sm m-0 lh-relaxed border-bottom pb-xs pt-xs"
                        >
                            <span class="fw-bold text-primary-dark block"
                                >Martes a Sábado:</span
                            >
                            Desde las 10:00 AM hasta las 19:00 PM hrs.
                        </p>
                        <p class="text-soft text-sm m-0 lh-relaxed pt-xs">
                            <span class="fw-bold text-primary-dark block"
                                >Domingo:</span
                            >
                            Desde las 10:00 AM hasta las 17:00 PM hrs.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 3. MAPA PLACEHOLDER -->
    <section class="bg-white py-xl">
        <div class="container text-center max-w-lg mx-auto">
            <h2 class="text-primary-dark mb-lg lh-1">
                Encuéntranos fácilmente en Coyoacán
            </h2>
            <div
                class="map-placeholder flex items-center justify-center border-radius"
            >
                <span class="emoji-map block">📍</span>
            </div>
        </div>
    </section>

    <!-- 4. CTA FINAL -->
    <section class="cta-section bg-primary py-xl text-center">
        <div class="container max-w-lg mx-auto">
            <h2 class="text-white mb-lg text-2xl lh-1">
                ¡Te esperamos pronto en Coyoacán!
            </h2>
            <p class="text-white opacity-90 mb-xl text-lg lh-relaxed">
                <a 
  href="https://maps.app.goo.gl/GricGKCzpp6BXJgE7?g_st=aw"
  target="_blank"
  rel="noopener"
  aria-label="Ver ubicación en Google Maps"
  class="maps-link"
>
  Av. División del Norte 3595, San Pablo Tepetlapa, 
  CP 04620, Coyoacán, CDMX
</a>
            </p>
            <div class="flex flex-wrap justify-center gap-md">
                <a
                    href="https://wa.me/525513843004"
                    target="_blank"
                    rel="noopener"
                    class="btn-white-theme text-primary fw-bold text-md px-lg py-sm border-radius transition-transform inline-block"
                    >💬 Hablar por WhatsApp</a
                >
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    /* Local Fluid CSS Utilities - NO FIXED PX */
    .bg-white {
        background-color: var(--color-bg);
    }
    .bg-soft {
        background-color: var(--color-bg-soft);
    }
    .bg-primary {
        background-color: var(--color-primary);
    }

    .text-white {
        color: var(--color-bg);
    }
    .text-primary {
        color: var(--color-primary);
    }
    .text-primary-dark {
        color: var(--color-primary-dark);
    }
    .text-soft {
        color: var(--color-text-soft);
    }

    .text-center {
        text-align: center;
    }
    .text-left {
        text-align: left;
    }
    .text-sm {
        font-size: var(--text-sm);
    }
    .text-md {
        font-size: var(--text-md);
    }
    .text-lg {
        font-size: var(--text-lg);
    }
    .text-2xl {
        font-size: var(--text-2xl);
    }
    .fw-bold {
        font-weight: 700;
    }

    .block {
        display: block;
    }
    .inline-block {
        display: inline-block;
    }
    .flex {
        display: flex;
    }
    .flex-col {
        display: flex;
        flex-direction: column;
    }
    .flex-wrap {
        flex-wrap: wrap;
    }
    .flex-fill {
        flex: 1;
    }
    .items-center {
        align-items: center;
    }
    .items-start {
        align-items: flex-start;
    }
    .justify-center {
        justify-content: center;
    }

    .m-0 {
        margin: 0;
    }
    .my-sm {
        margin-block: var(--space-sm);
    }
    .mt-sm {
        margin-top: var(--space-sm);
    }
    .mt-xs {
        margin-top: var(--space-xs);
    }
    .mt-auto {
        margin-top: auto;
    }
    .mb-xs {
        margin-bottom: var(--space-xs);
    }
    .mb-sm {
        margin-bottom: var(--space-sm);
    }
    .mb-md {
        margin-bottom: var(--space-md);
    }
    .mb-lg {
        margin-bottom: var(--space-lg);
    }
    .mb-xl {
        margin-bottom: var(--space-xl);
    }
    .pb-xs {
        padding-bottom: var(--space-xs);
    }
    .pt-xs {
        padding-top: var(--space-xs);
    }
    .mx-auto {
        margin-inline: auto;
    }

    .py-sm {
        padding-block: var(--space-sm);
    }
    .p-sm {
        padding: var(--space-sm);
    }
    .py-xl {
        padding-block: var(--space-xl);
    }
    .p-lg {
        padding: var(--space-lg);
    }
    .px-lg {
        padding-inline: var(--space-lg);
    }

    .gap-xs {
        gap: var(--space-xs);
    }
    .gap-sm {
        gap: var(--space-sm);
    }
    .gap-md {
        gap: var(--space-md);
    }
    .gap-lg {
        gap: var(--space-lg);
    }
    .gap-xl {
        gap: var(--space-xl);
    }

    .lh-1 {
        line-height: 1.2;
    }
    .lh-relaxed {
        line-height: 1.6;
    }
    .max-w-lg {
        max-width: 60rem;
    }
    .opacity-90 {
        opacity: 0.9;
    }
    .full-width {
        width: 100%;
        box-sizing: border-box;
    }

    .border-radius {
        border-radius: var(--radius);
    }
    .border-radius-sm {
        border-radius: var(--radius-sm);
    }
    .border-subtle {
        border: 0.1rem solid var(--color-border);
        border-radius: var(--radius-lg);
    }
    .border-bottom {
        border-bottom: 0.1rem solid var(--color-border);
    }

    .emoji-md {
        font-size: clamp(1.2rem, 2vw, 1.8rem);
        line-height: 1;
    }
    .emoji-lg {
        font-size: clamp(1.5rem, 3vw, 2.5rem);
    }
    .emoji-xl {
        font-size: clamp(2.5rem, 5vw, 4rem);
    }
    .emoji-map {
        font-size: clamp(5rem, 10vw, 8rem);
        animation: bounce 2s infinite ease-in-out;
    }

    .transition-transform {
        transition:
            transform 0.2s ease,
            box-shadow 0.2s ease,
            background-color 0.2s ease,
            color 0.2s ease,
            border-color 0.2s ease;
    }
    .hover-lift:hover {
        transform: translateY(-0.2rem);
        box-shadow: var(--shadow-md);
        border-color: var(--color-primary-light);
    }

    a {
        text-decoration: none;
    }
    .pointer {
        cursor: pointer;
    }

    /* Form Elements */
    .grid-2-form {
        display: grid;
        grid-template-columns: 1fr;
    }
    @media (min-width: 48rem) {
        .grid-2-form {
            grid-template-columns: 1fr 1fr;
            align-items: start;
        }
    }

    .form-box-shadow {
        box-shadow: var(--shadow-sm);
    }

    .form-input {
        width: 100%;
        padding: var(--space-sm);
        border: 0.15rem solid var(--color-border);
        border-radius: var(--radius-sm);
        font-size: var(--text-sm);
        font-family: inherit;
        background-color: var(--color-bg-soft);
        color: var(--color-primary-dark);
        box-sizing: border-box;
        outline: none;
        transition:
            border-color 0.2s ease,
            background-color 0.2s ease;
    }
    .form-input:focus {
        border-color: var(--color-primary);
        background-color: var(--color-bg);
    }
    .form-input::placeholder {
        color: var(--color-text-soft);
        opacity: 0.7;
    }

    /* Butons */
    .btn-primary {
        background-color: var(--color-primary);
        color: var(--color-bg);
        border: none;
        display: block;
        width: 100%;
    }
    .btn-primary:hover {
        background-color: var(--color-primary-dark);
        transform: translateY(-0.15rem);
        box-shadow: var(--shadow-md);
    }

    .btn-outline {
        background-color: transparent;
        border: 0.15rem solid var(--color-primary-dark);
    }
    .btn-outline:hover {
        background-color: var(--color-primary-dark);
        color: var(--color-bg);
        transform: translateY(-0.15rem);
    }

    .btn-white-theme {
        background-color: var(--color-bg);
        border: 0.15rem solid var(--color-bg);
        color: var(--color-primary);
    }
    .btn-white-theme:hover {
        transform: translateY(-0.2rem);
        box-shadow: var(--shadow-md);
        background-color: var(--color-bg-soft);
    }

    .btn-outline-white {
        background-color: transparent;
        border: 0.15rem solid var(--color-bg);
    }
    .btn-outline-white:hover {
        transform: translateY(-0.2rem);
        background-color: var(--color-bg);
        color: var(--color-primary);
    }

    /* Map Placeholder */
    .map-placeholder {
        background-color: #e8fafa; /* Light turquesa-ish */
        min-height: clamp(18rem, 35vw, 28rem);
        border: 0.2rem dashed var(--color-primary-light);
    }

    @keyframes bounce {
        0%,
        100% {
            transform: translateY(0);
        }
        50% {
            transform: translateY(-1rem);
        }
    }

  .maps-link {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: var(--color-primary);
    text-underline-offset: 0.2rem;
    transition: color 0.2s;
  }
  .maps-link:hover {
    color: var(--color-primary);
  }
</style>
