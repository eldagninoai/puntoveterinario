---
import BaseLayout from "../layouts/BaseLayout.astro";
import Schema from "../components/Schema.astro";

const schema = [
    {"@context": "https://schema.org","@type": "LocalBusiness",
        name: "Punto Veterinario",
        url: "https://puntoveterinario.com/contacto",
        telephone: "+525513843004",
        email: "puntovetcdmx@gmail.com",
        description:"Veterinaria en Coyoacán CDMX, ubicada en San Pablo Tepetlapa. Consultas, cirugías, estética, laboratorio y farmacia.",
        address: {"@type": "PostalAddress",
            streetAddress: "Av. División del Norte 3595",
            addressLocality: "San Pablo Tepetlapa",
            addressRegion: "Coyoacán, Ciudad de México",
            postalCode: "04620",
            addressCountry: "MX",
        },
        openingHoursSpecification: [
            {"@type": "OpeningHoursSpecification",
                dayOfWeek: ["Tuesday","Wednesday","Thursday","Friday","Saturday",
                ],
                opens: "10:00",
                closes: "19:00",
            },
            {"@type": "OpeningHoursSpecification",
                dayOfWeek: ["Sunday"],
                opens: "10:00",
                closes: "17:00",
            },
        ],
    },
];
---

<BaseLayout
    title="Contacto y Citas | Punto Veterinario Coyoacán"
    description='Agenda tu cita en Punto Veterinario, Coyoacán. <a href="https://maps.app.goo.gl/GricGKCzpp6BXJgE7?g_st=aw" target="_blank" rel="noopener" aria-label="Ver ubicación en Google Maps" class="maps-link">Av. División del Norte 3595, San Pablo Tepetlapa, CP 04620, Coyoacán, CDMX</a>. Tel: 55 1384 3004'
    schema={schema[0]}
>
    <!-- 1. HERO -->
    <section class="seccion fondo-blanco">
        <div class="container hero-inner">
            <h1 class="titulo-principal">
                Contacto y Citas | Punto Veterinario Coyoacán
            </h1>
            <p class="subtitulo">
    Servicio profesional de estética, baño y cortes especializados respetando la tranquilidad de tu mascota.
</p>
        </div>
    </section>

    <!-- 2. GRID 2 COLUMNAS -->
    <section class="bg-soft py-xl">
        <div class="container form-section-wrapper">
            <div class="grid-2-form gap-xl">
                <!-- Izquierda — Formulario HTML puro -->
                <div
                    class="form-container bg-white p-lg border-subtle border-radius flex-col gap-md form-box-shadow"
                >
                    <form
                        name="contacto-punto-veterinario"
                        method="POST"
                        data-netlify="true"
                        netlify-honeypot="bot-field"
                        class="formulario"
                    >
                        <input
                            type="hidden"
                            name="form-name"
                            value="contacto-punto-veterinario"
                        />
                        <p class="hidden">
                            <label>No llenar: <input name="bot-field" /></label>
                        </p>

                        <div class="campo">
                            <label for="nombre">Nombre completo *</label>
                            <input
                                type="text"
                                id="nombre"
                                name="nombre"
                                required
                                placeholder="Tu nombre"
                            />
                        </div>

                        <div class="campo">
                            <label for="telefono">Teléfono *</label>
                            <input
                                type="tel"
                                id="telefono"
                                name="telefono"
                                required
                                placeholder="55 1234 5678"
                            />
                        </div>

                        <div class="campo">
                            <label for="servicio">Servicio de interés</label>
                            <select id="servicio" name="servicio">
                                <option value="">Selecciona un servicio</option>
                                <option value="consulta">Consulta Médica</option
                                >
                                <option value="estetica"
                                    >Estética Canina y Felina</option
                                >
                                <option value="esterilizacion"
                                    >Esterilización</option
                                >
                                <option value="cirugia">Cirugías</option>
                                <option value="laboratorio"
                                    >Laboratorio Clínico</option
                                >
                                <option value="alimento"
                                    >Alimento para Mascotas</option
                                >
                            </select>
                        </div>

                        <div class="campo">
                            <label for="mensaje">Mensaje</label>
                            <textarea
                                id="mensaje"
                                name="mensaje"
                                rows="4"
                                placeholder="¿En qué podemos ayudarte?"
                            ></textarea>
                        </div>

                        <button type="submit" class="btn-enviar"
                            >📅 Enviar solicitud de cita</button
                        >
                        <p class="form-nota">
                            También puedes escribirnos directamente por
                            <a
                                href="https://wa.me/525513843004"
                                target="_blank"
                                rel="noopener">WhatsApp</a
                            >
                        </p>
                    </form>
                </div>

                <!-- Derecha — Datos de contacto -->
                <div class="contact-info flex-col gap-lg items-start text-left">
                    <div class="flex-col gap-xs">
                        <h2
                            class="text-primary-dark m-0 mb-sm border-bottom pb-xs"
                        >
                            Información de Contacto
                        </h2>

                        <div
                            class="flex items-start gap-sm mt-xs hover-lift p-sm border-radius-sm transition-transform bg-white border-subtle"
                        >
                            <span class="emoji-md m-0">📍</span>
                            <p
                                class="text-soft text-sm lh-relaxed m-0 text-primary-dark"
                            >
                                <span class="fw-bold block"
                                    >Visítanos centralmente en:</span
                                >
                                Av. División del Norte 3595,<br />
                                Colonia San Pablo Tepetlapa,<br />
                                CP 04620, Delegación Coyoacán, CDMX.
                            </p>
                        </div>

                        <a
                            href="tel:+525513843004"
                            class="flex items-center gap-sm mt-sm hover-lift p-sm border-radius-sm transition-transform bg-white border-subtle"
                        >
                            <span class="emoji-md m-0">📞</span>
                            <p
                                class="text-soft text-sm lh-relaxed m-0 text-primary-dark"
                            >
                                <span class="fw-bold block"
                                    >Teléfono de Citas:</span
                                > +52 55 1384 3004
                            </p>
                        </a>

                        <a
                            href="https://wa.me/525513843004"
                            target="_blank"
                            rel="noopener"
                            class="flex items-center gap-sm mt-sm hover-lift p-sm border-radius-sm transition-transform bg-white border-subtle"
                        >
                            <span class="emoji-md m-0">💬</span>
                            <p
                                class="text-soft text-sm lh-relaxed m-0 text-primary-dark"
                            >
                                <span class="fw-bold block"
                                    >Chat Inmediato:</span
                                > WhatsApp Oficial
                            </p>
                        </a>

                        <a
                            href="mailto:puntovetcdmx@gmail.com"
                            class="flex items-center gap-sm mt-sm hover-lift p-sm border-radius-sm transition-transform bg-white border-subtle"
                        >
                            <span class="emoji-md m-0">✉️</span>
                            <p
                                class="text-soft text-sm lh-relaxed m-0 text-primary-dark"
                            >
                                <span class="fw-bold block"
                                    >Correo Electrónico:</span
                                > puntovetcdmx@gmail.com
                            </p>
                        </a>

                        <a
                            href="https://instagram.com/punto_veterinario"
                            target="_blank"
                            rel="noopener"
                            class="flex items-center gap-sm mt-sm hover-lift p-sm border-radius-sm transition-transform bg-white border-subtle"
                        >
                            <span class="emoji-md m-0">📸</span>
                            <p
                                class="text-soft text-sm lh-relaxed m-0 text-primary-dark"
                            >
                                <span class="fw-bold block"
                                    >Instagram Comunidad:</span
                                > @punto_veterinario
                            </p>
                        </a>
                    </div>

                    <div
                        class="flex-col gap-xs mt-sm bg-white p-lg border-subtle border-radius form-box-shadow full-width"
                    >
                        <h3
                            class="text-primary-dark m-0 mb-xs text-lg flex items-center gap-xs"
                        >
                            <span class="emoji-md m-0 inline-block">🕐</span> Nuestro
                            Horario
                        </h3>
                        <p
                            class="text-soft text-sm m-0 lh-relaxed border-bottom pb-xs"
                        >
                            <span class="fw-bold text-primary-dark block"
                                >Lunes:</span
                            >
                            Cerrado.
                        </p>
                        <p
                            class="text-soft text-sm m-0 lh-relaxed border-bottom pb-xs pt-xs"
                        >
                            <span class="fw-bold text-primary-dark block"
                                >Martes a Sábado:</span
                            >
                            Desde las 10:00 AM hasta las 19:00 PM hrs.
                        </p>
                        <p class="text-soft text-sm m-0 lh-relaxed pt-xs">
                            <span class="fw-bold text-primary-dark block"
                                >Domingo:</span
                            >
                            Desde las 10:00 AM hasta las 17:00 PM hrs.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 3. MAPA PLACEHOLDER -->
    <section class="bg-white py-xl">
        <div class="container text-center">
            <h2 class="text-primary-dark mb-lg lh-1">
                Encuéntranos fácilmente en Coyoacán
            </h2>
            <div
                class="map-placeholder flex items-center justify-center border-radius"
            >
                <span class="emoji-map block">📍</span>
            </div>
        </div>
    </section>

    <!-- 4. CTA FINAL -->
    <section class="cta-section bg-primary py-xl text-center">
        <div class="container">
            <h2 class="text-white mb-lg text-2xl lh-1">
                ¡Te esperamos pronto en Coyoacán!
            </h2>
            <p class="text-white opacity-90 mb-xl text-lg lh-relaxed">
    Somos <strong>Punto Veterinario</strong>, clínica en <strong>San Pablo Tepetlapa</strong> (CP 04620), <strong>Coyoacán</strong>. Brindamos atención médica de calidad en <strong>Av. División del Norte 3595</strong>.
</p>
            <div class="flex flex-wrap justify-center gap-md">
                <a
                    href="https://wa.me/525513843004"
                    target="_blank"
                    rel="noopener"
                    class="btn-white-theme text-primary fw-bold text-md px-lg py-sm border-radius transition-transform inline-block"
                    >💬 Hablar por WhatsApp</a
                >
            </div>
        </div>
    </section>
</BaseLayout>

<style>



    /* ===== HERO CENTRADO ===== */
    .hero-inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: clamp(1rem, 2vw, 3vw);
        width: 100%;
    }
    .titulo-principal {
        font-size: clamp(1.8rem, 3.2vw, 5.5vw);
        color: var(--color-primary-dark);
        line-height: 1.15;
        margin: 0;
    }
    .subtitulo {
        font-size: clamp(0.95rem, 1.4vw, 2.5vw);
        color: var(--color-text-soft);
        line-height: 1.6;
        margin: 0 auto;
        max-width: 75ch;
        text-align: center;
    }
    .botones {
        display: flex;
        flex-wrap: wrap;
        gap: clamp(0.8rem, 1.5vw, 2.5vw);
        justify-content: center;
    }

    /* Local Fluid CSS Utilities - NO FIXED PX */
    .bg-white {
        background-color: var(--color-bg);
    }
    .bg-soft {
        background-color: var(--color-bg-soft);
    }
    .bg-primary {
        background-color: var(--color-primary);
    }

    .text-white {
        color: var(--color-bg);
    }
    .text-primary {
        color: var(--color-primary);
    }
    .text-primary-dark {
        color: var(--color-primary-dark);
    }
    .text-soft {
        color: var(--color-text-soft);
    }

    .text-center {
        text-align: center;
    }
    .text-left {
        text-align: left;
    }
    .text-sm {
        font-size: clamp(0.9rem, 1.2vw, 2.2vw);
    }
    .text-md {
        font-size: clamp(1.1rem, 1.8vw, 3vw);
    }
    .text-lg {
        font-size: clamp(1.4rem, 2.5vw, 4vw);
    }
    .text-2xl {
        font-size: clamp(2.2rem, 4vw, 6vw);
    }
    .fw-bold {
        font-weight: 700;
    }

    .block {
        display: block;
    }
    .inline-block {
        display: inline-block;
    }
    .flex {
        display: flex;
    }
    .flex-col {
        display: flex;
        flex-direction: column;
    }
    .flex-wrap {
        flex-wrap: wrap;
    }
    .flex-fill {
        flex: 1;
    }
    .items-center {
        align-items: center;
    }
    .items-start {
        align-items: flex-start;
    }
    .justify-center {
        justify-content: center;
    }

    .m-0 {
        margin: 0;
    }
    .my-sm {
        margin-block: clamp(0.6rem, 1vw, 1.8vw);
    }
    .mt-sm {
        margin-top: clamp(0.6rem, 1vw, 1.8vw);
    }
    .mt-xs {
        margin-top: clamp(0.4rem, 0.8vw, 1.4vw);
    }
    .mt-auto {
        margin-top: auto;
    }
    .mb-xs {
        margin-bottom: clamp(0.4rem, 0.8vw, 1.4vw);
    }
    .mb-sm {
        margin-bottom: clamp(0.6rem, 1vw, 1.8vw);
    }
    .mb-md {
        margin-bottom: clamp(1rem, 2vw, 3.5vw);
    }
    .mb-lg {
        margin-bottom: clamp(1.5rem, 3vw, 5vw);
    }
    .mb-xl {
        margin-bottom: clamp(2.5rem, 5vw, 8vw);
    }
    .pb-xs {
        padding-bottom: clamp(0.4rem, 0.8vw, 1.4vw);
    }
    .pt-xs {
        padding-top: clamp(0.4rem, 0.8vw, 1.4vw);
    }
    .mx-auto {
        margin-inline: auto;
    }

    .py-sm {
        padding-block: clamp(0.6rem, 1vw, 1.8vw);
    }
    .p-sm {
        padding: clamp(0.6rem, 1vw, 1.8vw);
    }
    .py-xl {
        padding-block: clamp(2.5rem, 5vw, 8vw);
    }
    .p-lg {
        padding: clamp(1.5rem, 3vw, 5vw);
    }
    .px-lg {
        padding-inline: clamp(1.5rem, 3vw, 5vw);
    }

    .gap-xs {
        gap: clamp(0.4rem, 0.8vw, 1.4vw);
    }
    .gap-sm {
        gap: clamp(0.6rem, 1vw, 1.8vw);
    }
    .gap-md {
        gap: clamp(1rem, 2vw, 3.5vw);
    }
    .gap-lg {
        gap: clamp(1.5rem, 3vw, 5vw);
    }
    .gap-xl {
        gap: clamp(2.5rem, 5vw, 8vw);
    }

    .lh-1 {
        line-height: 1.2;
    }
    .lh-relaxed {
        line-height: 1.6;
    }
    . {
        
    }
    .opacity-90 {
        opacity: 0.9;
    }
    .full-width {
        width: 100%;
        box-sizing: border-box;
    }

    .border-radius {
        border-radius: var(--radius);
    }
    .border-radius-sm {
        border-radius: var(--radius-sm);
    }
    .border-subtle {
        border: 0.1rem solid var(--color-border);
        border-radius: var(--radius-lg);
    }
    .border-bottom {
        border-bottom: 0.1rem solid var(--color-border);
    }

    .emoji-md {
        font-size: clamp(1.2rem, 2vw, 3.6vw);
        line-height: 1;
    }
    .emoji-lg {
        font-size: clamp(1.5rem, 3vw, 5.4vw);
    }
    .emoji-xl {
        font-size: clamp(2.5rem, 5vw, 9vw);
    }
    .emoji-map {
        font-size: clamp(5rem, 10vw, 18vw);
        animation: bounce 2s infinite ease-in-out;
    }

    .transition-transform {
        transition:
            transform 0.2s ease,
            box-shadow 0.2s ease,
            background-color 0.2s ease,
            color 0.2s ease,
            border-color 0.2s ease;
    }
    .hover-lift:hover {
        transform: translateY(-0.2rem);
        box-shadow: var(--shadow-md);
        border-color: var(--color-primary-light);
    }

    a {
        text-decoration: none;
    }
    .pointer {
        cursor: pointer;
    }

    /* Form Elements */
    .grid-2-form {
        display: grid;
        grid-template-columns: 1fr;
    }
    @media (min-width: 48rem) {
        .grid-2-form {
            grid-template-columns: 1fr 1fr;
            align-items: start;
        }
    }

    .form-box-shadow {
        box-shadow: var(--shadow-sm);
    }

    .form-input {
        width: 100%;
        padding: clamp(0.6rem, 1vw, 1.8vw);
        border: 0.15rem solid var(--color-border);
        border-radius: var(--radius-sm);
        font-size: clamp(0.9rem, 1.2vw, 2.2vw);
        font-family: inherit;
        background-color: var(--color-bg-soft);
        color: var(--color-primary-dark);
        box-sizing: border-box;
        outline: none;
        transition:
            border-color 0.2s ease,
            background-color 0.2s ease;
    }
    .form-input:focus {
        border-color: var(--color-primary);
        background-color: var(--color-bg);
    }
    .form-input::placeholder {
        color: var(--color-text-soft);
        opacity: 0.7;
    }

    /* Butons */
    .btn-primary {
        background-color: var(--color-primary);
        color: var(--color-bg);
        border: none;
        display: block;
        width: 100%;
    }
    .btn-primary:hover {
        background-color: var(--color-primary-dark);
        transform: translateY(-0.15rem);
        box-shadow: var(--shadow-md);
    }

    .btn-outline {
        background-color: transparent;
        border: 0.15rem solid var(--color-primary-dark);
    }
    .btn-outline:hover {
        background-color: var(--color-primary-dark);
        color: var(--color-bg);
        transform: translateY(-0.15rem);
    }

    .btn-white-theme {
        background-color: var(--color-bg);
        border: 0.15rem solid var(--color-bg);
        color: var(--color-primary);
    }
    .btn-white-theme:hover {
        transform: translateY(-0.2rem);
        box-shadow: var(--shadow-md);
        background-color: var(--color-bg-soft);
    }

    .btn-outline-white {
        background-color: transparent;
        border: 0.15rem solid var(--color-bg);
    }
    .btn-outline-white:hover {
        transform: translateY(-0.2rem);
        background-color: var(--color-bg);
        color: var(--color-primary);
    }

    /* Map Placeholder */
    .map-placeholder {
        background-color: #e8fafa; /* Light turquesa-ish */
        min-height: clamp(18rem, 35vw, 63vw);
        border: 0.2rem dashed var(--color-primary-light);
    }

    @keyframes bounce {
        0%,
        100% {
            transform: translateY(0);
        }
        50% {
            transform: translateY(-1rem);
        }
    }

    .maps-link {
        color: inherit;
        text-decoration: underline;
        text-decoration-color: var(--color-primary);
        text-underline-offset: 0.2rem;
        transition: color 0.2s;
    }
    .maps-link:hover {
        color: var(--color-primary);
    }

    .hidden {
        display: none;
    }
    .formulario {
        display: flex;
        flex-direction: column;
        gap: clamp(1rem, 1.8vw, 3vw);
    }
    .campo {
        display: flex;
        flex-direction: column;
        gap: clamp(0.3rem, 0.5vw, 0.8vw);
    }
    .campo label {
        font-size: clamp(0.9rem, 1.2vw, 2vw);
        font-weight: 600;
        color: var(--color-primary-dark);
    }
    .campo input,
    .campo select,
    .campo textarea {
        font-family: var(--font-main);
        font-size: clamp(0.9rem, 1.2vw, 2vw);
        padding: clamp(0.6rem, 1vw, 1.8vw);
        border: 0.1rem solid var(--color-border);
        border-radius: var(--radius);
        background: var(--color-bg);
        color: var(--color-text);
        transition: border-color 0.2s;
        width: 100%;
    }
    .campo input:focus,
    .campo select:focus,
    .campo textarea:focus {
        outline: none;
        border-color: var(--color-primary);
    }
    .btn-enviar {
        background: var(--color-primary);
        color: #fff;
        padding: clamp(0.7rem, 1.2vw, 2vw) clamp(1.5rem, 2.5vw, 4vw);
        font-size: clamp(0.9rem, 1.3vw, 2.2vw);
        font-family: var(--font-main);
        font-weight: 700;
        border: none;
        border-radius: var(--radius);
        cursor: pointer;
        transition:
            background 0.2s,
            transform 0.2s;
    }
    .btn-enviar:hover {
        background: var(--color-primary-dark);
        transform: translateY(-0.15rem);
    }
    .form-nota {
        font-size: clamp(0.85rem, 1.1vw, 2vw);
        color: var(--color-text-soft);
        margin: 0;
    }
    .form-nota a {
        color: var(--color-primary-dark);
        font-weight: 600;
    }

    .seccion {
        padding-block: clamp(3rem, 6vw, 10vw);
        width: 100%;
    }

    @media (max-width: 48rem) {
        [class*="grid-"] {
            grid-template-columns: repeat(2, 1fr) !important;
        }
    }
    @media (max-width: 30rem) {
        [class*="grid-"] {
            grid-template-columns: 1fr !important;
        }
    }
</style>
