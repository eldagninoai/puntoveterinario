---
import BaseLayout from "../layouts/BaseLayout.astro";
import { MissionSuccessDialog } from "@/components/ui/mission-success-dialog";

const schema = [
    {
        "@context": "https://schema.org",
        "@type": "LocalBusiness",
        name: "Punto Veterinario",
        url: "https://puntoveterinario.com/contacto",
        telephone: "+525513843004",
        email: "puntovetcdmx@gmail.com",
        description:
            "Veterinaria en Coyoacán CDMX, ubicada en San Pablo Tepetlapa. Consultas, cirugías, estética, laboratorio y farmacia.",
        address: {
            "@type": "PostalAddress",
            streetAddress: "Av. División del Norte 3595",
            addressLocality: "San Pablo Tepetlapa",
            addressRegion: "Coyoacán, Ciudad de México",
            postalCode: "04620",
            addressCountry: "MX",
        },
        openingHoursSpecification: [
            {
                "@type": "OpeningHoursSpecification",
                dayOfWeek: [
                    "Tuesday",
                    "Wednesday",
                    "Thursday",
                    "Friday",
                    "Saturday",
                ],
                opens: "10:00",
                closes: "19:00",
            },
            {
                "@type": "OpeningHoursSpecification",
                dayOfWeek: ["Sunday"],
                opens: "10:00",
                closes: "17:00",
            },
        ],
    },
];
---

<BaseLayout
    title="Contacto y Citas | Punto Veterinario Coyoacán"
    description="Agenda tu cita en Punto Veterinario, Coyoacán. Av. División del Norte 3595, San Pablo Tepetlapa, CP 04620, Coyoacán, CDMX. Tel: 55 1384 3004"
    schema={schema[0]}
>
    <!-- 1. HERO -->
    <section class="seccion fondo-blanco">
        <h1 class="titulo-principal">
            Contacto y Citas | Punto Veterinario Coyoacán
        </h1>
        <p class="subtitulo">
            Servicio profesional de estética, baño y cortes especializados
            respetando la tranquilidad de tu mascota.
        </p>
    </section>

    <!-- 2. GRID 2 COLUMNAS -->
    <section class="bg-soft py-xl">
        <div class="grid-2-form gap-xl">
            <!-- Izquierda — Formulario Web3Forms -->
            <div
                class="form-container bg-white p-lg border-subtle border-radius flex-col gap-md form-box-shadow"
            >
                <form
                    name="contacto-punto-veterinario"
                    method="POST"
                    action="https://api.web3forms.com/submit"
                    class="formulario"
                >
                    <input
                        type="hidden"
                        name="access_key"
                        value="b2219aa1-7045-4c6e-9f36-e4d7b780c0a5"
                    />
                    <input
                        type="hidden"
                        name="subject"
                        value="Nueva solicitud de cita - Punto Veterinario"
                    />
                    <input
                        type="hidden"
                        name="from_name"
                        value="Punto Veterinario Web"
                    />
                    <!-- Honeypot anti-spam -->
                    <input
                        type="checkbox"
                        name="botcheck"
                        class="hidden"
                        style="display:none"
                    />

                    <div class="campo">
                        <label for="nombre">Nombre completo *</label>
                        <input
                            type="text"
                            id="nombre"
                            name="nombre"
                            required
                            placeholder="Tu nombre"
                        />
                    </div>

                    <div class="campo">
                        <label for="telefono">Teléfono *</label>
                        <input
                            type="tel"
                            id="telefono"
                            name="telefono"
                            required
                            placeholder="55 1234 5678"
                        />
                    </div>

                    <div class="campo">
                        <label for="servicio">Servicio de interés</label>
                        <select id="servicio" name="servicio">
                            <option value="">Selecciona un servicio</option>
                            <option value="consulta">Consulta Médica</option>
                            <option value="estetica"
                                >Estética Canina y Felina</option
                            >
                            <option value="esterilizacion"
                                >Esterilización</option
                            >
                            <option value="cirugia">Cirugías</option>
                            <option value="laboratorio"
                                >Laboratorio Clínico</option
                            >
                            <option value="alimento"
                                >Alimento para Mascotas</option
                            >
                        </select>
                    </div>

                    <div class="campo">
                        <label for="mensaje">Mensaje</label>
                        <textarea
                            id="mensaje"
                            name="mensaje"
                            rows="4"
                            placeholder="¿En qué podemos ayudarte?"></textarea>
                    </div>

                    <button type="submit" class="btn-enviar">
                        📅 Enviar solicitud de cita
                    </button>
                    <p class="form-nota">
                        También puedes escribirnos directamente por
                        <a
                            href="https://wa.me/525513843004"
                            target="_blank"
                            rel="noopener">WhatsApp</a
                        >
                    </p>
                </form>
            </div>

            <!-- Derecha — Datos de contacto -->
            <div class="contact-info flex-col gap-lg items-start text-left">
                <div class="flex-col gap-xs">
                    <h2 class="text-primary-dark m-0 mb-sm border-bottom pb-xs">
                        Información de Contacto
                    </h2>

                    <a
                        href="https://maps.app.goo.gl/GricGKCzpp6BXJgE7?g_st=aw"
                        target="_blank"
                        rel="noopener"
                        class="flex items-start gap-sm mt-xs hover-lift p-sm border-radius-sm transition-transform bg-white border-subtle"
                    >
                        <span class="emoji-md m-0">📍</span>
                        <p
                            class="text-soft text-sm lh-relaxed m-0 text-primary-dark"
                        >
                            <span class="fw-bold block"
                                >Visítanos centralmente en:</span
                            >
                            Av. División del Norte 3595,<br />
                            Colonia San Pablo Tepetlapa,<br />
                            CP 04620, Delegación Coyoacán, CDMX.
                        </p>
                    </a>

                    <a
                        href="tel:+525513843004"
                        class="flex items-center gap-sm mt-sm hover-lift p-sm border-radius-sm transition-transform bg-white border-subtle"
                    >
                        <span class="emoji-md m-0">📞</span>
                        <p
                            class="text-soft text-sm lh-relaxed m-0 text-primary-dark"
                        >
                            <span class="fw-bold block">Teléfono de Citas:</span
                            >
                            +52 55 1384 3004
                        </p>
                    </a>

                    <a
                        href="https://wa.me/525513843004"
                        target="_blank"
                        rel="noopener"
                        class="flex items-center gap-sm mt-sm hover-lift p-sm border-radius-sm transition-transform bg-white border-subtle"
                    >
                        <span class="emoji-md m-0">💬</span>
                        <p
                            class="text-soft text-sm lh-relaxed m-0 text-primary-dark"
                        >
                            <span class="fw-bold block">Chat Inmediato:</span>
                            WhatsApp Oficial
                        </p>
                    </a>

                    <a
                        href="mailto:puntovetcdmx@gmail.com"
                        class="flex items-center gap-sm mt-sm hover-lift p-sm border-radius-sm transition-transform bg-white border-subtle"
                    >
                        <span class="emoji-md m-0">✉️</span>
                        <p
                            class="text-soft text-sm lh-relaxed m-0 text-primary-dark"
                        >
                            <span class="fw-bold block"
                                >Correo Electrónico:</span
                            >
                            puntovetcdmx@gmail.com
                        </p>
                    </a>

                    <a
                        href="https://instagram.com/punto_veterinario"
                        target="_blank"
                        rel="noopener"
                        class="flex items-center gap-sm mt-sm hover-lift p-sm border-radius-sm transition-transform bg-white border-subtle"
                    >
                        <span class="emoji-md m-0">📸</span>
                        <p
                            class="text-soft text-sm lh-relaxed m-0 text-primary-dark"
                        >
                            <span class="fw-bold block"
                                >Instagram Comunidad:</span
                            >
                            @punto_veterinario
                        </p>
                    </a>
                </div>

                <div
                    class="flex-col gap-xs mt-sm bg-white p-lg border-subtle border-radius form-box-shadow full-width"
                >
                    <h3
                        class="text-primary-dark m-0 mb-xs text-lg flex items-center gap-xs"
