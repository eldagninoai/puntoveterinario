---
import BaseLayout from "../layouts/BaseLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "VeterinaryCare"],
  name: "Punto Veterinario",
  url: "https://puntoveterinario.com",
  telephone: "+525513843004",
  email: "puntovetcdmx@gmail.com",
  description:
    "Clínica veterinaria en Coyoacán. Consultas médicas, cirugías, estética canina, laboratorio clínico y esterilización en San Pablo Tepetlapa, CP 04620.",
  image:
    "https://puntoveterinario.com/images/veterinaria-coyoacan-punto-veterinario.svg",
  priceRange: "$$",
  currenciesAccepted: "MXN",
  paymentAccepted: "Cash, Credit Card",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Av. División del Norte 3595",
    addressLocality: "San Pablo Tepetlapa",
    addressRegion: "Coyoacán, Ciudad de México",
    postalCode: "04620",
    addressCountry: "MX",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 19.322004,
    longitude: -99.13922,
  },
  hasMap: "https://maps.app.goo.gl/GricGKCzpp6BXJgE7",
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
      opens: "10:00",
      closes: "19:00",
    },
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Sunday"],
      opens: "10:00",
      closes: "17:00",
    },
  ],
  sameAs: ["https://www.instagram.com/punto_veterinario/"],
  areaServed: {
    "@type": "GeoCircle",
    geoMidpoint: {
      "@type": "GeoCoordinates",
      latitude: 19.322004,
      longitude: -99.13922,
    },
    geoRadius: "5000",
  },
  hasOfferCatalog: {
    "@type": "OfferCatalog",
    name: "Servicios Veterinarios",
    itemListElement: [
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Consulta Veterinaria Coyoacán",
        },
      },
      {
        "@type": "Offer",
        itemOffered: { "@type": "Service", name: "Estética Canina Coyoacán" },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Esterilización de mascotas Coyoacán",
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Cirugía Veterinaria Coyoacán",
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Laboratorio Clínico Veterinario Coyoacán",
        },
      },
      {
        "@type": "Offer",
        itemOffered: {
          "@type": "Service",
          name: "Alimento para mascotas San Pablo Tepetlapa",
        },
      },
    ],
  },
};

const servicios = [
  {
    emoji: "🩺",
    title: "Consulta Médica",
    desc: "Diagnóstico preciso y atención personalizada.",
    href: "/servicios/consulta-veterinaria",
  },
  {
    emoji: "🛁",
    title: "Estética Canina",
    desc: "Baño, corte y cuidado profesional.",
    href: "/servicios/estetica-canina",
  },
  {
    emoji: "✂️",
    title: "Esterilización",
    desc: "Procedimiento seguro con seguimiento post-operatorio.",
    href: "/servicios/esterilizacion",
  },
  {
    emoji: "🏥",
    title: "Cirugías",
    desc: "Quirófano equipado para atención especializada.",
    href: "/servicios/cirugia-veterinaria",
  },
  {
    emoji: "🔬",
    title: "Laboratorio Clínico",
    desc: "Análisis clínicos y resultados rápidos de confianza.",
    href: "/servicios/laboratorio-clinico",
  },
  {
    emoji: "🛒",
    title: "Alimento para Mascotas",
    desc: "Croquetas y dietas premium para cuidar su nutrición.",
    href: "/servicios/alimento-mascotas",
  },
];

const porque = [
  {
    emoji: "❤️",
    title: "Atención con amor",
    desc: "Tratamos a tu mascota como si fuera nuestra.",
  },
  {
    emoji: "🏆",
    title: "Médicos especializados",
    desc: "Equipo profesional en constante actualización.",
  },
  {
    emoji: "📍",
    title: "En San Pablo Tepetlapa, Coyoacán",
    desc: "Ubicación accesible en el sur de la ciudad.",
  },
  {
    emoji: "💰",
    title: "Precios accesibles",
    desc: "Medicina veterinaria de calidad al alcance de todos.",
  },
];

const resenas = [
  {
    texto:
      "Profesionales, excelente servicio al cliente. Las mascotas son atendidas como si fueran las de ellos. Altamente recomendable.",
    nombre: "Rodrigo Maldonado",
  },
  {
    texto:
      "Muy buena atención por parte de la Dra. Pilar. Nos apoyó con la esterilización de mi gatita y salió perfecto.",
    nombre: "Marcelo Caraveo",
  },
  {
    texto:
      "La Dra. fue la única que dio el diagnóstico correcto. Gracias a eso Max sigue con nosotros y lo mantiene estable.",
    nombre: "Monica Alvarez",
  },
];
---

<BaseLayout
  title="Veterinaria en Coyoacán CDMX | Punto Veterinario — San Pablo Tepetlapa"
  description="Clínica veterinaria en Av. División del Norte 3595, San Pablo Tepetlapa CP 04620, Coyoacán CDMX. Consultas, cirugías, estética canina, laboratorio y esterilización. ☎️ 55 1384 3004"
  canonical="https://puntoveterinario.com"
  ogImage="/images/veterinaria-coyoacan-punto-veterinario.svg"
  schema={schema}
>
  <Fragment slot="head">
    <link
      rel="preload"
      as="video"
      href="/videos/veterinaria-coyoacan.mp4"
      type="video/mp4"
    />
  </Fragment>

  <!-- 1. HERO -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__text">
        <h1>Veterinaria en Coyoacán, CDMX | Punto Veterinario</h1>
        <p class="hero__slogan">¡De cola a nariz, tu mascota feliz!</p>
        <p class="hero__desc">
          Clínica veterinaria en Av. División del Norte 3595, San Pablo
          Tepetlapa CP 04620, Coyoacán. Atendemos perros y gatos con consultas
          médicas, cirugías, estética canina y laboratorio clínico.
        </p>
        <div class="hero__btns">
          <a
            href="https://wa.me/525513843004"
            class="btn-wa"
            target="_blank"
            rel="noopener"
          >
            💬 Agendar por WhatsApp
          </a>
          <a href="/servicios/consulta-veterinaria" class="btn-sec">
            Ver Servicios
          </a>
        </div>
        <div class="hero__datos">
          <span>📞 <a href="tel:+525513843004">55 1384 3004</a></span>
          <span>📍 Av. División del Norte 3595, CDMX</span>
          <span>
            <a href="https://wa.me/525513843004" target="_blank" rel="noopener">
              💬 WhatsApp Urgente
            </a>
          </span>
        </div>
      </div>

      <!-- VIDEO — mismo estilo que nosotros.astro -->
      <div class="hero-video">
        <div class="video-wrapper">
          <video
            autoplay
            muted
            loop
            playsinline
            preload="none"
            class="video-hero"
            id="video-hero"
            aria-label="Clínica veterinaria Punto Veterinario en Coyoacán — Av. División del Norte 3595, San Pablo Tepetlapa CP 04620, CDMX"
            title="Punto Veterinario — Veterinaria en Coyoacán CDMX"
          >
            <source src="/videos/veterinaria-coyoacan.mp4" type="video/mp4" />
            <source
              src="/videos/veterinaria-coyoacan.mov"
              type="video/quicktime"
            />
          </video>
          <button
            class="btn-sonido"
            id="btn-sonido-hero"
            aria-label="Activar sonido del video"
          >
            🔇
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. SERVICIOS -->
  <section class="seccion fondo-suave">
    <div class="container">
      <h2 class="titulo-sec">Nuestros Servicios en Coyoacán</h2>
      <div class="grid-servicios">
        {
          servicios.map((s) => (
            <a href={s.href} class="card-servicio">
              <span class="card-emoji">{s.emoji}</span>
              <h3 class="card-titulo">{s.title}</h3>
              <p class="card-desc">{s.desc}</p>
              <span class="card-ver">Ver más →</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 3. POR QUÉ ELEGIRNOS -->
  <section class="seccion fondo-blanco">
    <div class="container">
      <h2 class="titulo-sec">¿Por qué elegir Punto Veterinario?</h2>
      <div class="grid-porque">
        {
          porque.map((r) => (
            <div class="card-porque">
              <span class="card-emoji">{r.emoji}</span>
              <h3 class="card-titulo">{r.title}</h3>
              <p class="card-desc">{r.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 4. RESEÑAS -->
  <section class="seccion fondo-suave">
    <div class="container">
      <h2 class="titulo-sec">Lo que dicen nuestros clientes</h2>
      <div class="grid-resenas">
        {
          resenas.map((r) => (
            <div class="card-resena">
              <p class="estrellas">⭐⭐⭐⭐⭐</p>
              <p class="resena-texto">"{r.texto}"</p>
              <p class="resena-nombre">— {r.nombre}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 5. CÓMO LLEGAR -->
  <section class="seccion fondo-blanco">
    <div class="container">
      <h2 class="titulo-sec">¿Cómo llegar a Punto Veterinario en Coyoacán?</h2>
      <div class="como-llegar-grid">
        <div class="como-llegar-info">
          <p class="direccion-label">Ubicación central en el sur:</p>
          <a
            href="https://maps.app.goo.gl/GricGKCzpp6BXJgE7?g_st=aw"
            target="_blank"
            rel="noopener"
            class="maps-link"
          >
            Av. División del Norte 3595, San Pablo Tepetlapa, CP 04620,
            Coyoacán, CDMX
          </a>
          <div class="transporte-lista">
            <div class="transporte-item">
              <span>🚇</span>
              <p><b>Metro:</b> Línea 3 estación Universidad + combi local</p>
            </div>
            <div class="transporte-item">
              <span>🚌</span>
              <p><b>Metrobús:</b> Línea 1, conexión rápida Coyoacán sur</p>
            </div>
            <div class="transporte-item">
              <span>🚗</span>
              <p><b>En auto:</b> Vía rápida Av. División del Norte 3595</p>
            </div>
          </div>
          <div class="horario-box">
            <p><span class="horario-label">Lunes:</span> Cerrado</p>
            <p><span class="horario-label">Mar-Sáb:</span> 10:00 - 19:00 hrs</p>
            <p><span class="horario-label">Dom:</span> 10:00 - 17:00 hrs</p>
          </div>
          <a href="/ubicacion" class="btn-mapa">📍 Ver cómo llegar en el mapa</a
          >
        </div>
        <div class="mapa-placeholder">
          <span class="pin-emoji">📍</span>
          <p class="mapa-texto">Av. División del Norte 3595,<br />Coyoacán</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. CTA FINAL -->
  <section class="cta-final">
    <div class="container cta-inner">
      <h2 class="cta-titulo">¿Tu mascota necesita atención en Coyoacán?</h2>
      <p class="cta-dir">
        <a
          href="https://maps.app.goo.gl/GricGKCzpp6BXJgE7?g_st=aw"
          target="_blank"
          rel="noopener"
          class="maps-link-blanco"
        >
          Av. División del Norte 3595, San Pablo Tepetlapa, CP 04620, Coyoacán,
          CDMX
        </a>
      </p>
      <div class="cta-btns">
        <a href="/contacto" class="btn-cta-blanco">📅 Agendar Cita</a>
        <a
          href="https://wa.me/525513843004"
          target="_blank"
          rel="noopener"
          class="btn-cta-outline"
        >
          💬 WhatsApp
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline>
  const videoHero = document.getElementById("video-hero");
  const btnHero = document.getElementById("btn-sonido-hero");
  btnHero?.addEventListener("click", () => {
    if (videoHero.muted) {
      videoHero.muted = false;
      btnHero.textContent = "🔊";
      btnHero.setAttribute("aria-label", "Silenciar video");
    } else {
      videoHero.muted = true;
      btnHero.textContent = "🔇";
      btnHero.setAttribute("aria-label", "Activar sonido del video");
    }
  });
</script>

<style>
  /* ===== HERO VIDEO — idéntico a nosotros.astro ===== */
  .hero-video {
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .video-wrapper {
    position: relative;
    width: 100%;
    max-width: clamp(14rem, 22vw, 35vw);
    margin-inline: auto;
  }
  .video-hero {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    object-fit: cover;
    display: block;
  }
  @media (max-width: 48rem) {
    .video-wrapper {
      max-width: 60vw;
    }
  }
  .btn-sonido {
    position: absolute;
    bottom: clamp(0.5rem, 1vw, 1.5vw);
    right: clamp(0.5rem, 1vw, 1.5vw);
    background: rgba(0, 0, 0, 0.55);
    color: #fff;
    border: none;
    border-radius: 50%;
    width: clamp(2rem, 3vw, 4rem);
    height: clamp(2rem, 3vw, 4rem);
    font-size: clamp(0.9rem, 1.5vw, 2vw);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition:
      background 0.2s,
      transform 0.2s;
    backdrop-filter: blur(4px);
  }
  .btn-sonido:hover {
    background: rgba(0, 0, 0, 0.75);
    transform: scale(1.1);
  }
  @media (max-width: 48rem) {
    .video-hero {
      margin-inline: auto;
    }
  }

  /* ===== SECCIONES ===== */
  .seccion {
    padding-block: clamp(3rem, 6vw, 12rem);
  }
  .fondo-suave {
    background: var(--color-bg-soft);
  }
  .fondo-blanco {
    background: var(--color-bg);
  }

  /* ===== TÍTULOS DE SECCIÓN ===== */
  .titulo-sec {
    font-size: clamp(1.6rem, 2.8vw, 5rem);
    color: var(--color-primary);
    text-align: center;
    margin-bottom: clamp(2rem, 4vw, 7rem);
    line-height: 1.2;
  }

  /* ===== HERO ===== */
  .hero {
    padding-block: clamp(3rem, 6vw, 12rem);
    background: var(--color-bg);
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(2rem, 4vw, 8rem);
    align-items: center;
  }
  @media (max-width: 48rem) {
    .hero__inner {
      grid-template-columns: 1fr;
    }
  }
  .hero__text h1 {
    font-size: clamp(1.8rem, 3.2vw, 6rem);
    line-height: 1.15;
    margin-bottom: clamp(1rem, 1.5vw, 3rem);
    color: var(--color-text);
  }
  .hero__slogan {
    font-size: clamp(1.1rem, 2vw, 4rem);
    font-weight: 500;
    color: var(--color-primary-dark);
    margin-bottom: clamp(1rem, 2vw, 4rem);
  }
  .hero__desc {
    font-size: clamp(0.95rem, 1.4vw, 2.8rem);
    color: var(--color-text-soft);
    line-height: 1.6;
    margin-bottom: clamp(1.5rem, 2.5vw, 5rem);
    max-width: 90%;
  }
  .hero__btns {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(0.8rem, 1.5vw, 3rem);
    margin-bottom: clamp(1.5rem, 2.5vw, 5rem);
  }
  .btn-wa {
    background: var(--color-primary);
    color: #fff;
    padding: clamp(0.6rem, 1vw, 2rem) clamp(1.2rem, 2.5vw, 5rem);
    font-size: clamp(0.9rem, 1.3vw, 2.6rem);
    border-radius: var(--radius);
    font-weight: 600;
    text-decoration: none;
    transition:
      background 0.2s,
      transform 0.2s;
  }
  .btn-wa:hover {
    background: var(--color-primary-dark);
    transform: translateY(-0.15rem);
  }
  .btn-sec {
    padding: clamp(0.6rem, 1vw, 2rem) clamp(1.2rem, 2.5vw, 5rem);
    font-size: clamp(0.9rem, 1.3vw, 2.6rem);
    border: 0.15rem solid var(--color-secondary);
    color: var(--color-secondary-dark);
    border-radius: var(--radius);
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }
  .btn-sec:hover {
    background: var(--color-secondary);
    color: #fff;
    transform: translateY(-0.15rem);
  }
  .hero__datos {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(0.8rem, 1.5vw, 3rem);
    font-size: clamp(0.85rem, 1.1vw, 2.2rem);
    color: var(--color-text-soft);
    border-top: 0.1rem solid var(--color-border);
    padding-top: clamp(1rem, 1.5vw, 3rem);
  }
  .hero__datos a {
    color: var(--color-primary-dark);
    text-decoration: none;
    font-weight: 500;
  }
  .hero__datos a:hover {
    text-decoration: underline;
  }

  /* ===== GRIDS ===== */
  .grid-servicios {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(1rem, 2vw, 4rem);
  }
  .grid-porque {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(1rem, 2vw, 4rem);
  }
  .grid-resenas {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1rem, 2vw, 4rem);
  }
  @media (max-width: 48rem) {
    .grid-servicios,
    .grid-porque,
    .grid-resenas {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 30rem) {
    .grid-servicios,
    .grid-porque,
    .grid-resenas {
      grid-template-columns: 1fr;
    }
  }

  /* ===== CARDS ===== */
  .card-servicio {
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
    border: 0.1rem solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: clamp(1.2rem, 2.5vw, 5rem);
    text-decoration: none;
    transition:
      transform 0.3s,
      box-shadow 0.3s;
  }
  .card-servicio:hover {
    transform: translateY(-0.3rem);
    box-shadow: var(--shadow-md);
  }
  .card-porque {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    background: var(--color-bg);
    border: 0.1rem solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: clamp(1.2rem, 2.5vw, 5rem);
    transition:
      transform 0.2s,
      box-shadow 0.2s;
  }
  .card-porque:hover {
    transform: translateY(-0.2rem);
    box-shadow: var(--shadow-md);
  }
  .card-resena {
    display: flex;
    flex-direction: column;
    background: var(--color-bg);
    border: 0.1rem solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: clamp(1.2rem, 2.5vw, 5rem);
  }
  .card-emoji {
    font-size: clamp(2rem, 3.5vw, 7rem);
    display: block;
    margin-bottom: clamp(0.8rem, 1.2vw, 2.5rem);
  }
  .card-titulo {
    font-size: clamp(1rem, 1.6vw, 3.2rem);
    color: var(--color-primary-dark);
    margin-bottom: clamp(0.5rem, 0.8vw, 1.5rem);
    line-height: 1.3;
  }
  .card-desc {
    font-size: clamp(0.9rem, 1.2vw, 2.4rem);
    color: var(--color-text-soft);
    line-height: 1.6;
    flex-grow: 1;
    margin: 0;
  }
  .card-ver {
    font-size: clamp(0.9rem, 1.2vw, 2.4rem);
    color: var(--color-primary);
    font-weight: 700;
    margin-top: clamp(0.8rem, 1.2vw, 2.5rem);
    display: inline-block;
  }
  .estrellas {
    font-size: clamp(1rem, 1.5vw, 3rem);
    line-height: 1;
    margin-bottom: clamp(0.8rem, 1.2vw, 2.5rem);
  }
  .resena-texto {
    font-size: clamp(0.9rem, 1.2vw, 2.4rem);
    color: var(--color-text-soft);
    font-style: italic;
    line-height: 1.6;
    flex-grow: 1;
    margin: 0 0 clamp(0.8rem, 1.2vw, 2.5rem);
  }
  .resena-nombre {
    font-size: clamp(0.9rem, 1.2vw, 2.4rem);
    color: var(--color-primary-dark);
    font-weight: 700;
    margin: 0;
  }

  /* ===== CÓMO LLEGAR ===== */
  .como-llegar-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(2rem, 4vw, 8rem);
    align-items: center;
  }
  @media (max-width: 48rem) {
    .como-llegar-grid {
      grid-template-columns: 1fr;
    }
  }
  .como-llegar-info {
    display: flex;
    flex-direction: column;
    gap: clamp(1rem, 1.8vw, 3.5rem);
    background: var(--color-bg-soft);
    border: 0.1rem solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: clamp(1.2rem, 2.5vw, 5rem);
  }
