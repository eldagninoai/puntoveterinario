---
import BaseLayout from "../layouts/BaseLayout.astro";

const schema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "VeterinaryCare"],
  name: "Punto Veterinario",
  url: "https://puntoveterinario.com",
  telephone: "+525513843004",
  email: "puntovetcdmx@gmail.com",
  description: "Veterinaria en Coyoacán CDMX.",
  address: {
    "@type": "PostalAddress",
    streetAddress: "Av. División del Norte 3595",
    addressLocality: "San Pablo Tepetlapa",
    addressRegion: "Coyoacán, Ciudad de México",
    postalCode: "04620",
    addressCountry: "MX",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: 19.322004,
    longitude: -99.13922,
  },
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
      opens: "10:00",
      closes: "19:00",
    },
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Sunday"],
      opens: "10:00",
      closes: "17:00",
    },
  ],
  sameAs: ["https://www.instagram.com/punto_veterinario/"],
};

const servicios = [
  {
    emoji: "🩺",
    title: "Consulta Médica",
    desc: "Diagnóstico preciso y atención personalizada.",
    href: "/servicios/consulta-veterinaria",
  },
  {
    emoji: "🛁",
    title: "Estética Canina y Felina",
    desc: "Baño, corte y cuidado profesional.",
    href: "/servicios/estetica-canina-felina",
  },
  {
    emoji: "✂️",
    title: "Esterilización",
    desc: "Procedimiento seguro con seguimiento post-operatorio.",
    href: "/servicios/esterilizacion",
  },
  {
    emoji: "🏥",
    title: "Cirugías",
    desc: "Quirófano equipado para atención especializada.",
    href: "/servicios/cirugia-veterinaria",
  },
  {
    emoji: "🔬",
    title: "Laboratorio Clínico",
    desc: "Análisis clínicos y resultados rápidos de confianza.",
    href: "/servicios/laboratorio-clinico",
  },
  {
    emoji: "🛒",
    title: "Alimento para Mascotas",
    desc: "Croquetas y dietas premium para cuidar su nutrición.",
    href: "/servicios/alimento-mascotas",
  },
];

const porque = [
  {
    emoji: "❤️",
    title: "Atención con amor",
    desc: "Tratamos a tu mascota como si fuera nuestra.",
  },
  {
    emoji: "🏆",
    title: "Médicos especializados",
    desc: "Equipo profesional en constante actualización.",
  },
  {
    emoji: "📍",
    title: "En San Pablo Tepetlapa, Coyoacán",
    desc: "Ubicación accesible en el sur de la ciudad.",
  },
  {
    emoji: "💰",
    title: "Precios accesibles",
    desc: "Medicina veterinaria de calidad al alcance de todos.",
  },
];

const resenas = [
  {
    texto:
      "Profesionales, excelente servicio al cliente. Las mascotas son atendidas como si fueran las de ellos. Altamente recomendable.",
    nombre: "Rodrigo Maldonado",
  },
  {
    texto:
      "Muy buena atención por parte de la Dra. Pilar. Nos apoyó con la esterilización de mi gatita y salió perfecto.",
    nombre: "Marcelo Caraveo",
  },
  {
    texto:
      "La Dra. fue la única que dio el diagnóstico correcto. Gracias a eso Max sigue con nosotros y lo mantiene estable.",
    nombre: "Monica Alvarez",
  },
];
---

<BaseLayout
  title="Veterinaria Coyoacán CDMX | Punto Veterinario"
  description="Veterinaria en Av. División del Norte, Coyoacán. Consultas, cirugías, estética canina, laboratorio y esterilización. Atendemos a tu mascota con amor. ☎️ 55 1384 3004"
  schema={schema}
>
  <!-- 1. HERO -->
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__text">
        <h1>Veterinaria en Coyoacán, CDMX | Punto Veterinario</h1>

        <p class="hero__slogan text-primary-dark">
          ¡De cola a nariz, tu mascota feliz!
        </p>

        <p class="hero__desc">
          Atención veterinaria integral con amor y profesionalismo. Encuéntranos
          en Av. División del Norte, San Pablo Tepetlapa. Ofrecemos consultas
          médicas, laboratorio, cirugías, estética y esterilización.
        </p>

        <div class="hero__btns">
          <a
            href="https://wa.me/525513843004"
            class="btn-primary cta__btn-wa"
            target="_blank"
            rel="noopener"
          >
            💬 Agendar por WhatsApp
          </a>
          <a href="/servicios/consulta-veterinaria" class="btn-secondary"
            >Ver Servicios</a
          >
        </div>

        <div class="hero__datos mt-md">
          <span>📞 <a href="tel:+525513843004">55 1384 3004</a></span>
          <span>📍 Av. División del Norte 3595, CDMX</span>
          <span
            ><a href="https://wa.me/525513843004" target="_blank" rel="noopener"
              >💬 WhatsApp Urgente</a
            ></span
          >
        </div>
      </div>

      <div class="hero__img">
        <figure class="hero__figure">
          <img
            src="/images/veterinaria-coyoacan-punto-veterinario.svg"
            alt="Veterinaria Punto Veterinario en Coyoacán, San Pablo Tepetlapa — atención médica para perros y gatos"
            title="Punto Veterinario — Clínica Veterinaria en Coyoacán, CDMX"
            class="hero__img-real"
            width="800"
            height="600"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
          <figcaption class="visually-hidden">
            Clínica veterinaria Punto Veterinario ubicada en Av. División del
            Norte 3595, San Pablo Tepetlapa, CP 04620, Coyoacán, CDMX
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- 2. SERVICIOS -->
  <section class="bg-soft">
    <div class="container">
      <h2 class="text-center mb-xl">Nuestros Servicios en Coyoacán</h2>
      <div class="grid-3 servicios__grid">
        {
          servicios.map((s) => (
            <a
              href={s.href}
              class="card card-hover-effect flex-col gap-sm p-lg"
            >
              <span class="emoji-xl">{s.emoji}</span>
              <h3 class="text-primary mt-sm">{s.title}</h3>
              <p class="text-soft flex-grow">{s.desc}</p>
              <span class="text-primary fw-bold mt-sm inline-block">
                Ver más →
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 3. POR QUÉ ELEGIRNOS -->
  <section class="bg-white">
    <div class="container">
      <h2 class="text-center mb-xl">¿Por qué elegir Punto Veterinario?</h2>
      <div class="grid-4 porque__grid">
        {
          porque.map((r) => (
            <div class="card p-lg text-center border-subtle flex-col items-center">
              <span class="emoji-xl mb-md block">{r.emoji}</span>
              <h3 class="text-primary mb-sm text-md">{r.title}</h3>
              <p class="text-soft text-sm">{r.desc}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 4. RESEÑAS -->
  <section class="bg-soft">
    <div class="container">
      <h2 class="text-center mb-xl">Lo que dicen nuestros clientes</h2>
      <div class="grid-3 resenas__grid">
        {
          resenas.map((r) => (
            <div class="card p-lg border-subtle flex-col gap-md">
              <p class="text-lg lh-1">⭐⭐⭐⭐⭐</p>
              <p class="text-soft text-italic flex-grow lh-relaxed">
                "{r.texto}"
              </p>
              <p class="text-primary fw-bold">— {r.nombre}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 5. COMO LLEGAR -->
  <section class="como-llegar bg-white">
    <div class="container py-xl">
      <h2 class="text-center text-primary-dark mb-xl lh-1">
        ¿Cómo llegar a Punto Veterinario en Coyoacán?
      </h2>

      <div class="grid-2 gap-lg items-center text-left">
        <!-- Izquierda: Direcciones -->
        <div class="flex-col gap-md bg-soft p-lg border-subtle border-radius">
          <p class="text-soft text-md lh-relaxed m-0 text-primary-dark">
            <span class="fw-bold block">Ubicación central en el sur:</span>
            Av. División del Norte 3595, San Pablo Tepetlapa,<br />
            CP 04620, Coyoacán, CDMX.
          </p>

          <div class="flex-col gap-sm">
            <div
              class="card p-sm bg-white border-radius-sm flex items-center gap-sm box-shadow-sm"
            >
              <span class="emoji-md m-0">🚇</span>
              <p class="text-soft text-sm lh-1 m-0">
                <b>Metro:</b> Línea 3 estación Universidad + combi local
              </p>
            </div>
            <div
              class="card p-sm bg-white border-radius-sm flex items-center gap-sm box-shadow-sm"
            >
              <span class="emoji-md m-0">🚌</span>
              <p class="text-soft text-sm lh-1 m-0">
                <b>Metrobús:</b> Línea 1, conexión rápida Coyoacán sur
              </p>
            </div>
            <div
              class="card p-sm bg-white border-radius-sm flex items-center gap-sm box-shadow-sm"
            >
              <span class="emoji-md m-0">🚗</span>
              <p class="text-soft text-sm lh-1 m-0">
                <b>En auto:</b> Vía rápida Av. División del Norte 3595
              </p>
            </div>
          </div>

          <div class="horarios-box pt-sm border-top border-border">
            <p class="text-soft text-sm m-0 lh-relaxed">
              <span class="text-primary-dark fw-bold block">Lunes:</span> Cerrado
              <br /><span class="text-primary-dark fw-bold block mt-xs"
                >Mar-Sáb:</span
              > 10:00 - 19:00 hrs
              <br /><span class="text-primary-dark fw-bold block mt-xs"
                >Dom:</span
              > 10:00 - 17:00 hrs
            </p>
          </div>

          <a
            href="/ubicacion"
            class="btn-primary flex justify-center mt-xs pointer text-md fw-bold py-sm transition-transform border-radius block text-center f-width"
          >
            <span>📍 Ver cómo llegar en el mapa</span>
          </a>
        </div>

        <!-- Derecha: Mapa CSS -->
        <div
          class="mapa-css bg-light-map border-radius flex-col items-center justify-center dashed-border hover-lift transition-transform"
        >
          <span class="emoji-xl map-pin bounce-anim block mb-xs">📍</span>
          <p class="text-primary-dark fw-bold m-0 t-map text-center">
            Av. División del Norte 3595,<br />Coyoacán
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. CTA FINAL -->
  <section class="cta-section">
    <div class="container text-center max-w-lg mx-auto">
      <h2 class="text-white mb-lg text-2xl">
        ¿Tu mascota necesita atención en Coyoacán?
      </h2>
      <p class="text-white opacity-90 mb-xl text-lg lh-relaxed">
        Av. División del Norte 3595, San Pablo Tepetlapa, CP 04620
      </p>
      <div class="flex-wrap justify-center gap-md">
        <a
          href="/contacto"
          class="btn-primary btn-white-theme text-md px-lg py-sm fw-bold"
          >📅 Agendar Cita</a
        >
        <a
          href="https://wa.me/525513843004"
          target="_blank"
          rel="noopener"
          class="btn-outline-white text-md px-lg py-sm fw-bold">💬 WhatsApp</a
        >
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* UTILIDADES GLOBALES DE LA PÁGINA (Sin PX) */
  .bg-white {
    background-color: var(--color-bg);
  }
  .bg-soft {
    background-color: var(--color-bg-soft);
  }
  .text-white {
    color: var(--color-bg);
  }
  .text-primary {
    color: var(--color-primary);
  }
  .text-primary-dark {
    color: var(--color-primary-dark);
  }
  .text-soft {
    color: var(--color-text-soft);
  }
  .text-center {
    text-align: center;
  }
  .text-italic {
    font-style: italic;
  }
  .text-sm {
    font-size: var(--text-sm);
  }
  .text-md {
    font-size: var(--text-md);
  }
  .text-lg {
    font-size: var(--text-lg);
  }
  .text-2xl {
    font-size: var(--text-2xl);
  }
  .fw-bold {
    font-weight: 700;
  }

  .mb-sm {
    margin-bottom: var(--space-sm);
  }
  .mb-md {
    margin-bottom: var(--space-md);
  }
  .mb-lg {
    margin-bottom: var(--space-lg);
  }
  .mb-xl {
    margin-bottom: var(--space-xl);
  }
  .mt-sm {
    margin-top: var(--space-sm);
  }
  .mt-md {
    margin-top: var(--space-md);
  }

  .p-lg {
    padding: var(--space-lg);
  }
  .px-lg {
    padding-inline: var(--space-lg);
  }
  .py-sm {
    padding-block: var(--space-sm);
  }

  .gap-sm {
    gap: var(--space-sm);
  }
  .gap-md {
    gap: var(--space-md);
  }

  .flex-col {
    display: flex;
    flex-direction: column;
  }
  .flex-wrap {
    display: flex;
    flex-wrap: wrap;
  }
  .flex-grow {
    flex-grow: 1;
  }
  .items-center {
    align-items: center;
  }
  .justify-center {
    justify-content: center;
  }

  .block {
    display: block;
  }
  .inline-block {
    display: inline-block;
  }
  .max-w-lg {
    max-width: 60rem;
  }
  .mx-auto {
    margin-inline: auto;
  }

  .lh-1 {
    line-height: 1;
  }
  .lh-relaxed {
    line-height: 1.6;
  }
  .opacity-90 {
    opacity: 0.9;
  }

  .emoji-xl {
    font-size: clamp(2.5rem, 5vw, 4rem);
  }
  .border-subtle {
    border: 0.1rem solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .card-hover-effect {
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
    border-radius: var(--radius-lg);
    background-color: var(--color-bg);
    border: 0.1rem solid var(--color-border);
    text-decoration: none;
  }
  .card-hover-effect:hover {
    transform: translateY(-0.3rem);
    box-shadow: var(--shadow-md);
  }

  /* 1. HERO */
  .hero {
    padding-block: var(--space-xl);
    background-color: var(--color-bg);
  }

  .hero__inner {
    display: grid;
    /* Split content and placeholder smoothly */
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 25rem), 1fr));
    gap: var(--space-xl);
    align-items: center;
  }

  .hero__text h1 {
    font-size: var(--text-2xl);
    line-height: 1.2;
    margin-bottom: var(--space-xs);
    color: var(--color-text);
  }

  .hero__slogan {
    font-size: var(--text-lg);
    font-weight: 500;
    margin-bottom: var(--space-md);
  }

  .hero__desc {
    font-size: var(--text-md);
    color: var(--color-text-soft);
    margin-bottom: var(--space-lg);
    line-height: 1.6;
    max-width: 90%;
  }

  .hero__btns {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .cta__btn-wa {
    background-color: var(--color-primary);
    color: var(--color-bg);
    text-decoration: none;
    padding: var(--space-sm) var(--space-md);
    border-radius: var(--radius);
    font-weight: 600;
    transition:
      background-color 0.2s ease,
      transform 0.2s ease;
  }
  .cta__btn-wa:hover {
    background-color: var(--color-primary-dark);
    transform: translateY(-0.15rem);
  }

  .btn-secondary {
    display: inline-block;
    padding: var(--space-sm) var(--space-md);
    border: 0.15rem solid var(--color-secondary);
    color: var(--color-secondary-dark);
    text-decoration: none;
    border-radius: var(--radius);
    font-weight: 600;
    background-color: transparent;
    transition:
      background-color 0.2s ease,
      color 0.2s ease,
      transform 0.2s ease;
  }
  .btn-secondary:hover {
    background-color: var(--color-secondary);
    color: var(--color-bg);
    transform: translateY(-0.15rem);
  }

  .hero__datos {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    font-size: var(--text-sm);
    color: var(--color-text-soft);
    border-top: 0.1rem solid var(--color-border);
    padding-top: var(--space-md);
  }

  .hero__datos a {
    color: var(--color-primary-dark);
    text-decoration: none;
    font-weight: 500;
  }
  .hero__datos a:hover {
    text-decoration: underline;
  }

  .hero__img {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero__figure {
    margin: 0;
    width: 100%;
  }
  .hero__img-real {
    width: 100%;
    height: clamp(18rem, 40vw, 32rem);
    object-fit: contain;
    border-radius: var(--radius-lg);
  }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }

  /* 6. CTA FINAL */
  .cta-section {
    background-color: var(--color-primary);
    padding-block: var(--space-xl);
  }

  .btn-white-theme {
    background-color: var(--color-bg);
    color: var(--color-primary);
    text-decoration: none;
    border-radius: var(--radius);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
    display: inline-block;
  }
  .btn-white-theme:hover {
    transform: translateY(-0.2rem);
    box-shadow: var(--shadow-md);
  }

  .btn-outline-white {
    background-color: transparent;
    color: var(--color-bg);
    border: 0.15rem solid var(--color-bg);
    text-decoration: none;
    border-radius: var(--radius);
    transition:
      background-color 0.2s ease,
      color 0.2s ease,
      transform 0.2s ease;
    display: inline-block;
  }
  .btn-outline-white:hover {
    background-color: var(--color-bg);
    color: var(--color-primary);
    transform: translateY(-0.2rem);
  }

  /* UTILS NEW COMO LLEGAR */
  .box-shadow-sm {
    box-shadow: var(--shadow-sm);
  }
  .f-width {
    width: 100%;
    box-sizing: border-box;
  }
  .bg-light-map {
    background-color: #e8fafa;
  }
  .dashed-border {
    border: 0.2rem dashed var(--color-primary-light);
  }
  .mapa-css {
    min-height: clamp(18rem, 35vw, 26rem);
    padding: var(--space-lg);
  }
  .t-map {
    font-size: clamp(1.3rem, 3vw, 1.8rem);
    line-height: 1.3;
  }

  .bounce-anim {
    animation: mapb 2s infinite ease-in-out;
  }

  @keyframes mapb {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-1rem);
    }
  }

  .border-top {
    border-top: 0.1rem solid;
  }
  .border-border {
    border-color: var(--color-border);
  }
  .mt-xs {
    margin-top: var(--space-xs);
  }
  .mb-xs {
    margin-bottom: var(--space-xs);
  }

  .horarios-box p {
    color: var(--color-text-soft);
  }

  .grid-2 {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }
  @media (min-width: 48rem) {
    .grid-2 {
      grid-template-columns: 1.3fr 1fr;
    }
  }
</style>
