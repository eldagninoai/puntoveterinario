---
import BaseLayout from "../layouts/BaseLayout.astro";

const schemaLocal = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["LocalBusiness", "VeterinaryCare"],
      "@id": "https://puntoveterinario.com/#localbusiness",
      name: "Punto Veterinario",
      url: "https://puntoveterinario.com",
      image: "https://puntoveterinario.com/og-image.jpg",
      hasMap: "https://maps.app.goo.gl/GricGKCzpp6BXJgE7",
      telephone: "+525513843004",
      email: "puntovetcdmx@gmail.com",
      priceRange: "$$",
      description:
        "Veterinaria en Coyoacán CDMX. Consulta médica, cirugías, estética canina, laboratorio clínico, esterilización y alimento para mascotas en San Pablo Tepetlapa.",
      address: {
        "@type": "PostalAddress",
        streetAddress: "Av. División del Norte 3595",
        addressLocality: "Coyoacán",
        addressRegion: "CDMX",
        postalCode: "04620",
        addressCountry: "MX",
      },
      areaServed: {
        "@type": "AdministrativeArea",
        name: "Coyoacán",
      },
      geo: {
        "@type": "GeoCoordinates",
        latitude: 19.322004,
        longitude: -99.13922,
      },
      openingHoursSpecification: [
        {
          "@type": "OpeningHoursSpecification",
          dayOfWeek: ["Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
          opens: "10:00",
          closes: "19:00",
        },
        {
          "@type": "OpeningHoursSpecification",
          dayOfWeek: ["Sunday"],
          opens: "10:00",
          closes: "17:00",
        },
      ],
      sameAs: ["https://www.instagram.com/punto_veterinario/"],
    },
    {
      "@type": "FAQPage",
      mainEntity: [
        {
          "@type": "Question",
          name: "¿Cuánto cuesta una consulta veterinaria en Coyoacán?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "En Punto Veterinario ofrecemos consultas médicas generales a precios accesibles en Coyoacán, CDMX. Contáctanos por WhatsApp al 55 1384 3004 para informarte sobre el costo actual.",
          },
        },
        {
          "@type": "Question",
          name: "¿Atienden perros y gatos?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Sí, atendemos perros y gatos en todos nuestros servicios: consulta médica, esterilización, cirugías y laboratorio clínico. El servicio de estética canina es exclusivo para perros.",
          },
        },
        {
          "@type": "Question",
          name: "¿Dónde está ubicada la veterinaria?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Estamos en Av. División del Norte 3595, San Pablo Tepetlapa, CP 04620, Coyoacán, CDMX. Puedes llegar desde Metro Universidad tomando una combi por División del Norte.",
          },
        },
        {
          "@type": "Question",
          name: "¿Cuáles son los horarios de atención?",
          acceptedAnswer: {
            "@type": "Answer",
            text: "Atendemos martes a sábado de 10:00 a 19:00 hrs y domingos de 10:00 a 17:00 hrs. Los lunes permanecemos cerrados.",
          },
        },
      ],
    },
  ],
};

const servicios = [
  {
    emoji: "🩺",
    title: "Consulta Médica",
    desc: "Diagnóstico completo para perros y gatos. Revisión de nariz a cola, historial clínico y plan de salud preventiva.",
    href: "/servicios/consulta-veterinaria",
  },
  {
    emoji: "🛁",
    title: "Estética Canina",
    desc: "Baño, corte y cuidado profesional para perros en Coyoacán. Usamos productos específicos para cada tipo de pelaje.",
    href: "/servicios/estetica-canina",
  },
  {
    emoji: "✂️",
    title: "Esterilización",
    desc: "Procedimiento seguro para perros y gatos con seguimiento post-operatorio. Incluye valoración prequirúrgica.",
    href: "/servicios/esterilizacion",
  },
  {
    emoji: "🏥",
    title: "Cirugías",
    desc: "Quirófano equipado para cirugías de tejidos blandos y procedimientos especializados en el sur de CDMX.",
    href: "/servicios/cirugia-veterinaria",
  },
  {
    emoji: "🔬",
    title: "Laboratorio Clínico",
    desc: "Análisis de sangre, hemograma y perfil bioquímico para perros y gatos. Resultados el mismo día.",
    href: "/servicios/laboratorio-clinico",
  },
  {
    emoji: "🛒",
    title: "Alimento para Mascotas",
    desc: "Croquetas y dietas premium recomendadas por veterinarios. Asesoría personalizada según las necesidades de tu mascota.",
    href: "/servicios/alimento-mascotas",
  },
];

const porque = [
  {
    emoji: "❤️",
    title: "Trato personalizado",
    desc: "Tratamos a cada paciente como si fuera nuestra propia mascota. Conocemos su historial, su carácter y sus necesidades.",
  },
  {
    emoji: "🏆",
    title: "Médicos veterinarios especializados",
    desc: "Equipo veterinario con formación especializada y actualización constante en medicina preventiva y cirugía. Más que un consultorio, somos profesionales dedicados a diagnósticos precisos y tratamientos efectivos.",
  },
  {
    emoji: "📍",
    title: "Ubicación accesible en Coyoacán",
    desc: "Estamos en Av. División del Norte 3595, San Pablo Tepetlapa — fácil de llegar desde Metro Universidad y colonias vecinas como Pedregal de Santo Domingo, Copilco y Ajusco.",
  },
  {
    emoji: "💰",
    title: "Precios accesibles",
    desc: "Creemos que el cuidado veterinario de calidad debe estar al alcance de todos los dueños de mascotas en el sur de CDMX.",
  },
];

const datos = [
  {
    dato: "1 de cada 4 perras no esterilizadas desarrolla cáncer mamario",
    desc: "Esterilizar antes del primer celo reduce este riesgo a menos del 1%. Una decisión preventiva que puede salvarle la vida.",
  },
  {
    dato: "80% de las perras presentarán piometra si no se esterilizan",
    desc: "La piometra es una infección uterina grave que requiere cirugía de urgencia. Se previene completamente con la esterilización.",
  },
  {
    dato: "Un chequeo anual detecta enfermedades antes de que den síntomas",
    desc: "Enfermedades renales, hepáticas o tumorales son silentes en etapas tempranas. La consulta preventiva es la herramienta más efectiva.",
  },
];

const resenas = [
  {
    texto:
      "Profesionales, excelente servicio al cliente. Las mascotas son atendidas como si fueran las de ellos. Altamente recomendable.",
    nombre: "Rodrigo Maldonado",
  },
  {
    texto:
      "Muy buena atención por parte de la Dra. Pilar. Nos apoyó con la esterilización de mi gatita y salió perfecto.",
    nombre: "Marcelo Caraveo",
  },
  {
    texto:
      "La Dra. fue la única que dio el diagnóstico correcto. Gracias a eso Max sigue con nosotros y lo mantiene estable.",
    nombre: "Monica Alvarez",
  },
];

const faqs = (schemaLocal as any)["@graph"][1].mainEntity;

let posts = [];
try {
  posts = Object.values(
    import.meta.glob("./blog/*.md", { eager: true }) || {},
  ).slice(0, 3);
} catch (e) {}
---

<BaseLayout
  title="Veterinaria en Coyoacán, CDMX | Punto Veterinario"
  description="Clínica veterinaria en Coyoacán, CDMX. Consulta médica, estética canina, esterilización, cirugías y laboratorio clínico en San Pablo Tepetlapa. ¡Agenda por WhatsApp!"
  canonical="https://puntoveterinario.com"
>
  <Fragment slot="head">
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_MX" />
    <script type="application/ld+json" set:html={JSON.stringify(schemaLocal)} />
  </Fragment>

  <!-- SECCIÓN 1 — HERO -->
  <section class="hero content-section">
    <div class="hero__text">
      <h1 class="h1-hero">Veterinaria en Coyoacán, CDMX | Punto Veterinario</h1>
      <p class="hero__desc">
        Atendemos a tu perro o gato con diagnóstico preciso, precios accesibles
        y el trato que tu mascota merece. Estamos en Av. División del Norte
        3595, San Pablo Tepetlapa — en el corazón del sur de la ciudad.
      </p>
      <div class="hero__slogan-box">
        <p class="hero__slogan">¡De cola a nariz, tu mascota feliz!</p>
      </div>
      <div class="hero__btns">
        <a
          href="https://wa.me/525513843004"
          class="btn-wa"
          target="_blank"
          rel="noopener"
        >
          💬 Agendar por WhatsApp
        </a>
        <a href="/servicios/consulta-veterinaria" class="btn-sec">
          Ver nuestros servicios
        </a>
      </div>
    </div>
  </section>

  <!-- SECCIÓN 2 — SERVICIOS -->
  <section class="content-section bg-soft">
    <h2 class="titulo-sec">Servicios Veterinarios en Coyoacán</h2>
    <div class="grid-auto">
      {
        servicios.map((s) => (
          <a href={s.href} class="card-ui">
            <span class="icon-scalable">{s.emoji}</span>
            <h3 class="card-titulo">{s.title}</h3>
            <p class="card-desc">{s.desc}</p>
            <span class="card-ver">Ver más →</span>
          </a>
        ))
      }
    </div>
  </section>

  <!-- SECCIÓN 3 — POR QUÉ ELEGIRNOS -->
  <section class="content-section">
    <h2 class="titulo-sec">
      ¿Por qué elegir Punto Veterinario en San Pablo Tepetlapa?
    </h2>
    <div class="grid-porque">
      {
        porque.map((r) => (
          <div class="card-ui card-static">
            <span class="card-emoji">{r.emoji}</span>
            <h3 class="card-titulo">{r.title}</h3>
            <p class="card-desc">{r.desc}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- SECCIÓN 4 — DATOS QUE IMPORTAN -->
  <section class="content-section bg-soft">
    <h2 class="titulo-sec">Lo que debes saber sobre la salud de tu mascota</h2>
    <div class="grid-auto">
      {
        datos.map((d) => (
          <div class="card-ui">
            <h3 class="dato-titulo">{d.dato}</h3>
            <p class="dato-desc">{d.desc}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- SECCIÓN 5 — RESEÑAS -->
  <section class="content-section">
    <h2 class="titulo-sec">Lo que dicen los dueños de mascotas en Coyoacán</h2>
    <div class="grid-auto" style="margin-bottom: max(1.5rem, 3vw);">
      {
        resenas.map((r) => (
          <div class="card-ui">
            <p class="estrellas">⭐⭐⭐⭐⭐</p>
            <p class="resena-texto">"{r.texto}"</p>
            <p class="resena-nombre">— {r.nombre}</p>
          </div>
        ))
      }
    </div>
    <a
      href="https://maps.app.goo.gl/GricGKCzpp6BXJgE7"
      target="_blank"
      rel="noopener"
      class="link-mas"
    >
      Ver más reseñas en Google →
    </a>
  </section>

  <!-- SECCIÓN 6 — FAQ -->
  <section class="content-section bg-soft">
    <h2 class="titulo-sec">
      Preguntas frecuentes sobre nuestra veterinaria en Coyoacán
    </h2>
    <div class="faq-accordion">
      {
        faqs.map((faq: any) => (
          <details class="faq-item">
            <summary class="faq-question">{faq.name}</summary>
            <p class="faq-answer">{faq.acceptedAnswer.text}</p>
          </details>
        ))
      }
    </div>
  </section>

  <!-- SECCIÓN BLOG (MUDADA AQUÍ) -->
  <section class="seccion-blog content-section bg-soft">
    <h2 class="titulo-sec">
      Consejos veterinarios para dueños de mascotas en CDMX
    </h2>
    <div class="grid-auto">
      <article class="card-ui">
        <img
          src="https://images.unsplash.com/photo-1583337130417-3346a1be7dee?auto=format&fit=crop&w=600&q=80"
          alt="Perro en parque - Placeholder"
          width="600"
          height="400"
          loading="lazy"
          decoding="async"
          class="blog-img"
          style="width:100%; height:max(12rem, 18vw); object-fit:cover; border-radius:var(--radius-sm); margin-bottom:var(--space-sm);"
        />
        <div class="blog-content">
          <span
            class="card-ver"
            style="margin-top:0; color:var(--color-primary); font-size:var(--text-sm);"
            >Prevención</span
          >
          <h3 class="blog-titulo">
            Los mejores parques para perros en Coyoacán
          </h3>
          <p class="card-desc">
            Conoce los espacios más seguros en el sur de la CDMX y qué vacunas
            necesita tu mascota antes de salir a jugar.
          </p>
          <a
            href="/blog/mejores-parques-perros-coyoacan-cuidados"
            class="card-ver">Leer artículo →</a
          >
        </div>
      </article>

      <article class="card-ui">
        <img
          src="https://images.unsplash.com/photo-1514888286974-6c03e2ca1dba?auto=format&fit=crop&w=600&q=80"
          alt="Gato en revisión - Placeholder"
          width="600"
          height="400"
          loading="lazy"
          decoding="async"
          class="blog-img"
          style="width:100%; height:max(12rem, 18vw); object-fit:cover; border-radius:var(--radius-sm); margin-bottom:var(--space-sm);"
        />
        <div class="blog-content">
          <span
            class="card-ver"
            style="margin-top:0; color:var(--color-primary); font-size:var(--text-sm);"
            >Salud Felina</span
          >
          <h3 class="blog-titulo">¿Por qué mi gato toma tanta agua?</h3>
          <p class="card-desc">
            El aumento en el consumo de agua puede ser una señal silente de
            problemas renales. Descubre cuándo preocuparte.
          </p>
          <a href="/blog" class="card-ver">Leer artículo →</a>
        </div>
      </article>

      <article class="card-ui">
        <img
          src="https://images.unsplash.com/photo-1576201836106-db1758fd1c97?auto=format&fit=crop&w=600&q=80"
          alt="Perro veterinario - Placeholder"
          width="600"
          height="400"
          loading="lazy"
          decoding="async"
          class="blog-img"
          style="width:100%; height:max(12rem, 18vw); object-fit:cover; border-radius:var(--radius-sm); margin-bottom:var(--space-sm);"
        />
        <div class="blog-content">
          <span
            class="card-ver"
            style="margin-top:0; color:var(--color-primary); font-size:var(--text-sm);"
            >Nutrición</span
          >
          <h3 class="blog-titulo">
            Croquetas de súper vs. Premium: ¿Cuál elegir?
          </h3>
          <p class="card-desc">
            La diferencia real en digestibilidad y por qué el alimento económico
            puede salir más caro a largo plazo.
          </p>
          <a href="/servicios/alimento-mascotas" class="card-ver"
            >Leer artículo →</a
          >
        </div>
      </article>
    </div>
  </section>

  <!-- SECCIÓN 7 — UBICACIÓN Y HORARIOS -->
  <section class="content-section">
    <h2 class="titulo-sec">¿Cómo llegar a Punto Veterinario en Coyoacán?</h2>

    <div class="rf-ubicacion">
      <p class="rf-ubicacion-text">
        Nos encontramos en Av. División del Norte 3595, San Pablo Tepetlapa, CP
        04620, Coyoacán, CDMX — una zona accesible para dueños de mascotas de
        colonias como Pedregal de Santo Domingo, Copilco el Alto, Ajusco, Los
        Reyes y El Caracol.
      </p>
    </div>

    <div class="como-llegar-grid">
      <div class="como-llegar-info">
        <p class="direccion-label">Ubicación central en el sur:</p>
        <a
          href="https://maps.app.goo.gl/GricGKCzpp6BXJgE7?g_st=aw"
          target="_blank"
          rel="noopener"
          class="maps-link"
        >
          Av. División del Norte 3595, San Pablo Tepetlapa, CP 04620, Coyoacán,
          CDMX
        </a>
        <div class="transporte-lista">
          <div class="transporte-item">
            <span>🚇</span>
            <p><b>Metro:</b> Línea 3 estación Universidad + combi local</p>
          </div>
          <div class="transporte-item">
            <span>🚌</span>
            <p><b>Metrobús:</b> Línea 1, conexión rápida Coyoacán sur</p>
          </div>
          <div class="transporte-item">
            <span>🚗</span>
            <p><b>En auto:</b> Vía rápida Av. División del Norte 3595</p>
          </div>
        </div>
        <div class="horario-box">
          <p><span class="horario-label">Lunes:</span> Cerrado</p>
          <p><span class="horario-label">Mar-Sáb:</span> 10:00 - 19:00 hrs</p>
          <p><span class="horario-label">Dom:</span> 10:00 - 17:00 hrs</p>
        </div>
        <a href="/ubicacion" class="btn-mapa">📍 Ver cómo llegar en el mapa</a>
      </div>

      <div class="mapa-placeholder">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3765.0454378776846!2d-99.1417531!3d19.3238356!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x85ce01a52002f2ab%3A0xe5a3c0e3e5c9b7e7!2sPunto%20Veterinario!5e0!3m2!1sen!2smx!4v1707575344445!5m2!1sen!2smx"
          width="100%"
          height="100%"
          style="border:0; border-radius: max(1rem, 2vw); min-height: max(20rem, 30vw);"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        >
        </iframe>
      </div>
    </div>
  </section>

  <!-- SECCIÓN 8 — CTA FINAL -->
  <section class="cta-final content-section">
    <h2 class="cta-titulo-blanc">
      ¿Tu perro o gato necesita atención veterinaria en Coyoacán?
    </h2>
    <p class="cta-desc-blanc">
      Agenda tu cita fácilmente por WhatsApp o llámanos directamente. Estamos en
      Av. División del Norte 3595, San Pablo Tepetlapa — atendiendo a las
      mascotas del sur de CDMX.
    </p>
    <div class="cta-btns">
      <a
        href="https://wa.me/525513843004"
        target="_blank"
        rel="noopener"
        class="btn-cta-blanco"
      >
        💬 Agendar por WhatsApp
      </a>
      <a href="tel:+525513843004" class="btn-cta-outline"> 📞 55 1384 3004 </a>
    </div>
  </section>
  <!-- BOTÓN FLOTANTE WA REMOVIDO: Ya existe nativamente en BaseLayout.astro -->
</BaseLayout>

<style>
  /* ====== FLUID SYSTEM + RESPONSIVE ====== */

  .content-section {
    padding-block: max(3rem, 6vw);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .pt-0 {
    padding-top: 0;
  }
  .bg-soft {
    background: var(--color-bg-soft);
  }

  .h1-hero {
    color: var(--color-text);
    font-size: max(2rem, 5vw);
    margin-bottom: max(1rem, 2vw);
  }

  .titulo-sec {
    color: var(--color-primary);
    text-align: center;
    font-size: max(1.75rem, 3.5vw);
    margin-bottom: max(2rem, 4vw);
    line-height: 1.2;
  }

  /* HERO — portada vertical perfecta */
  .hero {
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--color-bg);
  }
  .hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .hero__text {
    width: 100%;
    margin-inline: auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero__desc {
    color: var(--color-text-soft);
    margin-bottom: max(1.5rem, 2vw);
    margin-inline: auto;
  }

  .hero__slogan-box {
    background: var(--color-primary-light);
    border-radius: max(0.6rem, 1vw);
    padding: max(0.8rem, 1.5vw);
    margin-bottom: max(1.5rem, 2.5vw);
    display: inline-block;
  }

  .hero__slogan {
    font-size: max(1rem, 1.6vw);
    font-weight: 600;
    color: var(--color-primary-dark);
    margin: 0;
    line-height: 1.3;
  }

  .hero__btns {
    display: flex;
    flex-wrap: wrap;
    gap: max(0.8rem, 1.5vw);
    margin-bottom: max(1rem, 2vw);
    justify-content: center;
  }

  .btn-wa {
    background: var(--color-primary);
    color: #fff;
    padding: max(0.6rem, 1.2vw) max(1.2rem, 2.5vw);
    border-radius: max(0.4rem, 1vw);
    font-weight: 600;
    text-decoration: none;
    transition:
      background 0.2s,
      transform 0.2s;
  }
  .btn-wa:hover {
    background: var(--color-primary-dark);
    transform: translateY(-0.15rem);
  }

  .btn-sec {
    padding: max(0.6rem, 1.2vw) max(1.2rem, 2.5vw);
    border: max(0.1rem, 0.15vw) solid var(--color-secondary);
    color: var(--color-secondary-dark);
    border-radius: max(0.4rem, 1vw);
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }
  .btn-sec:hover {
    background: var(--color-secondary);
    color: #fff;
    transform: translateY(-0.15rem);
  }

  .card-titulo,
  .dato-titulo,
  .blog-titulo {
    color: var(--color-primary-dark);
    margin-bottom: max(0.5rem, 1vw);
  }
  .dato-titulo {
    color: var(--color-text);
  }
  .card-desc,
  .dato-desc {
    color: var(--color-text-soft);
    flex-grow: 1;
    margin: 0;
  }

  .card-ver {
    color: var(--color-primary);
    font-weight: 700;
    margin-top: max(0.8rem, 1.2vw);
    display: inline-block;
    text-decoration: none !important;
  }

  /* =========================================
     GRIDS Y TARJETAS — HOMEPAGE ESPECÍFICOS
     ========================================= */

  /* Centrado de emojis en tarjetas */
  .card-emoji,
  .icon-scalable {
    display: block;
    text-align: center;
    margin-inline: auto;
  }
