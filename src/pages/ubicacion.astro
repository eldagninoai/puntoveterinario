---
import BaseLayout from "../layouts/BaseLayout.astro";

const schema = {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    name: "Contacto y Ubicación de Punto Veterinario",
    url: "https://puntoveterinario.com/ubicacion",
    mainEntity: {
        "@type": "VeterinaryCare",
        "@id": "https://puntoveterinario.com/#localbusiness",
        name: "Punto Veterinario",
        image: "https://puntoveterinario.com/fachada-clinica.jpg",
        hasMap: "https://maps.app.goo.gl/GricGKCzpp6BXJgE7",
        telephone: "+525513843004",
        email: "puntovetcdmx@gmail.com",
        address: {
            "@type": "PostalAddress",
            streetAddress: "Av. División del Norte 3595",
            addressLocality: "Coyoacán",
            addressRegion: "CDMX",
            postalCode: "04620",
            addressCountry: "MX",
        },
        geo: {
            "@type": "GeoCoordinates",
            latitude: 19.322004,
            longitude: -99.13922,
        },
        openingHoursSpecification: [
            {
                "@type": "OpeningHoursSpecification",
                dayOfWeek: [
                    "Tuesday",
                    "Wednesday",
                    "Thursday",
                    "Friday",
                    "Saturday",
                ],
                opens: "10:00",
                closes: "19:00",
            },
            {
                "@type": "OpeningHoursSpecification",
                dayOfWeek: ["Sunday"],
                opens: "10:00",
                closes: "17:00",
            },
        ],
    },
};
---

<BaseLayout
    title="Ubicación y Horarios | Veterinaria en San Pablo Tepetlapa, Coyoacán"
    description="Encuentra Punto Veterinario en Av. División del Norte 3595, San Pablo Tepetlapa, CDMX. Conoce nuestros horarios, mapa y rutas de llegada en Coyoacán."
    canonical="https://puntoveterinario.com/ubicacion"
>
    <Fragment slot="head">
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    </Fragment>

    <!-- SECCIÓN 1 — HERO & DATOS DE CONTACTO (NAP) -->
    <section class="hero content-section">
            <div class="hero__text">
                <h1 class="h1-hero">
                    Cómo llegar a Punto Veterinario en Coyoacán
                </h1>
                <p class="hero__desc">
                    Estamos listos para recibir a tu mascota en el corazón del
                    sur de la CDMX. Encuentra nuestra dirección exacta, horarios
                    de atención y las mejores rutas para llegar desde tu
                    colonia.
                </p>
            </div>

            <div class="nap-grid">
                <div class="nap-card">
                    <span class="nap-icon" aria-hidden="true">📍</span>
                    <h2 class="nap-title">Dirección</h2>
                    <p class="nap-text">
                        Av. División del Norte 3595, San Pablo Tepetlapa, CP
                        04620, Coyoacán, CDMX.
                    </p>
                </div>
                <div class="nap-card">
                    <span class="nap-icon" aria-hidden="true">🕒</span>
                    <h2 class="nap-title">Horarios</h2>
                    <p class="nap-text">
                        <strong>Martes a Sábado:</strong> 10:00 a 19:00 hrs.<br
                        /><strong>Domingos:</strong> 10:00 a 17:00 hrs.<br
                        /><strong>Lunes:</strong> Cerrado.
                    </p>
                </div>
                <div class="nap-card">
                    <span class="nap-icon" aria-hidden="true">📞</span>
                    <h2 class="nap-title">Contacto Directo</h2>
                    <p class="nap-text">
                        WhatsApp y Teléfono:<br /><strong>55 1384 3004</strong>
                    </p>
                </div>
            </div>

            <div class="hero__btns">
                <a
                    href="https://wa.me/525513843004"
                    class="btn-wa"
                    target="_blank"
                    rel="noopener"
                >
                    💬 Escribir por WhatsApp
                </a>
                <a
                    href="https://maps.app.goo.gl/GricGKCzpp6BXJgE7"
                    class="btn-outline-primary"
                    target="_blank"
                    rel="noopener"
                >
                    🗺️ Abrir en Google Maps
                </a>
            </div>
        </section>

    <!-- SECCIÓN 2 — MAPA INTERACTIVO Y FACHADA -->
    <section class="content-section bg-soft">
            <h2 class="titulo-sec">Nuestra clínica en San Pablo Tepetlapa</h2>

            <div class="map-grid">
                <div class="map-wrapper">
                    <iframe
                        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3764.5!2d-99.13922!3d19.322004!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x85ce010007f0a32f%3A0x9c168bcfa6aad89f!2sPunto%20Veterinario!5e0!3m2!1ses!2smx!4v1"
                        width="100%"
                        height="100%"
                        style="border:0;"
                        allowfullscreen=""
                        loading="lazy"
                        referrerpolicy="no-referrer-when-downgrade"
                        title="Mapa interactivo de la veterinaria Punto Veterinario en Coyoacán"
                        class="google-map-iframe"></iframe>
                </div>
                <div class="fachada-wrapper">
                    <img
                        src="/fachada-clinica.jpg"
                        alt="Fachada de la clínica Punto Veterinario sobre Av. División del Norte en San Pablo Tepetlapa"
                        class="fachada-img"
                        width="800"
                        height="600"
                        loading="lazy"
                        decoding="async"
                        onerror="this.src='/placeholder-fachada.webp'; this.alt='Imagen representativa de la fachada local en Coyoacán';"
                    />
                </div>
            </div>
        </section>

    <!-- SECCIÓN 3 — RUTAS DE LLEGADA (SEO HIPERLOCAL) -->
    <section class="content-section">
            <h2 class="titulo-sec">
                Indicaciones para llegar desde el sur de CDMX
            </h2>

            <div class="rutas-grid">
                <div class="ruta-card">
                    <div class="ruta-header">
                        <span class="ruta-icon" aria-hidden="true">🚗</span>
                        <h3 class="ruta-title">En auto</h3>
                    </div>
                    <p class="ruta-desc">
                        Nos encontramos sobre Av. División del Norte, una de las
                        arterias principales del sur. De muy fácil acceso si
                        vienes desde <strong>Copilco el Alto</strong>, el <strong
                            >Ajusco</strong
                        > o Coapa.
                    </p>
                </div>

                <div class="ruta-card">
                    <div class="ruta-header">
                        <span class="ruta-icon" aria-hidden="true">🚇</span>
                        <h3 class="ruta-title">En transporte público</h3>
                    </div>
                    <p class="ruta-desc">
                        Si vienes en Metro, la estación más cercana es <strong
                            >Metro Universidad</strong
                        >. Desde ahí, puedes tomar un transporte
                        (combi/microbús) que baje por Avenida División del Norte
                        y bajarte a la altura de <strong
                            >San Pablo Tepetlapa</strong
                        >.
                    </p>
                </div>

                <div class="ruta-card">
                    <div class="ruta-header">
                        <span class="ruta-icon" aria-hidden="true">🐕</span>
                        <h3 class="ruta-title">
                            Colonias vecinas a las que servimos
                        </h3>
                    </div>
                    <p class="ruta-desc">
                        Estamos a menos de 10 minutos de <strong
                            >Pedregal de Santo Domingo</strong
                        >, Los Reyes, El Caracol y la zona de hospitales.
                    </p>
                </div>
            </div>
        </section>

    <!-- SECCIÓN 4 — CTA FINAL (¿TIENES UNA URGENCIA?) -->
    <section class="content-section bg-soft">
            <h2 class="cta-titulo-urgencia">
                ¿Necesitas agendar o tienes una urgencia en horario laboral?
            </h2>
            <p class="cta-desc-urgencia">
                Si notas a tu mascota muy decaída o sufrió un accidente dentro
                de nuestros horarios de servicio, llámanos inmediatamente para
                preparar el consultorio antes de tu llegada.
            </p>

            <div class="cta-urgencia-btns">
                <a href="tel:+525513843004" class="btn-urgencia-rojo">
                    📞 Llamar ahora al 55 1384 3004
                </a>
                <a
                    href="https://wa.me/525513843004"
                    target="_blank"
                    rel="noopener"
                    class="btn-wa"
                >
                    💬 Avisar por WhatsApp
                </a>
            </div>
        </section>
</BaseLayout>

<style>
    /* ====== CLAMP SYSTEM + RESPONSIVE ====== */
    /* No Tailwind/Bootstrap allowed, 100% Fluid Vanilla CSS */

    .content-section {
        padding-block: clamp(3rem, 6vw, 12rem);
    }
    .bg-soft {
        background: var(--color-bg-soft);
    }

    .h1-hero {
        font-size: clamp(1.8rem, 3.2vw, 6rem);
        color: var(--color-text);
        line-height: 1.15;
        margin-bottom: clamp(1rem, 2vw, 3rem);
        text-align: center;
    }

    .titulo-sec {
        font-size: clamp(1.6rem, 2.8vw, 5rem);
        color: var(--color-primary-dark);
        text-align: center;
        margin-bottom: clamp(2rem, 4vw, 7rem);
        line-height: 1.2;
    }

    /* HERO & NAP */
    .hero {
        background: var(--color-bg);
    }
    .hero__inner {
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    .hero__text {
        width: 100%;
        margin-inline: auto;
        text-align: center;
    }
    @media (min-width: 48rem) {
        .hero__text {
        }
    }

    .hero__desc {
        font-size: clamp(0.95rem, 1.4vw, 2.8rem);
        color: var(--color-text-soft);
        line-height: 1.6;
        margin-bottom: clamp(2rem, 4vw, 6rem);
        margin-inline: auto;
    }

    /* NAP Grid */
    .nap-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: clamp(1.5rem, 3vw, 5rem);
        width: 100%;
        margin-bottom: clamp(2rem, 4vw, 6rem);
    }
    @media (max-width: 60rem) {
        .nap-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    @media (max-width: 40rem) {
        .nap-grid {
            grid-template-columns: 1fr;
        }
    }

    .nap-card {
        background: var(--color-bg-soft);
        border: clamp(0.05rem, 0.1vw, 0.2rem) solid var(--color-border);
        border-radius: clamp(0.5rem, 1.5vw, 2.5rem);
        padding: clamp(1.5rem, 2.5vw, 4rem);
        text-align: center;
        box-shadow: var(--shadow-sm);
        display: flex;
        flex-direction: column;
        align-items: center;
        transition:
            transform 0.2s,
            box-shadow 0.2s;
    }
    .nap-card:hover {
        transform: translateY(-0.15rem);
        box-shadow: var(--shadow-md);
    }

    .nap-icon {
        font-size: clamp(2.5rem, 4vw, 7rem);
        margin-bottom: clamp(0.8rem, 1.2vw, 2.5rem);
        display: block;
    }

    .nap-title {
        font-size: clamp(1.2rem, 1.8vw, 3.5rem);
        color: var(--color-primary-dark);
        margin-bottom: clamp(0.5rem, 1vw, 2rem);
        line-height: 1.2;
    }

    .nap-text {
        font-size: clamp(0.95rem, 1.3vw, 2.6rem);
        color: var(--color-text-soft);
        line-height: 1.6;
        margin: 0;
    }

    /* BOTONES HERO */
    .hero__btns {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: clamp(1rem, 1.5vw, 3rem);
    }

    .btn-wa {
        background: var(--color-primary);
        color: #fff;
        padding: clamp(0.6rem, 1.2vw, 2.5rem) clamp(1.2rem, 2.5vw, 5rem);
        font-size: clamp(0.9rem, 1.2vw, 2.4rem);
        border-radius: clamp(0.4rem, 1vw, 1.5rem);
        font-weight: 600;
        text-decoration: none;
        transition:
            background 0.2s,
            transform 0.2s;
        text-align: center;
    }
    .btn-wa:hover {
        background: var(--color-primary-dark);
        transform: translateY(-0.15rem);
    }

    .btn-outline-primary {
        background: transparent;
        color: var(--color-primary);
        border: clamp(0.1rem, 0.2vw, 0.4rem) solid var(--color-primary);
        padding: clamp(0.6rem, 1.2vw, 2.5rem) clamp(1.2rem, 2.5vw, 5rem);
        font-size: clamp(0.9rem, 1.2vw, 2.4rem);
        border-radius: clamp(0.4rem, 1vw, 1.5rem);
        font-weight: 600;
        text-decoration: none;
        transition:
            background 0.2s,
            transform 0.2s,
            color 0.2s;
        text-align: center;
    }
    .btn-outline-primary:hover {
        background: var(--color-primary);
        color: #fff;
        transform: translateY(-0.15rem);
    }

    /* MAPA Y FACHADA */
    .map-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: clamp(1.5rem, 3vw, 5rem);
        width: 100%;
    }
    @media (max-width: 48rem) {
        .map-grid {
            grid-template-columns: 1fr;
        }
    }

    .map-wrapper {
        width: 100%;
        /* Altura fluida que escala con el viewport, dando espacio en móvil y desktop */
        height: clamp(25rem, 40vw, 55rem);
        border-radius: clamp(0.5rem, 1.5vw, 2.5rem);
        overflow: hidden;
        box-shadow: var(--shadow-md);
        border: clamp(0.05rem, 0.1vw, 0.2rem) solid var(--color-border);
    }
    .google-map-iframe {
        width: 100%;
        height: 100%;
        display: block;
        border: 0;
    }

    .fachada-wrapper {
        width: 100%;
        height: clamp(25rem, 40vw, 55rem);
        border-radius: clamp(0.5rem, 1.5vw, 2.5rem);
        overflow: hidden;
        box-shadow: var(--shadow-md);
        border: clamp(0.05rem, 0.1vw, 0.2rem) solid var(--color-border);
    }
    .fachada-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        display: block;
        transition: transform 0.5s ease;
    }
    .fachada-wrapper:hover .fachada-img {
        transform: scale(1.05); /* Ligerísimo zoom in per eye candy */
    }

    /* RUTAS DE LLEGADA GRID */
    .rutas-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: clamp(1.5rem, 3vw, 5rem);
        width: 100%;
    }
    @media (max-width: 60rem) {
        .rutas-grid {
            grid-template-columns: 1fr;
        }
    }

    .ruta-card {
        background: var(--color-bg);
        border-left: clamp(0.3rem, 0.5vw, 0.8rem) solid var(--color-primary);
        border-radius: clamp(0.4rem, 1vw, 1.5rem);
        padding: clamp(1.5rem, 2vw, 4rem);
        box-shadow: var(--shadow-sm);
        transition:
            transform 0.2s,
            box-shadow 0.2s;
    }
    .ruta-card:hover {
        transform: translateY(-0.15rem);
        box-shadow: var(--shadow-md);
    }

    .ruta-header {
        display: flex;
        align-items: center;
        gap: clamp(0.8rem, 1.2vw, 2.5rem);
        margin-bottom: clamp(1rem, 1.5vw, 3rem);
    }
    .ruta-icon {
        font-size: clamp(1.8rem, 2.5vw, 5rem);
    }
    .ruta-title {
        font-size: clamp(1.2rem, 1.8vw, 3.5rem);
        color: var(--color-primary-dark);
        margin: 0;
        line-height: 1.2;
    }

    .ruta-desc {
        font-size: clamp(0.95rem, 1.3vw, 2.6rem);
        color: var(--color-text-soft);
        line-height: 1.6;
        margin: 0;
    }
    .ruta-desc strong {
        color: var(--color-text); /* Destaca las colonias */
    }

    /* CTA FINAL (URGENCIA) */
    .cta-urgencia-inner {
        text-align: center;
        max-width: clamp(20rem, 80vw, 850px);
        margin: 0 auto;
    }

    .cta-titulo-urgencia {
        font-size: clamp(1.8rem, 2.8vw, 5.5rem);
        color: var(--color-primary-dark);
        margin-bottom: clamp(1rem, 1.5vw, 3rem);
        line-height: 1.2;
    }

    .cta-desc-urgencia {
        font-size: clamp(1rem, 1.4vw, 2.8rem);
        color: var(--color-text-soft);
        line-height: 1.6;
        margin-bottom: clamp(2rem, 4vw, 6rem);
    }

    .cta-urgencia-btns {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: clamp(1rem, 1.5vw, 3rem);
    }

    /* Rojo Alerta para llamada de urgencia */
    .btn-urgencia-rojo {
        background: #e63946; /* Rojo Urgencia clásico web */
        color: #fff;
        padding: clamp(0.6rem, 1.2vw, 2.5rem) clamp(1.2rem, 2.5vw, 5rem);
        font-size: clamp(0.9rem, 1.2vw, 2.4rem);
        border-radius: clamp(0.4rem, 1vw, 1.5rem);
        font-weight: 600;
        text-decoration: none;
        transition:
            background 0.2s,
            transform 0.2s;
        text-align: center;
    }
    .btn-urgencia-rojo:hover {
        background: #c1121f; /* Rojo oscuro hover */
        transform: translateY(-0.15rem);
        box-shadow: 0 clamp(0.4rem, 0.8vw, 1.5rem) clamp(1rem, 2vw, 3.5rem)
            rgba(230, 57, 70, 0.25);
    }
</style>
