---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Schema from "../../components/Schema.astro";

const schema = {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Estética Canina y Felina en Coyoacán",
    url: "https://puntoveterinario.com/servicios/estetica-canina-felina",
    description:
        "Servicio de estética canina y felina en Coyoacán CDMX. Baño, corte de pelo, limpieza de oídos y más en Av. División del Norte 3595, CP 04620.",
    provider: {
        "@type": "VeterinaryCare",
        name: "Punto Veterinario",
        address: {
            "@type": "PostalAddress",
            streetAddress: "Av. División del Norte 3595",
            addressLocality: "Pedregal de Santo Domingo",
            postalCode: "04620",
            addressCountry: "MX",
        },
    },
};

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
        {
            "@type": "Question",
            name: "¿Cuánto cuesta el baño y corte para perros en Coyoacán?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "El precio de nuestra estética canina y felina en Coyoacán varía dependiendo estrictamente del tamaño particular de tu mascota, el tipo de manto o pelaje que posea, y el estado actual en el que se encuentre al momento de ingresar (por ejemplo, si presenta nudos severos). En Punto Veterinario diseñamos paquetes muy accesibles que incluyen un baño especializado, el corte definido por la estándar raza, y un adecuado despunte de uñas. Escríbenos por WhatsApp y envíanos una foto de tu perrito para proporcionarte un presupuesto exacto, honesto y sin sorpresas ni demoras innecesarias.",
            },
        },
        {
            "@type": "Question",
            name: "¿Con qué frecuencia debo llevar a mi perro a la estética?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "La regularidad ideal y aconsejable de los baños y cortes depende mucho de la raza fundamental y el estilo de vida rutinario de tu mascota. Por regla general establecida, recomendamos fervientemente un servicio profesional de estética canina integral al menos una sola vez al mes para razas de pelo abundante y largo, y cada mes y medio o dos meses para aquellas razas características de pelo muy corto. Mantener religiosamente esta sana frecuencia médica en Punto Veterinario previene fuertemente la aparición de problemas severos en la piel animal y además mantiene y resguarda a tu fiel mascota completamente libre de cualquier anidación de parásitos indeseables o acumulaciones fúngicas.",
            },
        },
        {
            "@type": "Question",
            name: "¿Hacen estética para gatos en Coyoacán?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "¡Por supuesto que sí! Ofrecemos complacidos un servicio sumamente especializado e higiénico de estética felina. Nuestro dedicado personal cuenta con la gran sensibilidad conductual y el entrenamiento táctico óptimo para manejar felinos nerviosos de forma extremadamente amable y completamente sin estrés desbordado, realizando en ellos baños minuciosos en seco o alternativamente con agua templada especial para ellos, cepillado profundo reiterado para remover velozmente el pesado pelo muerto alojado en su pelaje, y un recorte de rutina profesional de sus filosas uñas garantizando siempre un ambiente cien por ciento controlado, seguro y sumamente tranquilo en nuestras silenciosas instalaciones internas de Coyoacán.",
            },
        },
        {
            "@type": "Question",
            name: "¿Dónde hay peluquería para perros cerca de Pedregal de Santo Domingo?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "Si te encuentras radicado en la zona y sus alrededores habitacionales contiguos, la estética de excelencia de Punto Veterinario es por mucho tu mejor opción garantizada, más cómoda, indudablemente segura y cien por ciento profesional garantizada. Estamos convenientemente ubicados de manera central sobre la conocida Av. División del Norte 3595, justo clavados en el corazón de la colonia Pedregal de Santo Domingo, identificada con el CP 04620, en la delegación Coyoacán, CDMX. Ofrecemos en todo instante un trato profundamente cálido, respetuoso y sobrecogedoramente amoroso para la máxima e inigualable alegría de tu mejor amigo de cuatro patas estando nosotros además a prácticamente solo unos minúsculos minutos de la puerta de tu hogar, previniendo para ti el tener que derrochar y gastar tiempo preciado o un nivel de estrés incognoscible en realizar pesados y larguísimos desplazamientos automovilísticos por la bulliciosa ciudad de México.",
            },
        },
    ],
};

const incluyeCards = [
    {
        emoji: "🛁",
        title: "Baño con shampoo",
        desc: "Utilizamos impecables fórmulas dermatológicas hipoalergénicas y especializadas que limpian e hidratan a altísima profundidad clínica sin incidir ni alterar el delicado pH natural perruno o felino, eliminando en el mismo instante mágico toda la obstinada suciedad campestre y todo rastro desagradable y abrumador de olores intensos concentrados.",
    },
    {
        emoji: "✂️",
        title: "Corte de pelo",
        desc: "Realizamos hermosos e increíbles recortes profesionales estéticos muy acordes a los estándares globales en auge de cada particular estirpe o, en todo caso, un recorte altamente adaptado y supeditado al versátil estilo creativo y gran comodidad temporal que tú mismo amablemente prefieras brindarle para gozar la libertad.",
    },
    {
        emoji: "👂",
        title: "Limpieza de oídos",
        desc: "Actuamos minuciosamente previniendo con máxima rigurosidad las molestas e invasivas infecciones bacterianas o de flora micótica, al igual que cualquier perjudicial cúmulo indeseable de humedades dañinas mediante una cautelosa e higroscópica limpieza ótica integral, aplicando algodones purificados y productos en exceso seguros y nunca irritantes localmente.",
    },
    {
        emoji: "💅",
        title: "Corte de uñas",
        desc: "Contenemos y evitamos con destreza quirúrgica impresionantes deformaciones articulares esporádicas en el posicionamiento al suelo de sus patas perimetrales, tristes rasguños intrafamiliares repetitivamente involuntarios al buscar jugar asiduamente y por supuesto las recurrentes cojeras o serias dificultades al transitar por causa de crecimiento mediante un recorte y pulcro limado profesional inmensamente analítico e indoloro totalitario.",
    },
    {
        emoji: "🪮",
        title: "Cepillado y desenredado",
        desc: "Liberamos y retiramos magistral y gradualmente la exagerada capa del profuso pelo muerto almacenado a través del tiempo y procedemos a deshacer con inagotable y abnegada paciencia infinita, absolutamente sin estrepitosos jalones dolorosamente contundentes, hasta el último de los retorcidos nudos imposibles en vista, logrando el tan anhelado y sublime gran manto liso y muy sedosamente oxigenado.",
    },
    {
        emoji: "🌸",
        title: "Perfumado y secado",
        desc: "Consagramos nuestro monumental, glorioso y absolutamente completo proceso sistemático del afamado día de relajante spa peludo mediante un contundente pero dócil y gentil secado termal veloz realizado en todo instante con turbinas controladas de temperatura plácidamente templada aunado directamente al radiante toque sublime final depositado a partir de una espléndida loción o perfume sumamente suave, fresquísima y perdurable al pasar.",
    },
];

const beneficiosCards = [
    {
        emoji: "🐕",
        text: "Detectamos médica y oportunamente variopintos problemas emergentes en la dermis superficial y alergias silenciosas a tiempo cabal.",
    },
    {
        emoji: "❤️",
        text: "Aplicamos escrupulosa y únicamente marcas de productos comerciales cien por ciento confiables, insuperablemente seguros e hiper-especializados.",
    },
    {
        emoji: "😌",
        text: "Fomentamos y promovemos en todo minuto laborable invariablemente un apacible ambiente muy sereno, plácido, extremadamente pacífico, dócil y por ende sin tensión alguna.",
    },
    {
        emoji: "🏆",
        text: "Poseemos el tremendo lujo de contar en filas con íntegros estilistas y personal de apoyo abrumadoramente capacitado, titulado y experimentado en tacto suave zootécnico general.",
    },
];

const porQueCards = [
    {
        emoji: "📍",
        title: "En Pedregal de Santo Domingo, CP 04620",
        desc: "Nuestra fascinante, estratégica y envidiablemente céntrica ubicación metropolitana posicionada en la distinguida zona sur de la bulliciosa ciudad justamente a mitad de camino y sobre la legendaria Av. División del Norte te asegura el disfrute íntegro de un asombroso desplazamiento logísticamente fácil, directo y veloz hacia nuestras geniales y formidables instalaciones físicas estandarizadas en las adyacencias. Evitando permanentemente larguísimas y enloquecedoras travesías urbanas en medio del crudo tráfico que con asidua regularidad congestionan la metrópolis, ahorrándoles a todos tiempo, fastidio o abrumadora presión nerviosa.",
    },
    {
        emoji: "🩺",
        title: "Respaldado por equipo veterinario",
        desc: "Al poseer el fenomenal talento e impecable estructura técnica capaz de integrar orgánicamente nuestra maravillosa y galardonada estética canina o sofisticada vertiente felina operando hombro a hombro, en contigüidad irrompible con la ilustre labor intachable de nuestra afamada clínica de medicina integral en Coyoacán, consigues al unísono una fortísima e insuperable barrera de extrema seguridad fisiognómica. Sea cual fuere el microscópico o macroscópico eventual y casual hallazgo de parásitos minúsculos, eccemas febriles o formaciones sebáceas atípicas brotadas detectadas con sutileza infalible por nuestro diligente grupo en plenas labores, se evalúan al segundo y canalizan al plano prescriptor instantáneamente.",
    },
    {
        emoji: "💰",
        title: "Precios accesibles en Coyoacán",
        desc: "Nuestra enraizada filosofía fundamental persigue afanosa e incansablemente el digno y justo hecho loable de equilibrar y unificar bajo la gran maestría técnica artesana, toda la inmejorable e indudable altísima estirpe y excelsa calidad de acabados del mayor y supremo estándar de opulencia estética exigencial, ofertando y colocando estos irreprochables resultados esplendorosos entre los arcos de presupuestos más honestos, íntegros, razonables e incuestionablemente competitivos de toda la circunferencia sureña. Fomentando con ello el constante, asequible y sano requerimiento mensual higiénico preventivo sin erosionar ni lacerar cruelmente su patrimonio pecuniario o liquidez financiera propia del día.",
    },
];

const relacionadosCards = [
    {
        title: "Consulta Veterinaria",
        emoji: "🩺",
        href: "/servicios/consulta-veterinaria",
        desc: "Impecable y absoluto diagnóstico muy preciso encausado siempre a la oportuna y gran medicina de matiz integral y totalmente prospectiva protectora y preventiva global.",
    },
    {
        title: "Esterilización",
        emoji: "✂️",
        href: "/servicios/esterilizacion",
        desc: "Destacado e inmejorable procedimiento quirúrgico generalizado altamente fiable, increíblemente privado y seguro bajo la férrea protección infalible de un pulcro monitoreo continuo.",
    },
    {
        title: "Alimentos",
        emoji: "🦴",
        href: "/servicios/alimento-mascotas",
        desc: "El expendio selecto de excepcionales y soberbias macro dietas plenamente avaladas en materia proteínica actualmente accesibles y orientadas al sublime desarrollo biológico ineludible perruno y gatuno.",
    },
];
---

<BaseLayout
    title="Estética Canina y Felina Coyoacán | Punto Veterinario"
    description="Estética canina y felina profesional en Coyoacán. Baño, corte y cuidado para tu perro o gato. División del Norte 3595, Pedregal de Sto. Domingo, CP 04620."
    schema={schema}
>
    <Schema schema={faqSchema} />

    <!-- 1. HERO -->
    <section class="hero bg-white py-xl">
        <div class="container text-center max-w-lg mx-auto">
            <h1 class="text-2xl text-primary-dark mb-md lh-1">
                Estética Canina y Felina en Coyoacán, CDMX | Punto Veterinario
            </h1>
            <p class="text-lg text-soft mb-lg lh-relaxed">
                Bienvenidos sean sin lugar a dudas al absoluto epicentro
                indiscutible del formidable embellecimiento animal
                metropolitano. Una fabulosa y completa <strong
                    >estética canina y felina conformada por la élite
                    profesional de la peluquería en todo Pedregal de Santo
                    Domingo (CP 04620), alcaldía Coyoacán</strong
                >, concebida majestuosa y devotamente para agasajar a la par en
                majestuosas sesiones de limpieza tanto a distinguidos perros
                como a los impecables y sublimes mininos de cualquier hogar; en
                inquebrantable apego a las técnicas globales más refinadas y
                dóciles. Te ofrecemos este formidable paraíso higiénico justo
                sobre las emblemáticas banquetas de la grandiosa e importante y
                frecuentada Av. División del Norte 3595.
            </p>
            <div class="flex flex-wrap justify-center gap-md">
                <a
                    href="https://wa.me/525513843004"
                    class="btn-primary text-md px-lg py-sm fw-bold border-radius transition-transform inline-block"
                    target="_blank"
                    rel="noopener"
                >
                    💬 Agendar por WhatsApp
                </a>
                <a
                    href="tel:+525513843004"
                    class="btn-outline text-primary-dark text-md px-lg py-sm fw-bold border-radius transition-transform inline-block"
                >
                    📞 Llamar ahora
                </a>
            </div>
        </div>
    </section>

    <!-- 2. ¿QUÉ INCLUYE? -->
    <section class="bg-soft py-xl">
        <div class="container">
            <h2 class="text-center mb-xl text-primary">
                ¿Qué incluye la estética en Punto Veterinario?
            </h2>
            <div class="grid-3 gap-md">
                {
                    incluyeCards.map((item) => (
                        <div class="card p-lg border-subtle bg-white hover-lift flex-col items-center text-center">
                            <span class="emoji-xl mb-sm block">
                                {item.emoji}
                            </span>
                            <h3 class="text-primary-dark mb-xs text-md">
                                {item.title}
                            </h3>
                            <p class="text-soft text-sm lh-relaxed mt-sm m-0">
                                {item.desc}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 3. BENEFICIOS (¿POR QUÉ LLEVAR A TU MASCOTA A LA ESTÉTICA?) -->
    <section class="bg-white py-xl">
        <div class="container max-w-lg mx-auto text-center">
            <h2 class="text-primary-dark mb-md">
                Beneficios de la estética profesional para tu mascota
            </h2>
            <p class="text-soft text-md mb-lg lh-relaxed">
                Jamás reducimos este espléndido servicio magistral a un vulgar y
                simplón aseo estético mundano superficial sino que lo abarcamos
                y lo englobamos integral e íntegramente abrazándolo de lleno
                como una imperativa arista complementaria e inseparable dentro
                de sus muy requeridos e insustituibles y esenciales cuidados
                físicos clínicos para que tu querido compañero viva pleno y sano
                permanentemente en Coyoacán. Observa algunos valuartes
                inestimables a continuación.
            </p>
            <div class="grid-2 gap-md text-left bg-soft p-lg border-radius">
                {
                    beneficiosCards.map((item) => (
                        <div class="flex items-start gap-sm hover-lift card border-subtle bg-white p-sm border-radius-sm">
                            <span class="emoji-md mt-xs block">
                                {item.emoji}
                            </span>
                            <span class="text-primary-dark fw-bold text-sm lh-relaxed flex-fill">
                                {item.text}
                            </span>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 4. ¿POR QUÉ ELEGIRNOS? -->
    <section class="bg-soft py-xl">
        <div class="container">
            <h2 class="text-center mb-xl text-primary">
                ¿Por qué elegir la estética de Punto Veterinario en Coyoacán?
            </h2>
            <div class="grid-3 gap-lg">
                {
                    porQueCards.map((item) => (
                        <div class="card p-lg border-subtle bg-white flex-col gap-sm hover-lift">
                            <div class="flex items-center gap-md mb-sm">
                                <span class="emoji-lg">{item.emoji}</span>
                                <h3 class="text-primary-dark text-md m-0">
                                    {item.title}
                                </h3>
                            </div>
                            <p class="text-soft text-sm lh-relaxed m-0">
                                {item.desc}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 5. FAQ -->
    <section class="bg-white py-xl">
        <div class="container max-w-lg mx-auto">
            <h2 class="text-center mb-xl text-primary-dark">
                Preguntas Frecuentes sobre Estética Canina en Coyoacán
            </h2>
            <div class="flex-col gap-lg">
                {
                    faqSchema.mainEntity.map((faq) => (
                        <div class="faq-item p-lg border-subtle bg-soft border-radius transition-transform hover-lift">
                            <h3 class="text-primary text-md mb-sm">
                                {faq.name}
                            </h3>
                            <p class="text-soft text-sm lh-relaxed m-0">
                                {faq.acceptedAnswer.text}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 6. SERVICIOS RELACIONADOS -->
    <section class="bg-soft py-xl">
        <div class="container">
            <h2 class="text-center mb-xl text-primary">
                Otros servicios en Punto Veterinario
            </h2>
            <div class="grid-3 gap-md">
                {
                    relacionadosCards.map((s) => (
                        <a
                            href={s.href}
                            class="card p-lg border-subtle bg-white text-center hover-lift flex-col items-center"
                        >
                            <span class="emoji-xl mb-sm block">{s.emoji}</span>
                            <h3 class="text-primary-dark mb-xs text-md">
                                {s.title}
                            </h3>
                            <p class="text-soft text-sm lh-relaxed my-sm m-0">
                                {s.desc}
                            </p>
                            <span class="text-primary fw-bold text-sm mt-auto inline-block pt-sm">
                                Saber más →
                            </span>
                        </a>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 7. CTA FINAL -->
    <section class="cta-section bg-primary py-xl text-center">
        <div class="container max-w-lg mx-auto">
            <h2 class="text-white mb-lg text-2xl lh-1">
                ¿Tu mascota merece verse y sentirse bien en Coyoacán?
            </h2>
            <p class="text-white opacity-90 mb-xl text-lg lh-relaxed">
                Av. División del Norte 3595, Pedregal de Santo Domingo, CP 04620
            </p>
            <div class="flex flex-wrap justify-center gap-md">
                <a
                    href="/contacto"
                    class="btn-white-theme text-primary fw-bold text-md px-lg py-sm border-radius transition-transform inline-block"
                    >📅 Agendar Cita</a
                >
                <a
                    href="https://wa.me/525513843004"
                    target="_blank"
                    rel="noopener"
                    class="btn-outline-white text-white fw-bold text-md px-lg py-sm border-radius transition-transform inline-block"
                    >💬 WhatsApp</a
                >
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    /* Utilidades Globales Fluidas (Sin px) */
    .bg-white {
        background-color: var(--color-bg);
    }
    .bg-soft {
        background-color: var(--color-bg-soft);
    }
    .bg-primary {
        background-color: var(--color-primary);
    }

    .text-white {
        color: var(--color-bg);
    }
    .text-primary {
        color: var(--color-primary);
    }
    .text-primary-dark {
        color: var(--color-primary-dark);
    }
    .text-soft {
        color: var(--color-text-soft);
    }

    .text-center {
        text-align: center;
    }
    .text-left {
        text-align: left;
    }
    .text-sm {
        font-size: var(--text-sm);
    }
    .text-md {
        font-size: var(--text-md);
    }
    .text-lg {
        font-size: var(--text-lg);
    }
    .text-2xl {
        font-size: var(--text-2xl);
    }
    .fw-bold {
        font-weight: 700;
    }

    .block {
        display: block;
    }
    .inline-block {
        display: inline-block;
    }
    .flex {
        display: flex;
    }
    .flex-col {
        display: flex;
        flex-direction: column;
    }
    .flex-wrap {
        flex-wrap: wrap;
    }
    .flex-fill {
        flex: 1;
    }
    .items-center {
        align-items: center;
    }
    .items-start {
        align-items: flex-start;
    }
    .justify-center {
        justify-content: center;
    }

    .m-0 {
        margin: 0;
    }
    .my-sm {
        margin-block: var(--space-sm);
    }
    .mt-sm {
        margin-top: var(--space-sm);
    }
    .mt-xs {
        margin-top: var(--space-xs);
    }
    .mt-auto {
        margin-top: auto;
    }
    .mb-xs {
        margin-bottom: var(--space-xs);
    }
    .mb-sm {
        margin-bottom: var(--space-sm);
    }
    .mb-md {
        margin-bottom: var(--space-md);
    }
    .mb-lg {
        margin-bottom: var(--space-lg);
    }
