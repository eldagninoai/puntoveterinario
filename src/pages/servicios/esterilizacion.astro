---
import BaseLayout from "../../layouts/BaseLayout.astro";

const schema = {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Esterilización y Castración Veterinaria",
    provider: {
        "@type": "VeterinaryCare",
        name: "Punto Veterinario",
        image: "https://puntoveterinario.com/og-image.jpg",
        address: {
            "@type": "PostalAddress",
            streetAddress: "Av. División del Norte 3595",
            addressLocality: "Coyoacán",
            addressRegion: "CDMX",
            postalCode: "04620",
            addressCountry: "MX",
        },
    },
    areaServed: {
        "@type": "AdministrativeArea",
        name: "Coyoacán",
    },
    description:
        "Cirugía de esterilización (ovariohisterectomía) para hembras y castración (orquiectomía) para machos en CDMX. Prevención de piometra, tumores y cuidado integral.",
};

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
        {
            "@type": "Question",
            name: "¿Cuánto cuesta esterilizar a un perro o gato en Coyoacán?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "El costo de la esterilización depende del peso, especie y sexo de tu mascota. En Punto Veterinario, nuestras cirugías incluyen estudios prequirúrgicos para garantizar su seguridad. Escríbenos por WhatsApp al 55 1384 3004 para darte un presupuesto exacto.",
            },
        },
        {
            "@type": "Question",
            name: "¿A qué edad se recomienda esterilizar a mi mascota?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "Recomendamos esterilizar a hembras y machos antes de su primer celo o etapa reproductiva (generalmente entre los 4 y 6 meses de edad). Esto reduce drásticamente el riesgo de desarrollar cáncer mamario o prostático en el futuro.",
            },
        },
        {
            "@type": "Question",
            name: "¿Mi gata o perra necesita tener una camada antes de esterilizarse?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "No, esto es un mito. No existe ningún beneficio médico ni emocional en permitir que tengan una camada. Al contrario, cada celo que pasan sin reproducirse aumenta su riesgo de desarrollar piometra (infección uterina grave) y tumores.",
            },
        },
    ],
};

const faqs = faqSchema.mainEntity;

const datosCards = [
    {
        emoji: "📉",
        dato: "De 25% a 0.05%",
        desc: "Esterilizar a una hembra antes de su primer celo reduce el riesgo de cáncer de glándula mamaria a casi cero.",
    },
    {
        emoji: "🚨",
        dato: "80% de riesgo de Piometra",
        desc: "Las perras no esterilizadas tienen una altísima probabilidad de desarrollar esta infección uterina mortal que requiere cirugía de emergencia.",
    },
    {
        emoji: "🐈",
        dato: "7 veces más riesgo en gatas",
        desc: "Las gatas sin esterilizar son sumamente propensas a tumores mamarios, de los cuales más del 80% suelen ser malignos.",
    },
    {
        emoji: "🐕",
        dato: "95% en machos senior",
        desc: "Casi todos los perros machos no castrados (orquiectomía) desarrollan problemas de próstata a partir de los 9 años.",
    },
];

const mitos = [
    {
        mito: "Hay que dejarla tener una camada antes de operarla para que no se deprima.",
        realidad:
            "Completamente falso. Las mascotas no tienen el deseo psicológico de ser madres. No existe ningún beneficio médico en esperar; de hecho, cada celo aumenta dramáticamente el riesgo de cáncer y piometra.",
    },
    {
        mito: "La cirugía los hace flojos, tristes y gordos.",
        realidad:
            "Parcialmente incorrecto. La esterilización disminuye su metabolismo basal porque ya no gastan energía en buscar pareja, pero no cambia su personalidad. El aumento de peso se controla fácilmente ajustando su porción de alimento y manteniendo sus paseos diarios.",
    },
];

const protocoloPasos = [
    {
        emoji: "🩸",
        title: "Estudios Prequirúrgicos Obligatorios",
        desc: "Antes de la anestesia, realizamos análisis de sangre para verificar que sus riñones e hígado funcionen perfectamente y pueda procesar los medicamentos sin riesgo.",
    },
    {
        emoji: "🏥",
        title: "Quirófano Equipado",
        desc: "Contamos con monitoreo anestésico constante durante toda la ovariohisterectomía (hembras) o castración (machos).",
    },
    {
        emoji: "💊",
        title: "Protocolo del Dolor y Recuperación",
        desc: "Tu mascota se va a casa el mismo día, caminando, con una receta clara de analgésicos y antibióticos para que su recuperación sea rápida y sin dolor.",
    },
];

const relacionadosCards = [
    {
        title: "Consulta Médica",
        emoji: "🩺",
        href: "/servicios/consulta-veterinaria",
        desc: "Chequeos generales y medicina preventiva.",
    },
    {
        title: "Laboratorio Clínico",
        emoji: "🔬",
        href: "/servicios/laboratorio-clinico",
        desc: "Estudios prequirúrgicos y perfiles completos.",
    },
    {
        title: "Estética Canina",
        emoji: "🛁",
        href: "/servicios/estetica-canina",
        desc: "Grooming profesional exclusivo para perros.",
    },
];
---

<BaseLayout
    title="Esterilización de Perros y Gatos en Coyoacán | Punto Veterinario"
    description="Cirugía de esterilización y castración segura en Coyoacán, sur de CDMX. Previene tumores y piometra. Incluye valoración prequirúrgica. ¡Agenda por WhatsApp!"
    canonical="https://puntoveterinario.com/servicios/esterilizacion"
>
    <Fragment slot="head">
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
        <script
            type="application/ld+json"
            set:html={JSON.stringify(faqSchema)}
        />
    </Fragment>

    <!-- SECCIÓN 1 — HERO -->
    <section class="hero content-section">
            <div class="hero__text">
                <h1 class="h1-hero">
                    Esterilización y Castración de Perros y Gatos en Coyoacán
                </h1>
                <p class="hero__desc">
                    Una decisión preventiva que puede salvarle la vida.
                    Realizamos cirugías seguras con estudios prequirúrgicos y
                    monitoreo anestésico en San Pablo Tepetlapa, CDMX. Protege a
                    tu mascota contra tumores, infecciones y problemas de
                    comportamiento.
                </p>
                <div class="hero__btns">
                    <a
                        href="https://wa.me/525513843004"
                        class="btn-wa"
                        target="_blank"
                        rel="noopener"
                    >
                        💬 Cotizar cirugía por WhatsApp
                    </a>
                    <a href="#protocolo" class="btn-sec">
                        Conoce el proceso seguro →
                    </a>
                </div>
            </div>
        </section>

    <!-- SECCIÓN 2 — DATOS MÉDICOS (E-E-A-T) -->
    <section class="content-section bg-soft">
            <h2 class="titulo-sec">
                ¿Por qué la esterilización es el mejor acto de amor?
            </h2>
            <p class="text-center text-soft intro-desc">
                Esterilizar a tu mascota no solo evita camadas no deseadas; es
                la intervención médica preventiva más importante para extender
                su esperanza de vida y evitar problemas como el cáncer de
                glándula mamaria o piometra.
            </p>
            <div class="grid-datos-medicos">
                {
                    datosCards.map((item) => (
                        <div class="card card-dato">
                            <span class="dato-emoji">{item.emoji}</span>
                            <div class="dato-content">
                                <h3 class="dato-numero">{item.dato}</h3>
                                <p class="card-desc">{item.desc}</p>
                            </div>
                        </div>
                    ))
                }
            </div>
        </section>

    <!-- SECCIÓN 3 — MITO VS REALIDAD -->
    <section class="content-section">
            <h2 class="titulo-sec">
                Mitos comunes sobre la esterilización y castración de perros
                CDMX
            </h2>
            <div class="mitos-lista">
                {
                    mitos.map((m, index) => (
                        <div class="mito-realidad-box-vertical">
                            <div class="mito-block">
                                <span class="bad-icon">❌</span>
                                <p>
                                    <strong>Mito {index + 1}:</strong> "{m.mito}
                                    "
                                </p>
                            </div>
                            <div class="realidad-block">
                                <span class="good-icon">✅</span>
                                <p>
                                    <strong>Realidad:</strong> {m.realidad}
                                </p>
                            </div>
                        </div>
                    ))
                }
            </div>
        </section>

    <!-- SECCIÓN 4 — EL PROTOCOLO SEGURO -->
    <section id="protocolo" class="content-section bg-soft">
            <h2 class="titulo-sec">
                ¿Por qué elegir Punto Veterinario para la cirugía de tu mascota?
            </h2>

            <blockquote class="valor-quote text-center">
                "En CDMX existen campañas de esterilización gratuita, pero
                muchas operan sin conocer el estado interno de la mascota. En
                Punto Veterinario no tomamos riesgos con la vida de tu mejor
                amigo. Nuestro protocolo quirúrgico es estricto y seguro."
            </blockquote>

            <div class="timeline-protocolo mt-fluid">
                {
                    protocoloPasos.map((paso, index) => (
                        <div class="timeline-item">
                            <div class="timeline-marker protocol-marker">
                                {paso.emoji}
                            </div>
                            <div class="timeline-content card card-protocolo">
                                <span class="paso-num">Paso {index + 1}</span>
                                <h3 class="timeline-titulo">{paso.title}</h3>
                                <p class="card-desc">{paso.desc}</p>
                            </div>
                        </div>
                    ))
                }
            </div>
        </section>

    <!-- SECCIÓN 5 — FAQ (PREGUNTAS FRECUENTES) -->
    <section class="content-section">
            <h2 class="titulo-sec">
                Preguntas frecuentes sobre la esterilización en Coyoacán
            </h2>
            <div class="faq-accordion">
                {
                    faqs.map((faq) => (
                        <details class="faq-item">
                            <summary class="faq-question">{faq.name}</summary>
                            <p class="faq-answer">{faq.acceptedAnswer.text}</p>
                        </details>
                    ))
                }
            </div>
        </section>

    <!-- SECCIÓN 6 — OTROS SERVICIOS RELACIONADOS -->
    <section class="content-section bg-soft">
            <h2 class="titulo-sec">Cuidado integral en San Pablo Tepetlapa</h2>
            <div class="grid-relacionados">
                {
                    relacionadosCards.map((s) => (
                        <a href={s.href} class="card card-servicio">
                            <span class="card-emoji">{s.emoji}</span>
                            <h3 class="card-titulo">{s.title}</h3>
                            <p class="card-desc">{s.desc}</p>
                            <span class="card-ver">Ver detalles →</span>
                        </a>
                    ))
                }
            </div>
        </section>

    <!-- SECCIÓN 7 — CTA FINAL Y CONTACTO LOCAL -->
    <section class="cta-final content-section">
            <h2 class="cta-titulo-blanc">
                ¿Listo para agendar la esterilización de tu mascota?
            </h2>
            <p class="cta-desc-blanc">
                El costo de prevenir hoy es mucho menor al de tratar una
                urgencia médica mañana. Contáctanos para cotizar la cirugía de
                tu perro o gato. Estamos en Av. División del Norte 3595, a
                minutos del Pedregal de Santo Domingo y Copilco.
            </p>
            <div class="cta-btns">
                <a
                    href="https://wa.me/525513843004"
                    target="_blank"
                    rel="noopener"
                    class="btn-cta-blanco"
                >
                    💬 Cotizar por WhatsApp
                </a>
                <a href="tel:+525513843004" class="btn-cta-outline">
                    📞 Llamar al 55 1384 3004
                </a>
            </div>
        </section>
</BaseLayout>

<style>
    /* ====== CLAMP SYSTEM + RESPONSIVE ====== */

    .content-section {
        padding-block: clamp(3rem, 6vw, 12rem);
    }
    .bg-soft {
        background: var(--color-bg-soft);
    }

    .h1-hero {
        font-size: clamp(1.8rem, 3.2vw, 6rem);
        color: var(--color-text);
        line-height: 1.15;
        margin-bottom: clamp(1rem, 2vw, 3rem);
    }

    .titulo-sec {
        font-size: clamp(1.6rem, 2.8vw, 5rem);
        color: var(--color-primary);
        text-align: center;
        margin-bottom: clamp(2rem, 4vw, 7rem);
        line-height: 1.2;
    }

    .text-center {
        text-align: center;
    }

    .mt-fluid {
        margin-top: clamp(2rem, 4vw, 7rem);
    }

    .intro-desc {
        font-size: clamp(0.95rem, 1.4vw, 2.8rem);
        
        margin-inline: auto;
        margin-bottom: clamp(2rem, 4vw, 7rem);
        line-height: 1.6;
    }

    /* HERO CLASSES */
    .hero {
        background: var(--color-bg);
    }
    .hero__inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }
    .hero__text {
        width: 100%;
        margin-inline: auto;
    }
    @media (min-width: 48rem) {
        .hero__text {
            
        }
    }

    .hero__desc {
        font-size: clamp(0.95rem, 1.4vw, 2.8rem);
        color: var(--color-text-soft);
        line-height: 1.6;
        margin-bottom: clamp(1.5rem, 2vw, 4rem);
        margin-inline: auto;
    }

    .hero__btns {
        display: flex;
        flex-wrap: wrap;
        gap: clamp(0.8rem, 1.5vw, 3rem);
        margin-bottom: clamp(1rem, 2vw, 4rem);
        justify-content: center;
    }

    .btn-wa {
        background: var(--color-primary);
        color: #fff;
        padding: clamp(0.6rem, 1.2vw, 2.5rem) clamp(1.2rem, 2.5vw, 5rem);
        font-size: clamp(0.9rem, 1.2vw, 2.4rem);
        border-radius: clamp(0.4rem, 1vw, 1.5rem);
        font-weight: 600;
        text-decoration: none;
        transition:
            background 0.2s,
            transform 0.2s;
    }
    .btn-wa:hover {
        background: var(--color-primary-dark);
        transform: translateY(-0.15rem);
    }

    .btn-sec {
        padding: clamp(0.6rem, 1.2vw, 2.5rem) clamp(1.2rem, 2.5vw, 5rem);
        font-size: clamp(0.9rem, 1.2vw, 2.4rem);
        border: clamp(0.1rem, 0.15vw, 0.3rem) solid var(--color-secondary);
        color: var(--color-secondary-dark);
        border-radius: clamp(0.4rem, 1vw, 1.5rem);
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s;
    }
    .btn-sec:hover {
        background: var(--color-secondary);
        color: #fff;
        transform: translateY(-0.15rem);
    }

    /* GRID LAYOUTS */
    .grid-datos-medicos {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: clamp(1.5rem, 3vw, 6rem);
    }
    .grid-relacionados {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: clamp(1rem, 2vw, 4rem);
    }
    @media (max-width: 60rem) {
        .grid-datos-medicos {
            grid-template-columns: 1fr;
        }
        .grid-relacionados {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    @media (max-width: 35rem) {
        .grid-relacionados {
            grid-template-columns: 1fr;
        }
    }

    /* CARDS */
    .card {
        background: var(--color-bg);
        border: clamp(0.05rem, 0.1vw, 0.2rem) solid var(--color-border);
        border-radius: clamp(0.5rem, 1.5vw, 2.5rem);
        padding: clamp(1.2rem, 2vw, 4rem);
        display: flex;
        flex-direction: column;
        text-decoration: none;
        transition:
            transform 0.3s,
            box-shadow 0.3s;
    }
    .card-servicio:hover {
        transform: translateY(-0.25rem);
        box-shadow: var(--shadow-md);
    }

    .card-dato {
        flex-direction: row;
        align-items: center;
        gap: clamp(1rem, 2vw, 4rem);
        border-left: clamp(0.3rem, 0.5vw, 1rem) solid var(--color-secondary);
        background: var(--color-bg);
    }

    @media (max-width: 48rem) {
        .card-dato {
            flex-direction: column;
            text-align: center;
        }
    }

    .dato-emoji {
        font-size: clamp(3rem, 5vw, 10rem);
        flex-shrink: 0;
    }

    .dato-numero {
        font-size: clamp(1.2rem, 1.8vw, 3.6rem);
        color: var(--color-secondary-dark);
        margin-bottom: clamp(0.5rem, 1vw, 2rem);
        line-height: 1.2;
        font-weight: 800;
    }

    .card-emoji {
        font-size: clamp(2rem, 3.5vw, 7rem);
        margin-bottom: clamp(0.8rem, 1.2vw, 2.5rem);
        display: block;
        text-align: center;
    }

    .card-titulo {
        font-size: clamp(1.1rem, 1.6vw, 3.2rem);
        color: var(--color-primary-dark);
        margin-bottom: clamp(0.5rem, 1vw, 2rem);
        line-height: 1.3;
        text-align: center;
    }
    .card-desc {
        font-size: clamp(0.95rem, 1.3vw, 2.6rem);
        color: var(--color-text-soft);
        line-height: 1.6;
        flex-grow: 1;
        margin: 0;
    }

    .card-servicio .card-desc {
        text-align: center;
    }

    .card-ver {
        font-size: clamp(0.9rem, 1.1vw, 2.2rem);
        color: var(--color-primary);
        font-weight: 700;
        margin-top: clamp(0.8rem, 1.2vw, 2.5rem);
        display: inline-block;
        text-align: center;
    }

    /* MITO VS REALIDAD (VERTICAL STACK) */
    .mitos-lista {
        display: flex;
        flex-direction: column;
        gap: clamp(1.5rem, 3vw, 6rem);
    }

    .mito-realidad-box-vertical {
        display: flex;
        flex-direction: column;
        gap: clamp(0rem, 0vw, 0rem); /* No gap, attached */
        border-radius: clamp(0.5rem, 1vw, 2rem);
        box-shadow: var(--shadow);
        overflow: hidden;
        border: clamp(0.05rem, 0.1vw, 0.2rem) solid var(--color-border);
    }

    .mito-block,
    .realidad-block {
        display: flex;
        align-items: flex-start;
        gap: clamp(0.8rem, 1.2vw, 2.5rem);
        padding: clamp(1rem, 1.5vw, 3rem);
    }
    .mito-block {
        background: var(--color-bg-soft);
        border-bottom: clamp(0.05rem, 0.1vw, 0.2rem) solid var(--color-border);
    }
    .realidad-block {
        background: var(--color-bg);
    }
    .mito-block p,
    .realidad-block p {
        font-size: clamp(0.95rem, 1.3vw, 2.6rem);
        color: var(--color-text-soft);
        margin: 0;
        line-height: 1.6;
    }
    .mito-block p strong {
        color: var(--color-urgencia);
    }
    .realidad-block p strong {
        color: #4caf50;
    }
    .bad-icon,
    .good-icon {
        font-size: clamp(1.2rem, 1.8vw, 3.5rem);
        flex-shrink: 0;
        margin-top: clamp(0.2rem, 0.4vw, 0.8rem);
    }

    /* BLOCKQUOTE */
    .valor-quote {
        background: var(--color-primary-light);
        border-radius: clamp(0.5rem, 1vw, 2rem);
        padding: clamp(1.5rem, 3vw, 6rem);
        font-size: clamp(1.1rem, 1.6vw, 3.2rem);
        color: var(--color-primary-dark);
        font-style: italic;
        font-weight: 500;
        line-height: 1.6;
        margin: 0 auto;
        position: relative;
        
    }

    /* TIMELINE PROTOCOLO */
    .timeline-protocolo {
        display: flex;
        flex-direction: column;
        gap: clamp(1.5rem, 3vw, 6rem);
        
        margin-inline: auto;
    }
    .timeline-item {
        display: flex;
        align-items: center;
        gap: clamp(1rem, 2vw, 4rem);
    }
    .protocol-marker {
        flex-shrink: 0;
        width: clamp(3rem, 5vw, 10rem);
        height: clamp(3rem, 5vw, 10rem);
        background: var(--color-bg);
        border: clamp(0.15rem, 0.2vw, 0.4rem) solid var(--color-primary);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: clamp(1.5rem, 2.5vw, 5rem);
        box-shadow: var(--shadow);
    }
    .timeline-content {
        flex-grow: 1;
        text-align: left;
    }
    .card-protocolo {
        position: relative;
    }
    .paso-num {
        font-size: clamp(0.8rem, 1vw, 2rem);
        color: var(--color-primary);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: clamp(0.05rem, 0.1vw, 0.2rem);
        margin-bottom: clamp(0.2rem, 0.5vw, 1rem);
        display: block;
    }
    .timeline-titulo {
        font-size: clamp(1.2rem, 1.8vw, 3.5rem);
        color: var(--color-primary-dark);
        margin-bottom: clamp(0.5rem, 1vw, 2rem);
        line-height: 1.2;
    }

    @media (max-width: 48rem) {
        .timeline-protocolo {
            
        }
    }

    /* FAQ ACCORDION */
    .faq-accordion {
        display: flex;
        flex-direction: column;
        gap: clamp(0.8rem, 1.2vw, 2.5rem);
    }
    .faq-item {
        background: var(--color-bg);
        border: clamp(0.05rem, 0.1vw, 0.2rem) solid var(--color-border);
        border-radius: clamp(0.5rem, 1vw, 2rem);
        padding: clamp(1rem, 1.5vw, 3rem);
    }
    .faq-item[open] .faq-question {
        color: var(--color-primary-dark);
        margin-bottom: clamp(0.8rem, 1vw, 2rem);
    }
    .faq-question {
        font-size: clamp(1rem, 1.4vw, 2.8rem);
        font-weight: 600;
        color: var(--color-text);
        cursor: pointer;
        list-style: none; /* Hide default arrow */
        position: relative;
        padding-right: clamp(2rem, 3vw, 6rem);
        line-height: 1.4;
    }
    .faq-question::-webkit-details-marker {
        display: none;
    }
    .faq-question::after {
        content: "+";
        position: absolute;
        right: 0;
        top: 0;
        font-size: clamp(1.2rem, 1.8vw, 3.5rem);
        color: var(--color-primary);
    }
    .faq-item[open] .faq-question::after {
        content: "-";
    }
    .faq-answer {
        font-size: clamp(0.95rem, 1.3vw, 2.6rem);
        color: var(--color-text-soft);
        line-height: 1.6;
        margin: 0;
