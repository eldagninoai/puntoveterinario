---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Schema from "../../components/Schema.astro";

const schema = {
    "@context": "https://schema.org",
    "@type": "MedicalProcedure",
    name: "Esterilización Veterinaria en Coyoacán",
    url: "https://puntoveterinario.com/servicios/esterilizacion",
    description:
        "Servicio de esterilización para perros y gatos en Coyoacán, CDMX. Anestesia monitoreada, seguimiento post-operatorio y atención personalizada.",
    provider: {
        "@type": "VeterinaryCare",
        name: "Punto Veterinario",
        address: {
            "@type": "PostalAddress",
            streetAddress: "Av. División del Norte 3595",
            addressLocality: "Pedregal de Santo Domingo",
            postalCode: "04620",
            addressCountry: "MX",
        },
    },
};

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
        {
            "@type": "Question",
            name: "¿Cuánto cuesta esterilizar a un perro en Coyoacán?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "El costo de la esterilización veterinaria depende principalmente de la especie (perro o gato), el sexo, el peso y la edad de la mascota. En Punto Veterinario, ubicado en Pedregal de Santo Domingo, ofrecemos valoraciones pre-quirúrgicas completas para garantizar la máxima seguridad durante el procedimiento y brindarte un presupuesto exacto y transparente diseñado específicamente para las necesidades de tu compañero.",
            },
        },
        {
            "@type": "Question",
            name: "¿A qué edad se puede esterilizar a mi mascota?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "La edad ideal puede variar entre perros y gatos, así como por el tamaño de la raza. Generalmente, recomendamos programar la esterilización a partir de los 6 meses de edad, antes de que alcancen la madurez sexual plena. Nuestro médico evaluará de manera individual a tu mascota para determinar el momento más seguro y propicio para realizar el procedimiento con éxito.",
            },
        },
        {
            "@type": "Question",
            name: "¿Cuánto tiempo dura la recuperación?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "Gracias a nuestras técnicas quirúrgicas modernas y la anestesia monitoreada, la recuperación suele ser bastante rápida. La mayoría de los perros y gatos pueden regresar a su rutina normal en un plazo de 10 a 14 días. Durante este periodo, te mantendremos en constante seguimiento post-operatorio para asegurar que las heridas sanen correctamente y evitar cualquier complicación.",
            },
        },
        {
            "@type": "Question",
            name: "¿La esterilización privada es mejor que la gratuita?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "Optar por un servicio de esterilización privada en Coyoacán brinda beneficios inigualables para la salud de tu mascota. A diferencia de las campañas gratuitas que suelen tener listas de espera interminables y atención masiva, nosotros te garantizamos una atención personalizada el mismo día, anestesia monitoreada en todo momento, y un seguimiento post-operatorio realizado por el mismo médico de confianza que ya conoce el historial de tu compañero.",
            },
        },
        {
            "@type": "Question",
            name: "¿Dónde esterilizar a mi perro cerca de Pedregal de Santo Domingo?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "Punto Veterinario es la opción más segura y confiable en la zona sur. Nos encontramos convenientemente ubicados en Av. División del Norte 3595, Pedregal de Santo Domingo, CP 04620, Coyoacán, CDMX. Contamos con un quirófano equipado y el compromiso total de cuidar a tu mascota como si fuera parte de nuestra propia familia.",
            },
        },
    ],
};

const incluyeCards = [
    {
        emoji: "🩺",
        title: "Valoración pre-quirúrgica",
        desc: "Examen físico integral detallado para asegurar que tu mascota se encuentre en óptimas condiciones de salud antes de ingresar a quirófano, minimizando riesgos.",
    },
    {
        emoji: "💉",
        title: "Anestesia monitoreada",
        desc: "Protocolos anestésicos seguros y personalizados, con monitoreo constante de sus signos vitales por parte de nuestro equipo especializado.",
    },
    {
        emoji: "✂️",
        title: "Cirugía por médico especializado",
        desc: "El procedimiento es llevado a cabo con técnicas quirúrgicas modernas y seguras en nuestro quirófano equipado para atención de tejidos blandos.",
    },
    {
        emoji: "🩹",
        title: "Seguimiento post-operatorio",
        desc: "No te dejamos solo tras la cirugía. Incluimos revisiones detalladas para cuidar la correcta cicatrización y pronta recuperación de tu compañero.",
    },
];

const privadaCards = [
    { text: "Sin lista de espera, agendamos pronto" },
    { text: "Anestesia monitoreada todo el tiempo" },
    { text: "Seguimiento post-op incluido" },
    { text: "Mismo médico que conoce a tu mascota" },
    { text: "Atención el mismo día que agendas" },
    { text: "En tu colonia — Pedregal de Santo Domingo, CP 04620" },
];

const porQueCards = [
    {
        emoji: "❤️",
        title: "Sin estrés adicional",
        desc: "Un ambiente privado y tranquilo hace que la experiencia sea mucho menos traumática en comparación con eventos masivos.",
    },
    {
        emoji: "🛡️",
        title: "Seguridad garantizada",
        desc: "Utilizamos material quirúrgico completamente esterilizado, medicamentos de alta calidad y protocolos estrictos de higiene.",
    },
    {
        emoji: "📍",
        title: "Cerca de ti",
        desc: "Para tu comodidad, estamos en Coyoacán (CP 04620), facilitando los traslados y el seguimiento rápido en caso de dudas post-operatorias.",
    },
];

const relacionadosCards = [
    {
        title: "Consulta Médica",
        emoji: "🩺",
        href: "/servicios/consulta-veterinaria",
        desc: "Diagnóstico preciso y medicina preventiva.",
    },
    {
        title: "Cirugías",
        emoji: "🏥",
        href: "/servicios/cirugia-veterinaria",
        desc: "Intervenciones quirúrgicas especializadas.",
    },
    {
        title: "Laboratorio Clínico",
        emoji: "🔬",
        href: "/servicios/laboratorio-clinico",
        desc: "Análisis clínicos para un diagnóstico exacto.",
    },
];
---

<BaseLayout
    title="Esterilización Veterinaria Coyoacán | Segura y Confiable"
    description="Esterilización privada para perros y gatos en Coyoacán. Sin filas, anestesia monitoreada y seguimiento post-op. CP 04620. Agenda hoy ☎️ 55 1384 3004"
    schema={schema}
>
    <Schema schema={faqSchema} />

    <!-- 1. HERO -->
    <section class="hero bg-white py-xl">
        <div class="container text-center max-w-lg mx-auto">
            <h1 class="text-2xl text-primary-dark mb-md lh-1">
                Esterilización Veterinaria en Coyoacán, CDMX | Punto Veterinario
            </h1>
            <p class="text-lg text-soft mb-lg lh-relaxed">
                Ofrecemos un <strong
                    >servicio de esterilización privada y confiable</strong
                > para perros y gatos en Pedregal de Santo Domingo, CP 04620. Priorizamos
                la seguridad con <strong>anestesia monitoreada</strong> y un seguimiento
                post-operatorio personalizado, sin las demoras de las campañas gratuitas
                masivas.
            </p>
            <div class="flex flex-wrap justify-center gap-md">
                <a
                    href="https://wa.me/525513843004"
                    class="btn-primary text-md px-lg py-sm fw-bold border-radius transition-transform inline-block"
                    target="_blank"
                    rel="noopener"
                >
                    💬 Agendar por WhatsApp
                </a>
                <a
                    href="tel:+525513843004"
                    class="btn-outline text-primary-dark text-md px-lg py-sm fw-bold border-radius transition-transform inline-block"
                >
                    📞 Llamar ahora
                </a>
            </div>
        </div>
    </section>

    <!-- 2. ¿QUÉ INCLUYE? -->
    <section class="bg-soft py-xl">
        <div class="container">
            <h2 class="text-center mb-xl text-primary">
                ¿Qué incluye la esterilización en Punto Veterinario?
            </h2>
            <div class="grid-4 gap-md">
                {
                    incluyeCards.map((item) => (
                        <div class="card p-lg border-subtle bg-white text-center hover-lift flex-col items-center">
                            <span class="emoji-xl mb-sm block">
                                {item.emoji}
                            </span>
                            <h3 class="text-primary-dark mb-xs text-md">
                                {item.title}
                            </h3>
                            <p class="text-soft text-sm lh-relaxed mt-sm">
                                {item.desc}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 3. PRIVADA VS GRATUITA -->
    <section class="bg-white py-xl">
        <div class="container max-w-lg mx-auto text-center">
            <h2 class="text-primary-dark mb-md">
                ¿Por qué elegir esterilización privada en Coyoacán?
            </h2>
            <p class="text-soft text-md mb-lg lh-relaxed">
                Las campañas de esterilización gratuita son un gran apoyo, pero
                suelen involucrar largas filas y atención masiva. En <strong
                    >Punto Veterinario</strong
                >, brindamos un entorno seguro y exclusivo donde la integridad
                de tu mascota es lo único que importa.
            </p>
            <div class="grid-2 gap-md text-left bg-soft p-lg border-radius">
                {
                    privadaCards.map((item) => (
                        <div class="flex items-center gap-sm">
                            <span class="emoji-md">✅</span>
                            <span class="text-primary-dark fw-bold text-sm">
                                {item.text}
                            </span>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 4. ¿POR QUÉ ELEGIRNOS? -->
    <section class="bg-soft py-xl">
        <div class="container">
            <h2 class="text-center mb-xl text-primary">
                ¿Por qué elegir Punto Veterinario en Coyoacán?
            </h2>
            <div class="grid-3 gap-lg">
                {
                    porQueCards.map((item) => (
                        <div class="card p-lg border-subtle bg-white flex-col gap-sm">
                            <div class="flex items-center gap-md mb-sm">
                                <span class="emoji-lg">{item.emoji}</span>
                                <h3 class="text-primary-dark text-md m-0">
                                    {item.title}
                                </h3>
                            </div>
                            <p class="text-soft text-sm lh-relaxed m-0">
                                {item.desc}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 5. FAQ -->
    <section class="bg-white py-xl">
        <div class="container max-w-lg mx-auto">
            <h2 class="text-center mb-xl text-primary-dark">
                Preguntas Frecuentes sobre Esterilización en Coyoacán
            </h2>
            <div class="flex-col gap-lg">
                {
                    faqSchema.mainEntity.map((faq) => (
                        <div class="faq-item p-lg border-subtle bg-soft border-radius">
                            <h3 class="text-primary text-md mb-sm">
                                {faq.name}
                            </h3>
                            <p class="text-soft text-sm lh-relaxed m-0">
                                {faq.acceptedAnswer.text}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 6. SERVICIOS RELACIONADOS -->
    <section class="bg-soft py-xl">
        <div class="container">
            <h2 class="text-center mb-xl text-primary">
                Otros servicios en Punto Veterinario
            </h2>
            <div class="grid-3 gap-md">
                {
                    relacionadosCards.map((s) => (
                        <a
                            href={s.href}
                            class="card p-lg border-subtle bg-white text-center hover-lift flex-col items-center"
                        >
                            <span class="emoji-xl mb-sm block">{s.emoji}</span>
                            <h3 class="text-primary-dark mb-xs text-md">
                                {s.title}
                            </h3>
                            <p class="text-soft text-sm lh-relaxed my-sm">
                                {s.desc}
                            </p>
                            <span class="text-primary fw-bold text-sm mt-auto inline-block">
                                Ver detalles →
                            </span>
                        </a>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 7. CTA FINAL -->
    <section class="cta-section bg-primary py-xl text-center">
        <div class="container max-w-lg mx-auto">
            <h2 class="text-white mb-lg text-2xl lh-1">
                ¿Lista para agendar la esterilización en Coyoacán?
            </h2>
            <p class="text-white opacity-90 mb-xl text-lg lh-relaxed">
                Av. División del Norte 3595, Pedregal de Santo Domingo, CP
                04620, Coyoacán
            </p>
            <div class="flex flex-wrap justify-center gap-md">
                <a
                    href="/contacto"
                    class="btn-white-theme text-primary fw-bold text-md px-lg py-sm border-radius transition-transform inline-block"
                    >📅 Agendar Cita</a
                >
                <a
                    href="https://wa.me/525513843004"
                    target="_blank"
                    rel="noopener"
                    class="btn-outline-white text-white fw-bold text-md px-lg py-sm border-radius transition-transform inline-block"
                    >💬 WhatsApp</a
                >
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    /* Utilidades Globales sin PX */
    .bg-white {
        background-color: var(--color-bg);
    }
    .bg-soft {
        background-color: var(--color-bg-soft);
    }
    .bg-primary {
        background-color: var(--color-primary);
    }

    .text-white {
        color: var(--color-bg);
    }
    .text-primary {
        color: var(--color-primary);
    }
    .text-primary-dark {
        color: var(--color-primary-dark);
    }
    .text-soft {
        color: var(--color-text-soft);
    }

    .text-center {
        text-align: center;
    }
    .text-left {
        text-align: left;
    }
    .text-sm {
        font-size: var(--text-sm);
    }
    .text-md {
        font-size: var(--text-md);
    }
    .text-lg {
        font-size: var(--text-lg);
    }
    .text-2xl {
        font-size: var(--text-2xl);
    }
    .fw-bold {
        font-weight: 700;
    }

    .block {
        display: block;
    }
    .inline-block {
        display: inline-block;
    }
    .flex {
        display: flex;
    }
    .flex-col {
        display: flex;
        flex-direction: column;
    }
    .flex-wrap {
        flex-wrap: wrap;
    }
    .items-center {
        align-items: center;
    }
    .justify-center {
        justify-content: center;
    }

    .m-0 {
        margin: 0;
    }
    .my-sm {
        margin-block: var(--space-sm);
    }
    .mt-sm {
        margin-top: var(--space-sm);
    }
    .mt-auto {
        margin-top: auto;
    }
    .mb-xs {
        margin-bottom: var(--space-xs);
    }
    .mb-sm {
        margin-bottom: var(--space-sm);
    }
    .mb-md {
        margin-bottom: var(--space-md);
    }
    .mb-lg {
        margin-bottom: var(--space-lg);
    }
    .mb-xl {
        margin-bottom: var(--space-xl);
    }
    .mx-auto {
        margin-inline: auto;
    }

    .py-sm {
        padding-block: var(--space-sm);
    }
    .py-xl {
        padding-block: var(--space-xl);
    }
    .p-lg {
        padding: var(--space-lg);
    }
    .px-lg {
        padding-inline: var(--space-lg);
    }

    .gap-sm {
        gap: var(--space-sm);
    }
    .gap-md {
        gap: var(--space-md);
    }
    .gap-lg {
        gap: var(--space-lg);
    }

    .lh-1 {
        line-height: 1.2;
    }
    .lh-relaxed {
        line-height: 1.6;
    }
    .max-w-lg {
        max-width: 60rem;
    }
    .opacity-90 {
        opacity: 0.9;
    }

    .border-radius {
        border-radius: var(--radius);
    }
    .border-subtle {
        border: 0.1rem solid var(--color-border);
        border-radius: var(--radius-lg);
    }

    .emoji-md {
        font-size: clamp(1.2rem, 2vw, 1.8rem);
        line-height: 1;
        display: block;
    }
    .emoji-lg {
        font-size: clamp(1.5rem, 3vw, 2.5rem);
    }
    .emoji-xl {
        font-size: clamp(2.5rem, 5vw, 4rem);
    }

    .transition-transform {
        transition:
            transform 0.2s ease,
            box-shadow 0.2s ease,
            background-color 0.2s ease,
            color 0.2s ease;
    }
    .hover-lift:hover {
        transform: translateY(-0.2rem);
        box-shadow: var(--shadow-md);
    }

    a {
        text-decoration: none;
    }

    .btn-primary {
        background-color: var(--color-primary);
        color: var(--color-bg);
    }
    .btn-primary:hover {
        background-color: var(--color-primary-dark);
        transform: translateY(-0.15rem);
    }

    .btn-outline {
        background-color: transparent;
        border: 0.15rem solid var(--color-primary-dark);
    }
    .btn-outline:hover {
        background-color: var(--color-primary-dark);
        color: var(--color-bg);
        transform: translateY(-0.15rem);
    }

    .btn-white-theme {
        background-color: var(--color-bg);
        border: 0.15rem solid var(--color-bg);
    }
    .btn-white-theme:hover {
        transform: translateY(-0.2rem);
        box-shadow: var(--shadow-md);
        background-color: var(--color-bg-soft);
    }

    .btn-outline-white {
        background-color: transparent;
        border: 0.15rem solid var(--color-bg);
    }
    .btn-outline-white:hover {
        transform: translateY(-0.2rem);
        background-color: var(--color-bg);
        color: var(--color-primary);
    }
</style>
