---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Schema from "../../components/Schema.astro";

const schema = {"@context": "https://schema.org","@type": "MedicalProcedure",
    name: "Esterilización Veterinaria en Coyoacán",
    url: "https://puntoveterinario.com/servicios/esterilizacion",
    description:"Servicio de esterilización para perros y gatos en Coyoacán, CDMX. Anestesia monitoreada, seguimiento post-operatorio y atención personalizada.",
    provider: {"@type": "VeterinaryCare",
        name: "Punto Veterinario",
        address: {"@type": "PostalAddress",
            streetAddress: "Av. División del Norte 3595",
            addressLocality: "San Pablo Tepetlapa",
            postalCode: "04620",
            addressCountry: "MX",
        },
    },
};

const faqSchema = {"@context": "https://schema.org","@type": "FAQPage",
    mainEntity: [
        {"@type": "Question",
            name: "¿Cuánto cuesta esterilizar a un perro en Coyoacán?",
            acceptedAnswer: {"@type": "Answer",
                text: "El costo se evalúa individualmente en consulta según las necesidades específicas de tu mascota.",
            },
        },
        {"@type": "Question",
            name: "¿A qué edad se puede esterilizar a mi mascota?",
            acceptedAnswer: {"@type": "Answer",
                text: "Generalmente recomendamos la esterilización a partir de los 6 meses de edad, antes de que alcancen la madurez sexual plena.",
            },
        },
        {"@type": "Question",
            name: "¿Cuánto tiempo dura la recuperación?",
            acceptedAnswer: {"@type": "Answer",
                text: "Sí, somos un equipo médico especializado exclusivamente en medicina interna y preventiva para perros y gatos.",
            },
        },
        {"@type": "Question",
            name: "¿La esterilización privada es mejor que la gratuita?",
            acceptedAnswer: {"@type": "Answer",
                text: "Monitoreo constante y comunicación abierta durante toda la recuperación médica en casa.",
            },
        },
        {"@type": "Question",
            name: "¿Dónde esterilizar a mi perro cerca de San Pablo Tepetlapa?",
            acceptedAnswer: {"@type": "Answer",
                text: "Excelente ubicación al sur de la CDMX en Av. División del Norte 3595, CP 04620, Coyoacán.",
            },
        },
    ],
};

const incluyeCards = [
    {
        emoji: "🩺",
        title: "Valoración pre-quirúrgica",
        desc: "Examen físico integral previo para asegurar que tu mascota esté en óptimas condiciones corporales.",
    },
    {
        emoji: "💉",
        title: "Anestesia monitoreada",
        desc: "Protocolos anestésicos seguros con monitoreo constante de signos vitales durante todo el procedimiento.",
    },
    {
        emoji: "✂️",
        title: "Cirugía por médico especializado",
        desc: "Técnicas modernas en quirófano equipado para garantizar mínimas molestias y riesgos.",
    },
    {
        emoji: "🩹",
        title: "Seguimiento post-operatorio",
        desc: "Revisiones detalladas para cuidar la correcta cicatrización y pronta recuperación de tu compañero.",
    },
];

const privadaCards = ["Sin lista de espera, agendamos pronto","Anestesia monitoreada todo el tiempo","Seguimiento post-op incluido","Mismo médico que conoce a tu mascota","Atención el mismo día que agendas","En tu colonia — San Pablo Tepetlapa, CP 04620",
];

const porQueCards = [
    {
        emoji: "❤️",
        title: "Sin estrés adicional",
        desc: "Un ambiente privado y tranquilo hace que la experiencia sea menos traumática para tu mascota.",
    },
    {
        emoji: "🛡️",
        title: "Seguridad garantizada",
        desc: "Material quirúrgico esterilizado, medicamentos de alta calidad y protocolos estrictos de higiene.",
    },
    {
        emoji: "📍",
        title: "Cerca de ti en Coyoacán",
        desc: "Ubicados en San Pablo Tepetlapa, facilitando significativamente los traslados y citas post-operatorias.",
    },
];

const relacionadosCards = [
    {
        title: "Consulta Médica",
        emoji: "🩺",
        href: "/servicios/consulta-veterinaria",
        desc: "Diagnóstico preciso, responsable y medicina preventiva para tu mascota.",
    },
    {
        title: "Cirugías",
        emoji: "🏥",
        href: "/servicios/cirugia-veterinaria",
        desc: "Intervenciones quirúrgicas especializadas.",
    },
    {
        title: "Laboratorio Clínico",
        emoji: "🔬",
        href: "/servicios/laboratorio-clinico",
        desc: "Análisis clínicos para un diagnóstico exacto.",
    },
];
---

<BaseLayout
    title="Esterilización Veterinaria Coyoacán | Segura y Confiable"
    description="Esterilización privada para perros y gatos en Coyoacán. Sin filas, anestesia monitoreada y seguimiento post-op. CP 04620. Agenda hoy ☎️ 55 1384 3004"
    schema={schema}
>
    <Schema schema={faqSchema} />

    <!-- 1. HERO -->
    <section class="seccion fondo-blanco">
        <div class="container hero-inner">
            <h1 class="titulo-principal">
                Esterilización Veterinaria en Coyoacán, CDMX | Punto Veterinario
            </h1>
            <p class="subtitulo">
    Ofrecemos esterilización privada para perros y gatos en Coyoacán. Priorizamos la seguridad clínica con anestesia constante y seguimiento.
</p>
            <div class="botones">
                <a
                    href="https://wa.me/525513843004"
                    class="btn-primary"
                    target="_blank"
                    rel="noopener"
                >
                    💬 Agendar por WhatsApp
                </a>
                <a href="tel:+525513843004" class="btn-outline">
                    📞 Llamar ahora
                </a>
            </div>
        </div>
    </section>

    <!-- 2. ¿QUÉ INCLUYE? -->
    <section class="seccion fondo-suave">
        <div class="container">
            <h2 class="titulo-seccion">
                ¿Qué incluye la esterilización en Punto Veterinario?
            </h2>
            <div class="grid-4">
                {
                    incluyeCards.map((item) => (
                        <div class="card centrado">
                            <span class="emoji-grande">{item.emoji}</span>
                            <h3 class="titulo-card">{item.title}</h3>
                            <p class="texto-suave">{item.desc}</p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 3. PRIVADA VS GRATUITA -->
    <section class="seccion bg-white">
        <div class="container centrado">
            <h2 class="titulo-seccion">
                ¿Por qué elegir esterilización privada en Coyoacán?
            </h2>
            <p class="texto-suave parrafo-intro">
    En Punto Veterinario blindamos la integridad de tu mascota evitando largas filas y atención masiva de las campañas.
</p>
            <div class="grid-ventajas fondo-suave">
                {
                    privadaCards.map((texto) => (
                        <div class="ventaja-item">
                            <span class="check">✅</span>
                            <span class="ventaja-texto">{texto}</span>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 4. ¿POR QUÉ ELEGIRNOS? -->
    <section class="seccion fondo-suave">
        <div class="container">
            <h2 class="titulo-seccion">
                ¿Por qué elegir Punto Veterinario en Coyoacán?
            </h2>
            <div class="grid-3">
                {
                    porQueCards.map((item) => (
                        <div class="card">
                            <div class="card-header">
                                <span class="emoji-mediano">{item.emoji}</span>
                                <h3 class="titulo-card">{item.title}</h3>
                            </div>
                            <p class="texto-suave">{item.desc}</p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 5. FAQ -->
    <section class="seccion bg-white">
        <div class="container ">
            <h2 class="titulo-seccion centrado">
                Preguntas Frecuentes sobre Esterilización en Coyoacán
            </h2>
            <div class="faqs">
                {
                    faqSchema.mainEntity.map((faq) => (
                        <div class="faq-item fondo-suave">
                            <h3 class="faq-pregunta">{faq.name}</h3>
                            <p class="texto-suave">{faq.acceptedAnswer.text}</p>
                        </div>
                    ))
                }
                <div class="faq-item fondo-suave">
                    <h3 class="faq-pregunta">
                        ¿Dónde esterilizar a mi perro cerca de San Pablo
                        Tepetlapa?
                    </h3>
                    <p class="texto-suave">
    Somos <strong>Punto Veterinario</strong>, clínica en <strong>San Pablo Tepetlapa</strong> (CP 04620), <strong>Coyoacán</strong>. Brindamos atención médica de calidad en <strong>Av. División del Norte 3595</strong>.
</p>
                </div>
            </div>
        </div>
    </section>

    <!-- 6. SERVICIOS RELACIONADOS -->
    <section class="seccion fondo-suave">
        <div class="container">
            <h2 class="titulo-seccion">Otros servicios en Punto Veterinario</h2>
            <div class="grid-3">
                {
                    relacionadosCards.map((s) => (
                        <a href={s.href} class="card card-link centrado">
                            <span class="emoji-grande">{s.emoji}</span>
                            <h3 class="titulo-card">{s.title}</h3>
                            <p class="texto-suave">{s.desc}</p>
                            <span class="ver-mas">Ver detalles →</span>
                        </a>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 7. CTA FINAL -->
    <section class="seccion cta-final centrado">
        <div class="container ">
            <h2 class="titulo-cta">
                ¿Lista para agendar la esterilización en Coyoacán?
            </h2>
            <p class="texto-cta">
                <a
                    href="https://maps.app.goo.gl/GricGKCzpp6BXJgE7?g_st=aw"
                    target="_blank"
                    rel="noopener"
                    class="maps-link-blanco"
                >
                    Av. División del Norte 3595, San Pablo Tepetlapa, CP 04620,
                    Coyoacán
                </a>
            </p>
            <div class="botones">
                <a href="/contacto" class="btn-blanco">📅 Agendar Cita</a>
                <a
                    href="https://wa.me/525513843004"
                    target="_blank"
                    rel="noopener"
                    class="btn-outline-blanco"
                >
                    💬 WhatsApp
                </a>
            </div>
        </div>
    </section>
</BaseLayout>

<style>



    /* ===== HERO CENTRADO ===== */
    .hero-inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: clamp(1rem, 2vw, 3vw);
        width: 100%;
    }
    .titulo-principal {
        font-size: clamp(1.8rem, 3.2vw, 5.5vw);
        color: var(--color-primary-dark);
        line-height: 1.15;
        margin: 0;
    }
    .subtitulo {
        font-size: clamp(0.95rem, 1.4vw, 2.5vw);
        color: var(--color-text-soft);
        line-height: 1.6;
        margin: 0 auto;
        max-width: 75ch;
        text-align: center;
    }
    .botones {
        display: flex;
        flex-wrap: wrap;
        gap: clamp(0.8rem, 1.5vw, 2.5vw);
        justify-content: center;
    }


    /* ===== SECCIONES ===== */
    .seccion {
        padding-block: clamp(3rem, 6vw, 10vw);
        width: 100%;
    }
    .bg-white {
        background: var(--color-bg);
    }
    .fondo-suave {
        background: var(--color-bg-soft);
    }
    .centrado {
        text-align: center;
    }
    . {
        
        margin-inline: auto;
    }

    /* ===== TIPOGRAFÍA ===== */
    
    .parrafo-intro {
        margin-bottom: clamp(1.5rem, 3vw, 5vw);
        
        margin-inline: auto;
    }

    /* ===== BOTONES ===== */
    
    .btn-primary {
        background: var(--color-primary);
        color: #fff;
        padding: clamp(0.6rem, 1vw, 1.8vw) clamp(1.5rem, 3vw, 5vw);
        border-radius: var(--radius);
        font-weight: 600;
        font-size: clamp(0.9rem, 1.2vw, 2.2vw);
        text-decoration: none;
        transition:
            background 0.2s,
            transform 0.2s;
    }
    .btn-primary:hover {
        background: var(--color-primary-dark);
        transform: translateY(-0.15rem);
    }
    .btn-outline {
        border: 0.125rem solid var(--color-primary-dark);
        color: var(--color-primary-dark);
        padding: clamp(0.6rem, 1vw, 1.8vw) clamp(1.5rem, 3vw, 5vw);
        border-radius: var(--radius);
        font-weight: 600;
        font-size: clamp(0.9rem, 1.2vw, 2.2vw);
        text-decoration: none;
        transition: all 0.2s;
    }
    .btn-outline:hover {
        background: var(--color-primary-dark);
        color: #fff;
        transform: translateY(-0.15rem);
    }

    /* ===== GRIDS ===== */
    .grid-3 {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: clamp(1rem, 2vw, 3.5vw);
    }
    .grid-4 {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: clamp(1rem, 2vw, 3.5vw);
    }

    /* ===== CARDS ===== */
    .card {
        background: var(--color-bg);
        border: 0.06rem solid var(--color-border);
        border-radius: var(--radius-lg);
        padding: clamp(1rem, 2vw, 3.5vw);
        transition:
            transform 0.2s,
            box-shadow 0.2s;
    }
    .card:hover {
        transform: translateY(-0.2rem);
        box-shadow: var(--shadow-md);
    }
    .card-header {
        display: flex;
        align-items: center;
        gap: clamp(0.6rem, 1vw, 1.8vw);
        margin-bottom: clamp(0.6rem, 1vw, 1.8vw);
    }
    .card-link {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-decoration: none;
    }
    .ver-mas {
        color: var(--color-primary);
        font-weight: 700;
        font-size: clamp(0.9rem, 1.2vw, 2.2vw);
        margin-top: clamp(0.6rem, 1vw, 1.8vw);
    }

    /* ===== EMOJIS ===== */
    .emoji-grande {
        font-size: clamp(2.5rem, 5vw, 9vw);
        display: block;
        margin-bottom: clamp(0.4rem, 0.8vw, 1.4vw);
    }
    .emoji-mediano {
        font-size: clamp(1.5rem, 3vw, 5.4vw);
    }

    /* ===== VENTAJAS ===== */
    .grid-ventajas {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: clamp(0.6rem, 1vw, 1.8vw);
        padding: clamp(1.5rem, 3vw, 5vw);
        border-radius: var(--radius-lg);
        text-align: left;
    }
    .ventaja-item {
        display: flex;
        align-items: center;
        gap: clamp(0.6rem, 1vw, 1.8vw);
    }
    .check {
        font-size: clamp(1.1rem, 1.8vw, 3vw);
    }
    .ventaja-texto {
        font-size: clamp(0.9rem, 1.2vw, 2.2vw);
        font-weight: 600;
        color: var(--color-primary-dark);
    }

    /* ===== FAQ ===== */
    .faqs {
        display: flex;
        flex-direction: column;
        gap: clamp(1rem, 2vw, 3.5vw);
    }
    .faq-item {
        padding: clamp(1.5rem, 3vw, 5vw);
        border-radius: var(--radius-lg);
        border: 0.06rem solid var(--color-border);
    }
    .faq-pregunta {
        font-size: clamp(1.1rem, 1.8vw, 3vw);
        color: var(--color-primary);
        margin-bottom: clamp(0.6rem, 1vw, 1.8vw);
    }

    /* ===== MAPS LINK ===== */
    .maps-link {
        color: var(--color-primary-dark);
        text-decoration: underline;
        text-decoration-color: var(--color-primary);
        text-underline-offset: 0.2rem;
        transition: color 0.2s;
    }
    .maps-link:hover {
        color: var(--color-primary);
    }

    /* ===== CTA FINAL ===== */
    .cta-final {
        background: var(--color-primary);
    }
    .titulo-cta {
        font-size: clamp(2.2rem, 4vw, 6vw);
        color: #fff;
        margin-bottom: clamp(1rem, 2vw, 3.5vw);
        line-height: 1.2;
    }
    .texto-cta {
        color: rgba(255, 255, 255, 0.9);
        font-size: clamp(1.1rem, 1.8vw, 3vw);
        margin-bottom: clamp(2.5rem, 5vw, 8vw);
        
    }
    .maps-link-blanco {
        color: rgba(255, 255, 255, 0.9);
        text-decoration: underline;
        text-decoration-color: rgba(255, 255, 255, 0.5);
        text-underline-offset: 0.2rem;
        transition: color 0.2s;
    }
    .maps-link-blanco:hover {
        color: #fff;
    }
    .btn-blanco {
        background: #fff;
        color: var(--color-primary);
        padding: clamp(0.6rem, 1vw, 1.8vw) clamp(1.5rem, 3vw, 5vw);
        border-radius: var(--radius);
        font-weight: 700;
        font-size: clamp(0.9rem, 1.2vw, 2.2vw);
        text-decoration: none;
        transition:
            transform 0.2s,
            box-shadow 0.2s;
    }
    .btn-blanco:hover {
        transform: translateY(-0.2rem);
        box-shadow: var(--shadow-md);
    }
    .btn-outline-blanco {
        border: 0.125rem solid #fff;
        color: #fff;
        padding: clamp(0.6rem, 1vw, 1.8vw) clamp(1.5rem, 3vw, 5vw);
        border-radius: var(--radius);
        font-weight: 700;
        font-size: clamp(0.9rem, 1.2vw, 2.2vw);
        text-decoration: none;
        transition: all 0.2s;
    }
    .btn-outline-blanco:hover {
        background: #fff;
        color: var(--color-primary);
        transform: translateY(-0.2rem);
    }

    @media (max-width: 48rem) {
        [class*="grid-"] {
            grid-template-columns: repeat(2, 1fr) !important;
        }
    }
    @media (max-width: 30rem) {
        [class*="grid-"] {
            grid-template-columns: 1fr !important;
        }
    }
</style>
