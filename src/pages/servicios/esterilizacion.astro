---
import BaseLayout from "../../layouts/BaseLayout.astro";

const schema = {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Esterilización y Castración Veterinaria",
    provider: {
        "@type": "VeterinaryCare",
        name: "Punto Veterinario",
        image: "https://puntoveterinario.com/og-image.jpg",
        address: {
            "@type": "PostalAddress",
            streetAddress: "Av. División del Norte 3595",
            addressLocality: "Coyoacán",
            addressRegion: "CDMX",
            postalCode: "04620",
            addressCountry: "MX",
        },
    },
    areaServed: {
        "@type": "AdministrativeArea",
        name: "Coyoacán",
    },
    description:
        "Cirugía de esterilización (ovariohisterectomía) para hembras y castración (orquiectomía) para machos en CDMX. Prevención de piometra, tumores y cuidado integral.",
};

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
        {
            "@type": "Question",
            name: "¿Cuánto cuesta esterilizar a un perro o gato en Coyoacán?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "El costo de la esterilización depende del peso, especie y sexo de tu mascota. En Punto Veterinario, nuestras cirugías incluyen estudios prequirúrgicos para garantizar su seguridad. Escríbenos por WhatsApp al 55 1384 3004 para darte un presupuesto exacto.",
            },
        },
        {
            "@type": "Question",
            name: "¿A qué edad se recomienda esterilizar a mi mascota?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "Recomendamos esterilizar a hembras y machos antes de su primer celo o etapa reproductiva (generalmente entre los 4 y 6 meses de edad). Esto reduce drásticamente el riesgo de desarrollar cáncer mamario o prostático en el futuro.",
            },
        },
        {
            "@type": "Question",
            name: "¿Mi gata o perra necesita tener una camada antes de esterilizarse?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "No, esto es un mito. No existe ningún beneficio médico ni emocional en permitir que tengan una camada. Al contrario, cada celo que pasan sin reproducirse aumenta su riesgo de desarrollar piometra (infección uterina grave) y tumores.",
            },
        },
    ],
};

const faqs = faqSchema.mainEntity;

const datosCards = [
    {
        emoji: "📉",
        dato: "De 25% a 0.05%",
        desc: "Esterilizar a una hembra antes de su primer celo reduce el riesgo de cáncer de glándula mamaria a casi cero.",
    },
    {
        emoji: "🚨",
        dato: "80% de riesgo de Piometra",
        desc: "Las perras no esterilizadas tienen una altísima probabilidad de desarrollar esta infección uterina mortal que requiere cirugía de emergencia.",
    },
    {
        emoji: "🐈",
        dato: "7 veces más riesgo en gatas",
        desc: "Las gatas sin esterilizar son sumamente propensas a tumores mamarios, de los cuales más del 80% suelen ser malignos.",
    },
    {
        emoji: "🐕",
        dato: "95% en machos senior",
        desc: "Casi todos los perros machos no castrados (orquiectomía) desarrollan problemas de próstata a partir de los 9 años.",
    },
];

const mitos = [
    {
        mito: "Hay que dejarla tener una camada antes de operarla para que no se deprima.",
        realidad:
            "Completamente falso. Las mascotas no tienen el deseo psicológico de ser madres. No existe ningún beneficio médico en esperar; de hecho, cada celo aumenta dramáticamente el riesgo de cáncer y piometra.",
    },
    {
        mito: "La cirugía los hace flojos, tristes y gordos.",
        realidad:
            "Parcialmente incorrecto. La esterilización disminuye su metabolismo basal porque ya no gastan energía en buscar pareja, pero no cambia su personalidad. El aumento de peso se controla fácilmente ajustando su porción de alimento y manteniendo sus paseos diarios.",
    },
];

const protocoloPasos = [
    {
        emoji: "🩸",
        title: "Estudios Prequirúrgicos Obligatorios",
        desc: "Antes de la anestesia, realizamos análisis de sangre para verificar que sus riñones e hígado funcionen perfectamente y pueda procesar los medicamentos sin riesgo.",
    },
    {
        emoji: "🏥",
        title: "Quirófano Equipado",
        desc: "Contamos con monitoreo anestésico constante durante toda la ovariohisterectomía (hembras) o castración (machos).",
    },
    {
        emoji: "💊",
        title: "Protocolo del Dolor y Recuperación",
        desc: "Tu mascota se va a casa el mismo día, caminando, con una receta clara de analgésicos y antibióticos para que su recuperación sea rápida y sin dolor.",
    },
];

const relacionadosCards = [
    {
        title: "Consulta Médica",
        emoji: "🩺",
        href: "/servicios/consulta-veterinaria",
        desc: "Chequeos generales y medicina preventiva.",
    },
    {
        title: "Laboratorio Clínico",
        emoji: "🔬",
        href: "/servicios/laboratorio-clinico",
        desc: "Estudios prequirúrgicos y perfiles completos.",
    },
    {
        title: "Estética Canina",
        emoji: "🛁",
        href: "/servicios/estetica-canina",
        desc: "Grooming profesional exclusivo para perros.",
    },
];
---

<BaseLayout
    title="Esterilización de Perros y Gatos en Coyoacán | Punto Veterinario"
    description="Cirugía de esterilización y castración segura en Coyoacán, sur de CDMX. Previene tumores y piometra. Incluye valoración prequirúrgica. ¡Agenda por WhatsApp!"
    canonical="https://puntoveterinario.com/servicios/esterilizacion"
>
    <Fragment slot="head">
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
        <script
            type="application/ld+json"
            set:html={JSON.stringify(faqSchema)}
        />
    </Fragment>

    <!-- SECCIÓN 1 — HERO -->
    <section class="hero content-section">
        <div class="hero__text">
            <h1 class="h1-hero">
                Esterilización y Castración de Perros y Gatos en Coyoacán
            </h1>
            <p class="hero__desc">
                Una decisión preventiva que puede salvarle la vida. Realizamos
                cirugías seguras con estudios prequirúrgicos y monitoreo
                anestésico en San Pablo Tepetlapa, CDMX. Protege a tu mascota
                contra tumores, infecciones y problemas de comportamiento.
            </p>
            <div class="hero__btns">
                <a
                    href="https://wa.me/525513843004"
                    class="btn-wa"
                    target="_blank"
                    rel="noopener"
                >
                    💬 Cotizar cirugía por WhatsApp
                </a>
                <a href="#protocolo" class="btn-sec">
                    Conoce el proceso seguro →
                </a>
            </div>
        </div>
    </section>

    <!-- SECCIÓN 2 — DATOS MÉDICOS (E-E-A-T) -->
    <section class="content-section bg-soft">
        <h2 class="titulo-sec">
            ¿Por qué la esterilización es el mejor acto de amor?
        </h2>
        <p class="text-center text-soft intro-desc">
            Esterilizar a tu mascota no solo evita camadas no deseadas; es la
            intervención médica preventiva más importante para extender su
            esperanza de vida y evitar problemas como el cáncer de glándula
            mamaria o piometra.
        </p>
        <div class="grid-auto">
            {
                datosCards.map((item) => (
                    <div class="card-ui">
                        <span class="icon-scalable">{item.emoji}</span>
                        <div class="dato-content">
                            <h3 class="dato-numero">{item.dato}</h3>
                            <p class="card-desc">{item.desc}</p>
                        </div>
                    </div>
                ))
            }
        </div>
    </section>

    <!-- SECCIÓN 3 — MITO VS REALIDAD -->
    <section class="content-section">
        <h2 class="titulo-sec">
            Mitos comunes sobre la esterilización y castración de perros CDMX
        </h2>

        <div class="mito-vs-realidad-grid">
            <div class="mito-content">
                <div class="mito-realidad-box">
                    <div class="mito-block">
                        <span class="bad-icon">❌</span>
                        <p>
                            <strong>Mito:</strong> "Hay que dejarla tener una camada
                            antes de operarla para que no se deprima."
                        </p>
                    </div>
                    <div class="realidad-block">
                        <span class="good-icon">✅</span>
                        <p>
                            <strong>Realidad:</strong> Completamente falso. Las mascotas
                            no tienen el deseo psicológico de ser madres. No existe
                            ningún beneficio médico en esperar; cada celo aumenta
                            el riesgo de cáncer.
                        </p>
                    </div>
                    <div class="mito-block">
                        <span class="bad-icon">❌</span>
                        <p>
                            <strong>Mito:</strong> "La cirugía los hace flojos, tristes
                            y gordos."
                        </p>
                    </div>
                    <div class="realidad-block">
                        <span class="good-icon">✅</span>
                        <p>
                            <strong>Realidad:</strong> Parcialmente incorrecto. La
                            esterilización disminuye su metabolismo basal, pero no
                            cambia su personalidad. El peso se controla con dieta
                            y ejercicio.
                        </p>
                    </div>
                </div>
            </div>

            <div class="mito-quote-box">
                <blockquote class="valor-quote">
                    "Esterilizar a tu mascota antes del primer celo reduce el
                    riesgo de tumores de mama en un 99.5%. Es el acto de amor
                    más grande y preventivo que puedes hacer."
                </blockquote>
            </div>
        </div>
    </section>

    <!-- SECCIÓN 4 — EL PROTOCOLO SEGURO -->
    <section id="protocolo" class="content-section bg-soft">
        <h2 class="titulo-sec">
            ¿Por qué elegir Punto Veterinario para la cirugía de tu mascota?
        </h2>

        <blockquote class="valor-quote text-center">
            "En CDMX existen campañas de esterilización gratuita, pero muchas
            operan sin conocer el estado interno de la mascota. En Punto
            Veterinario no tomamos riesgos con la vida de tu mejor amigo.
            Nuestro protocolo quirúrgico es estricto y seguro."
        </blockquote>

        <div class="timeline-protocolo mt-fluid">
            {
                protocoloPasos.map((paso, index) => (
                    <div class="timeline-item">
                        <div class="timeline-marker protocol-marker">
                            {paso.emoji}
                        </div>
                        <div class="timeline-content card-ui">
                            <span class="paso-num">Paso {index + 1}</span>
                            <h3 class="timeline-titulo">{paso.title}</h3>
                            <p class="card-desc">{paso.desc}</p>
                        </div>
                    </div>
                ))
            }
        </div>
    </section>

    <!-- SECCIÓN 5 — FAQ (PREGUNTAS FRECUENTES) -->
    <section class="content-section">
        <h2 class="titulo-sec">
            Preguntas frecuentes sobre la esterilización en Coyoacán
        </h2>
        <div class="faq-accordion">
            {
                faqs.map((faq) => (
                    <details class="faq-item">
                        <summary class="faq-question">{faq.name}</summary>
                        <p class="faq-answer">{faq.acceptedAnswer.text}</p>
                    </details>
                ))
            }
        </div>
    </section>

    <!-- SECCIÓN 6 — OTROS SERVICIOS RELACIONADOS -->
    <section class="content-section bg-soft">
        <h2 class="titulo-sec">Cuidado integral en San Pablo Tepetlapa</h2>
        <div class="grid-auto">
            {
                relacionadosCards.map((s) => (
                    <a href={s.href} class="card-ui">
                        <span class="icon-scalable">{s.emoji}</span>
                        <h3 class="card-titulo">{s.title}</h3>
                        <p class="card-desc">{s.desc}</p>
                        <span class="card-ver">Ver detalles →</span>
                    </a>
                ))
            }
        </div>
    </section>

    <!-- SECCIÓN 7 — CTA FINAL Y CONTACTO LOCAL -->
    <section class="cta-final content-section">
        <h2 class="cta-titulo-blanc">
            ¿Listo para agendar la esterilización de tu mascota?
        </h2>
        <p class="cta-desc-blanc">
            El costo de prevenir hoy es mucho menor al de tratar una urgencia
            médica mañana. Contáctanos para cotizar la cirugía de tu perro o
            gato. Estamos en Av. División del Norte 3595, a minutos del Pedregal
            de Santo Domingo y Copilco.
        </p>
        <div class="cta-btns">
            <a
                href="https://wa.me/525513843004"
                target="_blank"
                rel="noopener"
                class="btn-cta-blanco"
            >
                💬 Cotizar por WhatsApp
            </a>
            <a href="tel:+525513843004" class="btn-cta-outline">
                📞 Llamar al 55 1384 3004
            </a>
        </div>
    </section>
</BaseLayout>

<style>
    /* 1. REGLAS DE ORO: MITOS (COPIA FIEL DE ESTETICA) */
    .mito-vs-realidad-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: max(2rem, 4vw);
        align-items: center;
    }
    @media (min-width: 64rem) {
        .mito-vs-realidad-grid {
            grid-template-columns: 1.2fr 1fr;
        }
    }
    .mito-realidad-box {
        display: flex;
        flex-direction: column;
        gap: max(1rem, 2vw);
        margin-bottom: max(1.5rem, 3vw);
    }
    .mito-block,
    .realidad-block {
        display: flex;
        align-items: flex-start;
        gap: max(0.8rem, 1.2vw);
        background: var(--color-bg);
        padding: max(1rem, 1.5vw);
        border-radius: max(0.5rem, 1vw);
        border-left: max(0.3rem, 0.5vw) solid;
        box-shadow: var(--shadow);
        text-align: left;
    }
    .mito-block {
        border-left-color: #ff4d4d;
    }
    .realidad-block {
        border-left-color: #4caf50;
    }
    .bad-icon,
    .good-icon {
        font-size: max(1.2rem, 1.8vw);
        flex-shrink: 0;
        margin-top: max(0.2rem, 0.4vw);
    }
    .valor-quote {
        background: var(--color-primary-light);
        border-radius: max(0.5rem, 1vw);
        padding: max(1.5rem, 2.5vw);
        font-size: max(1.05rem, 1.4vw);
        color: var(--color-primary-dark);
        font-style: italic;
        font-weight: 500;
        line-height: 1.6;
        margin: 0;
        position: relative;
        text-align: left;
    }
    .valor-quote::before {
        content: "«";
        font-size: max(2rem, 4vw);
        position: absolute;
        top: max(-0.5rem, -1vw);
        left: max(0.5rem, 1vw);
        opacity: 0.2;
        font-weight: 700;
        font-style: normal;
    }

    /* ====== CLAMP SYSTEM + RESPONSIVE ====== */

    .content-section {
        padding-block: max(3rem, 6vw);
    }
    .bg-soft {
        background: var(--color-bg-soft);
    }

    .h1-hero {
        font-size: max(1.8rem, 3.2vw);
        color: var(--color-text);
        line-height: 1.15;
        margin-bottom: max(1rem, 2vw);
    }

    .titulo-sec {
        font-size: max(1.6rem, 2.8vw);
        color: var(--color-primary);
        text-align: center;
        margin-bottom: max(2rem, 4vw);
        line-height: 1.2;
    }

    .text-center {
        text-align: center;
    }

    .mt-fluid {
        margin-top: max(2rem, 4vw);
    }

    .intro-desc {
        font-size: max(0.95rem, 1.4vw);

        margin-inline: auto;
        margin-bottom: max(2rem, 4vw);
        line-height: 1.6;
    }

    /* HERO CLASSES */
    .hero {
        background: var(--color-bg);
    }
    .hero__inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }
    .hero__text {
        width: 100%;
        margin-inline: auto;
    }
    @media (min-width: 48rem) {
        .hero__text {
        }
    }

    .hero__desc {
        font-size: max(0.95rem, 1.4vw);
        color: var(--color-text-soft);
        line-height: 1.6;
        margin-bottom: max(1.5rem, 2vw);
        margin-inline: auto;
    }

    .hero__btns {
        display: flex;
        flex-wrap: wrap;
        gap: max(0.8rem, 1.5vw);
        margin-bottom: max(1rem, 2vw);
        justify-content: center;
    }

    .btn-wa {
        background: var(--color-primary);
        color: #fff;
        padding: max(0.6rem, 1.2vw) max(1.2rem, 2.5vw);
        font-size: max(0.9rem, 1.2vw);
        border-radius: max(0.4rem, 1vw);
        font-weight: 600;
        text-decoration: none;
        transition:
            background 0.2s,
            transform 0.2s;
    }
    .btn-wa:hover {
        background: var(--color-primary-dark);
        transform: translateY(-0.15rem);
    }

    .btn-sec {
        padding: max(0.6rem, 1.2vw) max(1.2rem, 2.5vw);
        font-size: max(0.9rem, 1.2vw);
        border: max(0.1rem, 0.15vw) solid var(--color-secondary);
        color: var(--color-secondary-dark);
        border-radius: max(0.4rem, 1vw);
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s;
    }
    .btn-sec:hover {
        background: var(--color-secondary);
        color: #fff;
        transform: translateY(-0.15rem);
    }

    /* GRID LAYOUTS */
    .grid-datos-medicos {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: max(1.5rem, 3vw);
    }
    .grid-relacionados {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: max(1rem, 2vw);
    }
    @media (max-width: 64rem) {
        .grid-datos-medicos {
            grid-template-columns: 1fr;
        }
        .grid-relacionados {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    @media (max-width: 48rem) {
        .grid-relacionados {
            grid-template-columns: 1fr;
        }
    }

    /* CARDS */
    .card {
        background: var(--color-bg);
        border: max(0.05rem, 0.1vw) solid var(--color-border);
        border-radius: max(0.5rem, 1.5vw);
        padding: max(1.2rem, 2vw);
        display: flex;
        flex-direction: column;
        text-decoration: none;
        transition:
            transform 0.3s,
            box-shadow 0.3s;
    }
    .card-servicio:hover {
        transform: translateY(-0.25rem);
        box-shadow: var(--shadow-md);
    }

    .card-dato {
        flex-direction: row;
        align-items: center;
        gap: max(1rem, 2vw);
        border-left: max(0.3rem, 0.5vw) solid var(--color-secondary);
        background: var(--color-bg);
    }

    @media (max-width: 48rem) {
        .card-dato {
            flex-direction: column;
            text-align: center;
        }
    }

    .dato-emoji {
        font-size: max(3rem, 5vw);
        flex-shrink: 0;
    }

    .dato-numero {
        font-size: max(1.2rem, 1.8vw);
        color: var(--color-secondary-dark);
        margin-bottom: max(0.5rem, 1vw);
        line-height: 1.2;
        font-weight: 800;
    }

    .card-emoji {
        font-size: max(2rem, 3.5vw);
        margin-bottom: max(0.8rem, 1.2vw);
        display: block;
        text-align: center;
    }

    .card-titulo {
        font-size: max(1.1rem, 1.6vw);
        color: var(--color-primary-dark);
        margin-bottom: max(0.5rem, 1vw);
        line-height: 1.3;
        text-align: center;
    }
    .card-desc {
        font-size: max(0.95rem, 1.3vw);
        color: var(--color-text-soft);
        line-height: 1.6;
        flex-grow: 1;
        margin: 0;
    }

    .card-servicio .card-desc {
        text-align: center;
    }

    .card-ver {
        font-size: max(0.9rem, 1.1vw);
        color: var(--color-primary);
        font-weight: 700;
        margin-top: max(0.8rem, 1.2vw);
        display: inline-block;
        text-align: center;
    }

    /* ======================================================== */
    /* MITO VS REALIDAD — Removido en esta línea y movido arriba */
    /* ======================================================== */

    /* TIMELINE PROTOCOLO */
    .timeline-protocolo {
        display: flex;
        flex-direction: column;
        gap: max(1.5rem, 3vw);

        margin-inline: auto;
    }
    .timeline-item {
        display: flex;
        align-items: center;
        gap: max(1rem, 2vw);
    }
    .protocol-marker {
        flex-shrink: 0;
        width: max(3rem, 5vw);
        height: max(3rem, 5vw);
        background: var(--color-bg);
        border: max(0.15rem, 0.2vw) solid var(--color-primary);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: max(1.5rem, 2.5vw);
        box-shadow: var(--shadow);
    }
    .timeline-content {
        flex-grow: 1;
        text-align: left;
    }
    .card-protocolo {
        position: relative;
    }
    .paso-num {
        font-size: max(0.8rem, 1vw);
        color: var(--color-primary);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: max(0.05rem, 0.1vw);
        margin-bottom: max(0.2rem, 0.5vw);
        display: block;
    }
    .timeline-titulo {
        font-size: max(1.2rem, 1.8vw);
        color: var(--color-primary-dark);
        margin-bottom: max(0.5rem, 1vw);
        line-height: 1.2;
    }

    @media (max-width: 48rem) {
        .timeline-item {
            flex-direction: column;
            gap: max(0.8rem, 1.2vw);
        }
    }
    .faq-item {
        background: var(--color-bg);
        border: max(0.05rem, 0.1vw) solid var(--color-border);
        border-radius: max(0.5rem, 1vw);
        padding: max(1rem, 1.5vw);
    }
    .faq-item[open] .faq-question {
        color: var(--color-primary-dark);
        margin-bottom: max(0.8rem, 1vw);
    }
    .faq-question {
        font-size: max(1rem, 1.4vw);
        font-weight: 600;
        color: var(--color-text);
        cursor: pointer;
        list-style: none; /* Hide default arrow */
        position: relative;
        padding-right: max(2rem, 3vw);
        line-height: 1.4;
    }
    .faq-question::-webkit-details-marker {
        display: none;
    }
    .faq-question::after {
        content: "+";
        position: absolute;
        right: 0;
        top: 0;
        font-size: max(1.2rem, 1.8vw);
        color: var(--color-primary);
