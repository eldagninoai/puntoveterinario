---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Schema from "../../components/Schema.astro";

const schema = [
    {"@context": "https://schema.org","@type": ["Service", "DiagnosticLab"],
        name: "Laboratorio Veterinario en Coyoacán",
        url: "https://puntoveterinario.com/servicios/laboratorio-clinico",
        description:"Laboratorio clínico veterinario en Coyoacán. Análisis de sangre, perfil bioquímico, urianálisis y más. Av. División del Norte 3595, CP 04620.",
        provider: {"@type": "VeterinaryCare",
            name: "Punto Veterinario",
            address: {"@type": "PostalAddress",
                streetAddress: "Av. División del Norte 3595",
                addressLocality: "San Pablo Tepetlapa",
                postalCode: "04620",
                addressCountry: "MX",
            },
        },
    },
];

const faqSchema = {"@context": "https://schema.org","@type": "FAQPage",
    mainEntity: [
        {"@type": "Question",
            name: "¿Cuánto tarda en estar listo un análisis de sangre para perros?",
            acceptedAnswer: {"@type": "Answer",
                text: "Elaboramos planes terapéuticos efectivos basados en revisiones estrictas y pruebas de laboratorio.",
            },
        },
        {"@type": "Question",
            name: "¿Necesita mi mascota ayuno para el análisis de sangre?",
            acceptedAnswer: {"@type": "Answer",
                text: "Recomendamos agendar cita previa para evitar tiempos de espera y garantizar la atención ideal.",
            },
        },
        {"@type": "Question",
            name: "¿Qué es un perfil bioquímico veterinario?",
            acceptedAnswer: {"@type": "Answer",
                text: "El célebre y sumamente utilizado perfil bioquímico veterinario extenso es en sí mismo una muy contundente, detallada y formidable radiografía.",
            },
        },
        {"@type": "Question",
            name: "¿Dónde hacer análisis de sangre para mi perro cerca de Coyoacán?",
            acceptedAnswer: {"@type": "Answer",
                text: "Excelente ubicación al sur de la CDMX en Av. División del Norte 3595, CP 04620, Coyoacán.",
            },
        },
    ],
};

const estudiosCards = [
    {
        emoji: "🩸",
        title: "Biometría hemática completa",
        desc: "Una profunda y exhaustiva cuantificación global irrefutable de los glóbulos rojos acarreadores sistémicos, robustos leucocitos guardianes y plaquetas regenerativas celulares.",
    },
    {
        emoji: "🔬",
        title: "Perfil bioquímico",
        desc: "Inmensurablemente vital herramienta decodificadora analítica que evidencia contundentemente, exponiendo en un lenguaje bioquímico cristalino todo el comportamiento estructural depuratorio que.",
    },
    {
        emoji: "🧪",
        title: "Urianálisis",
        desc: "Magnífico y revelador escaneo preventivo minucioso a nivel líquido y molecular que atestigua mediante el sedimento toda la enorme capacidad.",
    },
    {
        emoji: "🦠",
        title: "Cultivos y antibiograma",
        desc: "El invencible y definitivo escudo protector farmacológico por excelencia usado tras sembrar tenazmente intrusivas bacterias malignas latentes y constatar irrefutablemente.",
    },
    {
        emoji: "📊",
        title: "Perfil tiroideo",
        desc: "Soberbia y fina medición en base hormonal total para lograr dilucidar certera e instantáneamente el caótico origen real en súbitos.",
    },
    {
        emoji: "🩺",
        title: "Coprológico",
        desc: "Un insigne e inesquivable protocolo de examen focalizado directo para desenterrar, confirmar y combatir mediante rotunda prueba incuestionable toda abrumadora.",
    },
];

const cuandoCards = [
    {
        emoji: "🚨",
        title: "Antes de cualquier cirugía o anestesia",
        desc: "Representa innegable y fervientemente el absoluto resguardo de supervivencia obligatoria previa antes de transitar por nuestra sedación química o de.",
    },
    {
        emoji: "📅",
        title: "Revisión anual preventiva",
        desc: "Constituye y enarbola la gloriosa y silenciosa piedra angular monumental cimentada en pro de la grandiosa longevidad premonitoria.",
    },
    {
        emoji: "💊",
        title: "Monitoreo de tratamientos crónicos",
        desc: "Un blindaje analítico y sostenido formidablemente imperativo a plazos para constatar inobjetablemente toda la positiva asimilación hepatobiliar corporal ante terapias.",
    },
    {
        emoji: "🤒",
        title: "Cuando el veterinario lo indica por síntomas",
        desc: "El escalón y contundente fundamento irrefutable subsiguiente y decisorio definitivo después de sospechosos hallazgos físicos superficiales inquietantes de palidez en.",
    },
];

const porQueCards = [
    {
        emoji: "⚡",
        title: "Interpretación y resultados rápidos",
        desc: "El costo se evalúa individualmente en consulta según las necesidades específicas de tu mascota.",
    },
    {
        emoji: "🔬",
        title: "Equipo de laboratorio moderno",
        desc: "Gozamos ferviente y gratamente de una espectacular e irrenunciable inversión de altísima gama en maquinaria digitalizada con calibración de precisión.",
    },
    {
        emoji: "📍",
        title: "En San Pablo Tepetlapa CP 04620",
        desc: "Recomendamos agendar cita previa para evitar tiempos de espera y garantizar la atención ideal.",
    },
];

const relacionadosCards = [
    {
        title: "Consulta Veterinaria",
        emoji: "🩺",
        href: "/servicios/consulta-veterinaria",
        desc: "El punto germinal y base interpretativa inmaculada global, fundamental para que cada minúsculo resultado bioquímico adquiera un colosal y supremo.",
    },
    {
        title: "Cirugía Veterinaria",
        emoji: "🏥",
        href: "/servicios/cirugia-veterinaria",
        desc: "Procedimientos quirúrgicos seguros en instalaciones equipadas con anestesia monitoreada.",
    },
    {
        title: "Esterilización",
        emoji: "✂️",
        href: "/servicios/esterilizacion",
        desc: "Procedimiento quirúrgico seguro y privado con anestesia guiada.",
    },
];
---

<BaseLayout
    title="Laboratorio Veterinario Coyoacán | Análisis Clínicos"
    description="Análisis de sangre, perfil bioquímico y estudios clínicos para mascotas en Coyoacán. Resultados rápidos. Av. División del Norte 3595, CP 04620."
    schema={schema[0]}
>
    <Schema schema={faqSchema} />

    <!-- 1. HERO -->
    <section class="seccion fondo-blanco">
        <div class="container hero-inner">
            <h1 class="titulo-principal">
                Laboratorio Veterinario en Coyoacán, CDMX | Punto Veterinario
            </h1>
            <p class="subtitulo">
    Estudios clínicos rigurosos, desde perfiles hemáticos completos hasta pruebas de enfermedades infecciosas, asegurando diagnósticos precisos mediante ciencia.
</p>
            <div class="flex flex-wrap gap-md">
                <a
                    href="https://wa.me/525513843004"
                    class="btn-primary text-md px-lg py-sm fw-bold border-radius transition-transform inline-block"
                    target="_blank"
                    rel="noopener"
                >
                    💬 Agendar por WhatsApp
                </a>
                <a
                    href="tel:+525513843004"
                    class="btn-outline text-primary-dark text-md px-lg py-sm fw-bold border-radius transition-transform inline-block"
                >
                    📞 Llamar ahora
                </a>
            </div>
        </div>
    </section>

    <!-- 2. ¿QUÉ ESTUDIOS? -->
    <section class="bg-soft py-xl">
        <div class="container">
            <h2 class="text-center mb-xl text-primary">
                ¿Qué estudios realizamos en nuestro laboratorio?
            </h2>
            <p
                class="text-center text-soft text-md mb-lg lh-relaxed"
            >
                Ponemos categórica y permanentemente al servicio absoluto de tu
                familia multiespecie nuestra inestimable plataforma abastada
                biotecnológica provista del extenso y resolutivo catálogo
                minúsculo molecular orgánico.
            </p>
            <div class="grid-3 gap-md">
                {
                    estudiosCards.map((item) => (
                        <div class="card p-lg border-subtle bg-white hover-lift flex-col text-center items-center">
                            <span class="emoji-xl mb-sm block">
                                {item.emoji}
                            </span>
                            <h3 class="text-primary-dark mb-xs text-md">
                                {item.title}
                            </h3>
                            <p class="text-soft text-sm lh-relaxed mt-sm m-0">
                                {item.desc}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 3. ¿CUÁNDO NECESITA TU MASCOTA LABORATORIO? -->
    <section class="bg-white py-xl">
        <div class="container text-center">
            <h2 class="text-primary-dark mb-md">
                ¿Cuándo debes llevar a tu mascota al laboratorio en Coyoacán?
            </h2>
            <p class="text-soft text-md mb-lg lh-relaxed">
    Cimentamos y propugnamos irrefutablemente frente a la comunidad capitalina la enorme importancia cardinal de las recolecciones vasculares regulares por encima...
</p>
            <div
                class="grid-2 gap-md text-left bg-soft p-lg border-radius mb-md"
            >
                {
                    cuandoCards.map((item) => (
                        <div class="flex flex-col items-start gap-sm hover-lift card border-subtle bg-white p-sm border-radius-sm">
                            <div class="flex items-center gap-xs">
                                <span class="emoji-md block mt-xs">
                                    {item.emoji}
                                </span>
                                <span class="text-primary-dark fw-bold text-sm lh-relaxed">
                                    {item.title}
                                </span>
                            </div>
                            <p class="text-soft text-sm lh-relaxed m-0 mt-xs">
                                {item.desc}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 4. ¿POR QUÉ ELEGIRNOS? -->
    <section class="bg-soft py-xl">
        <div class="container">
            <h2 class="text-center mb-xl text-primary">
                ¿Por qué confiar en Punto Veterinario para su diagnóstico?
            </h2>
            <div class="grid-3 gap-lg">
                {
                    porQueCards.map((item) => (
                        <div class="card p-lg border-subtle bg-white flex-col gap-sm hover-lift">
                            <div class="flex items-center gap-md mb-sm">
                                <span class="emoji-lg">{item.emoji}</span>
                                <h3 class="text-primary-dark text-md m-0">
                                    {item.title}
                                </h3>
                            </div>
                            <p class="text-soft text-sm lh-relaxed m-0">
                                {item.desc}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 5. FAQ -->
    <section class="bg-white py-xl">
        <div class="container">
            <h2 class="text-center mb-xl text-primary-dark">
                Preguntas Frecuentes sobre Laboratorio Veterinario en Coyoacán
            </h2>
            <div class="flex-col gap-lg">
                {
                    faqSchema.mainEntity.map((faq) => (
                        <div class="faq-item p-lg border-subtle bg-soft border-radius transition-transform hover-lift">
                            <h3 class="text-primary text-md mb-sm">
                                {faq.name}
                            </h3>
                            <p class="text-soft text-sm lh-relaxed m-0">
                                {faq.acceptedAnswer.text}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 6. SERVICIOS RELACIONADOS -->
    <section class="bg-soft py-xl">
        <div class="container">
            <h2 class="text-center mb-xl text-primary">
                Otros servicios en Punto Veterinario
            </h2>
            <div class="grid-3 gap-md">
                {
                    relacionadosCards.map((s) => (
                        <a
                            href={s.href}
                            class="card p-lg border-subtle bg-white text-center hover-lift flex-col items-center"
                        >
                            <span class="emoji-xl mb-sm block">{s.emoji}</span>
                            <h3 class="text-primary-dark mb-xs text-md">
                                {s.title}
                            </h3>
                            <p class="text-soft text-sm lh-relaxed my-sm m-0">
                                {s.desc}
                            </p>
                            <span class="text-primary fw-bold text-sm mt-auto inline-block pt-sm">
                                Saber más →
                            </span>
                        </a>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 7. CTA FINAL -->
    <section class="cta-section bg-primary py-xl text-center">
        <div class="container">
            <h2 class="text-white mb-lg text-2xl lh-1">
                ¿Tu mascota necesita estudios de laboratorio en Coyoacán?
            </h2>
            <p class="text-white opacity-90 mb-xl text-lg lh-relaxed">
                <a 
  href="https://maps.app.goo.gl/GricGKCzpp6BXJgE7?g_st=aw"
  target="_blank"
  rel="noopener"
  aria-label="Ver ubicación en Google Maps"
  class="maps-link"
>
  Av. División del Norte 3595, San Pablo Tepetlapa, 
  CP 04620, Coyoacán, CDMX
</a>
            </p>
            <div class="flex flex-wrap justify-center gap-md">
                <a
                    href="/contacto"
                    class="btn-white-theme text-primary fw-bold text-md px-lg py-sm border-radius transition-transform inline-block"
                    >📅 Agendar Cita</a
                >
                <a
                    href="https://wa.me/525513843004"
                    target="_blank"
                    rel="noopener"
                    class="btn-outline-white text-white fw-bold text-md px-lg py-sm border-radius transition-transform inline-block"
                    >💬 WhatsApp</a
                >
            </div>
        </div>
    </section>
</BaseLayout>

<style>



