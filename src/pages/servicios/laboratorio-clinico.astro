---
import BaseLayout from "../../layouts/BaseLayout.astro";

const schema = {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Laboratorio Clínico Veterinario",
    provider: {
        "@type": "VeterinaryCare",
        name: "Punto Veterinario",
        image: "https://puntoveterinario.com/og-image.jpg",
        address: {
            "@type": "PostalAddress",
            streetAddress: "Av. División del Norte 3595",
            addressLocality: "Coyoacán",
            addressRegion: "CDMX",
            postalCode: "04620",
            addressCountry: "MX",
        },
    },
    areaServed: {
        "@type": "AdministrativeArea",
        name: "Coyoacán",
    },
    description:
        "Servicio de laboratorio clínico para mascotas en CDMX. Realizamos hemogramas, perfiles bioquímicos, urianálisis y estudios prequirúrgicos para perros y gatos.",
};

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
        {
            "@type": "Question",
            name: "¿Para qué sirve un análisis de sangre en perros y gatos?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "Los análisis de sangre permiten evaluar el funcionamiento de órganos vitales (riñones, hígado, páncreas) y detectar infecciones, anemia, diabetes o insuficiencia renal años antes de que la mascota muestre síntomas visibles de enfermedad.",
            },
        },
        {
            "@type": "Question",
            name: "¿Cuánto cuesta un análisis veterinario en Coyoacán?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "El costo depende del tipo de estudio que tu mascota necesite (hemograma básico, perfil bioquímico completo, urianálisis, etc.). Contáctanos por WhatsApp al 55 1384 3004 para indicarte el precio exacto del panel requerido.",
            },
        },
        {
            "@type": "Question",
            name: "¿Mi perro necesita ayuno para el análisis de sangre?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "Sí, para la mayoría de los estudios de laboratorio (especialmente los perfiles bioquímicos) se requiere un ayuno estricto de sólidos de 8 a 12 horas para garantizar que los resultados de glucosa y enzimas sean precisos y no se alteren.",
            },
        },
    ],
};

const faqs = faqSchema.mainEntity;

const estudiosCards = [
    {
        emoji: "🩸",
        title: "Hemograma Completo",
        desc: "Cuenta y evalúa los glóbulos rojos, glóbulos blancos, plaquetas y hemoglobina. Es esencial para detectar anemia, infecciones agudas, problemas de coagulación o enfermedades como la leucemia felina.",
    },
    {
        emoji: "🧪",
        title: "Perfil Bioquímico",
        desc: "Un panel vital que evalúa el funcionamiento de los órganos internos. Medimos enzimas hepáticas (ALT/AST), marcadores de función renal (Creatinina y BUN) y glucosa para detectar diabetes o insuficiencia renal temprana.",
    },
    {
        emoji: "🔬",
        title: "Urianálisis y Coproparasitoscópico",
        desc: "Análisis completo de orina para detectar infecciones del tracto urinario o enfermedad renal, y estudio de heces para identificar parásitos intestinales que no siempre son visibles.",
    },
];

const ventajasLista = [
    {
        title: "Menor margen de error",
        desc: "Aproximadamente el 70% de los resultados inconsistentes en laboratorio se deben a errores en la toma o conservación de la muestra. Al tomar la muestra en nuestra clínica con el protocolo correcto, garantizamos resultados fiables.",
    },
    {
        title: "Resultados oportunos para actuar rápido",
        desc: "Contar con la información clínica rápidamente nos permite iniciar el tratamiento médico correcto sin perder tiempo valioso para la salud de tu mascota. (Nota: Estos estudios son pre-requisito obligatorio antes de cualquier cirugía o procedimiento anestésico).",
    },
];

const relacionadosCards = [
    {
        title: "Cirugía Veterinaria",
        emoji: "🏥",
        href: "/servicios/cirugia-veterinaria",
        desc: "Operaciones seguras respaldadas por estudios prequirúrgicos.",
    },
    {
        title: "Consulta Médica",
        emoji: "🩺",
        href: "/servicios/consulta-veterinaria",
        desc: "Valoración e interpretación profesional de los resultados.",
    },
    {
        title: "Alimento para Mascotas",
        emoji: "🥩",
        href: "/servicios/alimento-mascotas",
        desc: "Dietas terapéuticas prescritas según los resultados del laboratorio.",
    },
];
---

<BaseLayout
    title="Laboratorio Clínico Veterinario en Coyoacán | Punto Veterinario"
    description="Análisis de sangre, hemogramas y perfiles bioquímicos para perros y gatos en Coyoacán. Diagnóstico temprano y resultados precisos en CDMX. ¡Contáctanos!"
    canonical="https://puntoveterinario.com/servicios/laboratorio-clinico"
>
    <Fragment slot="head">
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
        <script
            type="application/ld+json"
            set:html={JSON.stringify(faqSchema)}
        />
    </Fragment>

    <!-- SECCIÓN 1 — HERO -->
    <section class="hero content-section">
        <div class="hero__text">
            <h1 class="h1-hero">Laboratorio Clínico Veterinario en Coyoacán</h1>
            <p class="hero__desc">
                Diagnóstico temprano y preciso para perros y gatos. Realizamos
                análisis de sangre, química sanguínea y estudios prequirúrgicos
                en San Pablo Tepetlapa para detectar problemas de salud antes de
                que se conviertan en urgencias.
            </p>
            <div class="hero__btns">
                <a
                    href="https://wa.me/525513843004"
                    class="btn-wa"
                    target="_blank"
                    rel="noopener"
                >
                    💬 Cotizar estudios por WhatsApp
                </a>
                <a href="#estudios" class="btn-sec">
                    Ver tipos de análisis ↓
                </a>
            </div>
        </div>
    </section>

    <!-- SECCIÓN 2 — ¿QUÉ ANALIZAMOS? -->
    <section id="estudios" class="content-section bg-soft">
        <h2 class="titulo-sec">
            Estudios de laboratorio para un diagnóstico exacto
        </h2>
        <div class="grid-auto">
            {
                estudiosCards.map((item) => (
                    <div class="card-ui">
                        <span class="icon-scalable">{item.emoji}</span>
                        <h3 class="card-titulo">{item.title}</h3>
                        <p class="card-desc">{item.desc}</p>
                    </div>
                ))
            }
        </div>
    </section>

    <!-- SECCIÓN 3 — MITO VS REALIDAD (ENFERMEDADES SILENTES) -->
    <section class="content-section">
        <h2 class="titulo-sec">
            ¿Por qué no esperar a que tu mascota se sienta mal?
        </h2>

        <div class="mito-realidad-box mb-fluid">
            <div class="mito-block">
                <span class="icon-scalable bad-icon">❌</span>
                <p>
                    <strong>El Mito:</strong> "Si mi mascota come bien y juega, no
                    necesita análisis de sangre."
                </p>
            </div>
            <div class="realidad-block">
                <span class="icon-scalable good-icon">✅</span>
                <p>
                    <strong>La Realidad:</strong> Enfermedades gravísimas como la
                    insuficiencia renal, problemas hepáticos o la diabetes son "silentes".
                    No dan síntomas visibles (como dejar de comer o decaimiento) hasta
                    que la enfermedad está en etapas muy avanzadas e irreversibles.
                    Un chequeo de laboratorio anual las detecta años antes.
                </p>
            </div>
        </div>

        <blockquote class="valor-quote text-center">
            "Muchos dueños en Coyoacán esperan a que su mascota esté muy decaída
            para traerla a consulta. Para entonces, el problema ya es grave. Un
            perfil bioquímico preventivo cuesta significativamente menos que la
            hospitalización por una enfermedad detectada tarde."
        </blockquote>
    </section>

    <!-- SECCIÓN 4 — LA VENTAJA DE HACERLO EN CLÍNICA -->
    <section class="content-section bg-soft">
        <h2 class="titulo-sec">Precisión y rapidez en el sur de CDMX</h2>

        <div class="ventajas-lista">
            {
                ventajasLista.map((vent) => (
                    <div class="ventaja-item card-ui">
                        <div class="ventaja-icon">
                            <span class="icon-scalable">✅</span>
                        </div>
                        <div class="ventaja-texto">
                            <h3 class="ventaja-titulo">{vent.title}</h3>
                            <p class="ventaja-desc">{vent.desc}</p>
                        </div>
                    </div>
                ))
            }
        </div>
    </section>

    <!-- SECCIÓN 5 — FAQ (PREGUNTAS FRECUENTES) -->
    <section class="content-section">
        <h2 class="titulo-sec">
            Preguntas comunes sobre nuestros análisis clínicos
        </h2>
        <div class="faq-accordion">
            {
                faqs.map((faq) => (
                    <details class="faq-item">
                        <summary class="faq-question">{faq.name}</summary>
                        <p class="faq-answer">{faq.acceptedAnswer.text}</p>
                    </details>
                ))
            }
        </div>
    </section>

    <!-- SECCIÓN 6 — SERVICIOS VINCULADOS -->
    <section class="content-section bg-soft">
        <h2 class="titulo-sec">
            Servicios complementarios en Punto Veterinario
        </h2>
        <div class="grid-auto">
            {
                relacionadosCards.map((s) => (
                    <a href={s.href} class="card-ui">
                        <span class="icon-scalable">{s.emoji}</span>
                        <h3 class="card-titulo">{s.title}</h3>
                        <p class="card-desc">{s.desc}</p>
                        <span class="card-ver">Ver detalles →</span>
                    </a>
                ))
            }
        </div>
    </section>

    <!-- SECCIÓN 7 — CTA FINAL Y CONTACTO LOCAL -->
    <section class="cta-final content-section">
        <h2 class="cta-titulo-blanc">
            ¿Tu mascota necesita estudios de laboratorio?
        </h2>
        <p class="cta-desc-blanc">
            Agenda su toma de muestra de forma rápida y con el menor estrés
            posible. Estamos en Av. División del Norte 3595, San Pablo
            Tepetlapa, atendiendo a pacientes de todo Coyoacán.
        </p>
        <div class="cta-btns">
            <a
                href="https://wa.me/525513843004"
                target="_blank"
                rel="noopener"
                class="btn-cta-blanco"
            >
                💬 Agendar cita por WhatsApp
            </a>
            <a href="/ubicacion" class="btn-cta-outline">
                📍 Ver mapa y horarios
            </a>
        </div>
    </section>
</BaseLayout>

<style>
    /* ====== CLAMP SYSTEM + RESPONSIVE ====== */
    /* No Tailwind/Bootstrap allowed, 100% Fluid Vanilla CSS */

    .content-section {
        padding-block: max(3rem, 6vw);
    }
    .bg-soft {
        background: var(--color-bg-soft);
    }

    .h1-hero {
        font-size: max(1.8rem, 3.2vw);
        color: var(--color-text);
        line-height: 1.15;
        margin-bottom: max(1rem, 2vw);
    }

    .titulo-sec {
        font-size: max(1.6rem, 2.8vw);
        color: var(--color-primary);
        text-align: center;
        margin-bottom: max(2rem, 4vw);
        line-height: 1.2;
    }

    .text-center {
        text-align: center;
    }

    .mb-fluid {
        margin-bottom: max(2rem, 4vw);
    }

    /* HERO CLASSES */
    .hero {
        background: var(--color-bg);
    }
    .hero__inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }
    .hero__text {
        width: 100%;
        margin-inline: auto;
    }
    @media (min-width: 48rem) {
        .hero__text {
        }
    }

    .hero__desc {
        font-size: max(0.95rem, 1.4vw);
        color: var(--color-text-soft);
        line-height: 1.6;
        margin-bottom: max(1.5rem, 2vw);
        margin-inline: auto;
    }

    .hero__btns {
        display: flex;
        flex-wrap: wrap;
        gap: max(0.8rem, 1.5vw);
        margin-bottom: max(1rem, 2vw);
        justify-content: center;
    }

    .btn-wa {
        background: var(--color-primary);
        color: #fff;
        padding: max(0.6rem, 1.2vw) max(1.2rem, 2.5vw);
        font-size: max(0.9rem, 1.2vw);
        border-radius: max(0.4rem, 1vw);
        font-weight: 600;
        text-decoration: none;
        transition:
            background 0.2s,
            transform 0.2s;
    }
    .btn-wa:hover {
        background: var(--color-primary-dark);
        transform: translateY(-0.15rem);
    }

    .btn-sec {
        padding: max(0.6rem, 1.2vw) max(1.2rem, 2.5vw);
        font-size: max(0.9rem, 1.2vw);
        border: max(0.1rem, 0.15vw) solid var(--color-primary-dark);
        color: var(--color-primary-dark);
        background: transparent;
        border-radius: max(0.4rem, 1vw);
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s;
    }
    .btn-sec:hover {
        background: var(--color-primary-dark);
        color: #fff;
        transform: translateY(-0.15rem);
    }

    /* GRID LAYOUTS */
    .grid-estudios {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: max(1.5rem, 3vw);
    }
    .grid-relacionados {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: max(1rem, 2vw);
    }
    @media (
        }
    }
    @media (
        }
    }

    /* CARDS */
    .card {
        background: var(--color-bg);
        border: max(0.05rem, 0.1vw) solid var(--color-border);
        border-radius: max(0.5rem, 1.5vw);
        padding: max(1.2rem, 2vw);
        display: flex;
        flex-direction: column;
        text-decoration: none;
        transition:
            transform 0.3s,
            box-shadow 0.3s;
    }
    .card-estudio,
    .card-servicio,
    .ventaja-item {
        box-shadow: var(--shadow-sm);
    }
    .card-estudio:hover,
    .card-servicio:hover,
    .ventaja-item:hover {
        transform: translateY(-0.25rem);
        box-shadow: var(--shadow-md);
    }

    .card-emoji {
        font-size: max(2rem, 3.5vw);
        margin-bottom: max(0.8rem, 1.2vw);
        display: block;
        text-align: center;
    }

    .card-titulo {
        font-size: max(1.1rem, 1.6vw);
        color: var(--color-primary-dark);
        margin-bottom: max(0.5rem, 1vw);
        line-height: 1.3;
        text-align: center;
    }
    .card-desc {
        font-size: max(0.95rem, 1.3vw);
        color: var(--color-text-soft);
        line-height: 1.6;
        flex-grow: 1;
        margin: 0;
        text-align: center;
    }

    .card-ver {
        display: block;
        text-align: center;
        margin-top: max(1rem, 2vw);
        font-size: max(0.9rem, 1.2vw);
        color: var(--color-primary);
        font-weight: bold;
    }

    /* MITO VS REALIDAD (VERTICAL STACK) */
    .mito-realidad-box {
        display: flex;
        flex-direction: column;
        gap: max(0rem, 0vw); /* No gap, attached */
        border-radius: max(0.5rem, 1vw);
        box-shadow: var(--shadow);
        overflow: hidden;
        border: max(0.05rem, 0.1vw) solid var(--color-border);
    }

    .mito-block,
    .realidad-block {
        display: flex;
        align-items: flex-start;
        gap: max(0.8rem, 1.2vw);
        padding: max(1rem, 1.5vw);
    }
    .mito-block {
        background: var(--color-bg);
        border-bottom: max(0.05rem, 0.1vw) solid var(--color-border);
    }
    .realidad-block {
        background: var(--color-bg-soft);
    }
    .mito-block p,
    .realidad-block p {
        font-size: max(0.95rem, 1.3vw);
        color: var(--color-text-soft);
        margin: 0;
        line-height: 1.6;
    }
    .mito-block p strong {
        color: var(--color-urgencia);
    }
    .realidad-block p strong {
        color: #4caf50;
    }
    .bad-icon,
    .good-icon {
        font-size: max(1.2rem, 1.8vw);
        flex-shrink: 0;
        margin-top: max(0.2rem, 0.4vw);
    }

    /* BLOCKQUOTE */
    .valor-quote {
        background: var(--color-primary-light);
        border-radius: max(0.5rem, 1vw);
        padding: max(1.5rem, 3vw);
        font-size: max(1.1rem, 1.6vw);
        color: var(--color-primary-dark);
        font-style: italic;
        font-weight: 500;
        line-height: 1.6;
        margin: 0 auto;
        position: relative;
        
    }

    /* VENTAJAS LISTA */
    .ventajas-lista {
        display: flex;
        flex-direction: column;
        gap: max(1rem, 2vw);
    }

    .ventaja-item {
        display: flex;
        flex-direction: row;
        align-items: flex-start;
        gap: max(1rem, 2vw);
        text-align: left;
    }
    @media (
            align-items: center;
            text-align: center;
        }
    }

    .ventaja-icon {
        font-size: max(1.5rem, 2.5vw);
        flex-shrink: 0;
        margin-top: max(0.2rem, 0.4vw);
    }
    @media (
        }
    }

    .ventaja-titulo {
        font-size: max(1.1rem, 1.6vw);
        color: var(--color-primary-dark);
        margin-bottom: max(0.5rem, 1vw);
        line-height: 1.3;
    }
    .ventaja-desc {
        font-size: max(0.95rem, 1.3vw);
        color: var(--color-text-soft);
        line-height: 1.6;
        margin: 0;
    }

    /* FAQ ACCORDION */
    .faq-accordion {
        display: flex;
        flex-direction: column;
        gap: max(0.8rem, 1.2vw);
    }
    .faq-item {
        background: var(--color-bg);
        border: max(0.05rem, 0.1vw) solid var(--color-border);
        border-radius: max(0.5rem, 1vw);
        padding: max(1rem, 1.5vw);
    }
    .faq-item[open] .faq-question {
        color: var(--color-primary-dark);
        margin-bottom: max(0.8rem, 1vw);
    }
    .faq-question {
        font-size: max(1rem, 1.4vw);
        font-weight: 600;
        color: var(--color-text);
        cursor: pointer;
        list-style: none; /* Hide default arrow */
        position: relative;
        padding-right: max(2rem, 3vw);
        line-height: 1.4;
    }
    .faq-question::-webkit-details-marker {
        display: none;
    }
    .faq-question::after {
        content: "+";
        position: absolute;
        right: 0;
        top: 0;
        font-size: max(1.2rem, 1.8vw);
        color: var(--color-primary);
    }
    .faq-item[open] .faq-question::after {
        content: "-";
    }
    .faq-answer {
        font-size: max(0.95rem, 1.3vw);
        color: var(--color-text-soft);
        line-height: 1.6;
        margin: 0;
    }

    /* CTA FINAL */
    .cta-final {
        background: var(--color-primary);
        text-align: center;
        color: #fff;
    }
    .cta-titulo-blanc {
        font-size: max(1.6rem, 2.8vw);
        color: #fff;
        margin-bottom: max(1rem, 1.5vw);
        line-height: 1.2;
    }
    .cta-desc-blanc {
        font-size: max(1rem, 1.4vw);
        margin-bottom: max(1.5rem, 2.5vw);
        
        margin-inline: auto;
        color: #fff;
        opacity: 0.9;
        line-height: 1.6;
    }
    @media (
        justify-content: center;
        flex-wrap: wrap;
        gap: max(0.8rem, 1.5vw);
    }
    .btn-cta-blanco {
        background: #fff;
        color: var(--color-primary-dark);
        padding: max(0.6rem, 1.2vw) max(1.2rem, 2.5vw);
        font-size: max(0.9rem, 1.2vw);
        border-radius: max(0.4rem, 1vw);
        font-weight: 600;
        text-decoration: none;
    }
    .btn-cta-outline {
        border: max(0.1rem, 0.15vw) solid #fff;
        color: #fff;
        padding: max(0.6rem, 1.2vw) max(1.2rem, 2.5vw);
        font-size: max(0.9rem, 1.2vw);
        border-radius: max(0.4rem, 1vw);
        font-weight: 600;
        text-decoration: none;
    };
</style>
