---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Schema from "../../components/Schema.astro";

const schema = [
    {
        "@context": "https://schema.org",
        "@type": ["Service", "DiagnosticLab"],
        name: "Laboratorio Veterinario en Coyoacán",
        url: "https://puntoveterinario.com/servicios/laboratorio-clinico",
        description:
            "Laboratorio clínico veterinario en Coyoacán. Análisis de sangre, perfil bioquímico, urianálisis y más. Av. División del Norte 3595, CP 04620.",
        provider: {
            "@type": "VeterinaryCare",
            name: "Punto Veterinario",
            address: {
                "@type": "PostalAddress",
                streetAddress: "Av. División del Norte 3595",
                addressLocality: "San Pablo Tepetlapa",
                postalCode: "04620",
                addressCountry: "MX",
            },
        },
    },
];

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
        {
            "@type": "Question",
            name: "¿Cuánto tarda en estar listo un análisis de sangre para perros?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "La inmensa mayoría absoluta de nuestros resultados para análisis de sangre habituales de rutina preventiva (como biometrías hemáticas exhaustivas o químicas base) son procesados por los avanzados procesadores automatizados con suprema e incomparable velocidad, encontrándose comúnmente listos, corroborados médicamente y plenamente avalados para diagnóstico profesional el mismo día de la inicial extracción, usualmente transcurridas escasas horas de que tu incondicional y amado compañero nos ha facilitado la requerida y vital prueba vascular.",
            },
        },
        {
            "@type": "Question",
            name: "¿Necesita mi mascota ayuno para el análisis de sangre?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "Definitivamente sí. En términos absolutamente invariables y protocolares, solicitamos de manera formal y encarecida que mantengas a tu paciente canino o paciente gatuno bajo un estricto, prolongado y muy cuidadoso ayuno sólido previo de por lo menos unas sólidas y bien contabilizadas 8 a 12 horas consecutivas sin prueba de bocado consistente, permitiéndole única y primordialmente el franco consumo limitado y racional de agua completamente natural bebible fresca, logrando con esto una muestra sanguínea purificada y nítida.",
            },
        },
        {
            "@type": "Question",
            name: "¿Qué es un perfil bioquímico veterinario?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "El célebre y sumamente utilizado perfil bioquímico veterinario extenso es en sí mismo una muy contundente, detallada y formidable radiografía metabólica e invisible. Consta integralmente de un impresionante y meticuloso conjunto simultáneo de invaluables pruebas sanguíneas fraccionadas que analizan al microscopio con minucioso y soberbio detalle científico el impecable desempeño funcional operativo interno de órganos mayúsculos vitales esenciales (como el hígado noble, los eficientes riñones filtradores y el complejo sistema endocrino pancreático).",
            },
        },
        {
            "@type": "Question",
            name: "¿Dónde hacer análisis de sangre para mi perro cerca de Coyoacán?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "Si requieres ejecutar de manera apremiante, diligente y urgente cualquier imperante estudio laboratorial microscópico a nivel periférico sanguíneo sin tener que cruzar de punta a punta la gigantesca ciudad esquivando el pesado y denso y abrumador tránsito automovilístico, Punto Veterinario es a todas luces tu máxima, incuestionable y formidable elección insuperable sureña. Nos encontramos estratégicamente e insuperablemente clavados sobre la célebre Av. División del Norte 3595, inmersos con un cómodo gran acceso en la entrañable e inconfundible y bullanguera colonia de San Pablo Tepetlapa (CP 04620).",
            },
        },
    ],
};

const estudiosCards = [
    {
        emoji: "🩸",
        title: "Biometría hemática completa",
        desc: "Una profunda y exhaustiva cuantificación global irrefutable de los glóbulos rojos acarreadores sistémicos, robustos leucocitos guardianes y plaquetas regenerativas celulares para descartar anemias silenciosas ocultas.",
    },
    {
        emoji: "🔬",
        title: "Perfil bioquímico",
        desc: "Inmensurablemente vital herramienta decodificadora analítica que evidencia contundentemente, exponiendo en un lenguaje bioquímico cristalino todo el comportamiento estructural depuratorio que atraviesan los frágiles riñones e incesante hígado.",
    },
    {
        emoji: "🧪",
        title: "Urianálisis",
        desc: "Magnífico y revelador escaneo preventivo minucioso a nivel líquido y molecular que atestigua mediante el sedimento toda la enorme capacidad funcional para desechar de sus formidables vías y microscópicos uréteres en Coyoacán.",
    },
    {
        emoji: "🦠",
        title: "Cultivos y antibiograma",
        desc: "El invencible y definitivo escudo protector farmacológico por excelencia usado tras sembrar tenazmente intrusivas bacterias malignas latentes y constatar irrefutablemente frente a qué letal arsenal específico sintético ceden las mismas.",
    },
    {
        emoji: "📊",
        title: "Perfil tiroideo",
        desc: "Soberbia y fina medición en base hormonal total para lograr dilucidar certera e instantáneamente el caótico origen real en súbitos incrementos ponderales dramáticos de peso inexplicable o lastimosa y extrema letargia prolongada.",
    },
    {
        emoji: "🩺",
        title: "Coprológico",
        desc: "Un insigne e inesquivable protocolo de examen focalizado directo para desenterrar, confirmar y combatir mediante rotunda prueba incuestionable toda abrumadora e invisible parasitosis sistémica alojada en tramos fecales e intestinos.",
    },
];

const cuandoCards = [
    {
        emoji: "🚨",
        title: "Antes de cualquier cirugía o anestesia",
        desc: "Representa innegable y fervientemente el absoluto resguardo de supervivencia obligatoria previa antes de transitar por nuestra sedación química o de recibir prolongada inhalación inducida narcótica. Los datos revelan viabilidad y mitigan las inestabilidades.",
    },
    {
        emoji: "📅",
        title: "Revisión anual preventiva",
        desc: "Constituye y enarbola la gloriosa y silenciosa piedra angular monumental cimentada en pro de la grandiosa longevidad premonitoria. Se instalan invaluables y valiosos filtros anticipados en Coyoacán esquivando y desviando contundentes amenazas venideras.",
    },
    {
        emoji: "💊",
        title: "Monitoreo de tratamientos crónicos",
        desc: "Un blindaje analítico y sostenido formidablemente imperativo a plazos para constatar inobjetablemente toda la positiva asimilación hepatobiliar corporal ante terapias perennes por convulsiones o de disfunción cardíaca general.",
    },
    {
        emoji: "🤒",
        title: "Cuando el veterinario lo indica por síntomas",
        desc: "El escalón y contundente fundamento irrefutable subsiguiente y decisorio definitivo después de sospechosos hallazgos físicos superficiales inquietantes de palidez en las encías, sed patológica agobiante insaciable o inusitada fatiga pasiva en reposo.",
    },
];

const porQueCards = [
    {
        emoji: "⚡",
        title: "Interpretación y resultados rápidos",
        desc: "Exaltamos y empoderamos vertiginosamente al máximo el impagable bien absoluto de tus preciosos escasos segundos en asfixiantes momentos de apremiante incertidumbre médica apremiante devolviéndote valiosísimos diagnósticos precisos ultra-fluidos y veraces relámpago.",
    },
    {
        emoji: "🔬",
        title: "Equipo de laboratorio moderno",
        desc: "Gozamos ferviente y gratamente de una espectacular e irrenunciable inversión de altísima gama en maquinaria digitalizada con calibración de precisión nanoscópica automatizada para descartar implacablemente e íntegramente las desastrosas y letales falencias accidentales de ojo humano local.",
    },
    {
        emoji: "📍",
        title: "En San Pablo Tepetlapa CP 04620",
        desc: "Una imbatible y monumental ventaja logística sureña capitalina asequible que evita exponer irrazonablemente al cansado paciente agobiado, ubicándonos al pie exacto en el colosal y sumamente vial transcurso citable que representa a diario las banquetas en Av. División del Norte.",
    },
];

const relacionadosCards = [
    {
        title: "Consulta Veterinaria",
        emoji: "🩺",
        href: "/servicios/consulta-veterinaria",
        desc: "El punto germinal y base interpretativa inmaculada global, fundamental para que cada minúsculo resultado bioquímico adquiera un colosal y supremo sentido en la estrategia recuperativa curativa.",
    },
    {
        title: "Cirugía Veterinaria",
        emoji: "🏥",
        href: "/servicios/cirugia-veterinaria",
        desc: "Trascendental paso posterior resolutivo dependiente y atado íntimamente a los positivos análisis preventivos para otorgar siempre colosales e impolutas salvaguardas fisiológicas al quirófano.",
    },
    {
        title: "Esterilización",
        emoji: "✂️",
        href: "/servicios/esterilizacion",
        desc: "Formidable y excelso servicio definitivo poblacional cuya extrema fiabilidad general inalterable depende fuertemente siempre de la favorable aptitud funcional que reportan los incondicionales estudios preoperatorios.",
    },
];
---

<BaseLayout
    title="Laboratorio Veterinario Coyoacán | Análisis Clínicos"
    description="Análisis de sangre, perfil bioquímico y estudios clínicos para mascotas en Coyoacán. Resultados rápidos. Av. División del Norte 3595, CP 04620."
    schema={schema[0]}
>
    <Schema schema={faqSchema} />

    <!-- 1. HERO -->
    <section class="hero bg-white py-xl">
        <div class="container text-center max-w-lg mx-auto">
            <h1 class="text-2xl text-primary-dark mb-md lh-1">
                Laboratorio Veterinario en Coyoacán, CDMX | Punto Veterinario
            </h1>
            <p class="text-lg text-soft mb-lg lh-relaxed">
                Comprendemos profundamente que ante latentes e inquietantes
                sospechas silentes, la colosal y grandísima precisión de
                veredicto microscópico lo abarca y representa categóricamente
                absolutamente todo para preservar la sanidad intocable. Por ello
                apostamos y brindamos unos espectaculares y sorprendentes <strong
                    >resultados rápidos que salvan irrebatibles e inocentes
                    vidas desde San Pablo Tepetlapa (CP 04620)</strong
                >. Un espléndido apoyo de analítica irrenunciable e impecable
                siempre localizable sobre las márgenes de la célebre arteria
                citadina Av. División del Norte 3595 con la calidez y el
                resguardo de nuestro equipo zootecnista.
            </p>
            <div class="flex flex-wrap justify-center gap-md">
                <a
                    href="https://wa.me/525513843004"
                    class="btn-primary text-md px-lg py-sm fw-bold border-radius transition-transform inline-block"
                    target="_blank"
                    rel="noopener"
                >
                    💬 Agendar por WhatsApp
                </a>
                <a
                    href="tel:+525513843004"
                    class="btn-outline text-primary-dark text-md px-lg py-sm fw-bold border-radius transition-transform inline-block"
                >
                    📞 Llamar ahora
                </a>
            </div>
        </div>
    </section>

    <!-- 2. ¿QUÉ ESTUDIOS? -->
    <section class="bg-soft py-xl">
        <div class="container">
            <h2 class="text-center mb-xl text-primary">
                ¿Qué estudios realizamos en nuestro laboratorio?
            </h2>
            <p
                class="text-center text-soft text-md mb-lg lh-relaxed max-w-lg mx-auto"
            >
                Ponemos categórica y permanentemente al servicio absoluto de tu
                familia multiespecie nuestra inestimable plataforma abastada
                biotecnológica provista del extenso y resolutivo catálogo
                minúsculo molecular orgánico.
            </p>
            <div class="grid-3 gap-md">
                {
                    estudiosCards.map((item) => (
                        <div class="card p-lg border-subtle bg-white hover-lift flex-col text-center items-center">
                            <span class="emoji-xl mb-sm block">
                                {item.emoji}
                            </span>
                            <h3 class="text-primary-dark mb-xs text-md">
                                {item.title}
                            </h3>
                            <p class="text-soft text-sm lh-relaxed mt-sm m-0">
                                {item.desc}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 3. ¿CUÁNDO NECESITA TU MASCOTA LABORATORIO? -->
    <section class="bg-white py-xl">
        <div class="container max-w-lg mx-auto text-center">
            <h2 class="text-primary-dark mb-md">
                ¿Cuándo debes llevar a tu mascota al laboratorio en Coyoacán?
            </h2>
            <p class="text-soft text-md mb-lg lh-relaxed">
                Cimentamos y propugnamos irrefutablemente frente a la comunidad
                capitalina la enorme importancia cardinal de las recolecciones
                vasculares regulares por encima del apresurado y extenuante
                pánico reaccionario emergente frente al agudo decaimiento
                perruno y gatuno generalizado e instalado de facto.
            </p>
            <div
                class="grid-2 gap-md text-left bg-soft p-lg border-radius mb-md"
            >
                {
                    cuandoCards.map((item) => (
                        <div class="flex flex-col items-start gap-sm hover-lift card border-subtle bg-white p-sm border-radius-sm">
                            <div class="flex items-center gap-xs">
                                <span class="emoji-md block mt-xs">
                                    {item.emoji}
                                </span>
                                <span class="text-primary-dark fw-bold text-sm lh-relaxed">
                                    {item.title}
                                </span>
                            </div>
                            <p class="text-soft text-sm lh-relaxed m-0 mt-xs">
                                {item.desc}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 4. ¿POR QUÉ ELEGIRNOS? -->
    <section class="bg-soft py-xl">
        <div class="container">
            <h2 class="text-center mb-xl text-primary">
                ¿Por qué confiar en Punto Veterinario para su diagnóstico?
            </h2>
            <div class="grid-3 gap-lg">
                {
                    porQueCards.map((item) => (
                        <div class="card p-lg border-subtle bg-white flex-col gap-sm hover-lift">
                            <div class="flex items-center gap-md mb-sm">
                                <span class="emoji-lg">{item.emoji}</span>
                                <h3 class="text-primary-dark text-md m-0">
                                    {item.title}
                                </h3>
                            </div>
                            <p class="text-soft text-sm lh-relaxed m-0">
                                {item.desc}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 5. FAQ -->
    <section class="bg-white py-xl">
        <div class="container max-w-lg mx-auto">
            <h2 class="text-center mb-xl text-primary-dark">
                Preguntas Frecuentes sobre Laboratorio Veterinario en Coyoacán
            </h2>
            <div class="flex-col gap-lg">
                {
                    faqSchema.mainEntity.map((faq) => (
                        <div class="faq-item p-lg border-subtle bg-soft border-radius transition-transform hover-lift">
                            <h3 class="text-primary text-md mb-sm">
                                {faq.name}
                            </h3>
                            <p class="text-soft text-sm lh-relaxed m-0">
                                {faq.acceptedAnswer.text}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 6. SERVICIOS RELACIONADOS -->
    <section class="bg-soft py-xl">
        <div class="container">
            <h2 class="text-center mb-xl text-primary">
                Otros servicios en Punto Veterinario
            </h2>
            <div class="grid-3 gap-md">
                {
                    relacionadosCards.map((s) => (
                        <a
                            href={s.href}
                            class="card p-lg border-subtle bg-white text-center hover-lift flex-col items-center"
                        >
                            <span class="emoji-xl mb-sm block">{s.emoji}</span>
                            <h3 class="text-primary-dark mb-xs text-md">
                                {s.title}
                            </h3>
                            <p class="text-soft text-sm lh-relaxed my-sm m-0">
                                {s.desc}
                            </p>
                            <span class="text-primary fw-bold text-sm mt-auto inline-block pt-sm">
                                Saber más →
                            </span>
                        </a>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 7. CTA FINAL -->
    <section class="cta-section bg-primary py-xl text-center">
        <div class="container max-w-lg mx-auto">
            <h2 class="text-white mb-lg text-2xl lh-1">
                ¿Tu mascota necesita estudios de laboratorio en Coyoacán?
            </h2>
            <p class="text-white opacity-90 mb-xl text-lg lh-relaxed">
                <a 
  href="https://maps.app.goo.gl/GricGKCzpp6BXJgE7?g_st=aw"
  target="_blank"
  rel="noopener"
  aria-label="Ver ubicación en Google Maps"
  class="maps-link"
>
  Av. División del Norte 3595, San Pablo Tepetlapa, 
  CP 04620, Coyoacán, CDMX
</a>
            </p>
            <div class="flex flex-wrap justify-center gap-md">
                <a
                    href="/contacto"
                    class="btn-white-theme text-primary fw-bold text-md px-lg py-sm border-radius transition-transform inline-block"
                    >📅 Agendar Cita</a
                >
                <a
                    href="https://wa.me/525513843004"
                    target="_blank"
                    rel="noopener"
                    class="btn-outline-white text-white fw-bold text-md px-lg py-sm border-radius transition-transform inline-block"
                    >💬 WhatsApp</a
                >
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    /* Local Fluid CSS Utilities - NO FIXED PX */
    .bg-white {
        background-color: var(--color-bg);
    }
    .bg-soft {
        background-color: var(--color-bg-soft);
    }
    .bg-primary {
        background-color: var(--color-primary);
    }

    .text-white {
        color: var(--color-bg);
    }
    .text-primary {
        color: var(--color-primary);
    }
    .text-primary-dark {
        color: var(--color-primary-dark);
    }
    .text-soft {
        color: var(--color-text-soft);
    }

    .text-center {
        text-align: center;
    }
    .text-left {
        text-align: left;
    }
    .text-sm {
        font-size: var(--text-sm);
    }
    .text-md {
        font-size: var(--text-md);
    }
    .text-lg {
        font-size: var(--text-lg);
    }
    .text-2xl {
        font-size: var(--text-2xl);
    }
    .fw-bold {
        font-weight: 700;
    }

    .block {
        display: block;
    }
    .inline-block {
        display: inline-block;
    }
    .flex {
        display: flex;
    }
    .flex-col {
        display: flex;
        flex-direction: column;
    }
    .flex-wrap {
        flex-wrap: wrap;
    }
    .flex-fill {
        flex: 1;
    }
    .items-center {
        align-items: center;
    }
    .items-start {
        align-items: flex-start;
    }
    .justify-center {
        justify-content: center;
    }

    .m-0 {
        margin: 0;
    }
    .my-sm {
        margin-block: var(--space-sm);
    }
    .mt-sm {
        margin-top: var(--space-sm);
    }
    .mt-xs {
        margin-top: var(--space-xs);
    }
    .mt-auto {
        margin-top: auto;
    }
    .mb-xs {
        margin-bottom: var(--space-xs);
    }
    .mb-sm {
        margin-bottom: var(--space-sm);
    }
    .mb-md {
        margin-bottom: var(--space-md);
    }
    .mb-lg {
        margin-bottom: var(--space-lg);
    }
    .mb-xl {
        margin-bottom: var(--space-xl);
    }
    .mx-auto {
        margin-inline: auto;
    }

    .py-sm {
        padding-block: var(--space-sm);
    }
    .p-sm {
        padding: var(--space-sm);
    }
    .pt-sm {
        padding-top: var(--space-sm);
    }
    .py-xl {
        padding-block: var(--space-xl);
    }
    .p-lg {
        padding: var(--space-lg);
    }
    .px-lg {
        padding-inline: var(--space-lg);
    }

    .gap-xs {
        gap: var(--space-xs);
    }
    .gap-sm {
        gap: var(--space-sm);
    }
    .gap-md {
        gap: var(--space-md);
    }
    .gap-lg {
        gap: var(--space-lg);
    }

    .lh-1 {
        line-height: 1.2;
    }
    .lh-relaxed {
        line-height: 1.6;
    }
    .max-w-lg {
        max-width: 60rem;
    }
    .opacity-90 {
        opacity: 0.9;
    }

    .border-radius {
        border-radius: var(--radius);
    }
    .border-radius-sm {
        border-radius: var(--radius-sm);
    }
    .border-subtle {
        border: 0.1rem solid var(--color-border);
        border-radius: var(--radius-lg);
    }

    .emoji-md {
        font-size: clamp(1.2rem, 2vw, 1.8rem);
        line-height: 1;
        display: block;
    }
    .emoji-lg {
        font-size: clamp(1.5rem, 3vw, 2.5rem);
    }
    .emoji-xl {
        font-size: clamp(2.5rem, 5vw, 4rem);
    }

    .transition-transform {
        transition:
            transform 0.2s ease,
            box-shadow 0.2s ease,
            background-color 0.2s ease,
            color 0.2s ease;
    }
    .hover-lift:hover {
        transform: translateY(-0.2rem);
        box-shadow: var(--shadow-md);
    }

    a {
        text-decoration: none;
    }

    .btn-primary {
        background-color: var(--color-primary);
        color: var(--color-bg);
    }
    .btn-primary:hover {
        background-color: var(--color-primary-dark);
        transform: translateY(-0.15rem);
    }

    .btn-outline {
        background-color: transparent;
        border: 0.15rem solid var(--color-primary-dark);
    }
    .btn-outline:hover {
        background-color: var(--color-primary-dark);
        color: var(--color-bg);
        transform: translateY(-0.15rem);
    }

    .btn-white-theme {
        background-color: var(--color-bg);
        border: 0.15rem solid var(--color-bg);
    }
    .btn-white-theme:hover {
        transform: translateY(-0.2rem);
        box-shadow: var(--shadow-md);
        background-color: var(--color-bg-soft);
    }

    .btn-outline-white {
        background-color: transparent;
        border: 0.15rem solid var(--color-bg);
    }
    .btn-outline-white:hover {
        transform: translateY(-0.2rem);
        background-color: var(--color-bg);
        color: var(--color-primary);
    }

  .maps-link {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: var(--color-primary);
    text-underline-offset: 0.2rem;
    transition: color 0.2s;
  }
  .maps-link:hover {
    color: var(--color-primary);
  }
</style>
