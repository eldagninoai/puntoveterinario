---
import BaseLayout from "../../layouts/BaseLayout.astro";

const schema = {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Estética Canina y Grooming",
    provider: {
        "@type": "VeterinaryCare",
        name: "Punto Veterinario",
        image: "https://puntoveterinario.com/og-image.jpg",
        address: {
            "@type": "PostalAddress",
            streetAddress: "Av. División del Norte 3595",
            addressLocality: "Coyoacán",
            addressRegion: "CDMX",
            postalCode: "04620",
            addressCountry: "MX",
        },
    },
    areaServed: {
        "@type": "AdministrativeArea",
        name: "Coyoacán",
    },
    description:
        "Servicio de estética canina, baño, corte de pelo y grooming para perros en el sur de CDMX. Cuidado del pelaje, uñas y glándulas con enfoque en salud preventiva.",
};

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
        {
            "@type": "Question",
            name: "¿Cuánto cuesta el baño y corte de un perro en Coyoacán?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "El precio de la estética canina depende del tamaño de tu perro, tipo de pelaje y el servicio que requiera (solo baño o corte completo). Escríbenos por WhatsApp al 55 1384 3004 con la raza de tu perro para darte una cotización exacta.",
            },
        },
        {
            "@type": "Question",
            name: "¿Qué incluye el servicio de estética canina?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "Nuestro servicio de grooming incluye baño con champú específico según su tipo de piel, secado, cepillado profesional, corte de pelo (si lo requiere), limpieza de oídos, drenado de glándulas perianales y corte de uñas.",
            },
        },
        {
            "@type": "Question",
            name: "¿Cada cuánto debo bañar a mi perro?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "Depende de la raza y el tipo de pelo. Los perros de pelo largo o rizado necesitan grooming profesional cada 4 a 6 semanas para evitar nudos y dermatitis. Los perros de pelo corto pueden bañarse cada 1 a 2 meses.",
            },
        },
    ],
};

const faqs = faqSchema.mainEntity;

const incluyeCards = [
    {
        emoji: "🛁",
        title: "Baño Profundo",
        desc: "Uso de champú específico para su tipo de piel (sensible, seca, grasa o con hongos) respetando el pH canino.",
    },
    {
        emoji: "✂️",
        title: "Corte y Estilismo",
        desc: "Cortes a tijera o máquina según la raza, incluyendo técnicas como deshedding para razas de doble capa.",
    },
    {
        emoji: "🐾",
        title: "Corte de Uñas",
        desc: "Previene el dolor al caminar y deformaciones posturales a largo plazo.",
    },
    {
        emoji: "👂",
        title: "Limpieza de Oídos",
        desc: "Remoción de exceso de cera y humedad para prevenir infecciones dolorosas (otitis).",
    },
    {
        emoji: "💨",
        title: "Secado Profesional",
        desc: "Eliminación total de la humedad desde la raíz para evitar la proliferación de hongos y malos olores.",
    },
    {
        emoji: "🍑",
        title: "Glándulas Perianales",
        desc: "Drenaje cuidadoso (si el paciente lo requiere) para evitar inflamaciones crónicas.",
    },
];

const relacionadosCards = [
    {
        title: "Consulta Médica",
        emoji: "🩺",
        href: "/servicios/consulta-veterinaria",
        desc: "Revisión general y medicina preventiva.",
    },
    {
        title: "Esterilización",
        emoji: "✂️",
        href: "/servicios/esterilizacion",
        desc: "Procedimiento seguro para perros y gatos.",
    },
    {
        title: "Laboratorio Clínico",
        emoji: "🔬",
        href: "/servicios/laboratorio-clinico",
        desc: "Análisis de sangre y perfiles bioquímicos.",
    },
];
---

<BaseLayout
    title="Estética Canina en Coyoacán (Solo Perros) | Punto Veterinario"
    description="Baño, corte y grooming profesional para perros en Coyoacán. Higiene preventiva con productos específicos para su pH. ¡Agenda en San Pablo Tepetlapa!"
    canonical="https://puntoveterinario.com/servicios/estetica-canina"
>
    <Fragment slot="head">
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
        <script
            type="application/ld+json"
            set:html={JSON.stringify(faqSchema)}
        />
    </Fragment>

    <!-- SECCIÓN 1 — HERO -->
    <section class="hero content-section">
            <div class="hero__text">
                <h1 class="h1-hero">
                    Estética Canina y Grooming en Coyoacán (Exclusivo para
                    Perros)
                </h1>
                <p class="hero__desc">
                    Baño, corte y cuidado profesional del pelaje en San Pablo
                    Tepetlapa. Usamos productos formulados específicamente para
                    el pH canino, convirtiendo la estética canina Coyoacán en
                    una sesión de higiene preventiva para tu mejor amigo.
                </p>
                <div class="hero__btns">
                    <a
                        href="https://wa.me/525513843004"
                        class="btn-wa"
                        target="_blank"
                        rel="noopener"
                    >
                        💬 Cotizar estética por WhatsApp
                    </a>
                    <a href="/ubicacion" class="btn-sec">
                        📍 Ver cómo llegar
                    </a>
                </div>
            </div>
        </section>

    <!-- SECCIÓN 2 — ¿QUÉ INCLUYE? (GROOMING E-E-A-T) -->
    <section class="content-section bg-soft">
            <h2 class="titulo-sec">
                Más que un corte de pelo: higiene preventiva de nariz a cola
            </h2>
            <p class="text-center text-soft intro-desc">
                Durante una sesión de estética en nuestra clínica, no solo
                dejamos a tu perro luciendo increíble; nuestros estilistas están
                capacitados para detectar bultos, infecciones cutáneas o
                parásitos que a veces pasan desapercibidos en casa.
            </p>
            <div class="grid-incluye">
                {
                    incluyeCards.map((item) => (
                        <div class="card card-incluye">
                            <span class="card-emoji">{item.emoji}</span>
                            <h3 class="card-titulo">{item.title}</h3>
                            <p class="card-desc">{item.desc}</p>
                        </div>
                    ))
                }
            </div>
        </section>

    <!-- SECCIÓN 3 — MITO VS REALIDAD (EL PH) -->
    <section class="content-section">
            <div class="mito-content">
                <h2 class="titulo-sec left-align">
                    ¿Por qué no deberías bañar a tu perro con tu shampoo?
                </h2>

                <div class="mito-realidad-box">
                    <div class="mito-block">
                        <span class="bad-icon">❌</span>
                        <p>
                            <strong>El Mito:</strong> "Puedo bañar a mi perro con
                            mi shampoo para personas, o bañarlo muy seguido le hace
                            daño."
                        </p>
                    </div>
                    <div class="realidad-block">
                        <span class="good-icon">✅</span>
                        <p>
                            <strong>La Realidad:</strong> La piel del perro tiene
                            un pH diferente (más alcalino) que la humana. Usar productos
                            para humanos elimina sus aceites naturales y causa resequedad,
                            caspa e irritación. Con el champú veterinario adecuado,
                            la frecuencia correcta de un baño profesional y limpieza
                            en peluquería canina San Pablo Tepetlapa es 100% beneficiosa
                            para su piel e higiene preventiva.
                        </p>
                    </div>
                </div>

                <blockquote class="valor-quote">
                    "En la CDMX, el calor y la contaminación aceleran la
                    acumulación de suciedad y ácaros en el pelaje. Un perro sin
                    nudos y con la piel limpia es un perro menos ansioso, más
                    fresco y mucho más cómodo."
                </blockquote>
            </div>
            <div class="mito-img-box">
                <!-- Placeholder required by user rule instead of AI generated images unless requested -->
                <div class="placeholder-img">
                    <span class="pt-icon">🛁</span>
                    <p>Higiene Preventiva</p>
                </div>
            </div>
        </section>

    <!-- SECCIÓN 4 — FRECUENCIA IDEAL -->
    <section class="content-section bg-soft">
            <h2 class="titulo-sec">
                ¿Cada cuánto necesita venir a la estética?
            </h2>

            <div class="frecuencia-grid">
                <div class="card card-frecuencia card-largo">
                    <h3 class="frec-titulo">
                        Perros de pelo largo o rizado (Poodles, Schnauzers,
                        Maltés)
                    </h3>
                    <p class="frec-sub">Cada 4 a 6 semanas</p>
                    <p class="card-desc">
                        Su pelo se enreda fácilmente. Los nudos no tratados
                        evitan la ventilación de la piel y provocan dermatitis
                        severas.
                    </p>
                </div>
                <div class="card card-frecuencia card-corto">
                    <h3 class="frec-titulo">
                        Perros de pelo corto (Pugs, Chihuahuas, Bulldogs)
                    </h3>
                    <p class="frec-sub">Cada 1 a 2 meses</p>
                    <p class="card-desc">
                        Aunque no requieren corte, el baño profesional con
                        técnica de deshedding ayuda a controlar la caída
                        excesiva de pelo en casa y mantiene sus pliegues
                        limpios.
                    </p>
                </div>
            </div>
        </section>

    <!-- SECCIÓN 5 — FAQ (PREGUNTAS FRECUENTES) -->
    <section class="content-section">
            <h2 class="titulo-sec">
                Preguntas comunes sobre la estética canina en Punto Veterinario
            </h2>
            <div class="faq-accordion">
                {
                    faqs.map((faq) => (
                        <details class="faq-item">
                            <summary class="faq-question">{faq.name}</summary>
                            <p class="faq-answer">{faq.acceptedAnswer.text}</p>
                        </details>
                    ))
                }
            </div>
        </section>

    <!-- SECCIÓN 6 — OTROS SERVICIOS RELACIONADOS -->
    <section class="content-section bg-soft">
            <h2 class="titulo-sec">Cuidado integral para tu mascota</h2>
            <div class="grid-relacionados">
                {
                    relacionadosCards.map((s) => (
                        <a href={s.href} class="card card-servicio">
                            <span class="card-emoji">{s.emoji}</span>
                            <h3 class="card-titulo">{s.title}</h3>
                            <p class="card-desc">{s.desc}</p>
                            <span class="card-ver">Ver detalles →</span>
                        </a>
                    ))
                }
            </div>
        </section>

    <!-- SECCIÓN 7 — CTA FINAL Y CONTACTO LOCAL -->
    <section class="cta-final content-section">
            <h2 class="cta-titulo-blanc">
                ¿Tu perro necesita un baño profesional?
            </h2>
            <p class="cta-desc-blanc">
                Tratamos a tu perro con paciencia y sin estrés. Agenda su cita
                de estética canina en Av. División del Norte 3595, San Pablo
                Tepetlapa. ¡Estamos muy cerca de ti en el sur de CDMX!
            </p>
            <div class="cta-btns">
                <a
                    href="https://wa.me/525513843004"
                    target="_blank"
                    rel="noopener"
                    class="btn-cta-blanco"
                >
                    💬 Cotizar por WhatsApp
                </a>
                <a href="tel:+525513843004" class="btn-cta-outline">
                    📞 Llamar al 55 1384 3004
                </a>
            </div>
        </section>
</BaseLayout>

<style>
    /* ====== CLAMP SYSTEM + RESPONSIVE ====== */

    .content-section {
        padding-block: clamp(3rem, 6vw, 12rem);
    }
    .bg-soft {
        background: var(--color-bg-soft);
    }

    .h1-hero {
        font-size: clamp(1.8rem, 3.2vw, 6rem);
        color: var(--color-text);
        line-height: 1.15;
        margin-bottom: clamp(1rem, 2vw, 3rem);
    }

    .titulo-sec {
        font-size: clamp(1.6rem, 2.8vw, 5rem);
        color: var(--color-primary);
        text-align: center;
        margin-bottom: clamp(2rem, 4vw, 7rem);
        line-height: 1.2;
    }
    .left-align {
        text-align: left;
        margin-bottom: clamp(1.5rem, 3vw, 5rem);
    }

    .intro-desc {
        font-size: clamp(0.95rem, 1.4vw, 2.8rem);
        
        margin-inline: auto;
        margin-bottom: clamp(2rem, 4vw, 7rem);
        line-height: 1.6;
    }

    /* HERO CLASSES */
    .hero {
        background: var(--color-bg);
    }
    .hero__inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: left;
    }
    .hero__text {
        width: 100%;
        margin-inline: auto;
    }
    @media (min-width: 48rem) {
        .hero__text {
            
            text-align: center;
        }
    }

    .hero__desc {
        font-size: clamp(0.95rem, 1.4vw, 2.8rem);
        color: var(--color-text-soft);
        line-height: 1.6;
        margin-bottom: clamp(1.5rem, 2vw, 4rem);
        margin-inline: auto;
    }

    .hero__btns {
        display: flex;
        flex-wrap: wrap;
        gap: clamp(0.8rem, 1.5vw, 3rem);
        margin-bottom: clamp(1rem, 2vw, 4rem);
    }
    @media (min-width: 48rem) {
        .hero__btns {
            justify-content: center;
        }
    }

    .btn-wa {
        background: var(--color-primary);
        color: #fff;
        padding: clamp(0.6rem, 1.2vw, 2.5rem) clamp(1.2rem, 2.5vw, 5rem);
        font-size: clamp(0.9rem, 1.2vw, 2.4rem);
        border-radius: clamp(0.4rem, 1vw, 1.5rem);
        font-weight: 600;
        text-decoration: none;
        transition:
            background 0.2s,
            transform 0.2s;
    }
    .btn-wa:hover {
        background: var(--color-primary-dark);
        transform: translateY(-0.15rem);
    }

    .btn-sec {
        padding: clamp(0.6rem, 1.2vw, 2.5rem) clamp(1.2rem, 2.5vw, 5rem);
        font-size: clamp(0.9rem, 1.2vw, 2.4rem);
        border: clamp(0.1rem, 0.15vw, 0.3rem) solid var(--color-secondary);
        color: var(--color-secondary-dark);
        border-radius: clamp(0.4rem, 1vw, 1.5rem);
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s;
    }
    .btn-sec:hover {
        background: var(--color-secondary);
        color: #fff;
        transform: translateY(-0.15rem);
    }

    /* GRID LAYOUTS */
    .grid-incluye {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: clamp(1rem, 2vw, 4rem);
    }
    .grid-relacionados {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: clamp(1rem, 2vw, 4rem);
    }
    .frecuencia-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: clamp(1rem, 2vw, 4rem);
    }
    @media (max-width: 60rem) {
        .grid-incluye {
            grid-template-columns: repeat(2, 1fr);
        }
        .grid-relacionados {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    @media (max-width: 35rem) {
        .grid-incluye,
        .grid-relacionados,
        .frecuencia-grid {
            grid-template-columns: 1fr;
        }
    }

    /* CARDS */
    .card {
        background: var(--color-bg);
        border: clamp(0.05rem, 0.1vw, 0.2rem) solid var(--color-border);
        border-radius: clamp(0.5rem, 1.5vw, 2.5rem);
        padding: clamp(1.2rem, 2vw, 4rem);
        display: flex;
        flex-direction: column;
        text-decoration: none;
        transition:
            transform 0.3s,
            box-shadow 0.3s;
    }
    .card-incluye:hover,
    .card-servicio:hover {
        transform: translateY(-0.25rem);
        box-shadow: var(--shadow-md);
    }
    .card-frecuencia {
        border-left: clamp(0.3rem, 0.5vw, 1rem) solid var(--color-primary);
    }
    .card-corto {
        border-left-color: var(--color-secondary);
    }

    .card-emoji {
        font-size: clamp(2rem, 3.5vw, 7rem);
        margin-bottom: clamp(0.8rem, 1.2vw, 2.5rem);
        display: block;
        text-align: center;
    }

    .card-titulo {
        font-size: clamp(1.1rem, 1.6vw, 3.2rem);
        color: var(--color-primary-dark);
        margin-bottom: clamp(0.5rem, 1vw, 2rem);
        line-height: 1.3;
        text-align: center;
    }
    .card-desc {
        font-size: clamp(0.9rem, 1.2vw, 2.4rem);
        color: var(--color-text-soft);
        line-height: 1.6;
        flex-grow: 1;
        margin: 0;
        text-align: center;
    }

    .frec-titulo {
        font-size: clamp(1.1rem, 1.5vw, 3rem);
        color: var(--color-primary-dark);
        margin-bottom: clamp(0.2rem, 0.5vw, 1rem);
        line-height: 1.3;
    }
    .frec-sub {
        font-size: clamp(1rem, 1.4vw, 2.8rem);
        color: var(--color-text);
        font-weight: 600;
        margin-bottom: clamp(0.8rem, 1.2vw, 2.5rem);
    }
    .card-frecuencia .card-desc {
        text-align: left;
    }

    .card-ver {
        font-size: clamp(0.9rem, 1.1vw, 2.2rem);
        color: var(--color-primary);
        font-weight: 700;
        margin-top: clamp(0.8rem, 1.2vw, 2.5rem);
        display: inline-block;
        text-align: center;
    }

    /* MITO VS REALIDAD */
    .split-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: clamp(2rem, 4vw, 8rem);
        align-items: center;
    }
    @media (max-width: 48rem) {
        .split-grid {
            grid-template-columns: 1fr;
        }
        .mito-img-box {
            display: none;
        }
    }

    .mito-realidad-box {
        display: flex;
        flex-direction: column;
        gap: clamp(1rem, 2vw, 4rem);
        margin-bottom: clamp(1.5rem, 3vw, 6rem);
    }

    .mito-block,
    .realidad-block {
        display: flex;
        align-items: flex-start;
        gap: clamp(0.8rem, 1.2vw, 2.5rem);
        background: var(--color-bg-soft);
        padding: clamp(1rem, 1.5vw, 3rem);
        border-radius: clamp(0.5rem, 1vw, 2rem);
        border-left: clamp(0.3rem, 0.5vw, 1rem) solid;
        box-shadow: var(--shadow);
    }
    .mito-block {
        border-left-color: var(--color-urgencia);
    }
    .realidad-block {
        border-left-color: #4caf50;
    }
    .mito-block p,
    .realidad-block p {
        font-size: clamp(0.95rem, 1.2vw, 2.4rem);
        color: var(--color-text-soft);
        margin: 0;
        line-height: 1.5;
    }
    .mito-block p strong,
    .realidad-block p strong {
        color: var(--color-text);
    }
    .bad-icon,
    .good-icon {
        font-size: clamp(1.2rem, 1.8vw, 3.5rem);
        flex-shrink: 0;
        margin-top: clamp(0.2rem, 0.4vw, 0.8rem);
    }

    .valor-quote {
        background: var(--color-primary-light);
        border-radius: clamp(0.5rem, 1vw, 2rem);
        padding: clamp(1.2rem, 2vw, 4rem);
        font-size: clamp(1.05rem, 1.4vw, 2.8rem);
        color: var(--color-primary-dark);
        font-style: italic;
        font-weight: 500;
        line-height: 1.6;
        margin: 0;
        position: relative;
    }
    .valor-quote::before {
        content: "«";
        font-size: clamp(2rem, 4vw, 8rem);
        position: absolute;
        top: clamp(-0.5rem, -1vw, -2rem);
        left: clamp(0.5rem, 1vw, 2rem);
        opacity: 0.2;
        font-weight: 700;
        font-style: normal;
    }

    .placeholder-img {
        width: 100%;
        aspect-ratio: 4/5;
        background: var(--color-primary);
        border-radius: clamp(0.5rem, 1.5vw, 2.5rem);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: #fff;
        opacity: 0.8;
    }
    .pt-icon {
        font-size: clamp(4rem, 8vw, 16rem);
        margin-bottom: clamp(1rem, 2vw, 4rem);
    }

    /* FAQ ACCORDION */
    .faq-accordion {
        display: flex;
        flex-direction: column;
        gap: clamp(0.8rem, 1.2vw, 2.5rem);
    }
    .faq-item {
        background: var(--color-bg);
        border: clamp(0.05rem, 0.1vw, 0.2rem) solid var(--color-border);
        border-radius: clamp(0.5rem, 1vw, 2rem);
        padding: clamp(1rem, 1.5vw, 3rem);
    }
    .faq-item[open] .faq-question {
        color: var(--color-primary-dark);
        margin-bottom: clamp(0.8rem, 1vw, 2rem);
    }
    .faq-question {
        font-size: clamp(1rem, 1.3vw, 2.6rem);
        font-weight: 600;
        color: var(--color-text);
        cursor: pointer;
        list-style: none; /* Hide default arrow */
        position: relative;
        padding-right: clamp(2rem, 3vw, 6rem);
        line-height: 1.4;
    }
    .faq-question::-webkit-details-marker {
        display: none;
    }
    .faq-question::after {
        content: "+";
        position: absolute;
        right: 0;
        top: 0;
        font-size: clamp(1.2rem, 1.8vw, 3.5rem);
        color: var(--color-primary);
    }
    .faq-item[open] .faq-question::after {
        content: "-";
    }
    .faq-answer {
        font-size: clamp(0.95rem, 1.2vw, 2.4rem);
        color: var(--color-text-soft);
        line-height: 1.6;
        margin: 0;
    }

    /* CTA FINAL */
    .cta-final {
        background: var(--color-primary);
        text-align: center;
        color: #fff;
    }
    .cta-titulo-blanc {
        font-size: clamp(1.6rem, 2.8vw, 5rem);
        color: #fff;
        margin-bottom: clamp(1rem, 1.5vw, 3rem);
        line-height: 1.2;
    }
    .cta-desc-blanc {
        font-size: clamp(1rem, 1.3vw, 2.6rem);
        margin-bottom: clamp(1.5rem, 2.5vw, 5rem);
        
        margin-inline: auto;
        color: #fff;
        opacity: 0.9;
    }
    @media (max-width: 48rem) {
        .cta-desc-blanc {
            
        }
