---
import BaseLayout from "../../layouts/BaseLayout.astro";

const schema = {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Cirugía Veterinaria",
    provider: {
        "@type": "VeterinaryCare",
        name: "Punto Veterinario",
        image: "https://puntoveterinario.com/og-image.jpg",
        address: {
            "@type": "PostalAddress",
            streetAddress: "Av. División del Norte 3595",
            addressLocality: "Coyoacán",
            addressRegion: "CDMX",
            postalCode: "04620",
            addressCountry: "MX",
        },
    },
    areaServed: {
        "@type": "AdministrativeArea",
        name: "Coyoacán",
    },
    description:
        "Servicio de cirugía veterinaria general y de tejidos blandos en CDMX. Operación de mascotas con anestesia segura, monitoreo continuo y quirófano equipado.",
};

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
        {
            "@type": "Question",
            name: "¿Cuánto cuesta una cirugía veterinaria en CDMX?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "El precio de una cirugía veterinaria varía enormemente dependiendo del procedimiento (extracción de tumores, hernias, etc.), el peso del paciente y los medicamentos necesarios. Escríbenos por WhatsApp al 55 1384 3004 para evaluar tu caso y darte un presupuesto.",
            },
        },
        {
            "@type": "Question",
            name: "¿Cómo debo preparar a mi perro o gato para una cirugía?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "Todo paciente requiere un protocolo prequirúrgico que incluye un ayuno estricto (generalmente de 8 a 12 horas de sólidos) y análisis de sangre previos para garantizar que sus órganos procesarán la anestesia sin riesgos.",
            },
        },
        {
            "@type": "Question",
            name: "¿Qué tipo de cirugías hace un veterinario general?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "Realizamos principalmente cirugías de tejidos blandos, que incluyen extracciones de masas o tumores cutáneos, reparación de hernias, cirugías gastrointestinales, sutura de heridas profundas y esterilizaciones.",
            },
        },
    ],
};

const faqs = faqSchema.mainEntity;

const cirugiasCards = [
    {
        emoji: "✂️",
        title: "Cirugía de Tejidos Blandos",
        desc: "Intervenciones en órganos internos, músculos y piel, incluyendo cirugías gastrointestinales (como extracción de cuerpos extraños).",
    },
    {
        emoji: "🦠",
        title: "Extracción de Masas y Tumores",
        desc: "Remoción de bultos cutáneos o subcutáneos con opción a envío para estudio histopatológico (biopsia).",
    },
    {
        emoji: "🩹",
        title: "Reparación de Hernias",
        desc: "Corrección quirúrgica de hernias umbilicales o inguinales para evitar estrangulamiento de órganos.",
    },
    {
        emoji: "🩸",
        title: "Sutura de Heridas Mayores",
        desc: "Tratamiento y cierre de desgarros, mordeduras profundas o traumatismos que requieren anestesia general.",
    },
];

const protocoloPasos = [
    {
        num: "1",
        title: "Perfil Bioquímico y Hemograma",
        desc: "Antes de cualquier procedimiento con anestesia general, realizamos análisis de sangre obligatorios. Esto nos asegura que los riñones y el hígado de tu mascota funcionan al 100% y pueden metabolizar los fármacos sin riesgo.",
    },
    {
        num: "2",
        title: "Quirófano y Monitoreo Anestésico",
        desc: "Durante la cirugía, mantenemos a tu mascota bajo un estado de inconsciencia controlado y sin dolor, monitoreando constantemente su frecuencia cardíaca, oxigenación y temperatura.",
    },
    {
        num: "3",
        title: "Recuperación y Sutura",
        desc: "Supervisamos su despertar hasta que esté completamente estable. Te entregamos a tu mascota con indicaciones claras sobre el cuidado de la sutura (absorbible o no absorbible) y su tratamiento analgésico para casa.",
    },
];

const relacionadosCards = [
    {
        title: "Laboratorio Clínico",
        emoji: "🔬",
        href: "/servicios/laboratorio-clinico",
        desc: "Estudios prequirúrgicos, biometría hemática y química sanguínea.",
    },
    {
        title: "Consulta Veterinaria",
        emoji: "🩺",
        href: "/servicios/consulta-veterinaria",
        desc: "Valoración general antes de programar cualquier procedimiento.",
    },
    {
        title: "Esterilización",
        emoji: "✂️",
        href: "/servicios/esterilizacion",
        desc: "Cirugía preventiva segura para machos y hembras.",
    },
];
---

<BaseLayout
    title="Cirugía Veterinaria en Coyoacán CDMX | Punto Veterinario"
    description="Cirugías veterinarias de tejidos blandos para perros y gatos en Coyoacán. Quirófano equipado, anestesia segura y estudios prequirúrgicos obligatorios."
    canonical="https://puntoveterinario.com/servicios/cirugia-veterinaria"
>
    <Fragment slot="head">
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
        <script
            type="application/ld+json"
            set:html={JSON.stringify(faqSchema)}
        />
    </Fragment>

    <!-- SECCIÓN 1 — HERO -->
    <section class="hero content-section">
            <div class="hero__text">
                <h1 class="h1-hero">
                    Cirugía Veterinaria para Perros y Gatos en Coyoacán
                </h1>
                <p class="hero__desc">
                    Intervenciones seguras con quirófano equipado y monitoreo
                    anestésico continuo en San Pablo Tepetlapa. Operar en
                    nuestras instalaciones significa menos traslados y menos
                    estrés para tu mascota, con la tranquilidad de un protocolo
                    médico estricto.
                </p>
                <div class="hero__btns">
                    <a
                        href="https://wa.me/525513843004"
                        class="btn-wa"
                        target="_blank"
                        rel="noopener"
                    >
                        💬 Evaluar caso por WhatsApp
                    </a>
                    <a href="tel:+525513843004" class="btn-sec btn-urgencia">
                        📞 Urgencia: Llamar ahora
                    </a>
                </div>
            </div>
        </section>

    <!-- SECCIÓN 2 — TIPOS DE CIRUGÍAS -->
    <section class="content-section bg-soft">
            <h2 class="titulo-sec">
                Procedimientos quirúrgicos seguros en el sur de CDMX
            </h2>
            <p class="text-center text-soft intro-desc">
                Nuestro veterinario cirujano está capacitado para resolver las
                emergencias y patologías más comunes que requieren entrar a
                quirófano, enfocándonos en cirugías de tejidos blandos.
            </p>
            <div class="grid-cirugias">
                {
                    cirugiasCards.map((item) => (
                        <div class="card card-cirugia">
                            <span class="card-emoji">{item.emoji}</span>
                            <h3 class="card-titulo">{item.title}</h3>
                            <p class="card-desc">{item.desc}</p>
                        </div>
                    ))
                }
            </div>
        </section>

    <!-- SECCIÓN 3 — EL PROTOCOLO DE SEGURIDAD -->
    <section class="content-section">
            <h2 class="titulo-sec">
                Nuestra regla de oro: No hay cirugía sin estudios prequirúrgicos
            </h2>

            <div class="timeline-protocolo">
                {
                    protocoloPasos.map((paso) => (
                        <div class="timeline-item">
                            <div class="timeline-marker protocol-marker">
                                {paso.num}
                            </div>
                            <div class="timeline-content card card-protocolo">
                                <h3 class="timeline-titulo">{paso.title}</h3>
                                <p class="card-desc">{paso.desc}</p>
                            </div>
                        </div>
                    ))
                }
            </div>
        </section>

    <!-- SECCIÓN 4 — MITO VS REALIDAD (LA ANESTESIA) -->
    <section class="content-section bg-soft">
            <h2 class="titulo-sec">Desmitificando el quirófano veterinario</h2>

            <div class="mito-realidad-box-vertical mb-fluid">
                <div class="mito-block">
                    <span class="bad-icon">❌</span>
                    <p>
                        <strong>El Mito:</strong> "La anestesia veterinaria es demasiado
                        peligrosa, sobre todo si mi mascota ya está grande."
                    </p>
                </div>
                <div class="realidad-block">
                    <span class="good-icon">✅</span>
                    <p>
                        <strong>La Realidad:</strong> En animales sanos y evaluados
                        previamente, el riesgo anestésico es mínimo y comparable al
                        de los humanos. El verdadero peligro ocurre cuando se opera
                        "a ciegas", sin una valoración sanguínea previa. Por eso nuestros
                        estudios prequirúrgicos son la garantía de que la cirugía
                        veterinaria será segura.
                    </p>
                </div>
            </div>

            <blockquote class="valor-quote text-center">
                "No todos los consultorios están preparados para operar. Las
                cirugías requieren instalaciones adecuadas, esterilización
                instrumental y protocolo de recuperación. En Punto Veterinario
                tienes todo en un solo lugar."
            </blockquote>
        </section>

    <!-- SECCIÓN 5 — FAQ (PREGUNTAS FRECUENTES) -->
    <section class="content-section">
            <h2 class="titulo-sec">Dudas frecuentes antes de una cirugía</h2>
            <div class="faq-accordion">
                {
                    faqs.map((faq) => (
                        <details class="faq-item">
                            <summary class="faq-question">{faq.name}</summary>
                            <p class="faq-answer">{faq.acceptedAnswer.text}</p>
                        </details>
                    ))
                }
            </div>
        </section>

    <!-- SECCIÓN 6 — SERVICIOS DIRECTAMENTE RELACIONADOS -->
    <section class="content-section bg-soft">
            <h2 class="titulo-sec">Servicios complementarios a la cirugía</h2>
            <div class="grid-relacionados">
                {
                    relacionadosCards.map((s) => (
                        <a href={s.href} class="card card-servicio">
                            <span class="card-emoji">{s.emoji}</span>
                            <h3 class="card-titulo">{s.title}</h3>
                            <p class="card-desc">{s.desc}</p>
                            <span class="card-ver">Ver detalles →</span>
                        </a>
                    ))
                }
            </div>
        </section>

    <!-- SECCIÓN 7 — CTA FINAL Y CONTACTO LOCAL -->
    <section class="cta-final content-section">
            <h2 class="cta-titulo-blanc">
                ¿El veterinario te recomendó una cirugía para tu mascota?
            </h2>
            <p class="cta-desc-blanc">
                Si notas un bulto extraño, sufrió un accidente o necesita una
                cirugía de tejidos blandos programada, estamos aquí para
                ayudarte. Operamos con los más altos estándares de seguridad en
                San Pablo Tepetlapa, Coyoacán.
            </p>
            <div class="cta-btns">
                <a
                    href="https://wa.me/525513843004"
                    target="_blank"
                    rel="noopener"
                    class="btn-cta-blanco"
                >
                    💬 Consultar caso por WhatsApp
                </a>
                <a href="/ubicacion" class="btn-cta-outline">
                    📍 Ver ubicación y horarios
                </a>
            </div>
        </section>
</BaseLayout>

<style>
    /* ====== CLAMP SYSTEM + RESPONSIVE ====== */

    .content-section {
        padding-block: clamp(3rem, 6vw, 12rem);
    }
    .bg-soft {
        background: var(--color-bg-soft);
    }

    .h1-hero {
        font-size: clamp(1.8rem, 3.2vw, 6rem);
        color: var(--color-text);
        line-height: 1.15;
        margin-bottom: clamp(1rem, 2vw, 3rem);
    }

    .titulo-sec {
        font-size: clamp(1.6rem, 2.8vw, 5rem);
        color: var(--color-primary);
        text-align: center;
        margin-bottom: clamp(2rem, 4vw, 7rem);
        line-height: 1.2;
    }

    .text-center {
        text-align: center;
    }

    .mb-fluid {
        margin-bottom: clamp(2rem, 4vw, 7rem);
    }

    .intro-desc {
        font-size: clamp(0.95rem, 1.4vw, 2.8rem);
        
        margin-inline: auto;
        margin-bottom: clamp(2rem, 4vw, 7rem);
        line-height: 1.6;
    }

    /* HERO CLASSES */
    .hero {
        background: var(--color-bg);
    }
    .hero__inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }
    .hero__text {
        width: 100%;
        margin-inline: auto;
    }
    @media (min-width: 48rem) {
        .hero__text {
            
        }
    }

    .hero__desc {
        font-size: clamp(0.95rem, 1.4vw, 2.8rem);
        color: var(--color-text-soft);
        line-height: 1.6;
        margin-bottom: clamp(1.5rem, 2vw, 4rem);
        margin-inline: auto;
    }

    .hero__btns {
        display: flex;
        flex-wrap: wrap;
        gap: clamp(0.8rem, 1.5vw, 3rem);
        margin-bottom: clamp(1rem, 2vw, 4rem);
        justify-content: center;
    }

    .btn-wa {
        background: var(--color-primary);
        color: #fff;
        padding: clamp(0.6rem, 1.2vw, 2.5rem) clamp(1.2rem, 2.5vw, 5rem);
        font-size: clamp(0.9rem, 1.2vw, 2.4rem);
        border-radius: clamp(0.4rem, 1vw, 1.5rem);
        font-weight: 600;
        text-decoration: none;
        transition:
            background 0.2s,
            transform 0.2s;
    }
    .btn-wa:hover {
        background: var(--color-primary-dark);
        transform: translateY(-0.15rem);
    }

    .btn-sec {
        padding: clamp(0.6rem, 1.2vw, 2.5rem) clamp(1.2rem, 2.5vw, 5rem);
        font-size: clamp(0.9rem, 1.2vw, 2.4rem);
        border: clamp(0.1rem, 0.15vw, 0.3rem) solid var(--color-secondary);
        color: var(--color-secondary-dark);
        border-radius: clamp(0.4rem, 1vw, 1.5rem);
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s;
    }
    .btn-urgencia {
        border-color: var(--color-urgencia);
        color: var(--color-urgencia);
    }
    .btn-sec:hover {
        background: var(--color-secondary);
        color: #fff;
        border-color: var(--color-secondary);
        transform: translateY(-0.15rem);
    }
    .btn-urgencia:hover {
        background: var(--color-urgencia);
        border-color: var(--color-urgencia);
    }

    /* GRID LAYOUTS */
    .grid-cirugias {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: clamp(1.5rem, 3vw, 6rem);
    }
    .grid-relacionados {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: clamp(1rem, 2vw, 4rem);
    }
    @media (max-width: 75rem) {
        .grid-cirugias {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    @media (max-width: 60rem) {
        .grid-relacionados {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    @media (max-width: 35rem) {
        .grid-cirugias,
        .grid-relacionados {
            grid-template-columns: 1fr;
        }
    }

    /* CARDS */
    .card {
        background: var(--color-bg);
        border: clamp(0.05rem, 0.1vw, 0.2rem) solid var(--color-border);
        border-radius: clamp(0.5rem, 1.5vw, 2.5rem);
        padding: clamp(1.2rem, 2vw, 4rem);
        display: flex;
        flex-direction: column;
        text-decoration: none;
        transition:
            transform 0.3s,
            box-shadow 0.3s;
    }
    .card-cirugia:hover,
    .card-servicio:hover {
        transform: translateY(-0.25rem);
        box-shadow: var(--shadow-md);
    }

    .card-emoji {
        font-size: clamp(2rem, 3.5vw, 7rem);
        margin-bottom: clamp(0.8rem, 1.2vw, 2.5rem);
        display: block;
        text-align: center;
    }

    .card-titulo {
        font-size: clamp(1.1rem, 1.6vw, 3.2rem);
        color: var(--color-primary-dark);
        margin-bottom: clamp(0.5rem, 1vw, 2rem);
        line-height: 1.3;
        text-align: center;
    }
    .card-desc {
        font-size: clamp(0.95rem, 1.3vw, 2.6rem);
        color: var(--color-text-soft);
        line-height: 1.6;
        flex-grow: 1;
        margin: 0;
        text-align: center;
    }

    /* TIMELINE DEL PROTOCOLO DE SEGURIDAD */
    .timeline-protocolo {
        display: flex;
        flex-direction: column;
        gap: clamp(1.5rem, 3vw, 6rem);
        
        margin-inline: auto;
    }
    .timeline-item {
        display: flex;
        align-items: center;
        gap: clamp(1rem, 2vw, 4rem);
    }
    @media (max-width: 48rem) {
        .timeline-item {
            flex-direction: column;
            text-align: center;
        }
        .timeline-protocolo {
            
        }
    }

    .protocol-marker {
        flex-shrink: 0;
        width: clamp(3rem, 5vw, 10rem);
        height: clamp(3rem, 5vw, 10rem);
        background: var(--color-bg);
        border: clamp(0.15rem, 0.2vw, 0.4rem) solid var(--color-primary);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: clamp(1.5rem, 2.5vw, 5rem);
        font-weight: 800;
        color: var(--color-primary-dark);
        box-shadow: var(--shadow);
    }

    .timeline-content {
        flex-grow: 1;
        text-align: left;
        background: var(--color-bg-soft);
    }
    @media (max-width: 48rem) {
        .timeline-content {
            text-align: center;
        }
    }

    .timeline-titulo {
        font-size: clamp(1.1rem, 1.6vw, 3.2rem);
        color: var(--color-primary);
        margin-bottom: clamp(0.5rem, 1vw, 2rem);
        line-height: 1.3;
    }
    .timeline-content .card-desc {
        text-align: left;
    }
    @media (max-width: 48rem) {
        .timeline-content .card-desc {
            text-align: center;
        }
    }

    /* MITO VS REALIDAD (VERTICAL STACK) */
    .mito-realidad-box-vertical {
        display: flex;
        flex-direction: column;
        gap: clamp(0rem, 0vw, 0rem); /* No gap, attached */
        border-radius: clamp(0.5rem, 1vw, 2rem);
        box-shadow: var(--shadow);
        overflow: hidden;
        border: clamp(0.05rem, 0.1vw, 0.2rem) solid var(--color-border);
    }

    .mito-block,
    .realidad-block {
        display: flex;
        align-items: flex-start;
        gap: clamp(0.8rem, 1.2vw, 2.5rem);
        padding: clamp(1rem, 1.5vw, 3rem);
    }
    .mito-block {
        background: var(--color-bg);
        border-bottom: clamp(0.05rem, 0.1vw, 0.2rem) solid var(--color-border);
    }
    .realidad-block {
        background: var(--color-bg-soft);
    }
    .mito-block p,
    .realidad-block p {
        font-size: clamp(0.95rem, 1.3vw, 2.6rem);
        color: var(--color-text-soft);
        margin: 0;
        line-height: 1.6;
    }
    .mito-block p strong {
        color: var(--color-urgencia);
    }
    .realidad-block p strong {
        color: #4caf50;
    }
    .bad-icon,
    .good-icon {
        font-size: clamp(1.2rem, 1.8vw, 3.5rem);
        flex-shrink: 0;
        margin-top: clamp(0.2rem, 0.4vw, 0.8rem);
    }

    /* BLOCKQUOTE */
    .valor-quote {
        background: var(--color-primary-light);
        border-radius: clamp(0.5rem, 1vw, 2rem);
        padding: clamp(1.5rem, 3vw, 6rem);
        font-size: clamp(1.1rem, 1.6vw, 3.2rem);
        color: var(--color-primary-dark);
        font-style: italic;
        font-weight: 500;
        line-height: 1.6;
        margin: 0 auto;
        position: relative;
        
    }

    /* FAQ ACCORDION */
    .faq-accordion {
        display: flex;
        flex-direction: column;
        gap: clamp(0.8rem, 1.2vw, 2.5rem);
    }
    .faq-item {
        background: var(--color-bg);
        border: clamp(0.05rem, 0.1vw, 0.2rem) solid var(--color-border);
        border-radius: clamp(0.5rem, 1vw, 2rem);
        padding: clamp(1rem, 1.5vw, 3rem);
    }
    .faq-item[open] .faq-question {
        color: var(--color-primary-dark);
        margin-bottom: clamp(0.8rem, 1vw, 2rem);
    }
    .faq-question {
        font-size: clamp(1rem, 1.4vw, 2.8rem);
        font-weight: 600;
        color: var(--color-text);
        cursor: pointer;
        list-style: none; /* Hide default arrow */
        position: relative;
        padding-right: clamp(2rem, 3vw, 6rem);
        line-height: 1.4;
    }
    .faq-question::-webkit-details-marker {
        display: none;
    }
    .faq-question::after {
        content: "+";
        position: absolute;
        right: 0;
        top: 0;
        font-size: clamp(1.2rem, 1.8vw, 3.5rem);
        color: var(--color-primary);
    }
    .faq-item[open] .faq-question::after {
        content: "-";
    }
    .faq-answer {
        font-size: clamp(0.95rem, 1.3vw, 2.6rem);
        color: var(--color-text-soft);
        line-height: 1.6;
        margin: 0;
    }

    /* CTA FINAL */
    .cta-final {
        background: var(--color-primary);
        text-align: center;
        color: #fff;
    }
    .cta-titulo-blanc {
        font-size: clamp(1.6rem, 2.8vw, 5rem);
        color: #fff;
        margin-bottom: clamp(1rem, 1.5vw, 3rem);
        line-height: 1.2;
    }
    .cta-desc-blanc {
        font-size: clamp(1rem, 1.4vw, 2.8rem);
        margin-bottom: clamp(1.5rem, 2.5vw, 5rem);
        
        margin-inline: auto;
        color: #fff;
        opacity: 0.9;
        line-height: 1.6;
    }
    @media (max-width: 48rem) {
        .cta-desc-blanc {
            
        }
    }
    .cta-btns {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: clamp(0.8rem, 1.5vw, 3rem);
    }
    .btn-cta-blanco {
        background: #fff;
        color: var(--color-primary-dark);
        padding: clamp(0.6rem, 1.2vw, 2.5rem) clamp(1.2rem, 2.5vw, 5rem);
        font-size: clamp(0.9rem, 1.2vw, 2.4rem);
        border-radius: clamp(0.4rem, 1vw, 1.5rem);
        font-weight: 600;
        text-decoration: none;
    }
