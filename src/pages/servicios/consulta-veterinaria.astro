---
import BaseLayout from "../../layouts/BaseLayout.astro";

const schema = {
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "Service",
            name: "Consulta Veterinaria General",
            provider: {
                "@type": "VeterinaryCare",
                "@id": "https://puntoveterinario.com/#localbusiness",
                name: "Punto Veterinario",
                image: "https://puntoveterinario.com/logo.png",
                address: {
                    "@type": "PostalAddress",
                    streetAddress: "Av. División del Norte 3595",
                    addressLocality: "Coyoacán",
                    addressRegion: "CDMX",
                    postalCode: "04620",
                    addressCountry: "MX",
                },
            },
            areaServed: {
                "@type": "AdministrativeArea",
                name: "Coyoacán",
            },
            description:
                "Consulta médica, chequeo general y medicina preventiva para perros y gatos en el sur de la CDMX. Incluye exploración física completa y anamnesis.",
        },
        {
            "@type": "FAQPage",
            mainEntity: [
                {
                    "@type": "Question",
                    name: "¿Cuánto cuesta una consulta veterinaria en Coyoacán?",
                    acceptedAnswer: {
                        "@type": "Answer",
                        text: "En Punto Veterinario ofrecemos consultas a precios accesibles. Escríbenos por WhatsApp al 55 1384 3004 para darte el costo exacto y orientarte sobre lo que necesita tu mascota.",
                    },
                },
                {
                    "@type": "Question",
                    name: "¿Cada cuánto debo llevar a mi perro al veterinario si parece sano?",
                    acceptedAnswer: {
                        "@type": "Answer",
                        text: "Los perros adultos deben ir al menos 1 vez al año. Los cachorros necesitan 3 a 4 consultas en sus primeros 6 meses. Si tu mascota tiene más de 7 años, recomendamos una revisión cada 6 meses para detectar enfermedades silentes.",
                    },
                },
                {
                    "@type": "Question",
                    name: "¿Qué incluye exactamente una consulta general?",
                    acceptedAnswer: {
                        "@type": "Answer",
                        text: "Incluye anamnesis (historial clínico) y una exploración física completa: auscultación cardíaca y pulmonar, revisión de ojos, oídos, boca, palpación abdominal, revisión de piel, control de peso y temperatura.",
                    },
                },
            ],
        },
    ],
};

const faqs = (schema as any)["@graph"][1].mainEntity;

const incluyeCards = [
    {
        emoji: "🫀",
        title: "Corazón y Pulmones",
        desc: "Auscultación cardíaca y pulmonar para detectar soplos o anomalías respiratorias.",
    },
    {
        emoji: "👀",
        title: "Ojos y Oídos",
        desc: "Búsqueda de infecciones, cataratas tempranas, ácaros o signos de inflamación.",
    },
    {
        emoji: "🦷",
        title: "Boca y Dientes",
        desc: "Revisión de sarro, gingivitis y salud dental (clave para prevenir infecciones internas).",
    },
    {
        emoji: "🩺",
        title: "Palpación Abdominal",
        desc: "Revisión de órganos internos para detectar dolor, masas o inflamaciones anormales.",
    },
    {
        emoji: "🐕",
        title: "Piel y Pelaje",
        desc: "Detección de parásitos (pulgas, garrapatas), alergias, hongos o dermatitis.",
    },
    {
        emoji: "⚖️",
        title: "Peso y Temperatura",
        desc: "Control de condición corporal para prevenir obesidad o desnutrición, y toma de temperatura basal.",
    },
];

const frecuenciaCards = [
    {
        etapa: "Cachorros (0 a 6 meses)",
        frecuencia: "3 a 4 consultas en los primeros meses.",
        desc: "Es vital para iniciar su protocolo de vacunación y desparasitación interna y externa.",
    },
    {
        etapa: "Adultos (1 a 6 años)",
        frecuencia: "Mínimo 1 chequeo anual.",
        desc: "Necesario para actualizar vacunas, desparasitar y hacer un diagnóstico preventivo.",
    },
    {
        etapa: "Seniors (7+ años)",
        frecuencia: "Cada 6 meses.",
        desc: "Envejecen más rápido que nosotros. Las visitas semestrales son cruciales para detectar problemas renales, hepáticos o tumores que son silentes en sus primeras etapas.",
    },
];

const relacionadosCards = [
    {
        title: "Laboratorio Clínico",
        emoji: "💉",
        href: "/servicios/laboratorio-clinico",
        desc: "Análisis de sangre, hemogramas y perfil bioquímico.",
    },
    {
        title: "Esterilización",
        emoji: "✂️",
        href: "/servicios/esterilizacion",
        desc: "Cirugías seguras para perros y gatos.",
    },
    {
        title: "Estética Canina",
        emoji: "🛁",
        href: "/servicios/estetica-canina",
        desc: "Grooming profesional e higiene preventiva.",
    },
];
---

<BaseLayout
    title="Consulta Veterinaria en Coyoacán, CDMX | Punto Veterinario"
    description="Chequeo médico veterinario para perros y gatos en Coyoacán. Diagnóstico, medicina preventiva y revisión física completa. ¡Agenda por WhatsApp hoy mismo!"
    canonical="https://puntoveterinario.com/servicios/consulta-veterinaria"
>
    <Fragment slot="head">
        <meta property="og:type" content="website" />
        <meta property="og:locale" content="es_MX" />
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    </Fragment>

    <!-- SECCIÓN 1 — HERO -->
    <section class="hero content-section">
        <div class="hero__text">
            <h1 class="h1-hero">
                Consulta Veterinaria en Coyoacán para Perros y Gatos
            </h1>
            <p class="hero__desc">
                Medicina preventiva, diagnósticos precisos y trato empático para
                tu mascota en San Pablo Tepetlapa. No esperes a que se ponga
                grave para traerlo — una consulta de rutina hoy te puede ahorrar
                una urgencia mañana.
            </p>
            <div class="hero__btns">
                <a
                    href="https://wa.me/525513843004"
                    class="btn-wa"
                    target="_blank"
                    rel="noopener"
                >
                    💬 Agendar consulta por WhatsApp
                </a>
                <a href="tel:+525513843004" class="btn-sec">
                    📞 Llamar al 55 1384 3004
                </a>
            </div>
        </div>
    </section>

    <!-- SECCIÓN 2 — ¿QUÉ INCLUYE NUESTRO CHEQUEO? -->
    <section class="content-section bg-soft">
        <h2 class="titulo-sec">
            ¿Qué incluye una revisión veterinaria completa?
        </h2>
        <p class="text-center text-soft intro-desc">
            Una consulta general no es solo "ver" a tu mascota. Realizamos una
            exploración física completa de nariz a cola y una anamnesis
            (historial clínico detallado) para asegurar su bienestar total.
        </p>
        <div class="grid-auto">
            {
                incluyeCards.map((item: any) => (
                    <div class="card-ui">
                        <span class="icon-scalable">{item.emoji}</span>
                        <h3 class="card-titulo">{item.title}</h3>
                        <p class="card-desc">{item.desc}</p>
                    </div>
                ))
            }
        </div>
    </section>

    <!-- SECCIÓN 3 — ¿CADA CUÁNTO DEBE IR AL VETERINARIO? -->
    <section class="content-section">
        <h2 class="titulo-sec">
            Frecuencia recomendada para visitar al médico veterinario
        </h2>
        <div class="timeline">
            {
                frecuenciaCards.map((frec: any, index: number) => (
                    <div class="timeline-item">
                        <div class="timeline-marker">{index + 1}</div>
                        <div class="timeline-content card-ui">
                            <h3 class="timeline-titulo">{frec.etapa}</h3>
                            <p class="timeline-sub">{frec.frecuencia}</p>
                            <p class="card-desc">{frec.desc}</p>
                        </div>
                    </div>
                ))
            }
        </div>
    </section>

    <!-- SECCIÓN 4 — EL VALOR DE LA MEDICINA PREVENTIVA (MITO VS. REALIDAD) -->
    <section class="content-section bg-soft">
        <div class="mito-vs-realidad-grid">
            <div class="mito-content">
                <h2 class="titulo-sec left-align">
                    Por qué no debes esperar a que tu mascota se enferme
                </h2>

                <div class="mito-realidad-box">
                    <div class="mito-block">
                        <span class="bad-icon">❌</span>
                        <p>
                            <strong>El Mito:</strong> "Si mi mascota come bien y está
                            activa, no necesita ir al veterinario."
                        </p>
                    </div>
                    <div class="realidad-block">
                        <span class="good-icon">✅</span>
                        <p>
                            <strong>La Realidad:</strong> Muchas enfermedades graves
                            (insuficiencia renal, problemas cardíacos o tumores) no
                            presentan síntomas visibles hasta que están muy avanzadas.
                            El chequeo preventivo las detecta a tiempo.
                        </p>
                    </div>
                </div>
            </div>
            <div class="mito-quote-box">
                <blockquote class="valor-quote">
                    "Detectar una enfermedad temprano mediante medicina
                    preventiva cuesta hasta 5 veces menos que tratar una
                    urgencia médica o realizar una cirugía en etapa avanzada.
                    Cuidamos la salud de tu mascota y tu economía."
                </blockquote>
            </div>
        </div>
    </section>

    <!-- SECCIÓN 5 — FAQ (PREGUNTAS FRECUENTES) -->
    <section class="content-section">
        <h2 class="titulo-sec">
            Preguntas comunes sobre nuestras consultas en Coyoacán
        </h2>
        <div class="faq-accordion">
            {
                faqs.map((faq: any) => (
                    <details class="faq-item">
                        <summary class="faq-question">{faq.name}</summary>
                        <p class="faq-answer">{faq.acceptedAnswer.text}</p>
                    </details>
                ))
            }
        </div>
    </section>

    <!-- SECCIÓN 6 — OTROS SERVICIOS RELACIONADOS -->
    <section class="content-section bg-soft">
        <h2 class="titulo-sec">Otros servicios en nuestra clínica</h2>
        <div class="grid-auto">
            {
                relacionadosCards.map((s: any) => (
                    <a href={s.href} class="card-ui">
                        <span class="icon-scalable">{s.emoji}</span>
                        <h3 class="card-titulo">{s.title}</h3>
                        <p class="card-desc">{s.desc}</p>
                        <span class="card-ver">Ver detalles →</span>
                    </a>
                ))
            }
        </div>
    </section>

    <!-- SECCIÓN 7 — CTA FINAL Y CONTACTO LOCAL -->
    <section class="cta-final content-section">
        <h2 class="cta-titulo-blanc">
            ¿Tu mascota necesita una revisión médica?
        </h2>
        <p class="cta-desc-blanc">
            Agenda tu consulta veterinaria hoy mismo. Nuestro consultorio está
            ubicado en Av. División del Norte 3595, San Pablo Tepetlapa,
            Coyoacán.
        </p>
        <div class="cta-btns">
            <a
                href="https://wa.me/525513843004"
                target="_blank"
                rel="noopener"
                class="btn-cta-blanco"
            >
                💬 Agendar consulta por WhatsApp
            </a>
            <a href="/ubicacion" class="btn-cta-outline">
                📍 Ver ubicación en el mapa
            </a>
        </div>
    </section>
</BaseLayout>

<style>
    .pt-0 {
        padding-top: 0;
    }

    .h1-hero {
        font-size: max(2rem, 5vw); /* Escala idéntica a index.astro */
        text-align: center;
    }

    .left-align {
        text-align: left;
        margin-bottom: max(1.5rem, 3vw);
    }

    /* HERO CLASSES (Overrides) */
    .hero {
        min-height: 100svh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        background: var(--color-bg);
    }
    .hero__inner {
        text-align: left;
    }
    .hero__text {
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    @media (min-width: 64.0625rem) {
        .hero__btns {
            justify-content: center;
        }
    }

    /* Centrado específico para iconos */
    .icon-scalable,
    .card-emoji {
        display: block;
        text-align: center;
        margin-inline: auto;
        font-size: max(3rem, 5vw);
    }

    /* Centrado de texto SOLO en las cards de grids */
    .grid-auto .card-ui,
    .grid-servicios .card-ui {
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    /* TIMELINE */
    .timeline {
        display: flex;
        flex-direction: column;
        gap: max(1.5rem, 3vw);
        margin-inline: auto;
    }
    .timeline-item {
        display: flex;
        align-items: flex-start;
        gap: max(1rem, 2vw);
    }
    .timeline-marker {
        flex-shrink: 0;
        width: max(2.5rem, 4.5vw);
        height: max(2.5rem, 4.5vw);
        background: var(--color-primary);
        color: #fff;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: max(1.2rem, 2vw);
        font-weight: 700;
        margin-top: max(0.5rem, 1vw);
    }
    .timeline-content {
        flex-grow: 1;
        text-align: left;
    }
    .timeline-content .card-desc {
        text-align: left;
    }
    /* Mobile: centra el timeline */
    @media (max-width: 767px) {
        .timeline-item {
            flex-direction: column;
            align-items: center;
        }
        .timeline-content {
            text-align: center;
        }
        .timeline-content .card-desc {
            text-align: center;
        }
    }
    /* Desktop: restaura alineación izquierda en bloques complejos */
    @media (min-width: 64.0625rem) {
        .timeline-content {
            text-align: left;
        }
        .timeline-content .card-desc {
            text-align: left;
        }
        .left-align {
            text-align: left;
        }
        .mito-block p,
        .realidad-block p {
            text-align: left;
        }
    }
    .timeline-titulo {
        font-size: max(1.2rem, 1.8vw);
        color: var(--color-primary-dark);
        margin-bottom: max(0.2rem, 0.5vw);
        line-height: 1.2;
    }
    .timeline-sub {
        font-size: max(1rem, 1.4vw);
        color: var(--color-text);
        font-weight: 600;
        margin-bottom: max(0.8rem, 1.2vw);
    }

    .mito-vs-realidad-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: max(2rem, 4vw);
        align-items: center;
    }
    @media (min-width: 64rem) {
        .mito-vs-realidad-grid {
            grid-template-columns: 1.2fr 1fr;
        }
    }
    .mito-realidad-box {
        display: flex;
        flex-direction: column;
        gap: max(1rem, 2vw);
        margin-bottom: max(1.5rem, 3vw);
    }

    .mito-block,
    .realidad-block {
        display: flex;
        align-items: flex-start;
        gap: max(0.8rem, 1.2vw);
        background: var(--color-bg);
        padding: max(1rem, 1.5vw);
        border-radius: max(0.5rem, 1vw);
        border-left: max(0.3rem, 0.5vw) solid;
        box-shadow: var(--shadow);
    }
    .mito-block {
        border-left-color: var(--color-urgencia);
    }
    .realidad-block {
        border-left-color: #4caf50;
    }
    .mito-block p,
    .realidad-block p {
        font-size: max(0.95rem, 1.2vw);
        color: var(--color-text-soft);
        margin: 0;
        line-height: 1.5;
    }
    .mito-block p strong,
    .realidad-block p strong {
        color: var(--color-text);
    }
    .bad-icon,
    .good-icon {
        font-size: max(1.2rem, 1.8vw);
        flex-shrink: 0;
        margin-top: max(0.2rem, 0.4vw);
    }

    .valor-quote {
        background: var(--color-primary-light);
        border-radius: max(0.5rem, 1vw);
        padding: max(1.2rem, 2vw);
        font-size: max(1.05rem, 1.4vw);
        color: var(--color-primary-dark);
        font-style: italic;
        font-weight: 500;
        line-height: 1.6;
        margin: 0;
        position: relative;
    }
    .valor-quote::before {
        content: "«";
        font-size: max(2rem, 4vw);
        position: absolute;
        top: max(-0.5rem, -1vw);
        left: max(0.5rem, 1vw);
        opacity: 0.2;
        font-weight: 700;
        font-style: normal;
    }
</style>
