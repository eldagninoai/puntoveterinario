---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Schema from "../../components/Schema.astro";

const schema = {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Consulta Veterinaria en Coyoacán",
    url: "https://puntoveterinario.com/servicios/consulta-veterinaria",
    description:
        "Consulta médica veterinaria para perros y gatos en Coyoacán, CDMX. Diagnóstico preciso y atención personalizada en Av. División del Norte 3595.",
    provider: {
        "@type": "VeterinaryCare",
        name: "Punto Veterinario",
        address: {
            "@type": "PostalAddress",
            streetAddress: "Av. División del Norte 3595",
            addressLocality: "Pedregal de Santo Domingo",
            postalCode: "04620",
            addressCountry: "MX",
        },
    },
};

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
        {
            "@type": "Question",
            name: "¿Cuánto cuesta una consulta veterinaria en Coyoacán?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "El costo de una consulta veterinaria en Punto Veterinario es altamente competitivo y accesible para las familias de la zona sur. Nuestro precio incluye una exploración física minuciosa de tu mascota, apertura o actualización del expediente clínico, y la asesoría profesional de nuestros médicos veterinarios especializados. Te invitamos a contactarnos por WhatsApp para conocer el costo exacto y agendar tu cita en Coyoacán, CP 04620.",
            },
        },
        {
            "@type": "Question",
            name: "¿Necesito cita para la consulta veterinaria?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "Aunque siempre hacemos lo posible por atender emergencias de inmediato, para las consultas de rutina y medicina preventiva sugerimos encarecidamente agendar una cita previa. De esta manera, aseguramos que tú y tu mascota reciban la atención médica especializada y el tiempo de calidad exhaustivo que merecen en nuestra veterinaria, sin que tengan que pasar por prolongados y desesperantes tiempos de espera en la sala.",
            },
        },
        {
            "@type": "Question",
            name: "¿Atienden perros y gatos en Punto Veterinario?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "Sí, sin duda. Nuestro equipo médico cuenta con amplísima experiencia y una constante actualización académica en medicina interna y preventiva enfocada exclusivamente a especies de compañía: perros y gatos. Comprendemos a la perfección las profundas diferencias anatómicas, fisiológicas, genéticas y conductuales de ambas especies para poder brindar diagnósticos oportunos y exactos a cada uno de nuestros queridos pacientes caninos y felinos de la zona.",
            },
        },
        {
            "@type": "Question",
            name: "¿Dónde queda la veterinaria más cercana en Pedregal de Santo Domingo?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "Si te encuentras radicado en la zona sur de la ciudad, Punto Veterinario es tu clínica de absoluta confianza más cercana. Estamos estratégicamente ubicados sobre la Av. División del Norte 3595, justo en la colonia Pedregal de Santo Domingo, CP 04620, delegación Coyoacán, en CDMX. Contamos con instalaciones perfectamente equipadas para cualquier requerimiento físico y médico.",
            },
        },
    ],
};

const incluyeCards = [
    {
        emoji: "🩺",
        title: "Exploración física completa",
        desc: "Realizamos una revisión detallada que abarca desde la temperatura y frecuencia cardíaca hasta la evaluación del pelaje, ojos, oídos y mucosas para asegurar el estado general de salud de tu mascota e identificar anormalidades ocultas.",
    },
    {
        emoji: "📋",
        title: "Historial clínico detallado",
        desc: "Llevamos un minucioso registro preciso de cada visita, historial de vacunas aplicadas, desparasitaciones documentadas y antecedentes médicos de relevancia. Esta información vital es crucial para establecer patrones de salud y detectar oportunamente cualquier padecimiento a tiempo.",
    },
    {
        emoji: "💊",
        title: "Diagnóstico y plan de tratamiento",
        desc: "Basándonos objetivamente en nuestra revisión clínica estricta y, de ser necesario médicamente, en pruebas de laboratorio o ultrasonidos diagnósticos adicionales, nuestros experimentados doctores elaboran un plan terapéutico totalmente individualizado, certero y efectivo a largo plazo.",
    },
    {
        emoji: "📅",
        title: "Seguimiento post-consulta",
        desc: "Nuestra noble vocación profesional no termina en el instante en que tú y tu pequeña mascota abandonan el consultorio. Mantenemos una estrecha comunicación y canales abiertos para monitorear fervientemente la adaptación y evolución orgánica al tratamiento recetado.",
    },
];

const alertaCards = [
    {
        emoji: "🚨",
        text: "Falta de apetito o rechazo total al alimento normal por más de 24 horas consecutivas.",
    },
    {
        emoji: "🚨",
        text: "Presencia persistente de vómitos repetitivos o cuadros de diarrea aguda y abundante.",
    },
    {
        emoji: "🚨",
        text: "Letargo marcado a todas horas, debilidad muscular profunda o una apatía inusual repentina.",
    },
    {
        emoji: "🚨",
        text: "Problemas de jadeo excesivo, quejidos o esfuerzo anormal y visible al intentar respirar.",
    },
    {
        emoji: "🚨",
        text: "Exposición ante heridas accidentales, cortes profundos de gran consideración, o sospecha de golpes fuertes.",
    },
    {
        emoji: "🚨",
        text: "Ausencia prolongada de chequeos con un médico veterinario zootecnista (es decir, requerimiento de su necesaria revisión anual preventiva).",
    },
];

const porQueCards = [
    {
        emoji: "❤️",
        title: "Trato personalizado y con amor",
        desc: "Comprendemos íntimamente que tu amado perro o gato no es sólo una simple mascota que cuidar, sino que indudablemente es un integrante entrañable más de la vida e historia en tu hogar. Por esta humana razón principal, es que a las puertas de Punto Veterinario les damos siempre libremente el trato humano, empático, tierno y lleno de compasión que nosotros mismos daríamos incondicionalmente a los nuestros.",
    },
    {
        emoji: "📍",
        title: "En Pedregal de Santo Domingo, CP 04620",
        desc: "Afortunadamente no tienes la ineludible necesidad de estresarte por salir a la calle y recorrer abrumadoras distancias conduciendo ni sufriendo los desgastantes y peligrosos retrasos por tráfico pesado y caótico, esto de nada sirve si radicas y desempeñas tu vida normal a los alrededores de la alcaldía Coyoacán. Ubicándonos al pie del corredor principal de Av. División del Norte, los accesos principales de acercamiento se vuelven maravillosamente prácticos y cómodos.",
    },
    {
        emoji: "🏆",
        title: "Médicos especializados y actualizados",
        desc: "Sabemos plenamente hoy que el gigante y fascinante universo científico de la medicina dedicada a animales sufre metamorfosis y evoluciones drásticas mes con mes. Siendo profesionales dedicados de lleno a este gran ramo, nos vemos absolutamente obligados y al mismo tiempo honrados en asistir continuamente a congresos especializados y realizar simposios exhaustivos. Mantenemos nuestros conocimientos sumamente calibrados al límite de excelencia, con un objetivo intachable.",
    },
];

const relacionadosCards = [
    {
        title: "Esterilización",
        emoji: "✂️",
        href: "/servicios/esterilizacion",
        desc: "Procedimiento quirúrgico seguro y privado con anestesia monitoreada.",
    },
    {
        title: "Laboratorio Clínico",
        emoji: "🔬",
        href: "/servicios/laboratorio-clinico",
        desc: "Análisis minucioso para un diagnóstico biológico sumamente exacto.",
    },
    {
        title: "Estética",
        emoji: "🛁",
        href: "/servicios/estetica-canina-felina",
        desc: "Baños refrescantes de spa y diversos cortes altamente profesionales.",
    },
];
---

<BaseLayout
    title="Consulta Veterinaria Coyoacán | Punto Veterinario"
    description="Consulta veterinaria para perros y gatos en Coyoacán. Diagnóstico preciso, precios accesibles. Av. División del Norte 3595, CP 04620. Agenda hoy."
    schema={schema}
>
    <!-- Inyectar Schema FAQPage -->
    <Schema schema={faqSchema} />

    <!-- 1. HERO -->
    <section class="hero bg-white py-xl">
        <div class="container text-center max-w-lg mx-auto">
            <h1 class="text-2xl text-primary-dark mb-md lh-1">
                Consulta Veterinaria en Coyoacán, CDMX | Punto Veterinario
            </h1>
            <p class="text-lg text-soft mb-lg lh-relaxed">
                Brindamos el servicio más exclusivo y dedicado de <strong
                    >consulta médica veterinaria</strong
                > buscando el máximo bienestar y longevidad en la vida de invaluables
                perros y distinguidos gatos. Ubicados de manera enteramente central
                y altamente accesible para todo vecino, específicamente enclavados
                la demarcación Pedregal de Santo Domingo, CP 04620, garantizamos diagnósticos
                certeros, atención clínica profesional oportuna y de primera respuesta
                rápida, sumado a un amable trato completamente personalizado a tu
                manera de ser y de cuidar de tu animalito. Deposita en nuestro criterio
                experto para preservar el resplandor general en la salud de tu incondicional
                y más puro aliado que te espera a diario al llegar.
            </p>
            <div class="flex flex-wrap justify-center gap-md">
                <a
                    href="https://wa.me/525513843004"
                    class="btn-primary text-md px-lg py-sm fw-bold border-radius transition-transform inline-block"
                    target="_blank"
                    rel="noopener"
                >
                    💬 Agendar por WhatsApp
                </a>
                <a
                    href="tel:+525513843004"
                    class="btn-outline text-primary-dark text-md px-lg py-sm fw-bold border-radius transition-transform inline-block"
                >
                    📞 Llamar ahora
                </a>
            </div>
        </div>
    </section>

    <!-- 2. ¿QUÉ INCLUYE? -->
    <section class="bg-soft py-xl">
        <div class="container">
            <h2 class="text-center mb-xl text-primary">
                ¿Qué incluye la consulta veterinaria en Punto Veterinario?
            </h2>
            <p
                class="text-center text-soft text-md mb-lg max-w-lg mx-auto lh-relaxed"
            >
                A la hora de la salud nunca nos permitiremos jugar dejando
                ningún indicio a las especulaciones o azar. Nuestro juramento
                como médicos exige que en cada pequeña visita logremos aplicar e
                implementar de pies a cabeza nuestro comprobado e inalterable
                protocolo. Consistente en un dictamen generalizado orientativo
                encaminado solo a confirmar o asegurar mediante nuestra
                validación científica certera el bienestar absoluto general para
                la tranquilidad que buscas en tu adorado pero frágil amigo
                animal.
            </p>
            <div class="grid-4 gap-md">
                {
                    incluyeCards.map((item) => (
                        <div class="card p-lg border-subtle bg-white text-center hover-lift flex-col items-center">
                            <span class="emoji-xl mb-sm block">
                                {item.emoji}
                            </span>
                            <h3 class="text-primary-dark mb-xs text-md">
                                {item.title}
                            </h3>
                            <p class="text-soft text-sm lh-relaxed mt-sm m-0">
                                {item.desc}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 3. ¿CUÁNDO LLEVAR A TU MASCOTA? -->
    <section class="bg-white py-xl">
        <div class="container max-w-lg mx-auto text-center">
            <h2 class="text-primary-dark mb-md">
                ¿Cuándo debes llevar a tu mascota al veterinario en Coyoacán?
            </h2>
            <p class="text-soft text-md mb-lg lh-relaxed">
                Evidentemente todos y sin ninguna otra excepción en nuestras
                casas sabemos a ciencia cierta, pero dolorosamente, que los
                dulces integrantes amados recubiertos con pelo que tanto
                consentimos en casa, a diferencia nuestra no presentan ni
                presentarán nunca esa mágica particularidad intelectual avanzada
                del poder verbal para decirnos en propia voz humana con
                exactitud y prontitud ni cómo ni hacia en qué lugar se extienden
                silenciosas e invasivas las sensaciones que padecen en los
                intestinos o sistema óseo de la misma forma al estar doloridos y
                vulnerables. Como responsables custodios primarios y tenedores
                formales directos, debemos observar la realidad siendo muy
                rigurosos analistas silenciosos para lograr llegar al centro
                interpretando todas las claves mediante un monitoreo sistemático
                de pautas. Debemos percibir toda alerta extraña.
            </p>

            <div
                class="grid-2 gap-md text-left bg-soft p-lg border-radius mb-lg"
            >
                {
                    alertaCards.map((item) => (
                        <div class="flex items-start gap-sm hover-lift card border-subtle bg-white p-sm border-radius-sm">
                            <span class="emoji-md block mt-xs">
                                {item.emoji}
                            </span>
                            <span class="text-primary-dark fw-bold text-sm lh-relaxed flex-fill">
                                {item.text}
                            </span>
                        </div>
                    ))
                }
            </div>
            <p
                class="text-soft text-sm lh-relaxed opacity-90 mx-auto"
                style="max-width: 40rem;"
            >
                Frente al advenimiento incipiente de alguno o varios signos
                corporales o indicios comportamentales del tipo anterior, debes
                actuar velozmente. Trata de presentarte sin pretexto.
            </p>
        </div>
    </section>

    <!-- 4. ¿POR QUÉ ELEGIRNOS? -->
    <section class="bg-soft py-xl">
        <div class="container">
            <h2 class="text-center mb-xl text-primary">
                ¿Por qué elegir Punto Veterinario en Coyoacán?
            </h2>
            <div class="grid-3 gap-lg">
                {
                    porQueCards.map((item) => (
                        <div class="card p-lg border-subtle bg-white flex-col gap-sm hover-lift">
                            <div class="flex items-center gap-md mb-sm">
                                <span class="emoji-lg">{item.emoji}</span>
                                <h3 class="text-primary-dark text-md m-0">
                                    {item.title}
                                </h3>
                            </div>
                            <p class="text-soft text-sm lh-relaxed m-0">
                                {item.desc}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 5. FAQ -->
    <section class="bg-white py-xl">
        <div class="container max-w-lg mx-auto">
            <h2 class="text-center mb-xl text-primary-dark">
                Preguntas Frecuentes sobre Consulta Veterinaria en Coyoacán
            </h2>
            <div class="flex-col gap-lg">
                {
                    faqSchema.mainEntity.map((faq) => (
                        <div class="faq-item p-lg border-subtle bg-soft border-radius">
                            <h3 class="text-primary text-md mb-sm">
                                {faq.name}
                            </h3>
                            <p class="text-soft text-sm lh-relaxed m-0">
                                {faq.acceptedAnswer.text}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 6. SERVICIOS RELACIONADOS -->
    <section class="bg-soft py-xl">
        <div class="container">
            <h2 class="text-center mb-xl text-primary">
                Otros servicios en Punto Veterinario
            </h2>
            <div class="grid-3 gap-md">
                {
                    relacionadosCards.map((s) => (
                        <a
                            href={s.href}
                            class="card p-lg border-subtle bg-white text-center hover-lift flex-col items-center"
                        >
                            <span class="emoji-xl mb-sm block">{s.emoji}</span>
                            <h3 class="text-primary-dark mb-xs text-md">
                                {s.title}
                            </h3>
                            <p class="text-soft text-sm lh-relaxed my-sm m-0">
                                {s.desc}
                            </p>
                            <span class="text-primary fw-bold text-sm mt-auto inline-block pt-sm">
                                Ver detalles →
                            </span>
                        </a>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 7. CTA FINAL -->
    <section class="cta-section bg-primary py-xl text-center">
        <div class="container max-w-lg mx-auto">
            <h2 class="text-white mb-lg text-2xl lh-1">
                ¿Tu mascota necesita una consulta en Coyoacán?
            </h2>
            <p class="text-white opacity-90 mb-xl text-lg lh-relaxed">
                Av. División del Norte 3595, Pedregal de Santo Domingo, CP 04620
            </p>
            <div class="flex flex-wrap justify-center gap-md">
                <a
                    href="/contacto"
                    class="btn-white-theme text-primary fw-bold text-md px-lg py-sm border-radius transition-transform inline-block"
                    >📅 Agendar Cita</a
                >
                <a
                    href="https://wa.me/525513843004"
                    target="_blank"
                    rel="noopener"
                    class="btn-outline-white text-white fw-bold text-md px-lg py-sm border-radius transition-transform inline-block"
                    >💬 WhatsApp</a
                >
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    /* Utilidades Globales sin PX */
    .bg-white {
        background-color: var(--color-bg);
    }
    .bg-soft {
        background-color: var(--color-bg-soft);
    }
    .bg-primary {
        background-color: var(--color-primary);
    }

    .text-white {
        color: var(--color-bg);
    }
    .text-primary {
        color: var(--color-primary);
    }
    .text-primary-dark {
        color: var(--color-primary-dark);
    }
    .text-soft {
        color: var(--color-text-soft);
    }

    .text-center {
        text-align: center;
    }
    .text-left {
        text-align: left;
    }
    .text-sm {
        font-size: var(--text-sm);
    }
    .text-md {
        font-size: var(--text-md);
    }
    .text-lg {
        font-size: var(--text-lg);
    }
    .text-2xl {
        font-size: var(--text-2xl);
    }
    .fw-bold {
        font-weight: 700;
    }

    .block {
        display: block;
    }
    .inline-block {
        display: inline-block;
    }
    .flex {
        display: flex;
    }
    .flex-col {
        display: flex;
        flex-direction: column;
    }
    .flex-wrap {
        flex-wrap: wrap;
    }
    .flex-fill {
        flex: 1;
    }
    .items-center {
        align-items: center;
    }
    .items-start {
        align-items: flex-start;
    }
    .justify-center {
        justify-content: center;
    }

    .m-0 {
        margin: 0;
    }
    .my-sm {
        margin-block: var(--space-sm);
    }
    .mt-sm {
        margin-top: var(--space-sm);
    }
    .mt-xs {
        margin-top: var(--space-xs);
    }
    .mt-auto {
        margin-top: auto;
    }
    .mb-xs {
        margin-bottom: var(--space-xs);
    }
    .mb-sm {
        margin-bottom: var(--space-sm);
    }
    .mb-md {
        margin-bottom: var(--space-md);
    }
    .mb-lg {
        margin-bottom: var(--space-lg);
    }
    .mb-xl {
        margin-bottom: var(--space-xl);
    }
    .mx-auto {
        margin-inline: auto;
    }

    .py-sm {
        padding-block: var(--space-sm);
    }
    .p-sm {
        padding: var(--space-sm);
    }
    .pt-sm {
        padding-top: var(--space-sm);
    }
    .py-xl {
        padding-block: var(--space-xl);
    }
    .p-lg {
        padding: var(--space-lg);
    }
    .px-lg {
        padding-inline: var(--space-lg);
    }

    .gap-sm {
        gap: var(--space-sm);
    }
    .gap-md {
        gap: var(--space-md);
    }
    .gap-lg {
        gap: var(--space-lg);
    }

    .lh-1 {
        line-height: 1.2;
    }
    .lh-relaxed {
        line-height: 1.6;
    }
    .max-w-lg {
        max-width: 60rem;
    }
    .opacity-90 {
        opacity: 0.9;
    }

    .border-radius {
        border-radius: var(--radius);
    }
    .border-radius-sm {
        border-radius: var(--radius-sm);
    }
    .border-subtle {
        border: 0.1rem solid var(--color-border);
        border-radius: var(--radius-lg);
    }

    .emoji-md {
        font-size: clamp(1.2rem, 2vw, 1.8rem);
        line-height: 1;
        display: block;
    }
    .emoji-lg {
        font-size: clamp(1.5rem, 3vw, 2.5rem);
    }
    .emoji-xl {
        font-size: clamp(2.5rem, 5vw, 4rem);
    }

    .transition-transform {
        transition:
            transform 0.2s ease,
            box-shadow 0.2s ease,
            background-color 0.2s ease,
            color 0.2s ease;
    }
    .hover-lift:hover {
        transform: translateY(-0.2rem);
        box-shadow: var(--shadow-md);
    }

    a {
        text-decoration: none;
    }

    .btn-primary {
        background-color: var(--color-primary);
        color: var(--color-bg);
    }
    .btn-primary:hover {
        background-color: var(--color-primary-dark);
        transform: translateY(-0.15rem);
    }

    .btn-outline {
        background-color: transparent;
        border: 0.15rem solid var(--color-primary-dark);
    }
    .btn-outline:hover {
        background-color: var(--color-primary-dark);
        color: var(--color-bg);
        transform: translateY(-0.15rem);
    }

    .btn-white-theme {
        background-color: var(--color-bg);
        border: 0.15rem solid var(--color-bg);
    }
    .btn-white-theme:hover {
        transform: translateY(-0.2rem);
        box-shadow: var(--shadow-md);
        background-color: var(--color-bg-soft);
    }

    .btn-outline-white {
        background-color: transparent;
        border: 0.15rem solid var(--color-bg);
    }
    .btn-outline-white:hover {
        transform: translateY(-0.2rem);
        background-color: var(--color-bg);
        color: var(--color-primary);
    }
</style>
