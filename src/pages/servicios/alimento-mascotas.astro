---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Schema from "../../components/Schema.astro";

const schema = [
    {
        "@context": "https://schema.org",
        "@type": "Service",
        name: "Venta de Alimento para Mascotas en Coyoacán",
        url: "https://puntoveterinario.com/servicios/alimento-mascotas",
        description:
            "Tienda de alimento veterinario para mascotas en Coyoacán. Croquetas premium para perros y gatos en Av. División del Norte 3595, CP 04620.",
        provider: {
            "@type": "VeterinaryCare",
            name: "Punto Veterinario",
            address: {
                "@type": "PostalAddress",
                streetAddress: "Av. División del Norte 3595",
                addressLocality: "San Pablo Tepetlapa",
                postalCode: "04620",
                addressCountry: "MX",
            },
        },
    },
];

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
        {
            "@type": "Question",
            name: "¿Qué es mejor: alimento seco o húmedo para perros?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "La indiscutible respuesta óptima recae en una equilibrada combinación médica o en una elección rotundamente basada en los padecimientos individuales de tu mascota. Las excepcionales y fortificadas croquetas de corte seco benefician categóricamente de sobremanera toda la higiene periodontal mecánica y aportan la densidad calórica principal, mientras que las deliciosas dietas de sobrecitos húmedos son insuperables para estimular gratamente el esquivo apetito animal y potenciar crucialmente su rehidratación general diaria si beben poca agua.",
            },
        },
        {
            "@type": "Question",
            name: "¿Cómo elegir las croquetas correctas para mi perro?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "La delicada y responsable e integral elección de la futura bolsa nutricional recae obligatoriamente sobre formales variantes médicas de gran peso zootécnico como la exacta edad biológica, el minúsculo o mediano tamaño final de la raza representativa, su frenético o sedante nivel de incansable actividad metabólica diaria y el control de probables alergias dérmicas recurrentes. Aquí en nuestra sucursal recibes al instante imbatible prescripción de personal altamente calificado para hallar infaliblemente la dosis.",
            },
        },
        {
            "@type": "Question",
            name: "¿Venden alimento para gatos con problemas renales en Coyoacán?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "Por supuesto y de manera muy abundante y primordial. El crítico control sobre el fallo renal agudo en adorables felinos está inexorablemente anclado a severas e irrevocables restricciones de proteínas base sintéticas y limitantes cuotas fosfóricas en los sacos diarios. Mantenemos siempre disponible stock inmediato de maravillosas e impecables fórmulas certificadas y recetadas globales como Renal de Royal Canin o sus excelsas equivalencias en Coyoacán para sostener vitalmente su supervivencia de larga duración.",
            },
        },
        {
            "@type": "Question",
            name: "¿Dónde comprar croquetas veterinarias cerca de San Pablo Tepetlapa?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "En Punto Veterinario dispones orgullosamente y siempre de la mayor y vasta y espectacular variedad capitalina de insuperables croquetas, concentrados y deliciosos aderezos de prescripción local en la célebre Av. División del Norte 3595, justo enclavados profundamente en la segura colonia San Pablo Tepetlapa englobada bajo el consabido CP 04620. Contamos enteramente con abastecimiento inagotable, fresco y genuino al inmejorable alcance vecinal sin desvíos mayúsculos automotrices foráneos agobiantes.",
            },
        },
    ],
};

const alimentosCards = [
    {
        emoji: "🐕",
        title: "Croquetas para perros adultos",
        desc: "Bultos formulados biológicamente de manera equilibrada y contundente para mantener vitalicios y exuberantes la musculatura estriada y proporcionar sostenidas y admirables reservas calóricas diarias a sus paseos capitalinos.",
    },
    {
        emoji: "🐶",
        title: "Alimento para cachorros",
        desc: "Potentísimas y formidables matrices repletas por montones de finísimo DHA neuronal y proteínas hidrolizadas en diminutas y crujientes esferas, que cimientan rotundamente su glorioso y vertiginoso y robusto crecimiento musculoesquelético temprano.",
    },
    {
        emoji: "🐈",
        title: "Croquetas para gatos adultos",
        desc: "Supremas y exquisitas fórmulas altamente balanceadas que controlan irrefutablemente las letales bolas de excesivo pelo ingerido esporádico y mantienen maravillosamente el tracto inferior urinario intocado con acidez estabilizada en todo momento.",
    },
    {
        emoji: "🐱",
        title: "Alimento para gatitos",
        desc: "Sustento miniatura super premium denso en insuperables y formidables grasas provechosas y vital taurina que les permiten desbordar inconmensurable y grata energía traviesa para aprender e investigar insaciablemente su inexplorado y vasto entorno casero.",
    },
    {
        emoji: "🏥",
        title: "Dietas veterinarias especiales",
        desc: "La élite absoluta científica comestible enfocada categóricamente en contener agresivos pero incesantes padecimientos sistémicos tales como las desgastantes anomalías de obesidad severa, la letal y silenciosa diabetes subte y los devastadores malestares cutáneos generalizados.",
    },
    {
        emoji: "🌿",
        title: "Alimento natural y sin cereales",
        desc: "Vasta selección sublime incondicionalmente reservada a estómagos ultra sensibles intolerantes o para ejemplares exóticos portadores de asimilación débil que reclaman encarecidamente exquisita saciedad ancestral silvestre libre rotundamente de gluten denso en Coyoacán.",
    },
];

const porqueAlimentoCards = [
    {
        emoji: "💪",
        title: "Mejor nutrición = menos enfermedades",
        desc: "Un insuperable sistema hermético inmunológico invencible se forja indudablemente comenzando desde lo profundo e interno del vasto tejido tracto digestivo, impidiendo colosalmente inusitados ingresos virales o bacterianos de contagio furtivo.",
    },
    {
        emoji: "🦷",
        title: "Cuida dientes y digestión",
        desc: "La gran y precisa fricción estandarizada incesante sobre la fuerte e inquebrantable estructura ósea y maxilar en cada bocado seco disminuye infalible y progresivamente dolorosas e incómodas formaciones dentales de sarro calcificado amarillento adosado.",
    },
    {
        emoji: "✨",
        title: "Pelaje sano y brillante",
        desc: "La espléndida, lujosa y majestuosa adición inmaculada natural de insustituibles y esenciales aceites purificados omega tres propicia exuberantemente sedosas y brillantes texturas visuales envidiables libres de resequedades pruriginosas incómodas generalizadas.",
    },
    {
        emoji: "🩺",
        title: "Recomendado por nuestros veterinarios",
        desc: "Garantizamos y sustentamos ciegamente e irrefutablemente desde la noble y pura ética profesional nuestra rotunda sugerencia nutricional basados siempre en abrumadora evidencia casuística inesquivable empírica clínica contundente y local sureña.",
    },
];

const porQueElegirnosCards = [
    {
        emoji: "🩺",
        title: "Asesoría veterinaria incluida",
        desc: "No somos categórica y simplemente aburridos despachadores apáticos, somos profesionales que en todo acto indicamos la proporción nutritiva intachable exenta de perjudiciales engordas infundadas. La dosis imperativa y los volúmenes en Coyoacán te los marcamos nosotros.",
    },
    {
        emoji: "🏆",
        title: "Marcas súper y ultra premium",
        desc: "Nuestros robustos e imponentes estantes comerciales descansan albergando irrebatiblemente a las auténticas potencias nutritivas planetarias como Hill's Science Diet y la incuestionable Royal Canin genuinamente fresca sin riesgo alguno nocivo de severas caducidades rebasadas o alteradas.",
    },
    {
        emoji: "📍",
        title: "En San Pablo Tepetlapa CP 04620",
        desc: "Proveerse de voluminosas e imponentes pacas fortificadas resultará increíblemente holgado transitar en auto localmente y regresar cargado a cualquier hogar radicado contiguo a tan legendaria avenida sureña del Pedregal. Olvida las pesadas horas foráneas desaprovechadas acarreando.",
    },
];

const relacionadosCards = [
    {
        title: "Consulta Veterinaria",
        emoji: "🩺",
        href: "/servicios/consulta-veterinaria",
        desc: "El dictamen esencial previo y oportuno de inmenso y gran valor médico referencial para determinar sin medias tintas la imperativa bolsa nutricional de rescate o de vigoroso fortalecimiento biológico.",
    },
    {
        title: "Laboratorio Clínico",
        emoji: "🔬",
        href: "/servicios/laboratorio-clinico",
        desc: "Conocer e identificar la cruda realidad metabólica interna revelada en las infalibles biometrías para afinar abrumadoramente el rumbo hacia una inigualable y correcta prescripción de alimento dietético curativo.",
    },
    {
        title: "Estética Canina y Felina",
        emoji: "✂️",
        href: "/servicios/estetica-canina-felina",
        desc: "El colosal y supremo acompañante de belleza extrínseca de la nutrición; porque de nada sirve brillar y ostentar innegable salud desde el estómago, si no se luce y exuda externamente impecable.",
    },
];
---

<BaseLayout
    title="Alimento para Mascotas Coyoacán | Tienda Veterinaria"
    description="Venta de croquetas y alimento premium para perros y gatos en Coyoacán. Royal Canin, Hills y más. Av. División del Norte 3595, CP 04620, Coyoacán."
    schema={schema[0]}
>
    <Schema schema={faqSchema} />

    <!-- 1. HERO -->
    <section class="hero bg-white py-xl">
        <div class="container text-center max-w-lg mx-auto">
            <h1 class="text-2xl text-primary-dark mb-md lh-1">
                Alimento para Mascotas en Coyoacán, CDMX | Punto Veterinario
            </h1>
            <p class="text-lg text-soft mb-lg lh-relaxed">
                El fundamento invencible que resguarda absolutamente una
                prolongada y espléndida estancia longeva es infaliblemente
                inyectar la correcta combustión. Despliega majestuosos <strong
                    >abastecimientos y costales en venta repletos de la
                    excelencia en alimento premium, recomendado por veterinarios
                    a nivel global en nuestro céntrico punto del Pedregal de
                    Santo Domingo (CP 04620)</strong
                >. Respaldamos incondicionalmente los tractos y las estéticas
                corporales proveyendo raciones formidables resguardadas
                intachablemente en la afamada clínica apostada sobre Av.
                División del Norte 3595.
            </p>
            <div class="flex flex-wrap justify-center gap-md">
                <a
                    href="https://wa.me/525513843004"
                    class="btn-primary text-md px-lg py-sm fw-bold border-radius transition-transform inline-block"
                    target="_blank"
                    rel="noopener"
                >
                    💬 Agendar por WhatsApp
                </a>
                <a
                    href="tel:+525513843004"
                    class="btn-outline text-primary-dark text-md px-lg py-sm fw-bold border-radius transition-transform inline-block"
                >
                    📞 Llamar ahora
                </a>
            </div>
        </div>
    </section>

    <!-- 2. ¿QUÉ ALIMENTOS MANEJAMOS? -->
    <section class="bg-soft py-xl">
        <div class="container">
            <h2 class="text-center mb-xl text-primary">
                Alimento veterinario premium para tu mascota en Coyoacán
            </h2>
            <p
                class="text-center text-soft text-md mb-lg lh-relaxed max-w-lg mx-auto"
            >
                Sostenemos con sumo vigor en estantes los gigantes mundiales de
                nutrición que invariablemente garantizan biológicamente una
                incuestionable pureza exenta de letales desperdicios calóricos.
            </p>
            <div class="grid-3 gap-md">
                {
                    alimentosCards.map((item) => (
                        <div class="card p-lg border-subtle bg-white hover-lift flex-col text-center items-center">
                            <span class="emoji-xl mb-sm block">
                                {item.emoji}
                            </span>
                            <h3 class="text-primary-dark mb-xs text-md">
                                {item.title}
                            </h3>
                            <p class="text-soft text-sm lh-relaxed mt-sm m-0">
                                {item.desc}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 3. ¿POR QUÉ ALIMENTO VETERINARIO? -->
    <section class="bg-white py-xl">
        <div class="container max-w-lg mx-auto text-center">
            <h2 class="text-primary-dark mb-md">
                ¿Por qué tu mascota merece alimento de calidad?
            </h2>
            <p class="text-soft text-md mb-lg lh-relaxed">
                Renunciar rotundamente y al instante a las dietas burdas de
                supermercado comercial conformará de inmediato un inestimable
                parteaguas abismal salvador entre interminables cuentas
                infructuosas de apabullante hospitalización a plazos o años
                desbordantes de jovial travesura. Destacamos a continuación
                asombrosos argumentos.
            </p>
            <div
                class="grid-2 gap-md text-left bg-soft p-lg border-radius mb-md"
            >
                {
                    porqueAlimentoCards.map((item) => (
                        <div class="flex flex-col items-start gap-sm hover-lift card border-subtle bg-white p-sm border-radius-sm">
                            <div class="flex items-center gap-xs">
                                <span class="emoji-md block mt-xs">
                                    {item.emoji}
                                </span>
                                <span class="text-primary-dark fw-bold text-sm lh-relaxed">
                                    {item.title}
                                </span>
                            </div>
                            <p class="text-soft text-sm lh-relaxed m-0 mt-xs">
                                {item.desc}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 4. ¿POR QUÉ ELEGIRNOS? -->
    <section class="bg-soft py-xl">
        <div class="container">
            <h2 class="text-center mb-xl text-primary">
                ¿Por qué adquirir su sustento con nosotros?
            </h2>
            <div class="grid-3 gap-lg">
                {
                    porQueElegirnosCards.map((item) => (
                        <div class="card p-lg border-subtle bg-white flex-col gap-sm hover-lift">
                            <div class="flex items-center gap-md mb-sm">
                                <span class="emoji-lg">{item.emoji}</span>
                                <h3 class="text-primary-dark text-md m-0">
                                    {item.title}
                                </h3>
                            </div>
                            <p class="text-soft text-sm lh-relaxed m-0">
                                {item.desc}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 5. FAQ -->
    <section class="bg-white py-xl">
        <div class="container max-w-lg mx-auto">
            <h2 class="text-center mb-xl text-primary-dark">
                Preguntas Frecuentes sobre Alimento para Mascotas en Coyoacán
            </h2>
            <div class="flex-col gap-lg">
                {
                    faqSchema.mainEntity.map((faq) => (
                        <div class="faq-item p-lg border-subtle bg-soft border-radius transition-transform hover-lift">
                            <h3 class="text-primary text-md mb-sm">
                                {faq.name}
                            </h3>
                            <p class="text-soft text-sm lh-relaxed m-0">
                                {faq.acceptedAnswer.text}
                            </p>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 6. SERVICIOS RELACIONADOS -->
    <section class="bg-soft py-xl">
        <div class="container">
            <h2 class="text-center mb-xl text-primary">
                Otros servicios en Punto Veterinario
            </h2>
            <div class="grid-3 gap-md">
                {
                    relacionadosCards.map((s) => (
                        <a
                            href={s.href}
                            class="card p-lg border-subtle bg-white text-center hover-lift flex-col items-center"
                        >
                            <span class="emoji-xl mb-sm block">{s.emoji}</span>
                            <h3 class="text-primary-dark mb-xs text-md">
                                {s.title}
                            </h3>
                            <p class="text-soft text-sm lh-relaxed my-sm m-0">
                                {s.desc}
                            </p>
                            <span class="text-primary fw-bold text-sm mt-auto inline-block pt-sm">
                                Saber más →
                            </span>
                        </a>
                    ))
                }
            </div>
        </div>
    </section>

    <!-- 7. CTA FINAL -->
    <section class="cta-section bg-primary py-xl text-center">
        <div class="container max-w-lg mx-auto">
            <h2 class="text-white mb-lg text-2xl lh-1">
                ¿Buscas alimento premium para tu mascota en Coyoacán?
            </h2>
            <p class="text-white opacity-90 mb-xl text-lg lh-relaxed">
                <a 
  href="https://maps.app.goo.gl/GricGKCzpp6BXJgE7?g_st=aw"
  target="_blank"
  rel="noopener"
  aria-label="Ver ubicación en Google Maps"
  class="maps-link"
>
  Av. División del Norte 3595, San Pablo Tepetlapa, 
  CP 04620, Coyoacán, CDMX
</a>
            </p>
            <div class="flex flex-wrap justify-center gap-md">
                <a
                    href="/contacto"
                    class="btn-white-theme text-primary fw-bold text-md px-lg py-sm border-radius transition-transform inline-block"
                    >📅 Agendar Cita</a
                >
                <a
                    href="https://wa.me/525513843004"
                    target="_blank"
                    rel="noopener"
                    class="btn-outline-white text-white fw-bold text-md px-lg py-sm border-radius transition-transform inline-block"
                    >💬 WhatsApp</a
                >
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    /* Local Fluid CSS Utilities - NO FIXED PX */
    .bg-white {
        background-color: var(--color-bg);
    }
    .bg-soft {
        background-color: var(--color-bg-soft);
    }
    .bg-primary {
        background-color: var(--color-primary);
    }

    .text-white {
        color: var(--color-bg);
    }
    .text-primary {
        color: var(--color-primary);
    }
    .text-primary-dark {
        color: var(--color-primary-dark);
    }
    .text-soft {
        color: var(--color-text-soft);
    }

    .text-center {
        text-align: center;
    }
    .text-left {
        text-align: left;
    }
    .text-sm {
        font-size: var(--text-sm);
    }
    .text-md {
        font-size: var(--text-md);
    }
    .text-lg {
        font-size: var(--text-lg);
    }
    .text-2xl {
        font-size: var(--text-2xl);
    }
    .fw-bold {
        font-weight: 700;
    }

    .block {
        display: block;
    }
    .inline-block {
        display: inline-block;
    }
    .flex {
        display: flex;
    }
    .flex-col {
        display: flex;
        flex-direction: column;
    }
    .flex-wrap {
        flex-wrap: wrap;
    }
    .flex-fill {
        flex: 1;
    }
    .items-center {
        align-items: center;
    }
    .items-start {
        align-items: flex-start;
    }
    .justify-center {
        justify-content: center;
    }

    .m-0 {
        margin: 0;
    }
    .my-sm {
        margin-block: var(--space-sm);
    }
    .mt-sm {
        margin-top: var(--space-sm);
    }
    .mt-xs {
        margin-top: var(--space-xs);
    }
    .mt-auto {
        margin-top: auto;
    }
    .mb-xs {
        margin-bottom: var(--space-xs);
    }
    .mb-sm {
        margin-bottom: var(--space-sm);
    }
    .mb-md {
        margin-bottom: var(--space-md);
    }
    .mb-lg {
        margin-bottom: var(--space-lg);
    }
    .mb-xl {
        margin-bottom: var(--space-xl);
    }
    .mx-auto {
        margin-inline: auto;
    }

    .py-sm {
        padding-block: var(--space-sm);
    }
    .p-sm {
        padding: var(--space-sm);
    }
    .pt-sm {
        padding-top: var(--space-sm);
    }
    .py-xl {
        padding-block: var(--space-xl);
    }
    .p-lg {
        padding: var(--space-lg);
    }
    .px-lg {
        padding-inline: var(--space-lg);
