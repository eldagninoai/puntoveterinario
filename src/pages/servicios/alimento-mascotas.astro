---
import BaseLayout from "../../layouts/BaseLayout.astro";

const schema = {
    "@context": "https://schema.org",
    "@type": "Service",
    name: "Venta de Alimento y Asesoría Nutricional",
    provider: {
        "@type": "VeterinaryCare",
        name: "Punto Veterinario",
        image: "https://puntoveterinario.com/og-image.jpg",
        address: {
            "@type": "PostalAddress",
            streetAddress: "Av. División del Norte 3595",
            addressLocality: "Coyoacán",
            addressRegion: "CDMX",
            postalCode: "04620",
            addressCountry: "MX",
        },
    },
    areaServed: {
        "@type": "AdministrativeArea",
        name: "Coyoacán",
    },
    description:
        "Alimento premium para perros y gatos en el sur de CDMX. Venta de croquetas de mantenimiento y dietas medicadas/terapéuticas (renal, hepático, urinario).",
};

const faqSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
        {
            "@type": "Question",
            name: "¿Cuál es el mejor alimento para mi perro o gato?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "El mejor alimento depende de la edad, tamaño, raza y condición médica de tu mascota (por ejemplo, si está esterilizado o tiene problemas renales). Visítanos en Coyoacán para evaluar su condición corporal y recomendarte la dieta ideal.",
            },
        },
        {
            "@type": "Question",
            name: "¿El alimento de veterinaria es mejor que el del supermercado?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "Sí. La diferencia principal radica en la digestibilidad, el origen de las proteínas y la densidad de nutrientes. Los alimentos de supermercado suelen tener muchos rellenos que, a largo plazo, pueden causar problemas renales, cutáneos y articulares.",
            },
        },
        {
            "@type": "Question",
            name: "¿Venden alimento terapéutico o medicado para mascotas enfermas?",
            acceptedAnswer: {
                "@type": "Answer",
                text: "Sí, contamos con dietas terapéuticas especializadas (para problemas renales, hepáticos, urinarios o alergias alimentarias) que solo se venden bajo prescripción veterinaria.",
            },
        },
    ],
};

const faqs = faqSchema.mainEntity;

const alimentosCards = [
    {
        emoji: "🦴",
        title: "Alimento de Mantenimiento",
        desc: "Fórmulas balanceadas para perros y gatos adultos sanos. Ingredientes de alta digestibilidad que garantizan heces firmes, pelaje brillante y energía constante.",
    },
    {
        emoji: "🩺",
        title: "Dietas Terapéuticas / Medicadas",
        desc: "Alimentos formulados específicamente para tratar enfermedades (insuficiencia renal, problemas hepáticos, cálculos urinarios o alergias). Estas dietas son parte vital del tratamiento y requieren prescripción veterinaria.",
    },
    {
        emoji: "⚖️",
        title: "Control de Peso y Esterilizados",
        desc: "Alimento bajo en calorías para prevenir la obesidad, especialmente diseñado para mascotas esterilizadas o senior que tienen un metabolismo basal más lento.",
    },
];

const ventajasLista = [
    {
        title: "Asesoría sobre la porción correcta",
        desc: "Evaluamos la condición corporal de tu mascota (escala del 1 al 9) para indicarte exactamente cuántos gramos debe comer al día y evitar la obesidad.",
    },
    {
        title: "Transición segura de alimento",
        desc: "Te explicamos el protocolo gradual de 7 a 10 días para cambiar de croquetas sin causarle vómito o diarrea.",
    },
    {
        title: "Almacenamiento y frescura garantizada",
        desc: "A diferencia de negocios informales o tianguis, garantizamos la cadena de almacenamiento correcto para que el alimento no pierda propiedades ni desarrolle hongos.",
    },
];

const relacionadosCards = [
    {
        title: "Consulta Médica",
        emoji: "🩺",
        href: "/servicios/consulta-veterinaria",
        desc: "Evaluación de la condición corporal y prescripción de dieta.",
    },
    {
        title: "Laboratorio Clínico",
        emoji: "🔬",
        href: "/servicios/laboratorio-clinico",
        desc: "Análisis para determinar si tu mascota necesita alimento terapéutico renal o hepático.",
    },
    {
        title: "Esterilización",
        emoji: "✂️",
        href: "/servicios/esterilizacion",
        desc: "Te asesoramos sobre el alimento ideal post-cirugía para evitar el aumento de peso.",
    },
];
---

<BaseLayout
    title="Alimento para Perros y Gatos en Coyoacán | Punto Veterinario"
    description="Venta de alimento premium y dietas terapéuticas para mascotas en Coyoacán. Croquetas especializadas, control de peso y asesoría nutricional. ¡Visítanos!"
    canonical="https://puntoveterinario.com/servicios/alimento-mascotas"
>
    <Fragment slot="head">
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
        <script
            type="application/ld+json"
            set:html={JSON.stringify(faqSchema)}
        />
    </Fragment>

    <!-- SECCIÓN 1 — HERO -->
    <section class="hero content-section">
            <div class="hero__text">
                <h1 class="h1-hero">
                    Alimento Premium y Dietas Terapéuticas en Coyoacán
                </h1>
                <p class="hero__desc">
                    La nutrición es el factor más importante en la longevidad y
                    calidad de vida de tu mascota. Encuentra croquetas de alta
                    digestibilidad y dietas especializadas en San Pablo
                    Tepetlapa, CDMX, con la asesoría directa de nuestros médicos
                    veterinarios.
                </p>
                <div class="hero__btns">
                    <a
                        href="https://wa.me/525513843004"
                        class="btn-wa"
                        target="_blank"
                        rel="noopener"
                    >
                        💬 Consultar disponibilidad por WhatsApp
                    </a>
                    <a href="/ubicacion" class="btn-sec">
                        📍 Ver ubicación de la clínica
                    </a>
                </div>
            </div>
        </section>

    <!-- SECCIÓN 2 — TIPOS DE ALIMENTO QUE MANEJAMOS -->
    <section class="content-section bg-soft">
            <h2 class="titulo-sec">
                Nutrición especializada para cada etapa y necesidad
            </h2>
            <div class="grid-tres">
                {
                    alimentosCards.map((item) => (
                        <div class="card card-hover">
                            <span class="card-emoji">{item.emoji}</span>
                            <h3 class="card-titulo">{item.title}</h3>
                            <p class="card-desc">{item.desc}</p>
                        </div>
                    ))
                }
            </div>
        </section>

    <!-- SECCIÓN 3 — MITO VS REALIDAD (LA TRAMPA DEL SUPERMERCADO) -->
    <section class="content-section">
            <h2 class="titulo-sec">
                Lo que el alimento económico le cuesta a su salud
            </h2>

            <div class="mito-realidad-box mb-fluid">
                <div class="mito-block">
                    <span class="bad-icon">❌</span>
                    <p>
                        <strong>El Mito:</strong> "El alimento caro es igual al barato
                        pero con mejor empaque, y los gatos pueden comer lo mismo
                        que los perros."
                    </p>
                </div>
                <div class="realidad-block">
                    <span class="good-icon">✅</span>
                    <p>
                        <strong>La Realidad:</strong> Totalmente falso. El alimento
                        comercial de baja calidad usa "rellenos" difíciles de procesar
                        que a largo plazo dañan los riñones y articulaciones. Además,
                        los gatos son carnívoros obligados y necesitan taurina en
                        su dieta; darles alimento de perro puede causarles ceguera
                        y problemas cardíacos graves.
                    </p>
                </div>
            </div>

            <blockquote class="valor-quote text-center">
                "La diferencia principal entre un alimento premium y uno
                económico está en la digestibilidad. Tu mascota aprovecha casi
                todos los nutrientes del alimento premium, lo que significa que
                comerá menos cantidad para llenarse, sus heces serán más
                pequeñas y su salud estará protegida a largo plazo."
            </blockquote>
        </section>

    <!-- SECCIÓN 4 — LA VENTAJA DE COMPRAR EN LA VETERINARIA -->
    <section class="content-section bg-soft">
            <h2 class="titulo-sec">
                ¿Por qué comprar el alimento de tu mascota con nosotros?
            </h2>

            <div class="ventajas-lista">
                {
                    ventajasLista.map((vent) => (
                        <div class="ventaja-item card">
                            <div class="ventaja-icon">✅</div>
                            <div class="ventaja-texto">
                                <h3 class="ventaja-titulo">{vent.title}</h3>
                                <p class="ventaja-desc">{vent.desc}</p>
                            </div>
                        </div>
                    ))
                }
            </div>
        </section>

    <!-- SECCIÓN 5 — FAQ (PREGUNTAS FRECUENTES) -->
    <section class="content-section">
            <h2 class="titulo-sec">
                Dudas frecuentes sobre nutrición canina y felina
            </h2>
            <div class="faq-accordion">
                {
                    faqs.map((faq) => (
                        <details class="faq-item">
                            <summary class="faq-question">{faq.name}</summary>
                            <p class="faq-answer">{faq.acceptedAnswer.text}</p>
                        </details>
                    ))
                }
            </div>
        </section>

    <!-- SECCIÓN 6 — SERVICIOS VINCULADOS -->
    <section class="content-section bg-soft">
            <h2 class="titulo-sec">
                La nutrición es parte del cuidado integral
            </h2>
            <div class="grid-tres">
                {
                    relacionadosCards.map((s) => (
                        <a href={s.href} class="card card-hover">
                            <span class="card-emoji">{s.emoji}</span>
                            <h3 class="card-titulo">{s.title}</h3>
                            <p class="card-desc">{s.desc}</p>
                            <span class="card-ver">Ver detalles →</span>
                        </a>
                    ))
                }
            </div>
        </section>

    <!-- SECCIÓN 7 — CTA FINAL Y CONTACTO LOCAL -->
    <section class="cta-final content-section">
            <h2 class="cta-titulo-blanc">
                ¿Buscas un alimento específico para tu mascota?
            </h2>
            <p class="cta-desc-blanc">
                Escríbenos para confirmar disponibilidad de marcas y fórmulas
                especiales. Visítanos en Av. División del Norte 3595, San Pablo
                Tepetlapa, CDMX, y mejora la nutrición de tu mejor amigo hoy
                mismo.
            </p>
            <div class="cta-btns">
                <a
                    href="https://wa.me/525513843004"
                    target="_blank"
                    rel="noopener"
                    class="btn-cta-blanco"
                >
                    💬 Consultar disponibilidad por WhatsApp
                </a>
                <a href="/ubicacion" class="btn-cta-outline">
                    📍 Ver ubicación y horarios
                </a>
            </div>
        </section>
</BaseLayout>

<style>
    /* ====== CLAMP SYSTEM + RESPONSIVE ====== */
    /* No Tailwind/Bootstrap allowed, 100% Fluid Vanilla CSS */

    .content-section {
        padding-block: max(3rem, 6vw);
    }
    .bg-soft {
        background: var(--color-bg-soft);
    }

    .h1-hero {
        font-size: max(1.8rem, 3.2vw);
        color: var(--color-text);
        line-height: 1.15;
        margin-bottom: max(1rem, 2vw);
    }

    .titulo-sec {
        font-size: max(1.6rem, 2.8vw);
        color: var(--color-primary);
        text-align: center;
        margin-bottom: max(2rem, 4vw);
        line-height: 1.2;
    }

    .text-center {
        text-align: center;
    }

    .mb-fluid {
        margin-bottom: max(2rem, 4vw);
    }

    /* HERO CLASSES */
    .hero {
        background: var(--color-bg);
    }
    .hero__inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }
    .hero__text {
        width: 100%;
        margin-inline: auto;
    }
    @media (min-width: 48rem) {
        .hero__text {
            
        }
    }

    .hero__desc {
        font-size: max(0.95rem, 1.4vw);
        color: var(--color-text-soft);
        line-height: 1.6;
        margin-bottom: max(1.5rem, 2vw);
        margin-inline: auto;
    }

    .hero__btns {
        display: flex;
        flex-wrap: wrap;
        gap: max(0.8rem, 1.5vw);
        margin-bottom: max(1rem, 2vw);
        justify-content: center;
    }

    .btn-wa {
        background: var(--color-primary);
        color: #fff;
        padding: max(0.6rem, 1.2vw) max(1.2rem, 2.5vw);
        font-size: max(0.9rem, 1.2vw);
        border-radius: max(0.4rem, 1vw);
        font-weight: 600;
        text-decoration: none;
        transition:
            background 0.2s,
            transform 0.2s;
    }
    .btn-wa:hover {
        background: var(--color-primary-dark);
        transform: translateY(-0.15rem);
    }

    .btn-sec {
        padding: max(0.6rem, 1.2vw) max(1.2rem, 2.5vw);
        font-size: max(0.9rem, 1.2vw);
        border: max(0.1rem, 0.15vw) solid var(--color-primary-dark);
        color: var(--color-primary-dark);
        background: transparent;
        border-radius: max(0.4rem, 1vw);
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s;
    }
    .btn-sec:hover {
        background: var(--color-primary-dark);
        color: #fff;
        transform: translateY(-0.15rem);
    }

    /* GRID LAYOUTS */
    .grid-tres {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: max(1.5rem, 3vw);
    }
    @media (
        }
    }
    @media (
        }
    }

    /* CARDS */
    .card {
        background: var(--color-bg);
        border: max(0.05rem, 0.1vw) solid var(--color-border);
        border-radius: max(0.5rem, 1.5vw);
        padding: max(1.2rem, 2vw);
        display: flex;
        flex-direction: column;
        text-decoration: none;
        transition:
            transform 0.3s,
            box-shadow 0.3s;
        box-shadow: var(--shadow-sm);
    }
    .card-hover:hover {
        transform: translateY(-0.25rem);
        box-shadow: var(--shadow-md);
    }

    .card-emoji {
        font-size: max(2rem, 3.5vw);
        margin-bottom: max(0.8rem, 1.2vw);
        display: block;
        text-align: center;
    }

    .card-titulo {
        font-size: max(1.1rem, 1.6vw);
        color: var(--color-primary-dark);
        margin-bottom: max(0.5rem, 1vw);
        line-height: 1.3;
        text-align: center;
    }
    .card-desc {
        font-size: max(0.95rem, 1.3vw);
        color: var(--color-text-soft);
        line-height: 1.6;
        flex-grow: 1;
        margin: 0;
        text-align: center;
    }

    .card-ver {
        display: block;
        text-align: center;
        margin-top: max(1rem, 2vw);
        font-size: max(0.9rem, 1.2vw);
        color: var(--color-primary);
        font-weight: bold;
    }

    /* MITO VS REALIDAD (VERTICAL STACK) */
    .mito-realidad-box {
        display: flex;
        flex-direction: column;
        gap: max(0rem, 0vw); /* No gap, attached */
        border-radius: max(0.5rem, 1vw);
        box-shadow: var(--shadow);
        overflow: hidden;
        border: max(0.05rem, 0.1vw) solid var(--color-border);
    }

    .mito-block,
    .realidad-block {
        display: flex;
        align-items: flex-start;
        gap: max(0.8rem, 1.2vw);
        padding: max(1rem, 1.5vw);
    }
    .mito-block {
        background: var(--color-bg);
        border-bottom: max(0.05rem, 0.1vw) solid var(--color-border);
    }
    .realidad-block {
        background: var(--color-bg-soft);
    }
    .mito-block p,
    .realidad-block p {
        font-size: max(0.95rem, 1.3vw);
        color: var(--color-text-soft);
        margin: 0;
        line-height: 1.6;
    }
    .mito-block p strong {
        color: var(--color-urgencia);
    }
    .realidad-block p strong {
        color: #4caf50;
    }
    .bad-icon,
    .good-icon {
        font-size: max(1.2rem, 1.8vw);
        flex-shrink: 0;
        margin-top: max(0.2rem, 0.4vw);
    }

    /* BLOCKQUOTE */
    .valor-quote {
        background: var(--color-primary-light);
        border-radius: max(0.5rem, 1vw);
        padding: max(1.5rem, 3vw);
        font-size: max(1.1rem, 1.6vw);
        color: var(--color-primary-dark);
        font-style: italic;
        font-weight: 500;
        line-height: 1.6;
        margin: 0 auto;
        position: relative;
        
    }

    /* VENTAJAS LISTA */
    .ventajas-lista {
        display: flex;
        flex-direction: column;
        gap: max(1rem, 2vw);
    }

    .ventaja-item {
        display: flex;
        flex-direction: row;
        align-items: flex-start;
        gap: max(1rem, 2vw);
        text-align: left;
    }
    @media (
            align-items: center;
            text-align: center;
        }
    }

    .ventaja-icon {
        font-size: max(1.5rem, 2.5vw);
        flex-shrink: 0;
        margin-top: max(0.2rem, 0.4vw);
    }
    @media (
        }
    }

    .ventaja-titulo {
        font-size: max(1.1rem, 1.6vw);
        color: var(--color-primary-dark);
        margin-bottom: max(0.5rem, 1vw);
        line-height: 1.3;
    }
    .ventaja-desc {
        font-size: max(0.95rem, 1.3vw);
        color: var(--color-text-soft);
        line-height: 1.6;
        margin: 0;
    }

    /* FAQ ACCORDION */
    .faq-accordion {
        display: flex;
        flex-direction: column;
        gap: max(0.8rem, 1.2vw);
    }
    .faq-item {
        background: var(--color-bg);
        border: max(0.05rem, 0.1vw) solid var(--color-border);
        border-radius: max(0.5rem, 1vw);
        padding: max(1rem, 1.5vw);
    }
    .faq-item[open] .faq-question {
        color: var(--color-primary-dark);
        margin-bottom: max(0.8rem, 1vw);
    }
    .faq-question {
        font-size: max(1rem, 1.4vw);
        font-weight: 600;
        color: var(--color-text);
        cursor: pointer;
        list-style: none; /* Hide default arrow */
        position: relative;
        padding-right: max(2rem, 3vw);
        line-height: 1.4;
    }
    .faq-question::-webkit-details-marker {
        display: none;
    }
    .faq-question::after {
        content: "+";
        position: absolute;
        right: 0;
        top: 0;
        font-size: max(1.2rem, 1.8vw);
        color: var(--color-primary);
    }
    .faq-item[open] .faq-question::after {
        content: "-";
    }
    .faq-answer {
        font-size: max(0.95rem, 1.3vw);
        color: var(--color-text-soft);
        line-height: 1.6;
        margin: 0;
    }

    /* CTA FINAL */
    .cta-final {
        background: var(--color-primary);
        text-align: center;
        color: #fff;
    }
    .cta-titulo-blanc {
        font-size: max(1.6rem, 2.8vw);
        color: #fff;
        margin-bottom: max(1rem, 1.5vw);
        line-height: 1.2;
    }
    .cta-desc-blanc {
        font-size: max(1rem, 1.4vw);
        margin-bottom: max(1.5rem, 2.5vw);
        
        margin-inline: auto;
        color: #fff;
        opacity: 0.9;
        line-height: 1.6;
    }
    @media (
        justify-content: center;
        flex-wrap: wrap;
        gap: max(0.8rem, 1.5vw);
    }
    .btn-cta-blanco {
        background: #fff;
        color: var(--color-primary-dark);
        padding: max(0.6rem, 1.2vw) max(1.2rem, 2.5vw);
        font-size: max(0.9rem, 1.2vw);
        border-radius: max(0.4rem, 1vw);
        font-weight: 600;
        text-decoration: none;
    }
    .btn-cta-outline {
        border: max(0.1rem, 0.15vw) solid #fff;
        color: #fff;
        padding: max(0.6rem, 1.2vw) max(1.2rem, 2.5vw);
        font-size: max(0.9rem, 1.2vw);
        border-radius: max(0.4rem, 1vw);
        font-weight: 600;
        text-decoration: none;
    }
</style>
